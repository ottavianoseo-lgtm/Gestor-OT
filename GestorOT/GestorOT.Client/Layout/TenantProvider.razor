@using GestorOT.Shared.Dtos
@inject GestorOT.Client.Services.TenantState TenantState

@ChildContent

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [PersistentState]
    public string? PersistedTenantId { get; set; }

    [PersistentState]
    public string? PersistedTenantName { get; set; }

    protected override void OnInitialized()
    {
        if (!TenantState.IsSelected && !string.IsNullOrEmpty(PersistedTenantId) && Guid.TryParse(PersistedTenantId, out var tenantId))
        {
            TenantState.SetTenant(new TenantDto(tenantId, PersistedTenantName ?? "Empresa", DateTime.MinValue));
        }

        TenantState.OnChange += OnTenantChanged;
    }

    private void OnTenantChanged()
    {
        if (TenantState.CurrentTenant != null)
        {
            PersistedTenantId = TenantState.CurrentTenant.Id.ToString();
            PersistedTenantName = TenantState.CurrentTenant.Name;
        }
        else
        {
            PersistedTenantId = null;
            PersistedTenantName = null;
        }
        StateHasChanged();
    }
}
