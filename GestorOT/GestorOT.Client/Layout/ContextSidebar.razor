@using GestorOT.Shared.Dtos
@using AntDesign
@inject GestorOT.Client.Services.ContextState ContextState
@inject NavigationManager Nav
@implements IDisposable

<div class="context-sidebar @(ContextState.IsPanelOpen ? "context-sidebar--open" : "")">
    <div class="context-sidebar-backdrop @(ContextState.IsPanelOpen ? "context-sidebar-backdrop--visible" : "")"
         @onclick="Close"></div>

    <div class="context-sidebar-panel">
        <div class="context-sidebar-header">
            <span class="context-sidebar-title">
                @if (ContextState.LoteSeleccionado != null)
                {
                    <Icon Type="environment" Theme="IconThemeType.Outline" Style="margin-right: 6px;" />
                    @:Detalle del Lote
                }
                else if (ContextState.LaborSeleccionada != null)
                {
                    <Icon Type="tool" Theme="IconThemeType.Outline" Style="margin-right: 6px;" />
                    @:Detalle de Labor
                }
            </span>
            <div class="context-sidebar-close" @onclick="Close">
                <Icon Type="close" Theme="IconThemeType.Outline" />
            </div>
        </div>

        <div class="context-sidebar-body">
            @if (ContextState.LoteSeleccionado is { } lote)
            {
                <div class="ctx-card">
                    <div class="ctx-card-title">@lote.Nombre</div>
                    @if (lote.CampoNombre != null)
                    {
                        <div class="ctx-card-subtitle">
                            <Icon Type="bank" Theme="IconThemeType.Outline" Style="margin-right: 4px;" />
                            @lote.CampoNombre
                        </div>
                    }

                    <div class="ctx-card-divider"></div>

                    <div class="ctx-info-grid">
                        <div class="ctx-info-item">
                            <span class="ctx-info-label">Superficie</span>
                            <span class="ctx-info-value">@lote.SuperficieActualHa.ToString("N2") ha</span>
                        </div>
                        <div class="ctx-info-item">
                            <span class="ctx-info-label">Estado</span>
                            <Tag Color="@(lote.Estado == "Active" ? "green" : "red")"
                                 Style="border-radius: 12px; font-size: 11px;">
                                @(lote.Estado == "Active" ? "Activo" : "Inactivo")
                            </Tag>
                        </div>
                    </div>

                    @if (lote.CultivoActual != null)
                    {
                        <div class="ctx-highlight-box" style="border-left-color: #2ECC71;">
                            <div class="ctx-highlight-label">
                                <Icon Type="experiment" Theme="IconThemeType.Outline" Style="margin-right: 4px;" />
                                Cultivo Actual
                            </div>
                            <div class="ctx-highlight-value">@lote.CultivoActual</div>
                            @if (lote.DiasDesdeSiembra > 0)
                            {
                                <div class="ctx-highlight-sub">@lote.DiasDesdeSiembra días desde siembra</div>
                            }
                        </div>
                    }

                    @if (lote.ResponsableActual != null)
                    {
                        <div class="ctx-info-row">
                            <Icon Type="user" Theme="IconThemeType.Outline" Style="color: #3498DB; margin-right: 6px;" />
                            <span class="ctx-info-label" style="margin-right: 6px;">Responsable:</span>
                            <span class="ctx-info-value">@lote.ResponsableActual</span>
                        </div>
                    }

                    <div class="ctx-card-divider"></div>

                    @if (lote.UltimaLabor != null)
                    {
                        <div class="ctx-labor-mini">
                            <div class="ctx-labor-mini-header">
                                <Icon Type="check-circle" Theme="IconThemeType.Outline" Style="color: #2ECC71; margin-right: 4px;" />
                                Última Labor
                            </div>
                            <div class="ctx-labor-mini-body">
                                <span class="ctx-labor-mini-type">@lote.UltimaLabor.LaborType</span>
                                @if (lote.UltimaLabor.Fecha.HasValue)
                                {
                                    <span class="ctx-labor-mini-date">@lote.UltimaLabor.Fecha.Value.ToString("dd/MM/yyyy")</span>
                                }
                            </div>
                        </div>
                    }

                    @if (lote.ProximaLabor != null)
                    {
                        <div class="ctx-labor-mini">
                            <div class="ctx-labor-mini-header">
                                <Icon Type="clock-circle" Theme="IconThemeType.Outline" Style="color: #F1C40F; margin-right: 4px;" />
                                Próxima Labor
                            </div>
                            <div class="ctx-labor-mini-body">
                                <span class="ctx-labor-mini-type">@lote.ProximaLabor.LaborType</span>
                                @if (lote.ProximaLabor.Fecha.HasValue)
                                {
                                    <span class="ctx-labor-mini-date">@lote.ProximaLabor.Fecha.Value.ToString("dd/MM/yyyy")</span>
                                }
                            </div>
                        </div>
                    }

                    <div class="ctx-actions">
                        <Button Block Size="@ButtonSize.Small"
                                Style="border-radius: 8px; border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.7);"
                                OnClick="() => NavToLotHistory(lote.LoteId)">
                            <Icon Type="history" Theme="IconThemeType.Outline" /> Ver Historial
                        </Button>
                    </div>
                </div>
            }
            else if (ContextState.LaborSeleccionada is { } labor)
            {
                <div class="ctx-card">
                    <div class="ctx-card-title">@labor.TipoLabor</div>
                    <div class="ctx-card-subtitle">
                        <Icon Type="environment" Theme="IconThemeType.Outline" Style="margin-right: 4px;" />
                        @labor.LoteNombre
                    </div>

                    <div class="ctx-card-divider"></div>

                    <div class="ctx-info-grid">
                        <div class="ctx-info-item">
                            <span class="ctx-info-label">Estado</span>
                            <Tag Color="@GetLaborStatusColor(labor.Estado)"
                                 Style="border-radius: 12px; font-size: 11px;">
                                @labor.Estado
                            </Tag>
                        </div>
                        <div class="ctx-info-item">
                            <span class="ctx-info-label">Hectáreas</span>
                            <span class="ctx-info-value">@labor.Hectareas.ToString("N2") ha</span>
                        </div>
                    </div>

                    @if (labor.FechaPlanificada.HasValue)
                    {
                        <div class="ctx-info-row">
                            <Icon Type="calendar" Theme="IconThemeType.Outline" Style="color: #3498DB; margin-right: 6px;" />
                            <span class="ctx-info-label" style="margin-right: 6px;">Fecha:</span>
                            <span class="ctx-info-value">@labor.FechaPlanificada.Value.ToString("dd/MM/yyyy")</span>
                        </div>
                    }

                    @if (labor.NombreResponsable != null)
                    {
                        <div class="ctx-info-row">
                            <Icon Type="user" Theme="IconThemeType.Outline" Style="color: #9B59B6; margin-right: 6px;" />
                            <span class="ctx-info-label" style="margin-right: 6px;">Responsable:</span>
                            <span class="ctx-info-value">@labor.NombreResponsable</span>
                        </div>
                    }

                    @if (labor.Maquinaria != null)
                    {
                        <div class="ctx-info-row">
                            <Icon Type="car" Theme="IconThemeType.Outline" Style="color: #E67E22; margin-right: 6px;" />
                            <span class="ctx-info-label" style="margin-right: 6px;">Maquinaria:</span>
                            <span class="ctx-info-value">@labor.Maquinaria</span>
                        </div>
                    }

                    @if (labor.Insumos.Count > 0)
                    {
                        <div class="ctx-card-divider"></div>
                        <div style="margin-bottom: 8px;">
                            <span class="ctx-info-label" style="display: block; margin-bottom: 6px;">
                                <Icon Type="medicine-box" Theme="IconThemeType.Outline" Style="margin-right: 4px;" />
                                Insumos
                            </span>
                            <div style="display: flex; flex-wrap: wrap; gap: 4px;">
                                @foreach (var insumo in labor.Insumos)
                                {
                                    <Tag Style="border-radius: 10px; font-size: 11px; background: rgba(52,152,219,0.1); border-color: rgba(52,152,219,0.3); color: #3498DB;">
                                        @insumo
                                    </Tag>
                                }
                            </div>
                        </div>
                    }

                    @if (labor.NotasLabor != null)
                    {
                        <div class="ctx-highlight-box" style="border-left-color: #95A5A6;">
                            <div class="ctx-highlight-label">
                                <Icon Type="file-text" Theme="IconThemeType.Outline" Style="margin-right: 4px;" />
                                Notas
                            </div>
                            <div class="ctx-highlight-value" style="font-size: 12px;">@labor.NotasLabor</div>
                        </div>
                    }

                    <div class="ctx-actions">
                        <Button Block Size="@ButtonSize.Small"
                                Style="border-radius: 8px; background: #E74C3C15; border-color: #E74C3C40; color: #E74C3C;"
                                OnClick="() => NavToLot(labor.LoteId)">
                            <Icon Type="environment" Theme="IconThemeType.Outline" /> Ir al Lote en Mapa
                        </Button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        ContextState.OnChange += HandleStateChange;
    }

    private void HandleStateChange()
    {
        InvokeAsync(StateHasChanged);
    }

    private void Close()
    {
        ContextState.CerrarPanel();
    }

    private void NavToLotHistory(Guid lotId)
    {
        ContextState.CerrarPanel();
        Nav.NavigateTo($"/lots?history={lotId}");
    }

    private void NavToLot(Guid lotId)
    {
        ContextState.CerrarPanel();
        Nav.NavigateTo($"/mapa?lot={lotId}");
    }

    private static string GetLaborStatusColor(string status) => status switch
    {
        "Planned" or "Pendiente" => "gold",
        "InProgress" or "En Progreso" => "blue",
        "Completed" or "Cerrada" => "green",
        "Cancelled" or "Cancelada" => "red",
        _ => "default"
    };

    public void Dispose()
    {
        ContextState.OnChange -= HandleStateChange;
    }
}

<style>
    .context-sidebar {
        position: fixed;
        top: 0;
        right: 0;
        height: 100vh;
        z-index: 100;
        pointer-events: none;
    }

    .context-sidebar--open {
        pointer-events: auto;
    }

    .context-sidebar-backdrop {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0, 0, 0, 0.35);
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }

    .context-sidebar-backdrop--visible {
        opacity: 1;
        pointer-events: auto;
    }

    .context-sidebar-panel {
        position: fixed;
        top: 0;
        right: 0;
        width: 380px;
        height: 100vh;
        background: rgba(30, 30, 46, 0.85);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border-left: 1px solid rgba(255, 255, 255, 0.08);
        transform: translateX(100%);
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .context-sidebar--open .context-sidebar-panel {
        transform: translateX(0);
    }

    .context-sidebar-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        flex-shrink: 0;
    }

    .context-sidebar-title {
        color: rgba(255, 255, 255, 0.85);
        font-weight: 600;
        font-size: 14px;
        display: flex;
        align-items: center;
    }

    .context-sidebar-close {
        cursor: pointer;
        color: rgba(255, 255, 255, 0.4);
        font-size: 16px;
        padding: 4px;
        border-radius: 6px;
        transition: all 0.2s;
    }

    .context-sidebar-close:hover {
        color: rgba(255, 255, 255, 0.8);
        background: rgba(255, 255, 255, 0.06);
    }

    .context-sidebar-body {
        flex: 1;
        overflow-y: auto;
        padding: 16px 20px;
    }

    .ctx-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 12px;
        padding: 16px;
    }

    .ctx-card-title {
        font-size: 18px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 4px;
    }

    .ctx-card-subtitle {
        font-size: 12px;
        color: rgba(255, 255, 255, 0.45);
        display: flex;
        align-items: center;
    }

    .ctx-card-divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.06);
        margin: 14px 0;
    }

    .ctx-info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 12px;
    }

    .ctx-info-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .ctx-info-label {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.4);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .ctx-info-value {
        font-size: 14px;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.85);
    }

    .ctx-info-row {
        display: flex;
        align-items: center;
        margin-bottom: 10px;
        font-size: 13px;
    }

    .ctx-highlight-box {
        background: rgba(255, 255, 255, 0.02);
        border-left: 3px solid #2ECC71;
        border-radius: 0 8px 8px 0;
        padding: 10px 12px;
        margin-bottom: 12px;
    }

    .ctx-highlight-label {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.45);
        display: flex;
        align-items: center;
        margin-bottom: 4px;
    }

    .ctx-highlight-value {
        font-size: 14px;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.85);
    }

    .ctx-highlight-sub {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.35);
        margin-top: 2px;
    }

    .ctx-labor-mini {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.04);
        border-radius: 8px;
        padding: 10px 12px;
        margin-bottom: 8px;
    }

    .ctx-labor-mini-header {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.5);
        display: flex;
        align-items: center;
        margin-bottom: 4px;
    }

    .ctx-labor-mini-body {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .ctx-labor-mini-type {
        font-size: 13px;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.8);
    }

    .ctx-labor-mini-date {
        font-size: 12px;
        color: rgba(255, 255, 255, 0.45);
    }

    .ctx-actions {
        margin-top: 16px;
    }
</style>
