@page "/inventory"
@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using System.Net.Http.Json
@inject HttpClient Http
@inject IMessageService Message

<PageTitle>Inventario - GestorOT</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title">Inventario de Insumos</h2>
        <span class="page-subtitle">@_items.Count insumos registrados</span>
    </div>
    <Button Type="@ButtonType.Primary" OnClick="OpenCreateModal"
            Style="background: #E74C3C; border-color: #E74C3C; border-radius: 8px; font-weight: 600;">
        <Icon Type="plus" Theme="IconThemeType.Outline" /> Nuevo Insumo
    </Button>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <Alert Type="@AlertType.Error" Message="@_errorMessage" ShowIcon="true" Style="margin-bottom: 16px;" />
}

<Row Gutter="(16, 16)" Style="margin-bottom: 16px;">
    <Col Xs="24" Sm="8">
        <div class="kpi-card-sm" style="border-left: 3px solid #3498DB;">
            <span class="kpi-sm-value">@_items.Count</span>
            <span class="kpi-sm-label">Total Insumos</span>
        </div>
    </Col>
    <Col Xs="24" Sm="8">
        <div class="kpi-card-sm" style="border-left: 3px solid #E74C3C;">
            <span class="kpi-sm-value">@_items.Count(i => i.CurrentStock <= i.ReorderLevel)</span>
            <span class="kpi-sm-label">Stock Bajo</span>
        </div>
    </Col>
    <Col Xs="24" Sm="8">
        <div class="kpi-card-sm" style="border-left: 3px solid #2ECC71;">
            <span class="kpi-sm-value">@_items.Select(i => i.Category).Distinct().Count()</span>
            <span class="kpi-sm-label">Categorías</span>
        </div>
    </Col>
</Row>

<div class="glass-card">
    <Table TItem="InventoryDto" DataSource="_items" Loading="_loading" Size="@TableSize.Small"
           ScrollX="1100">
        <PropertyColumn Property="c => c.ItemName" Title="Insumo" Sortable>
            <span style="font-weight: 600;">@context.ItemName</span>
        </PropertyColumn>
        <PropertyColumn Property="c => c.Category" Title="Categoría" Sortable>
            <Tag Style="background: #3498DB20; color: #3498DB; border: 1px solid #3498DB40; border-radius: 12px; font-size: 11px; padding: 2px 10px;">
                @context.Category
            </Tag>
        </PropertyColumn>
        <Column TData="string" Title="Stock (Unidad A)">
            @{
                var isLow = context.CurrentStock <= context.ReorderLevel;
            }
            <span style="@(isLow ? "color: #E74C3C; font-weight: 700;" : "")">
                @context.CurrentStock.ToString("N2") @context.UnitA
            </span>
            @if (isLow)
            {
                <Tag Color="@("red")" Style="margin-left: 6px; border-radius: 12px; font-size: 10px; padding: 1px 6px;">
                    Bajo
                </Tag>
            }
        </Column>
        <Column TData="string" Title="Equivalente (Unidad B)">
            @if (context.ConversionFactor > 0 && !string.IsNullOrEmpty(context.UnitB))
            {
                var converted = context.CurrentStock * context.ConversionFactor;
                <span>@converted.ToString("N2") @context.UnitB</span>
            }
            else
            {
                <span style="color: rgba(255,255,255,0.3);">—</span>
            }
        </Column>
        <PropertyColumn Property="c => c.ReorderLevel" Title="Nivel Reposición">
            @context.ReorderLevel.ToString("N2") @context.UnitA
        </PropertyColumn>
        <Column TData="string" Title="Factor">
            @if (context.ConversionFactor != 1 && !string.IsNullOrEmpty(context.UnitB))
            {
                <span style="font-size: 11px; color: rgba(255,255,255,0.5);">
                    1 @context.UnitA = @context.ConversionFactor.ToString("N2") @context.UnitB
                </span>
            }
        </Column>
        <ActionColumn Title="Acciones" Width="160">
            <Space>
                <SpaceItem>
                    <Button Size="@ButtonSize.Small" OnClick="() => OpenEditModal(context)"
                            Style="border-radius: 6px; border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.7);">
                        <Icon Type="edit" Theme="IconThemeType.Outline" />
                    </Button>
                </SpaceItem>
                <SpaceItem>
                    <Popconfirm Title="¿Eliminar este insumo?"
                                OnConfirm="() => DeleteItem(context.Id)"
                                OkText="Eliminar" CancelText="Cancelar">
                        <Button Danger Size="@ButtonSize.Small" Style="border-radius: 6px;">
                            <Icon Type="delete" Theme="IconThemeType.Outline" />
                        </Button>
                    </Popconfirm>
                </SpaceItem>
            </Space>
        </ActionColumn>
    </Table>
</div>

<Modal Title="@(_isEditing ? "Editar Insumo" : "Nuevo Insumo")"
       Visible="_modalVisible"
       OnCancel="CloseModal"
       OnOk="SaveItem"
       OkText="@(_isEditing ? "Guardar" : "Crear")"
       ConfirmLoading="_saving"
       Width="600">
    <Form @ref="_form" Model="_formModel" Layout="@FormLayout.Vertical">
        <Row Gutter="16">
            <Col Span="12">
                <FormItem Label="Nombre del Insumo">
                    <Input @bind-Value="_formModel.ItemName" Placeholder="Ej: Glifosato 48%" />
                </FormItem>
            </Col>
            <Col Span="12">
                <FormItem Label="Categoría">
                    <Input @bind-Value="_formModel.Category" Placeholder="Ej: Herbicida, Fertilizante" />
                </FormItem>
            </Col>
        </Row>

        <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; padding: 16px; margin-bottom: 16px;">
            <div style="font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px;">
                Unidad Dual (Stock vs Aplicación)
            </div>
            <Row Gutter="16">
                <Col Span="12">
                    <FormItem Label="Unidad A (Stock)">
                        <Input @bind-Value="_formModel.UnitA" Placeholder="Ej: Bidones, Bolsas" />
                    </FormItem>
                </Col>
                <Col Span="12">
                    <FormItem Label="Unidad B (Aplicación)">
                        <Input @bind-Value="_formModel.UnitB" Placeholder="Ej: Litros, Kg" />
                    </FormItem>
                </Col>
            </Row>
            <FormItem Label="Factor de Conversión (1 Unidad A = X Unidad B)">
                <AntDesign.InputNumber @bind-Value="_formModel.ConversionFactor" Min="0.001" Step="0.1"
                           Style="width: 100%;" />
            </FormItem>
        </div>

        <Row Gutter="16">
            <Col Span="12">
                <FormItem Label="Stock Actual (Unidad A)">
                    <AntDesign.InputNumber @bind-Value="_formModel.CurrentStock" Min="0" Step="0.5"
                               Style="width: 100%;" />
                </FormItem>
            </Col>
            <Col Span="12">
                <FormItem Label="Nivel de Reposición (Unidad A)">
                    <AntDesign.InputNumber @bind-Value="_formModel.ReorderLevel" Min="0" Step="0.5"
                               Style="width: 100%;" />
                </FormItem>
            </Col>
        </Row>

        @if (_formModel.ConversionFactor > 0 && !string.IsNullOrEmpty(_formModel.UnitB))
        {
            <div style="background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.2); border-radius: 8px; padding: 12px; text-align: center;">
                <span style="color: #2ECC71; font-weight: 600; font-size: 13px;">
                    Stock equivalente: @((_formModel.CurrentStock * _formModel.ConversionFactor).ToString("N2")) @_formModel.UnitB
                </span>
            </div>
        }
    </Form>
</Modal>

<style>
    .kpi-card-sm {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 10px;
        padding: 14px 18px;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .kpi-sm-value {
        font-size: 22px;
        font-weight: 700;
        color: #fff;
    }
    .kpi-sm-label {
        font-size: 12px;
        color: rgba(255,255,255,0.5);
    }
</style>

@code {
    private List<InventoryDto> _items = new();
    private bool _loading = true;
    private string? _errorMessage;
    private bool _modalVisible;
    private bool _isEditing;
    private bool _saving;
    private Guid _editingId;
    private InvFormModel _formModel = new();
    private Form<InvFormModel>? _form;

    public class InvFormModel
    {
        public string ItemName { get; set; } = string.Empty;
        public string Category { get; set; } = string.Empty;
        public double CurrentStock { get; set; }
        public double ReorderLevel { get; set; }
        public string UnitA { get; set; } = string.Empty;
        public string UnitB { get; set; } = string.Empty;
        public double ConversionFactor { get; set; } = 1;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            _loading = true;
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));
            _items = await Http.GetFromJsonAsync("api/inventory",
                AppJsonSerializerContext.Default.ListInventoryDto, cts.Token) ?? new();
            _errorMessage = null;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void OpenCreateModal()
    {
        _isEditing = false;
        _formModel = new InvFormModel();
        _modalVisible = true;
    }

    private void OpenEditModal(InventoryDto item)
    {
        _isEditing = true;
        _editingId = item.Id;
        _formModel = new InvFormModel
        {
            ItemName = item.ItemName,
            Category = item.Category,
            CurrentStock = item.CurrentStock,
            ReorderLevel = item.ReorderLevel,
            UnitA = item.UnitA,
            UnitB = item.UnitB,
            ConversionFactor = item.ConversionFactor
        };
        _modalVisible = true;
    }

    private void CloseModal()
    {
        _modalVisible = false;
    }

    private async Task SaveItem()
    {
        if (string.IsNullOrWhiteSpace(_formModel.ItemName))
        {
            Message.Warning("El nombre del insumo es obligatorio.");
            return;
        }

        _saving = true;
        try
        {
            var dto = new InventoryDto(
                _isEditing ? _editingId : Guid.Empty,
                _formModel.Category,
                _formModel.ItemName,
                _formModel.CurrentStock,
                _formModel.ReorderLevel,
                _formModel.UnitA,
                _formModel.UnitB,
                _formModel.ConversionFactor
            );

            HttpResponseMessage response;
            if (_isEditing)
            {
                response = await Http.PutAsJsonAsync($"api/inventory/{_editingId}",
                    dto, AppJsonSerializerContext.Default.InventoryDto);
            }
            else
            {
                response = await Http.PostAsJsonAsync("api/inventory",
                    dto, AppJsonSerializerContext.Default.InventoryDto);
            }

            if (response.IsSuccessStatusCode)
            {
                Message.Success(_isEditing ? "Insumo actualizado." : "Insumo creado correctamente.");
                _modalVisible = false;
                await LoadData();
            }
            else
            {
                Message.Error($"Error al guardar: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteItem(Guid id)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/inventory/{id}");
            if (response.IsSuccessStatusCode)
            {
                Message.Success("Insumo eliminado correctamente.");
                await LoadData();
            }
            else
            {
                Message.Error($"Error al eliminar: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
    }
}
