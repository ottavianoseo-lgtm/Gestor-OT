@page "/public/ot/{Token}"
@layout GestorOT.Client.Layout.PublicLayout
@inject HttpClient Http
@inject IMessageService Message
@using GestorOT.Shared
@using GestorOT.Shared.Dtos

<div style="margin-bottom: 20px;">
    @if (_loading)
    {
        <div style="text-align: center; padding: 60px;">
            <Spin Tip="Cargando orden de trabajo..." />
        </div>
    }
    else if (_error != null)
    {
        <div class="public-error-card">
            <Icon Type="close-circle" Theme="IconThemeType.Outline" Style="font-size: 48px; color: #E74C3C; margin-bottom: 16px;" />
            <h2 style="color: #fff; margin: 0 0 8px;">Enlace no válido</h2>
            <p style="color: rgba(255,255,255,0.5); margin: 0;">@_error</p>
        </div>
    }
    else if (_workOrder != null)
    {
        <div class="public-wo-header">
            <div>
                <h1 style="color: #fff; margin: 0 0 4px; font-size: 20px; font-weight: 700;">@_workOrder.Description</h1>
                <p style="color: rgba(255,255,255,0.5); margin: 0; font-size: 13px;">
                    @(_workOrder.FieldName ?? "Campo") &mdash; @(_workOrder.LotName ?? "Lote") &bull; Responsable: @_workOrder.AssignedTo
                </p>
            </div>
            <Tag Color="@GetStatusColor(_workOrder.Status)">@_workOrder.Status</Tag>
        </div>

        <div style="margin-bottom: 12px;">
            <p style="color: rgba(255,255,255,0.4); font-size: 12px; text-transform: uppercase; letter-spacing: 1px; margin: 0 0 8px;">
                Vencimiento: @_workOrder.DueDate.ToString("dd/MM/yyyy")
            </p>
        </div>

        <h3 style="color: rgba(255,255,255,0.7); font-size: 14px; text-transform: uppercase; letter-spacing: 1px; margin: 24px 0 12px;">
            Labores (@(_workOrder.Labors?.Count ?? 0))
        </h3>

        @if (_workOrder.Labors != null)
        {
            foreach (var labor in _workOrder.Labors)
            {
                <div class="public-labor-card">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                        <div>
                            <span style="color: #fff; font-weight: 600; font-size: 15px;">@labor.LaborType</span>
                            <span style="color: rgba(255,255,255,0.4); font-size: 12px; margin-left: 8px;">@labor.Hectares Ha &bull; @(labor.LotName ?? "Lote")</span>
                        </div>
                        <Tag Color="@GetLaborStatusColor(labor.Status)">@labor.Status</Tag>
                    </div>

                    @if (labor.Supplies != null && labor.Supplies.Count > 0)
                    {
                        <table class="public-supply-table">
                            <thead>
                                <tr>
                                    <th>Insumo</th>
                                    <th>Dosis Plan</th>
                                    <th>Dosis Real</th>
                                    <th>Total Plan</th>
                                    <th>Total Real</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var supply in labor.Supplies)
                                {
                                    <tr>
                                        <td style="color: #fff;">@supply.SupplyName</td>
                                        <td>@supply.PlannedDose @supply.DoseUnit/@(supply.SupplyUnit ?? "u")</td>
                                        <td>
                                            @if (labor.Status != "Realized")
                                            {
                                                <AntDesign.InputNumber TValue="decimal?" Value="GetRealDose(supply)" ValueChanged="v => SetSupplyRealDose(supply, v)" Min="0m" Step="0.1m"
                                                    Style="width: 90px;" Placeholder="@supply.PlannedDose.ToString("0.##")" />
                                            }
                                            else
                                            {
                                                <span>@(supply.RealDose?.ToString("0.##") ?? "-")</span>
                                            }
                                        </td>
                                        <td>@supply.PlannedTotal.ToString("0.##")</td>
                                        <td>@(supply.RealTotal?.ToString("0.##") ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }

                    @if (labor.Status != "Realized")
                    {
                        <div style="text-align: right; margin-top: 12px;">
                            <Button Type="@ButtonType.Primary"
                                    Loading="_realizingLaborId == labor.Id"
                                    OnClick="() => RealizeLabor(labor)"
                                    Style="background: #2ECC71; border-color: #2ECC71;">
                                <Icon Type="check-circle" Theme="IconThemeType.Outline" />
                                Marcar como Realizada
                            </Button>
                        </div>
                    }
                </div>
            }
        }
    }
</div>

<style>
    .public-error-card {
        text-align: center;
        padding: 60px 20px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 16px;
    }

    .public-wo-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding: 20px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 14px;
        margin-bottom: 12px;
    }

    .public-labor-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        padding: 16px;
        margin-bottom: 10px;
    }

    .public-supply-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .public-supply-table th {
        text-align: left;
        color: rgba(255,255,255,0.4);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 6px 10px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        font-weight: 600;
    }

    .public-supply-table td {
        padding: 8px 10px;
        color: rgba(255,255,255,0.7);
        border-bottom: 1px solid rgba(255,255,255,0.04);
    }
</style>

@code {
    [Parameter] public string Token { get; set; } = string.Empty;

    private PublicWorkOrderDto? _workOrder;
    private bool _loading = true;
    private string? _error;
    private Guid? _realizingLaborId;
    private Dictionary<Guid, decimal?> _realDoseOverrides = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadWorkOrder();
    }

    private async Task LoadWorkOrder()
    {
        _loading = true;
        _error = null;
        _realDoseOverrides.Clear();
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));
            var response = await Http.GetAsync($"api/share/validate/{Token}", cts.Token);
            if (response.IsSuccessStatusCode)
            {
                _workOrder = await response.Content.ReadFromJsonAsync(
                    AppJsonSerializerContext.Default.PublicWorkOrderDto);
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();
                _error = errorText.Contains("expirado") ? "Este enlace ha expirado."
                    : errorText.Contains("revocado") ? "Este enlace ha sido revocado."
                    : "El enlace no es válido o ha expirado.";
            }
        }
        catch
        {
            _error = "No se pudo conectar con el servidor.";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RealizeLabor(PublicLaborDto labor)
    {
        _realizingLaborId = labor.Id;
        try
        {
            var supplies = labor.Supplies?.Select(s => new PublicLaborSupplyDto(
                s.Id, s.SupplyId, s.SupplyName, s.PlannedDose,
                GetRealDose(s) ?? s.PlannedDose,
                s.PlannedTotal, s.RealTotal, s.DoseUnit, s.SupplyUnit
            )).ToList() ?? new();

            var response = await Http.PostAsJsonAsync(
                $"api/share/realize/{Token}/labor/{labor.Id}",
                supplies, AppJsonSerializerContext.Default.ListPublicLaborSupplyDto);

            if (response.IsSuccessStatusCode)
            {
                Message.Success("Labor marcada como realizada.");
                await LoadWorkOrder();
            }
            else
            {
                var msg = await response.Content.ReadAsStringAsync();
                Message.Error(msg);
            }
        }
        catch
        {
            Message.Error("Error al marcar la labor.");
        }
        finally
        {
            _realizingLaborId = null;
            StateHasChanged();
        }
    }

    private string GetStatusColor(string status) => status switch
    {
        "Pending" => "orange",
        "InProgress" => "blue",
        "Completed" => "green",
        "Approved" => "cyan",
        _ => "default"
    };

    private string GetLaborStatusColor(string status) => status switch
    {
        "Planned" => "blue",
        "Realized" => "green",
        _ => "default"
    };

    private decimal? GetRealDose(PublicLaborSupplyDto supply)
    {
        return _realDoseOverrides.TryGetValue(supply.Id, out var val) ? val : supply.RealDose;
    }

    private void SetSupplyRealDose(PublicLaborSupplyDto supply, decimal? value)
    {
        _realDoseOverrides[supply.Id] = value;
    }
}
