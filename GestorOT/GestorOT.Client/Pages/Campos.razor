@page "/fields"
@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using System.Net.Http.Json
@inject HttpClient Http

<PageTitle>Campos - GestorOT</PageTitle>

<div class="page-header">
    <h2 class="page-title">Gestión de Campos</h2>
    <span class="page-subtitle">@_fields.Count campos registrados</span>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <Alert Type="@AlertType.Error" Message="@_errorMessage" ShowIcon="true" Closable="true" Style="margin-bottom: 16px;" />
}

<div class="glass-card">
    <Table TItem="FieldDto"
           DataSource="@_fields"
           Loading="@_loading"
           Size="TableSize.Small"
           ScrollX="800">
        <PropertyColumn Property="c => c.Name" Title="Nombre del Campo" Sortable>
            <span style="font-weight: 600;">@context.Name</span>
        </PropertyColumn>
        <PropertyColumn Property="c => c.TotalArea" Title="Área Total (ha)">
            @context.TotalArea.ToString("N2") ha
        </PropertyColumn>
        <Column TData="int" Title="Lotes">
            <Tag Style="background: #3498DB20; color: #3498DB; border: 1px solid #3498DB40; border-radius: 12px; font-size: 11px; padding: 2px 10px;">
                @context.Lots.Count lotes
            </Tag>
        </Column>
        <PropertyColumn Property="c => c.CreatedAt" Title="Creado" Sortable>
            @context.CreatedAt.ToString("dd/MM/yyyy")
        </PropertyColumn>
    </Table>
</div>

@code {
    private List<FieldDto> _fields = new();
    private bool _loading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));
            _fields = await Http.GetFromJsonAsync("api/fields",
                AppJsonSerializerContext.Default.ListFieldDto, cts.Token) ?? new();
        }
        catch (OperationCanceledException)
        {
            _errorMessage = "La solicitud tardó demasiado tiempo. Intente recargar la página.";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error de conexión: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }
}
