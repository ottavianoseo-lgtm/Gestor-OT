@page "/fields"
@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using System.Net.Http.Json
@using System.Text.Json
@inject HttpClient Http

<PageTitle>Campos - GestorOT</PageTitle>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
    <h2 style="margin: 0;">Gestión de Campos</h2>
    <Button Type="@ButtonType.Primary" Icon="@IconType.Outline.Plus">
        Nuevo Campo
    </Button>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <Alert Type="@AlertType.Error" Message="@_errorMessage" ShowIcon="true" Closable="true" Style="margin-bottom: 16px;" />
}

<Card Bordered="false" Style="box-shadow: 0 2px 8px rgba(0,0,0,0.09);">
    <Table TItem="FieldDto" 
           DataSource="@_fields" 
           Loading="@_loading"
           Size="TableSize.Middle"
           Bordered>
        <PropertyColumn Property="c => c.Name" Title="Nombre del Campo" Sortable />
        <PropertyColumn Property="c => c.TotalArea" Title="Área Total (has)">
            @context.TotalArea.ToString("N2")
        </PropertyColumn>
        <Column TData="int" Title="Lotes">
            <Tag Color="@("blue")">@context.Lots.Count lotes</Tag>
        </Column>
        <PropertyColumn Property="c => c.CreatedAt" Title="Creado">
            @context.CreatedAt.ToString("dd/MM/yyyy")
        </PropertyColumn>
        <ActionColumn Title="Acciones">
            <Space>
                <SpaceItem>
                    <Button Type="@ButtonType.Link" Icon="@IconType.Outline.Edit" Size="@ButtonSize.Small">
                        Editar
                    </Button>
                </SpaceItem>
                <SpaceItem>
                    <Button Type="@ButtonType.Link" Danger Icon="@IconType.Outline.Delete" Size="@ButtonSize.Small">
                        Eliminar
                    </Button>
                </SpaceItem>
            </Space>
        </ActionColumn>
    </Table>
</Card>

@code {
    private List<FieldDto> _fields = new();
    private bool _loading = true;
    private bool _hasLoaded = false;
    private string? _errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_hasLoaded)
        {
            _hasLoaded = true;
            await LoadDataAsync();
            StateHasChanged();
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));
            var response = await Http.GetAsync("api/fields", cts.Token);
            
            if (response.IsSuccessStatusCode)
            {
                var content = await response.Content.ReadAsStringAsync(cts.Token);
                _fields = JsonSerializer.Deserialize(content, AppJsonSerializerContext.Default.ListFieldDto) ?? new();
            }
            else
            {
                _errorMessage = $"Error al cargar campos: {response.StatusCode}";
            }
        }
        catch (OperationCanceledException)
        {
            _errorMessage = "La solicitud tardó demasiado tiempo. Intente recargar la página.";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error de conexión: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }
}
