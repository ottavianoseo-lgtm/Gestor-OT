@page "/planner"
@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using System.Net.Http.Json
@using AntDesign
@inject HttpClient Http
@inject IMessageService Message
@inject NavigationManager Nav

<PageTitle>Work Planner - GestorOT</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title">Work Planner</h2>
        <span class="page-subtitle">Planificación visual de órdenes de trabajo</span>
    </div>
    <div style="display: flex; gap: 8px; align-items: center;">
        <RadioGroup @bind-Value="_viewMode" ButtonStyle="RadioButtonStyle.Solid" Size="@InputSize.Small">
            <Radio RadioButton Value="@("month")">Mes</Radio>
            <Radio RadioButton Value="@("week")">Semana</Radio>
        </RadioGroup>
        <Button OnClick="GoToday" Size="@ButtonSize.Small"
                Style="border-radius: 6px; border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.7);">
            Hoy
        </Button>
        <Button OnClick="GoPrev" Size="@ButtonSize.Small"
                Style="border-radius: 6px; border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.7);">
            <Icon Type="left" Theme="IconThemeType.Outline" />
        </Button>
        <span style="color: #fff; font-weight: 600; min-width: 160px; text-align: center; font-size: 15px;">
            @GetHeaderLabel()
        </span>
        <Button OnClick="GoNext" Size="@ButtonSize.Small"
                Style="border-radius: 6px; border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.7);">
            <Icon Type="right" Theme="IconThemeType.Outline" />
        </Button>
        <Select TItemValue="string" TItem="string" @bind-Value="_filterStatus" Placeholder="Filtrar estado" AllowClear
                Style="width: 150px;" Size="@InputSize.Small">
            <SelectOption TItemValue="string" TItem="string" Value="@("all")" Label="Todos" />
            <SelectOption TItemValue="string" TItem="string" Value="@("Draft")" Label="Borrador" />
            <SelectOption TItemValue="string" TItem="string" Value="@("Pending")" Label="Pendiente" />
            <SelectOption TItemValue="string" TItem="string" Value="@("Scheduled")" Label="Planificada" />
            <SelectOption TItemValue="string" TItem="string" Value="@("InProgress")" Label="En Progreso" />
            <SelectOption TItemValue="string" TItem="string" Value="@("Completed")" Label="Completada" />
        </Select>
        <Button Type="@ButtonType.Primary" OnClick="GoToWorkOrders"
                Style="background: #E74C3C; border-color: #E74C3C; border-radius: 8px; font-weight: 600;" Size="@ButtonSize.Small">
            <Icon Type="unordered-list" Theme="IconThemeType.Outline" /> Vista Lista
        </Button>
    </div>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <Alert Type="@AlertType.Error" Message="@_errorMessage" ShowIcon="true" Closable="true" Style="margin-bottom: 16px;" />
}

<div class="planner-legend" style="margin-bottom: 12px; display: flex; gap: 16px; align-items: center;">
    <span class="legend-item"><span class="legend-dot" style="background: #9B59B6;"></span> Borrador</span>
    <span class="legend-item"><span class="legend-dot" style="background: #E74C3C;"></span> Pendiente</span>
    <span class="legend-item"><span class="legend-dot" style="background: #3498DB;"></span> Planificada</span>
    <span class="legend-item"><span class="legend-dot" style="background: #F1C40F;"></span> En Progreso</span>
    <span class="legend-item"><span class="legend-dot" style="background: #2ECC71;"></span> Completada</span>
    <span class="legend-item"><span class="legend-dot" style="background: #95A5A6;"></span> Cancelada</span>
    <span style="margin-left: auto; color: rgba(255,255,255,0.4); font-size: 12px;">
        @FilteredOrders.Count OTs visibles
    </span>
</div>

@if (_loading)
{
    <div style="text-align: center; padding: 60px;">
        <Spin Size="@SpinSize.Large" Tip="Cargando planificación..." />
    </div>
}
else if (_viewMode == "month")
{
    <div class="glass-card" style="padding: 0; overflow: hidden;">
        <div class="cal-grid cal-header">
            @foreach (var day in _dayNames)
            {
                <div class="cal-header-cell">@day</div>
            }
        </div>
        @foreach (var week in MonthWeeks)
        {
            <div class="cal-grid cal-week">
                @foreach (var day in week)
                {
                    var isToday = day.Date == DateTime.Today;
                    var isCurrentMonth = day.Month == _currentDate.Month;
                    var dayOrders = GetOrdersForDate(day);
                    <div class="cal-day @(isToday ? "cal-today" : "") @(!isCurrentMonth ? "cal-other-month" : "")"
                         @onclick="() => OnDayClick(day)">
                        <div class="cal-day-number">@day.Day</div>
                        @foreach (var wo in dayOrders.Take(3))
                        {
                            <div class="cal-event" style="background: @(GetStatusColor(wo.Status))20; border-left: 3px solid @(GetStatusColor(wo.Status)); cursor: pointer;"
                                 @onclick:stopPropagation="true" @onclick="() => NavigateToOrder(wo.Id)">
                                <span class="cal-event-text">@TruncateText(wo.Description, 18)</span>
                            </div>
                        }
                        @if (dayOrders.Count > 3)
                        {
                            <div class="cal-more">+@(dayOrders.Count - 3) más</div>
                        }
                    </div>
                }
            </div>
        }
    </div>
}
else
{
    <div class="glass-card" style="padding: 0; overflow: hidden;">
        <div class="week-grid week-header">
            <div class="week-time-col"></div>
            @foreach (var day in WeekDays)
            {
                var isToday = day.Date == DateTime.Today;
                <div class="week-day-header @(isToday ? "week-today-header" : "")">
                    <span style="font-size: 10px; text-transform: uppercase;">@day.ToString("ddd")</span>
                    <span style="font-size: 18px; font-weight: 700;">@day.Day</span>
                </div>
            }
        </div>
        <div class="week-body">
            @foreach (var day in WeekDays)
            {
                var isToday = day.Date == DateTime.Today;
                var dayOrders = GetOrdersForDate(day);
                <div class="week-day-col @(isToday ? "week-today-col" : "")">
                    @if (dayOrders.Count == 0)
                    {
                        <div class="week-empty" @onclick="() => OnDayClick(day)">
                            <Icon Type="plus" Theme="IconThemeType.Outline" Style="font-size: 16px;" />
                        </div>
                    }
                    @foreach (var wo in dayOrders)
                    {
                        <div class="week-card" style="border-left: 4px solid @(GetStatusColor(wo.Status));"
                             @onclick="() => NavigateToOrder(wo.Id)">
                            <div class="week-card-status" style="background: @(GetStatusColor(wo.Status));">
                                @GetStatusLabel(wo.Status)
                            </div>
                            <div class="week-card-title">@wo.Description</div>
                            <div class="week-card-meta">
                                <Icon Type="environment" Theme="IconThemeType.Outline" Style="font-size: 10px;" />
                                @(wo.LotName ?? "—")
                            </div>
                            <div class="week-card-meta">
                                <Icon Type="user" Theme="IconThemeType.Outline" Style="font-size: 10px;" />
                                @(wo.AssignedTo)
                            </div>
                            @if (wo.EstimatedCostUSD > 0)
                            {
                                <div class="week-card-meta" style="color: #2ECC71;">
                                    <Icon Type="dollar" Theme="IconThemeType.Outline" Style="font-size: 10px;" />
                                    $@wo.EstimatedCostUSD.ToString("N0")
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(wo.OTNumber))
                            {
                                <div class="week-card-ot">@wo.OTNumber</div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

<style>
    .planner-legend { font-size: 12px; color: rgba(255,255,255,0.6); }
    .legend-item { display: flex; align-items: center; gap: 5px; }
    .legend-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }

    .cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); }
    .cal-header-cell {
        padding: 10px 8px;
        text-align: center;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: rgba(255,255,255,0.4);
        font-weight: 600;
        background: rgba(255,255,255,0.04);
        border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .cal-day {
        min-height: 110px;
        padding: 6px;
        border-right: 1px solid rgba(255,255,255,0.04);
        border-bottom: 1px solid rgba(255,255,255,0.04);
        cursor: pointer;
        transition: background 0.15s;
    }
    .cal-day:hover { background: rgba(255,255,255,0.03); }
    .cal-day:nth-child(7) { border-right: none; }
    .cal-today { background: rgba(231,76,60,0.06) !important; }
    .cal-other-month { opacity: 0.35; }
    .cal-day-number {
        font-size: 13px;
        font-weight: 600;
        color: rgba(255,255,255,0.7);
        margin-bottom: 4px;
    }
    .cal-today .cal-day-number {
        color: #E74C3C;
        background: rgba(231,76,60,0.15);
        width: 26px;
        height: 26px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .cal-event {
        padding: 2px 6px;
        border-radius: 4px;
        margin-bottom: 2px;
        font-size: 11px;
        color: rgba(255,255,255,0.85);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        transition: transform 0.1s;
    }
    .cal-event:hover { transform: scale(1.02); }
    .cal-event-text { font-weight: 500; }
    .cal-more {
        font-size: 10px;
        color: rgba(255,255,255,0.4);
        padding: 1px 6px;
        cursor: pointer;
    }

    .week-grid { display: grid; grid-template-columns: repeat(7, 1fr); }
    .week-day-header {
        padding: 10px 8px;
        text-align: center;
        color: rgba(255,255,255,0.5);
        background: rgba(255,255,255,0.04);
        border-bottom: 1px solid rgba(255,255,255,0.06);
        border-right: 1px solid rgba(255,255,255,0.04);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
    }
    .week-today-header {
        color: #E74C3C !important;
        background: rgba(231,76,60,0.08) !important;
    }
    .week-time-col { display: none; }
    .week-body {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        min-height: 500px;
    }
    .week-day-col {
        padding: 8px 6px;
        border-right: 1px solid rgba(255,255,255,0.04);
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .week-today-col { background: rgba(231,76,60,0.04); }
    .week-empty {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 80px;
        color: rgba(255,255,255,0.15);
        cursor: pointer;
        border: 1px dashed rgba(255,255,255,0.08);
        border-radius: 8px;
        transition: all 0.15s;
    }
    .week-empty:hover {
        color: rgba(255,255,255,0.4);
        border-color: rgba(255,255,255,0.2);
        background: rgba(255,255,255,0.02);
    }
    .week-card {
        background: rgba(255,255,255,0.06);
        border-radius: 8px;
        padding: 10px;
        cursor: pointer;
        transition: all 0.15s;
    }
    .week-card:hover {
        background: rgba(255,255,255,0.1);
        transform: translateY(-1px);
    }
    .week-card-status {
        display: inline-block;
        padding: 1px 8px;
        border-radius: 10px;
        font-size: 9px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #fff;
        margin-bottom: 6px;
    }
    .week-card-title {
        font-size: 13px;
        font-weight: 600;
        color: rgba(255,255,255,0.9);
        margin-bottom: 6px;
        line-height: 1.3;
    }
    .week-card-meta {
        font-size: 11px;
        color: rgba(255,255,255,0.45);
        display: flex;
        align-items: center;
        gap: 4px;
        margin-bottom: 2px;
    }
    .week-card-ot {
        font-size: 10px;
        color: rgba(255,255,255,0.3);
        font-family: monospace;
        margin-top: 4px;
    }

    .ant-radio-group-solid .ant-radio-button-wrapper-checked {
        background: #E74C3C !important;
        border-color: #E74C3C !important;
    }
    .ant-radio-button-wrapper {
        background: rgba(255,255,255,0.06) !important;
        border-color: rgba(255,255,255,0.15) !important;
        color: rgba(255,255,255,0.6) !important;
    }
</style>

@code {
    private List<WorkOrderDto> _workOrders = new();
    private bool _loading = true;
    private string? _errorMessage;
    private DateTime _currentDate = DateTime.Today;
    private string _viewMode = "month";
    private string _filterStatus = "all";

    private static readonly string[] _dayNames = { "Lun", "Mar", "Mié", "Jue", "Vie", "Sáb", "Dom" };

    private List<WorkOrderDto> FilteredOrders => string.IsNullOrEmpty(_filterStatus) || _filterStatus == "all"
        ? _workOrders
        : _workOrders.Where(w => w.Status == _filterStatus).ToList();

    private List<DateTime[]> MonthWeeks
    {
        get
        {
            var firstDay = new DateTime(_currentDate.Year, _currentDate.Month, 1);
            var startOffset = ((int)firstDay.DayOfWeek + 6) % 7;
            var start = firstDay.AddDays(-startOffset);
            var weeks = new List<DateTime[]>();
            for (int w = 0; w < 6; w++)
            {
                var week = new DateTime[7];
                for (int d = 0; d < 7; d++)
                    week[d] = start.AddDays(w * 7 + d);
                if (w == 5 && week[0].Month != _currentDate.Month && week[0].Month != firstDay.AddMonths(1).Month)
                    break;
                weeks.Add(week);
            }
            return weeks;
        }
    }

    private DateTime[] WeekDays
    {
        get
        {
            var startOffset = ((int)_currentDate.DayOfWeek + 6) % 7;
            var monday = _currentDate.AddDays(-startOffset);
            return Enumerable.Range(0, 7).Select(i => monday.AddDays(i)).ToArray();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            _loading = true;
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));
            _workOrders = await Http.GetFromJsonAsync("api/workorders",
                AppJsonSerializerContext.Default.ListWorkOrderDto, cts.Token) ?? new();
            _errorMessage = null;
        }
        catch (OperationCanceledException)
        {
            _errorMessage = "La solicitud tardó demasiado tiempo.";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private List<WorkOrderDto> GetOrdersForDate(DateTime date)
    {
        return FilteredOrders
            .Where(w => (w.PlannedDate ?? w.DueDate).Date == date.Date)
            .OrderBy(w => w.Status)
            .ToList();
    }

    private void GoToWorkOrders() { Nav.NavigateTo("/workorders"); }
    private void GoToday() { _currentDate = DateTime.Today; }
    private void GoPrev()
    {
        _currentDate = _viewMode == "month"
            ? _currentDate.AddMonths(-1)
            : _currentDate.AddDays(-7);
    }
    private void GoNext()
    {
        _currentDate = _viewMode == "month"
            ? _currentDate.AddMonths(1)
            : _currentDate.AddDays(7);
    }

    private string GetHeaderLabel()
    {
        if (_viewMode == "month")
            return _currentDate.ToString("MMMM yyyy", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
        var days = WeekDays;
        return $"{days[0]:dd MMM} — {days[6]:dd MMM yyyy}";
    }

    private void OnDayClick(DateTime day)
    {
        _currentDate = day;
        if (_viewMode == "month")
            _viewMode = "week";
    }

    private void NavigateToOrder(Guid id)
    {
        Nav.NavigateTo($"/workorders?id={id}");
    }

    private static string GetStatusColor(string status) => status switch
    {
        "Draft" => "#9B59B6",
        "Scheduled" => "#3498DB",
        "InProgress" => "#F1C40F",
        "Completed" or "Done" or "Approved" => "#2ECC71",
        "Cancelled" => "#95A5A6",
        _ => "#E74C3C"
    };

    private static string GetStatusLabel(string status) => status switch
    {
        "Draft" => "Borrador",
        "Scheduled" => "Planificada",
        "InProgress" => "En Progreso",
        "Completed" or "Done" => "Completada",
        "Approved" => "Aprobada",
        "Cancelled" => "Cancelada",
        _ => "Pendiente"
    };

    private static string TruncateText(string text, int maxLen) =>
        text.Length > maxLen ? text[..maxLen] + "…" : text;
}
