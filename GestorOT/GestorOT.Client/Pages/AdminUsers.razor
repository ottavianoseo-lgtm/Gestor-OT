@page "/admin"
@layout AdminLayout
@inject HttpClient Http
@inject IMessageService Message
@using GestorOT.Shared

<div class="page-header">
    <div>
        <h1 class="page-title">Gestión de Usuarios</h1>
        <span class="page-subtitle">Administración de roles y permisos del sistema</span>
    </div>
    <Button Type="@ButtonType.Primary" OnClick="OpenCreateModal"
            Style="background: #E74C3C; border-color: #E74C3C; border-radius: 8px; font-weight: 600;">
        <Icon Type="user-add" Theme="IconThemeType.Outline" /> Nuevo Usuario
    </Button>
</div>

<div class="glass-card">
    <div style="display: flex; gap: 12px; margin-bottom: 16px; align-items: center;">
        <Input Placeholder="Buscar por nombre o email..." @bind-Value="_searchFilter"
               Style="max-width: 300px; background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.12); color: rgba(255,255,255,0.85); border-radius: 8px;"
               OnPressEnter="() => StateHasChanged()" />
        <Select TItemValue="string" TItem="string" @bind-Value="_roleFilter" Placeholder="Filtrar por rol"
                Style="width: 180px;" AllowClear OnSelectedItemChanged="_ => StateHasChanged()">
            <SelectOptions>
                <SelectOption TItemValue="string" TItem="string" Value="@("Admin")" Label="Admin" />
                <SelectOption TItemValue="string" TItem="string" Value="@("TenantAdmin")" Label="TenantAdmin" />
                <SelectOption TItemValue="string" TItem="string" Value="@("Agronomist")" Label="Agronomist" />
                <SelectOption TItemValue="string" TItem="string" Value="@("Contractor")" Label="Contractor" />
            </SelectOptions>
        </Select>
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <Alert Type="@AlertType.Error" Message="@_error" ShowIcon="true" Style="margin-bottom: 16px;" />
    }

    <Table TItem="UserProfileDto"
           DataSource="@FilteredUsers"
           Loading="@_loading"
           Size="TableSize.Small"
           ScrollX="900">
        <PropertyColumn Property="c => c.DisplayName" Title="Nombre" Sortable />
        <PropertyColumn Property="c => c.Email" Title="Email" Sortable />
        <Column TData="string" Title="Rol">
            <Tag Color="@GetRoleColor(context.Role)">@context.Role</Tag>
        </Column>
        <ActionColumn Title="Estado">
            @if (context.IsActive)
            {
                <Tag Color="@("green")">Activo</Tag>
            }
            else
            {
                <Tag Color="@("red")">Inactivo</Tag>
            }
        </ActionColumn>
        <PropertyColumn Property="c => c.CreatedAt" Title="Creado" Sortable>
            @context.CreatedAt.ToString("dd/MM/yyyy")
        </PropertyColumn>
        <ActionColumn Title="Acciones" Width="160">
            <Space>
                <SpaceItem>
                    <Button Type="@ButtonType.Text" OnClick="() => OpenEditModal(context)"
                            Style="color: rgba(255,255,255,0.6);">
                        <Icon Type="edit" Theme="IconThemeType.Outline" />
                    </Button>
                </SpaceItem>
                <SpaceItem>
                    <Popconfirm Title="¿Eliminar este usuario?" OnConfirm="() => DeleteUser(context.Id)"
                                OkText="Eliminar" CancelText="Cancelar">
                        <Button Type="@ButtonType.Text" Danger>
                            <Icon Type="delete" Theme="IconThemeType.Outline" />
                        </Button>
                    </Popconfirm>
                </SpaceItem>
            </Space>
        </ActionColumn>
    </Table>
</div>

<Modal Title="@(_editingUser != null ? "Editar Usuario" : "Nuevo Usuario")"
       Visible="_modalVisible" OnCancel="() => _modalVisible = false" OnOk="SaveUser"
       OkText="@("Guardar")" CancelText="@("Cancelar")">
    <Form Model="_formModel" LabelColSpan="8" WrapperColSpan="16">
        <FormItem Label="Nombre">
            <Input @bind-Value="_formModel.DisplayName" />
        </FormItem>
        <FormItem Label="Email">
            <Input @bind-Value="_formModel.Email" />
        </FormItem>
        <FormItem Label="Rol">
            <Select @bind-Value="_formModel.Role" TItemValue="string" TItem="string">
                <SelectOptions>
                    <SelectOption TItemValue="string" TItem="string" Value="@("Admin")" Label="Admin" />
                    <SelectOption TItemValue="string" TItem="string" Value="@("TenantAdmin")" Label="TenantAdmin" />
                    <SelectOption TItemValue="string" TItem="string" Value="@("Agronomist")" Label="Agronomist" />
                    <SelectOption TItemValue="string" TItem="string" Value="@("Contractor")" Label="Contractor" />
                </SelectOptions>
            </Select>
        </FormItem>
        <FormItem Label="Activo">
            <Switch @bind-Checked="_formModel.IsActive" />
        </FormItem>
    </Form>
</Modal>

@code {
    private List<UserProfileDto> _users = new();
    private bool _loading = true;
    private string? _error;
    private bool _modalVisible;
    private UserProfileDto? _editingUser;
    private UserFormModel _formModel = new();
    private string _searchFilter = "";
    private string? _roleFilter;

    private List<UserProfileDto> FilteredUsers => _users
        .Where(u =>
            (string.IsNullOrEmpty(_searchFilter) ||
             u.DisplayName.Contains(_searchFilter, StringComparison.OrdinalIgnoreCase) ||
             u.Email.Contains(_searchFilter, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(_roleFilter) || u.Role == _roleFilter))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        _loading = true;
        _error = null;
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));
            _users = await Http.GetFromJsonAsync("api/userprofiles",
                AppJsonSerializerContext.Default.ListUserProfileDto, cts.Token) ?? new();
        }
        catch (Exception ex)
        {
            _error = $"Error al cargar usuarios: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void OpenCreateModal()
    {
        _editingUser = null;
        _formModel = new UserFormModel { Role = "Agronomist", IsActive = true };
        _modalVisible = true;
    }

    private void OpenEditModal(UserProfileDto user)
    {
        _editingUser = user;
        _formModel = new UserFormModel
        {
            DisplayName = user.DisplayName,
            Email = user.Email,
            Role = user.Role,
            IsActive = user.IsActive
        };
        _modalVisible = true;
    }

    private async Task SaveUser()
    {
        if (string.IsNullOrWhiteSpace(_formModel.DisplayName) || string.IsNullOrWhiteSpace(_formModel.Email))
        {
            Message.Error("Nombre y Email son obligatorios.");
            return;
        }

        try
        {
            var dto = new UserProfileDto(
                _editingUser?.Id ?? Guid.Empty,
                _formModel.Email,
                _formModel.DisplayName,
                _formModel.Role,
                _formModel.IsActive,
                _editingUser?.CreatedAt ?? DateTime.UtcNow
            );

            if (_editingUser != null)
            {
                await Http.PutAsJsonAsync($"api/userprofiles/{_editingUser.Id}", dto,
                    AppJsonSerializerContext.Default.UserProfileDto);
                Message.Success("Usuario actualizado.");
            }
            else
            {
                await Http.PostAsJsonAsync("api/userprofiles", dto,
                    AppJsonSerializerContext.Default.UserProfileDto);
                Message.Success("Usuario creado.");
            }

            _modalVisible = false;
            await LoadUsers();
        }
        catch
        {
            Message.Error("Error al guardar usuario.");
        }
    }

    private async Task DeleteUser(Guid id)
    {
        try
        {
            await Http.DeleteAsync($"api/userprofiles/{id}");
            Message.Success("Usuario eliminado.");
            await LoadUsers();
        }
        catch
        {
            Message.Error("Error al eliminar usuario.");
        }
    }

    private string GetRoleColor(string role) => role switch
    {
        "Admin" => "red",
        "TenantAdmin" => "orange",
        "Agronomist" => "green",
        "Contractor" => "blue",
        _ => "default"
    };

    private class UserFormModel
    {
        public string DisplayName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Role { get; set; } = "Agronomist";
        public bool IsActive { get; set; } = true;
    }
}
