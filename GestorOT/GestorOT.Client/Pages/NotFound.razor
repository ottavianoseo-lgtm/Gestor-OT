@page "/not-found"
@using AntDesign

<div style="display: flex; align-items: center; justify-content: center; min-height: 80vh; padding: 40px;">
    <div style="text-align: center; max-width: 420px;">
        <div style="font-size: 96px; font-weight: 800; color: rgba(231,76,60,0.15); letter-spacing: -4px; line-height: 1;">
            404
        </div>
        <h2 style="color: rgba(255,255,255,0.85); font-size: 20px; font-weight: 600; margin: 16px 0 8px;">
            Página no encontrada
        </h2>
        <p style="color: rgba(255,255,255,0.45); font-size: 14px; margin: 0 0 28px; line-height: 1.6;">
            El recurso que buscás no existe o fue movido. Verificá la URL o volvé al inicio.
        </p>
        <div style="display: flex; gap: 10px; justify-content: center;">
            <a href="/" style="display: inline-flex; align-items: center; gap: 6px; padding: 10px 20px; background: #E74C3C; color: #fff; border-radius: 8px; text-decoration: none; font-size: 13px; font-weight: 600; transition: background 0.2s;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
                Volver al Inicio
            </a>
            <a href="/admin/users" style="display: inline-flex; align-items: center; gap: 6px; padding: 10px 20px; background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.7); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; text-decoration: none; font-size: 13px; font-weight: 500; transition: all 0.2s;">
                Panel Admin
            </a>
        </div>
    </div>
</div>
