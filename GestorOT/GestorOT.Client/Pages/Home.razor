@page "/"

<PageTitle>Dashboard - GestorOT</PageTitle>

<Row Gutter="(16, 16)">
    <Col Span="6">
        <Card Bordered="false" Style="box-shadow: 0 2px 8px rgba(0,0,0,0.09);">
            <Statistic Title="Campos Activos" Value="12">
                <PrefixTemplate>
                    <Icon Type="environment" Theme="IconThemeType.Outline" Style="color: #E74C3C;" />
                </PrefixTemplate>
            </Statistic>
        </Card>
    </Col>
    <Col Span="6">
        <Card Bordered="false" Style="box-shadow: 0 2px 8px rgba(0,0,0,0.09);">
            <Statistic Title="Lotes Registrados" Value="48">
                <PrefixTemplate>
                    <Icon Type="block" Theme="IconThemeType.Outline" Style="color: #E74C3C;" />
                </PrefixTemplate>
            </Statistic>
        </Card>
    </Col>
    <Col Span="6">
        <Card Bordered="false" Style="box-shadow: 0 2px 8px rgba(0,0,0,0.09);">
            <Statistic Title="OT Pendientes" Value="7" ValueStyle="color: #F1C40F;">
                <PrefixTemplate>
                    <Icon Type="clock-circle" Theme="IconThemeType.Outline" Style="color: #F1C40F;" />
                </PrefixTemplate>
            </Statistic>
        </Card>
    </Col>
    <Col Span="6">
        <Card Bordered="false" Style="box-shadow: 0 2px 8px rgba(0,0,0,0.09);">
            <Statistic Title="OT Completadas" Value="156" ValueStyle="color: #2ECC71;">
                <PrefixTemplate>
                    <Icon Type="check-circle" Theme="IconThemeType.Outline" Style="color: #2ECC71;" />
                </PrefixTemplate>
            </Statistic>
        </Card>
    </Col>
</Row>

<Row Gutter="(16, 16)" Style="margin-top: 24px;">
    <Col Span="16">
        <Card Title="Órdenes de Trabajo Recientes" Bordered="false" Style="box-shadow: 0 2px 8px rgba(0,0,0,0.09);">
            <Table TItem="RecentWorkOrder" DataSource="@_recentOrders" Size="TableSize.Small">
                <PropertyColumn Property="c => c.Description" Title="Descripción" />
                <PropertyColumn Property="c => c.LotName" Title="Lote" />
                <Column TData="string" Title="Estado">
                    @{
                        var color = context.Status switch
                        {
                            "Completada" => "green",
                            "En Progreso" => "gold",
                            _ => "red"
                        };
                    }
                    <Tag Color="@color">@context.Status</Tag>
                </Column>
                <PropertyColumn Property="c => c.AssignedTo" Title="Asignado" />
            </Table>
        </Card>
    </Col>
    <Col Span="8">
        <Card Title="Estado del Sistema" Bordered="false" Style="box-shadow: 0 2px 8px rgba(0,0,0,0.09);">
            <div style="padding: 16px 0;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 16px;">
                    <span>Conexión a Supabase</span>
                    <Tag Color="@("green")">Activo</Tag>
                </div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 16px;">
                    <span>PostGIS</span>
                    <Tag Color="@("green")">Habilitado</Tag>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span>Última sincronización</span>
                    <span style="color: #888;">Hace 5 min</span>
                </div>
            </div>
        </Card>
    </Col>
</Row>

@code {
    private List<RecentWorkOrder> _recentOrders = new()
    {
        new() { Description = "Fumigación parcela norte", LotName = "Lote A-1", Status = "Completada", AssignedTo = "Juan P." },
        new() { Description = "Riego sistema goteo", LotName = "Lote B-3", Status = "En Progreso", AssignedTo = "María G." },
        new() { Description = "Cosecha temprana", LotName = "Lote C-2", Status = "Pendiente", AssignedTo = "Carlos R." },
        new() { Description = "Mantenimiento cercas", LotName = "Lote A-4", Status = "En Progreso", AssignedTo = "Ana L." },
    };
    
    private class RecentWorkOrder
    {
        public string Description { get; set; } = "";
        public string LotName { get; set; } = "";
        public string Status { get; set; } = "";
        public string AssignedTo { get; set; } = "";
    }
}
