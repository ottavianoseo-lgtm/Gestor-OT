@page "/"
@using GestorOT.Shared.Dtos
@using System.Net.Http.Json
@using System.Text.Json
@inject HttpClient Http

<PageTitle>Dashboard - GestorOT</PageTitle>

<Alert Type="@AlertType.Info" Message="@(_loading ? "Cargando..." : _debugInfo)" Style="margin-bottom: 16px;" />

<Row Gutter="(16, 16)">
    <Col Span="6">
        <Card Bordered="false" Style="box-shadow: 0 2px 8px rgba(0,0,0,0.09);">
            <Statistic Title="Campos Activos" Value="@_stats.FieldsCount">
                <PrefixTemplate>
                    <Icon Type="environment" Theme="IconThemeType.Outline" Style="color: #E74C3C;" />
                </PrefixTemplate>
            </Statistic>
        </Card>
    </Col>
    <Col Span="6">
        <Card Bordered="false" Style="box-shadow: 0 2px 8px rgba(0,0,0,0.09);">
            <Statistic Title="Lotes Registrados" Value="@_stats.LotsCount">
                <PrefixTemplate>
                    <Icon Type="block" Theme="IconThemeType.Outline" Style="color: #E74C3C;" />
                </PrefixTemplate>
            </Statistic>
        </Card>
    </Col>
    <Col Span="6">
        <Card Bordered="false" Style="box-shadow: 0 2px 8px rgba(0,0,0,0.09);">
            <Statistic Title="OT Pendientes" Value="@_stats.PendingWorkOrders" ValueStyle="color: #F1C40F;">
                <PrefixTemplate>
                    <Icon Type="clock-circle" Theme="IconThemeType.Outline" Style="color: #F1C40F;" />
                </PrefixTemplate>
            </Statistic>
        </Card>
    </Col>
    <Col Span="6">
        <Card Bordered="false" Style="box-shadow: 0 2px 8px rgba(0,0,0,0.09);">
            <Statistic Title="OT Completadas" Value="@_stats.CompletedWorkOrders" ValueStyle="color: #2ECC71;">
                <PrefixTemplate>
                    <Icon Type="check-circle" Theme="IconThemeType.Outline" Style="color: #2ECC71;" />
                </PrefixTemplate>
            </Statistic>
        </Card>
    </Col>
</Row>

<Row Gutter="(16, 16)" Style="margin-top: 24px;">
    <Col Span="16">
        <Card Title="Órdenes de Trabajo Recientes" Bordered="false" Style="box-shadow: 0 2px 8px rgba(0,0,0,0.09);">
            <Table TItem="WorkOrderDto" DataSource="@_recentOrders" Size="TableSize.Small" Loading="@_loading">
                <PropertyColumn Property="c => c.Description" Title="Descripción" />
                <PropertyColumn Property="c => c.LotName" Title="Lote" />
                <Column TData="string" Title="Estado">
                    @{
                        var color = context.Status switch
                        {
                            "Completed" => "green",
                            "InProgress" => "gold",
                            _ => "red"
                        };
                        var label = context.Status switch
                        {
                            "Completed" => "Completada",
                            "InProgress" => "En Progreso",
                            _ => "Pendiente"
                        };
                    }
                    <Tag Color="@color">@label</Tag>
                </Column>
                <PropertyColumn Property="c => c.AssignedTo" Title="Asignado" />
            </Table>
        </Card>
    </Col>
    <Col Span="8">
        <Card Title="Estado del Sistema" Bordered="false" Style="box-shadow: 0 2px 8px rgba(0,0,0,0.09);">
            <div style="padding: 16px 0;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 16px;">
                    <span>Conexión a Supabase</span>
                    <Tag Color="@(_isConnected ? "green" : "red")">@(_isConnected ? "Activo" : "Desconectado")</Tag>
                </div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 16px;">
                    <span>PostGIS</span>
                    <Tag Color="@("green")">Habilitado</Tag>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span>Última sincronización</span>
                    <span style="color: #888;">@_lastSync</span>
                </div>
            </div>
        </Card>
    </Col>
</Row>

@code {
    private DashboardStatsDto _stats = new();
    private List<WorkOrderDto> _recentOrders = new();
    private bool _loading = true;
    private bool _isConnected = false;
    private string _lastSync = "Cargando...";
    private string _debugInfo = "";

    private static readonly JsonSerializerOptions _jsonOptions = new()
    {
        PropertyNameCaseInsensitive = true
    };

    protected override async Task OnInitializedAsync()
    {
        _debugInfo = "Iniciando...";
        StateHasChanged();
        
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(10));
            
            _debugInfo = "Llamando API stats...";
            StateHasChanged();
            
            var statsResponse = await Http.GetAsync("api/dashboard/stats", cts.Token);
            var statsContent = await statsResponse.Content.ReadAsStringAsync(cts.Token);
            
            _debugInfo = $"Stats: {statsResponse.StatusCode} ({statsContent.Length} bytes)";
            StateHasChanged();
            
            if (statsResponse.IsSuccessStatusCode && !string.IsNullOrEmpty(statsContent))
            {
                _stats = JsonSerializer.Deserialize<DashboardStatsDto>(statsContent, _jsonOptions) ?? new();
                _debugInfo = $"Stats OK: Fields={_stats.FieldsCount}, Lots={_stats.LotsCount}";
            }
            
            var ordersResponse = await Http.GetAsync("api/dashboard/recent-orders", cts.Token);
            var ordersContent = await ordersResponse.Content.ReadAsStringAsync(cts.Token);
            
            if (ordersResponse.IsSuccessStatusCode && !string.IsNullOrEmpty(ordersContent))
            {
                _recentOrders = JsonSerializer.Deserialize<List<WorkOrderDto>>(ordersContent, _jsonOptions) ?? new();
            }
            
            _isConnected = true;
            _lastSync = "Ahora";
            _debugInfo = $"Conectado: {_stats.FieldsCount} campos, {_stats.LotsCount} lotes, {_recentOrders.Count} ordenes";
        }
        catch (Exception ex)
        {
            _debugInfo = $"Error: {ex.GetType().Name}: {ex.Message}";
            _isConnected = false;
            _lastSync = "Error de conexión";
        }
        finally
        {
            _loading = false;
        }
    }
}
