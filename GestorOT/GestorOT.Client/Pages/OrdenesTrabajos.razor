    private void OpenRealizeModal(LaborDto labor)
    {
        _realizingLabor = labor;
        _realizeSupplies = labor.Supplies?.Select(s => new RealizeSupplyModel
        {
            Id = s.Id,
            SupplyId = s.SupplyId,
            SupplyName = s.SupplyName ?? "Insumo",
            PlannedDose = s.PlannedDose,
            DoseUnit = s.DoseUnit,
            RealDoseInput = s.PlannedDose
        }).ToList() ?? new();
        _realizeModalVisible = true;
    }

    private void CloseRealizeModal()
    {
        _realizeModalVisible = false;
        _realizingLabor = null;
    }

    private async Task ConfirmRealize()
    {
        if (_realizingLabor == null) return;

        _savingRealize = true;
        try
        {
            var realSupplies = _realizeSupplies.Select(rs => new LaborSupplyDto(
                rs.Id,
                _realizingLabor.Id,
                rs.SupplyId,
                rs.PlannedDose,
                rs.RealDoseInput,
                rs.PlannedDose * _realizingLabor.Hectares,
                rs.RealDoseInput * _realizingLabor.Hectares,
                rs.DoseUnit,
                rs.SupplyName,
                null
            )).ToList();

            var response = await Http.PostAsJsonAsync(
                $"api/labors/{_realizingLabor.Id}/realize",
                realSupplies,
                AppJsonSerializerContext.Default.ListLaborSupplyDto);

            if (response.IsSuccessStatusCode)
            {
                Message.Success("Labor confirmada como realizada.");
                _realizeModalVisible = false;
                _realizingLabor = null;
                await RefreshDetail();
            }
            else
            {
                Message.Error($"Error: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
        finally
        {
            _savingRealize = false;
        }
    }

    private async Task ReplicateLabor(Guid laborId)
    {
        try
        {
            var response = await Http.PostAsync($"api/labors/{laborId}/replicate", null);
            if (response.IsSuccessStatusCode)
            {
                Message.Success("Labor replicada como 'Realizada'.");
                await RefreshDetail();
            }
            else
            {
                Message.Error($"Error al replicar: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
    }
