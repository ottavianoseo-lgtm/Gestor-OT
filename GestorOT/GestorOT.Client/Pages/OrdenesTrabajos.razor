@page "/workorders"
@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using System.Net.Http.Json
@using AntDesign
@inject HttpClient Http
@inject IMessageService Message
@inject IJSRuntime JS
@inject GestorOT.Client.Services.CampaignState CampaignState
@inject GestorOT.Client.Services.TenantState TenantState
@implements IDisposable

<PageTitle>Órdenes de Trabajo - GestorOT</PageTitle>

@if (_selectedOrder == null)
{
    <div class="page-header">
        <div>
            <h2 class="page-title">Órdenes de Trabajo</h2>
            <span class="page-subtitle">@_workOrders.Count órdenes registradas</span>
        </div>
        <Button Type="@ButtonType.Primary" OnClick="OpenCreateModal"
                Style="background: #E74C3C; border-color: #E74C3C; border-radius: 8px; font-weight: 600;">
            <Icon Type="plus" Theme="IconThemeType.Outline" /> Nueva Orden
        </Button>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <Alert Type="@AlertType.Error" Message="@_errorMessage" ShowIcon="true" Style="margin-bottom: 16px;" />
    }

    <AntDesign.Row Gutter="@((16, 16))" Style="margin-bottom: 16px;">
        <AntDesign.Col Xs="24" Sm="6">
            <div class="kpi-card-sm" style="border-left: 3px solid #E74C3C;">
                <span class="kpi-sm-value">@_workOrders.Count(w => w.Status == "Pending" || w.Status == "Draft")</span>
                <span class="kpi-sm-label">Pendientes</span>
            </div>
        </AntDesign.Col>
        <AntDesign.Col Xs="24" Sm="6">
            <div class="kpi-card-sm" style="border-left: 3px solid #F1C40F;">
                <span class="kpi-sm-value">@_workOrders.Count(w => w.Status == "InProgress")</span>
                <span class="kpi-sm-label">En Progreso</span>
            </div>
        </AntDesign.Col>
        <AntDesign.Col Xs="24" Sm="6">
            <div class="kpi-card-sm" style="border-left: 3px solid #3498DB;">
                <span class="kpi-sm-value">@_workOrders.Count(w => w.Status == "Completed" || w.Status == "Done")</span>
                <span class="kpi-sm-label">Completadas</span>
            </div>
        </AntDesign.Col>
        <AntDesign.Col Xs="24" Sm="6">
            <div class="kpi-card-sm" style="border-left: 3px solid #2ECC71;">
                <span class="kpi-sm-value">@_workOrders.Count(w => w.Status == "Approved")</span>
                <span class="kpi-sm-label">Aprobadas</span>
            </div>
        </AntDesign.Col>
    </AntDesign.Row>

    <div class="glass-card">
        <Table TItem="WorkOrderDto" DataSource="_workOrders" Loading="_loading" Size="@TableSize.Small"
               ScrollX="1200">
            <PropertyColumn Property="c => c.Description" Title="Descripción">
                <span style="font-weight: 600;">@context.Description</span>
            </PropertyColumn>
            <PropertyColumn Property="c => c.LotName" Title="Lote" Sortable />
            <Column TData="string" Title="Estado">
                @{
                    var (color, label) = context.Status switch
                    {
                        "Approved" => ("#2ECC71", "Aprobada"),
                        "Completed" or "Done" => ("#3498DB", "Completada"),
                        "InProgress" => ("#F1C40F", "En Progreso"),
                        "Cancelled" => ("#95A5A6", "Cancelada"),
                        "Draft" => ("#9B59B6", "Borrador"),
                        _ => ("#E74C3C", "Pendiente")
                    };
                }
                <Tag Style="@($"background: {color}20; color: {color}; border: 1px solid {color}40; border-radius: 12px; font-size: 11px; font-weight: 600; padding: 2px 10px;")">
                    @label
                </Tag>
            </Column>
            <PropertyColumn Property="c => c.AssignedTo" Title="Asignado a" Sortable />
            <PropertyColumn Property="c => c.DueDate" Title="Fecha Límite" Sortable>
                @context.DueDate.ToString("dd/MM/yyyy")
            </PropertyColumn>
            <ActionColumn Title="Acciones" Width="220">
                <Space>
                    <SpaceItem>
                        <Button Size="@ButtonSize.Small" OnClick="() => OpenDetail(context.Id)"
                                Style="border-radius: 6px; background: #3498DB20; border-color: #3498DB40; color: #3498DB; font-size: 11px;">
                            <Icon Type="eye" Theme="IconThemeType.Outline" /> Ver
                        </Button>
                    </SpaceItem>
                    <SpaceItem>
                        <Button Size="@ButtonSize.Small" OnClick="() => OpenEditModal(context)"
                                Style="border-radius: 6px; border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.7);">
                            <Icon Type="edit" Theme="IconThemeType.Outline" />
                        </Button>
                    </SpaceItem>
                    <SpaceItem>
                        <Popconfirm Title="¿Eliminar esta orden de trabajo?"
                                    OnConfirm="() => DeleteWorkOrder(context.Id)"
                                    OkText="@("Eliminar")" CancelText="@("Cancelar")">
                            <Button Danger Size="@ButtonSize.Small" Style="border-radius: 6px;">
                                <Icon Type="delete" Theme="IconThemeType.Outline" />
                            </Button>
                        </Popconfirm>
                    </SpaceItem>
                </Space>
            </ActionColumn>
        </Table>
    </div>
}
else
{
    <div class="page-header">
        <div style="display: flex; align-items: center; gap: 12px;">
            <Button OnClick="BackToList" Style="border-radius: 6px; border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.7);">
                <Icon Type="arrow-left" Theme="IconThemeType.Outline" />
            </Button>
            <div>
                <h2 class="page-title">@_selectedOrder.Description</h2>
                <span class="page-subtitle">@_selectedOrder.FieldName — @_selectedOrder.LotName</span>
            </div>
        </div>
        <div style="display: flex; gap: 8px; align-items: center;">
            @{
                var (stColor, stLabel) = _selectedOrder.Status switch
                {
                    "Approved" => ("#2ECC71", "Aprobada"),
                    "Completed" or "Done" => ("#3498DB", "Completada"),
                    "InProgress" => ("#F1C40F", "En Progreso"),
                    "Cancelled" => ("#95A5A6", "Cancelada"),
                    "Draft" => ("#9B59B6", "Borrador"),
                    _ => ("#E74C3C", "Pendiente")
                };
            }
            <Tag Style="@($"background: {stColor}20; color: {stColor}; border: 1px solid {stColor}40; border-radius: 12px; font-size: 12px; font-weight: 600; padding: 4px 14px;")">
                @stLabel
            </Tag>
            <span style="color: rgba(255,255,255,0.5); font-size: 12px;">
                Responsable: <strong style="color: #fff;">@_selectedOrder.AssignedTo</strong>
            </span>
            <span style="color: rgba(255,255,255,0.5); font-size: 12px;">
                Vence: <strong style="color: #fff;">@_selectedOrder.DueDate.ToString("dd/MM/yyyy")</strong>
            </span>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <Alert Type="@AlertType.Error" Message="@_errorMessage" ShowIcon="true" Style="margin-bottom: 16px;" />
    }

    <AntDesign.Row Gutter="@((16, 16))" Style="margin-bottom: 16px;">
        <AntDesign.Col Xs="24" Sm="6">
            <div class="kpi-card-sm" style="border-left: 3px solid #3498DB;">
                <span class="kpi-sm-value">@_selectedOrder.Labors.Count</span>
                <span class="kpi-sm-label">Total Labores</span>
            </div>
        </AntDesign.Col>
        <AntDesign.Col Xs="24" Sm="6">
            <div class="kpi-card-sm" style="border-left: 3px solid #F1C40F;">
                <span class="kpi-sm-value">@_selectedOrder.Labors.Count(l => l.Status == "Planned")</span>
                <span class="kpi-sm-label">Planificadas</span>
            </div>
        </AntDesign.Col>
        <AntDesign.Col Xs="24" Sm="6">
            <div class="kpi-card-sm" style="border-left: 3px solid #2ECC71;">
                <span class="kpi-sm-value">@_selectedOrder.Labors.Count(l => l.Status == "Realized")</span>
                <span class="kpi-sm-label">Realizadas</span>
            </div>
        </AntDesign.Col>
        <AntDesign.Col Xs="24" Sm="6">
            <div class="kpi-card-sm" style="border-left: 3px solid #9B59B6;">
                @{
                    var totalHa = _selectedOrder.Labors.Sum(l => l.Hectares);
                }
                <span class="kpi-sm-value">@totalHa.ToString("N1")</span>
                <span class="kpi-sm-label">Hectáreas</span>
            </div>
        </AntDesign.Col>
    </AntDesign.Row>

    @if (_selectedOrder.Status != "Approved" && _selectedOrder.Status != "Cancelled")
    {
        <div style="display: flex; gap: 8px; margin-bottom: 16px;">
            @if (_selectedOrder.Labors.All(l => l.Status == "Realized") && _selectedOrder.Labors.Count > 0)
            {
                <Button Type="@ButtonType.Primary" OnClick="ApproveWorkOrder" Loading="_approving"
                        Style="background: #2ECC71; border-color: #2ECC71; border-radius: 8px; font-weight: 600;">
                    <Icon Type="check-circle" Theme="IconThemeType.Outline" /> Aprobar OT y Generar Liquidación
                </Button>
            }
            else if (_selectedOrder.Labors.Count > 0)
            {
                <Button Disabled
                        Style="border-radius: 8px; font-weight: 600; border-color: rgba(255,255,255,0.1); color: rgba(255,255,255,0.3);">
                    <Icon Type="lock" Theme="IconThemeType.Outline" /> Aprobar (faltan @(_selectedOrder.Labors.Count(l => l.Status == "Planned")) labores por realizar)
                </Button>
            }

            <Button OnClick="GenerateShareLink" Loading="_generatingLink"
                    Style="border-radius: 8px; font-weight: 600; border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.7);">
                <Icon Type="link" Theme="IconThemeType.Outline" /> Compartir con Contratista
            </Button>
        </div>

        @if (!string.IsNullOrEmpty(_shareLink))
        {
            <div class="glass-card" style="margin-bottom: 16px; padding: 14px 16px; border: 1px solid rgba(231,76,60,0.3); background: rgba(231,76,60,0.05);">
                <div style="display: flex; align-items: center; gap: 12px;">
                    <Icon Type="link" Theme="IconThemeType.Outline" Style="color: #E74C3C; font-size: 18px;" />
                    <div style="flex: 1; min-width: 0;">
                        <div style="color: rgba(255,255,255,0.5); font-size: 11px; margin-bottom: 2px;">Magic Link (expira @_shareLinkExpiry?.ToString("dd/MM/yyyy"))</div>
                        <div style="color: #fff; font-size: 12px; word-break: break-all; font-family: monospace;">@_shareLink</div>
                    </div>
                    <Button OnClick="CopyShareLink" Style="border-radius: 6px; border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.7); font-size: 12px; padding: 2px 8px;">
                        <Icon Type="copy" Theme="IconThemeType.Outline" /> Copiar
                    </Button>
                </div>
            </div>
        }
    }

    @if (_selectedOrder.Settlement != null)
    {
        <div class="glass-card" style="margin-bottom: 16px; padding: 20px; border: 1px solid rgba(46,204,113,0.3); background: rgba(46,204,113,0.05);">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div style="display: flex; align-items: center; gap: 12px;">
                    <div style="width: 44px; height: 44px; border-radius: 12px; background: #2ECC7120; display: flex; align-items: center; justify-content: center;">
                        <Icon Type="dollar" Theme="IconThemeType.Outline" Style="font-size: 20px; color: #2ECC71;" />
                    </div>
                    <div>
                        <span style="font-weight: 700; color: #2ECC71; font-size: 16px;">Liquidación Generada</span>
                        <br />
                        <span style="color: rgba(255,255,255,0.5); font-size: 12px;">
                            @_selectedOrder.Settlement.GeneratedAt.ToString("dd/MM/yyyy HH:mm") — Estado ERP: @_selectedOrder.Settlement.ErpSyncStatus
                        </span>
                    </div>
                </div>
                <div style="text-align: right;">
                    <div style="font-size: 24px; font-weight: 800; color: #2ECC71;">
                        $@_selectedOrder.Settlement.TotalAmount.ToString("N2")
                    </div>
                    <div style="color: rgba(255,255,255,0.5); font-size: 12px;">
                        @_selectedOrder.Settlement.TotalHectares.ToString("N2") ha totales
                    </div>
                </div>
            </div>
            @if (_selectedOrder.Settlement.Lines != null && _selectedOrder.Settlement.Lines.Count > 0)
            {
                <table class="supply-table" style="width: 100%; margin-top: 12px;">
                    <thead>
                        <tr>
                            <th>Labor</th>
                            <th>Cantidad</th>
                            <th>Tarifa</th>
                            <th style="text-align: right;">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in _selectedOrder.Settlement.Lines)
                        {
                            <tr>
                                <td style="font-weight: 600; color: #fff;">@line.LaborType</td>
                                <td>@line.Quantity.ToString("N2") @line.RateUnit</td>
                                <td>$@line.Rate.ToString("N2")/@line.RateUnit</td>
                                <td style="text-align: right; font-weight: 600; color: #2ECC71;">$@line.Subtotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" style="text-align: right; font-weight: 700; color: #fff;">TOTAL</td>
                            <td style="text-align: right; font-weight: 800; color: #2ECC71; font-size: 16px;">$@_selectedOrder.Settlement.TotalAmount.ToString("N2")</td>
                        </tr>
                    </tfoot>
                </table>
            }
        </div>
    }

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
        <h3 style="color: #fff; margin: 0; font-size: 16px;">Labores</h3>
        @if (_selectedOrder.Status != "Approved" && _selectedOrder.Status != "Cancelled")
        {
            <Button Type="@ButtonType.Primary" OnClick="OpenLaborModal"
                    Style="background: #E74C3C; border-color: #E74C3C; border-radius: 8px; font-weight: 600;">
                <Icon Type="plus" Theme="IconThemeType.Outline" /> Nueva Labor
            </Button>
        }
    </div>

    @if (_selectedOrder.Labors.Count == 0)
    {
        <div class="glass-card" style="text-align: center; padding: 40px;">
            <Icon Type="inbox" Theme="IconThemeType.Outline" Style="font-size: 40px; color: rgba(255,255,255,0.2); margin-bottom: 12px;" />
            <p style="color: rgba(255,255,255,0.4); margin: 0;">No hay labores cargadas. Agregá una labor para comenzar.</p>
        </div>
    }

    @foreach (var labor in _selectedOrder.Labors)
    {
        <div class="glass-card labor-card" style="margin-bottom: 12px;">
            <div class="labor-header">
                <div style="display: flex; align-items: center; gap: 10px;">
                    <Tag Style="@((labor.Status == "Realized" ? "background: #2ECC7120; color: #2ECC71; border: 1px solid #2ECC7140; " : "background: #F1C40F20; color: #F1C40F; border: 1px solid #F1C40F40; ") + "border-radius: 12px; font-size: 11px; font-weight: 600; padding: 2px 10px;")">
                        @(labor.Status == "Realized" ? "Realizada" : "Planificada")
                    </Tag>
                    <span style="font-weight: 700; color: #fff; font-size: 14px;">@labor.LaborType</span>
                    <span style="color: rgba(255,255,255,0.5); font-size: 12px;">
                        en <strong style="color: rgba(255,255,255,0.7);">@labor.LotName</strong> — @labor.Hectares.ToString("N2") ha
                    </span>
                    @if (labor.Rate > 0)
                    {
                        <span style="color: #2ECC71; font-size: 12px; font-weight: 600;">
                            $@labor.Rate.ToString("N2")/@labor.RateUnit
                        </span>
                    }
                    @if (labor.ExecutionDate.HasValue)
                    {
                        <span style="color: rgba(255,255,255,0.4); font-size: 11px;">
                            Fecha: @labor.ExecutionDate.Value.ToString("dd/MM/yyyy")
                        </span>
                    }
                </div>
                <div style="display: flex; gap: 6px;">
                    @if (labor.Status == "Planned" && _selectedOrder.Status != "Approved")
                    {
                        <Button Size="@ButtonSize.Small" OnClick="() => OpenRealizeModal(labor)"
                                Style="border-radius: 6px; background: #2ECC7120; border-color: #2ECC7140; color: #2ECC71; font-size: 11px;">
                            <Icon Type="check-circle" Theme="IconThemeType.Outline" /> Ejecutar Labor
                        </Button>
                    }
                    @if (_selectedOrder.Status != "Approved")
                    {
                        <Button Size="@ButtonSize.Small" OnClick="() => OpenEditLaborModal(labor)"
                                Style="border-radius: 6px; border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.7);">
                            <Icon Type="edit" Theme="IconThemeType.Outline" />
                        </Button>
                        <Popconfirm Title="¿Eliminar esta labor?" OnConfirm="() => DeleteLabor(labor.Id)"
                                    OkText="@("Eliminar")" CancelText="@("Cancelar")">
                            <Button Danger Size="@ButtonSize.Small" Style="border-radius: 6px;">
                                <Icon Type="delete" Theme="IconThemeType.Outline" />
                            </Button>
                        </Popconfirm>
                    }
                </div>
            </div>

            @if (labor.Supplies != null && labor.Supplies.Count > 0)
            {
                <div class="supply-table-wrapper">
                    <table class="supply-table">
                        <thead>
                            <tr>
                                <th>Insumo</th>
                                <th>Dosis Plan.</th>
                                <th>Total Plan.</th>
                                @if (labor.Status == "Realized")
                                {
                                    <th>Dosis Real</th>
                                    <th>Total Real</th>
                                    <th>Delta</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var supply in labor.Supplies)
                            {
                                <tr>
                                    <td style="font-weight: 600; color: #fff;">@supply.SupplyName</td>
                                    <td>@supply.PlannedDose.ToString("N2") @supply.DoseUnit</td>
                                    <td>@supply.PlannedTotal.ToString("N2") @supply.SupplyUnit</td>
                                    @if (labor.Status == "Realized")
                                    {
                                        <td>@(supply.RealDose?.ToString("N2") ?? "-") @supply.DoseUnit</td>
                                        <td>@(supply.RealTotal?.ToString("N2") ?? "-") @supply.SupplyUnit</td>
                                        <td>
                                            @if (supply.RealDose.HasValue && supply.PlannedDose > 0)
                                            {
                                                var delta = ((supply.RealDose.Value - supply.PlannedDose) / supply.PlannedDose) * 100;
                                                var deltaColor = delta > 0 ? "#E74C3C" : delta < 0 ? "#2ECC71" : "#F1C40F";
                                                <span style="color: @deltaColor; font-weight: 600;">
                                                    @(delta > 0 ? "+" : "")@delta.ToString("N1")%
                                                </span>
                                            }
                                            else
                                            {
                                                <span>-</span>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p style="color: rgba(255,255,255,0.3); font-size: 12px; margin: 8px 0 0 0;">Sin insumos asignados</p>
            }
        </div>
    }
}

<Modal Title="@(_isEditing ? "Editar Orden de Trabajo" : "Nueva Orden de Trabajo")"
       Visible="_modalVisible"
       OnCancel="CloseModal"
       OnOk="SaveWorkOrder"
       OkText="@(_isEditing ? "Guardar" : "Crear")"
       ConfirmLoading="_saving"
       Width="560">
    <Form @ref="_form" Model="_formModel" Layout="@FormLayout.Vertical">
        <FormItem Label="Descripción">
            <TextArea @bind-Value="_formModel.Description" Placeholder="Descripción de la orden"
                      Rows="3" />
        </FormItem>
        <FormItem Label="Lote">
            <Select TItem="LotDto"
                    TItemValue="Guid"
                    DataSource="_availableLots"
                    @bind-Value="_formModel.LotId"
                    LabelName="@nameof(LotDto.Name)"
                    ValueName="@nameof(LotDto.Id)"
                    Placeholder="Seleccionar lote"
                    Style="width: 100%;"
                    EnableSearch />
        </FormItem>
        <AntDesign.Row Gutter="16">
            <AntDesign.Col Span="8">
                <FormItem Label="Asignado a">
                    <Input @bind-Value="_formModel.AssignedTo" Placeholder="Nombre del responsable" />
                </FormItem>
            </AntDesign.Col>
            <AntDesign.Col Span="8">
                <FormItem Label="Fecha Límite">
                    <DatePicker @bind-Value="_formModel.DueDate" Style="width: 100%;"
                                Format="dd/MM/yyyy" />
                </FormItem>
            </AntDesign.Col>
        </AntDesign.Row>
        <FormItem Label="Estado">
            <RadioGroup @bind-Value="_formModel.Status">
                <Radio Value="@("Draft")">Borrador</Radio>
                <Radio Value="@("Pending")">Pendiente</Radio>
                <Radio Value="@("InProgress")">En Progreso</Radio>
            </RadioGroup>
        </FormItem>
    </Form>
</Modal>

<Modal Title="@(_isEditingLabor ? "Editar Labor" : "Nueva Labor")"
       Visible="_laborModalVisible"
       OnCancel="CloseLaborModal"
       OnOk="SaveLabor"
       OkText="@(_isEditingLabor ? "Guardar" : "Crear Labor")"
       ConfirmLoading="_savingLabor"
       Width="720">
    <Form Model="_laborForm" Layout="@FormLayout.Vertical">
        <AntDesign.Row Gutter="16">
            <AntDesign.Col Span="8">
                <FormItem Label="Tipo de Labor">
                    <Select TItem="string"
                            TItemValue="string"
                            DataSource="@_laborTypes"
                            @bind-Value="_laborForm.LaborType"
                            Placeholder="Seleccionar tipo"
                            Style="width: 100%;" />
                </FormItem>
            </AntDesign.Col>
            <AntDesign.Col Span="8">
                <FormItem Label="Lote">
                    <Select TItem="LotDto"
                            TItemValue="Guid"
                            DataSource="_availableLots"
                            @bind-Value="_laborForm.LotId"
                            LabelName="@nameof(LotDto.Name)"
                            ValueName="@nameof(LotDto.Id)"
                            Placeholder="Seleccionar lote"
                            Style="width: 100%;"
                            EnableSearch />
                </FormItem>
            </AntDesign.Col>
            <AntDesign.Col Span="8">
                <FormItem Label="Hectáreas">
                    <AntDesign.InputNumber TValue="decimal" @bind-Value="_laborForm.Hectares" Min="0m" Step="0.5m"
                                Style="width: 100%;" />
                </FormItem>
            </AntDesign.Col>
        </AntDesign.Row>
        <AntDesign.Row Gutter="16">
            <AntDesign.Col Span="8">
                <FormItem Label="Tarifa ($)">
                    <AntDesign.InputNumber TValue="decimal" @bind-Value="_laborForm.Rate" Min="0m" Step="100m"
                                Style="width: 100%;" />
                </FormItem>
            </AntDesign.Col>
            <AntDesign.Col Span="8">
                <FormItem Label="Unidad de Tarifa">
                    <Select TItem="string"
                            TItemValue="string"
                            DataSource="@_rateUnits"
                            @bind-Value="_laborForm.RateUnit"
                            Placeholder="Seleccionar unidad"
                            Style="width: 100%;" />
                </FormItem>
            </AntDesign.Col>
            <AntDesign.Col Span="8">
                <div style="padding-top: 30px;">
                    @if (_laborForm.Rate > 0)
                    {
                        <span style="color: rgba(255,255,255,0.4); font-size: 12px;">Subtotal estimado: </span>
                        <strong style="color: #2ECC71; font-size: 16px;">
                            $@((_laborForm.Rate * _laborForm.Hectares).ToString("N2"))
                        </strong>
                    }
                </div>
            </AntDesign.Col>
        </AntDesign.Row>

        <Divider Style="border-color: rgba(255,255,255,0.1); margin: 12px 0;">Insumos</Divider>

        @for (int i = 0; i < _laborForm.Supplies.Count; i++)
        {
            var idx = i;
            var supply = _laborForm.Supplies[idx];
            <div class="supply-row">
                <AntDesign.Row Gutter="8">
                    <AntDesign.Col Span="7">
                        <Select TItem="InventoryDto"
                                TItemValue="Guid"
                                DataSource="_availableSupplies"
                                Value="supply.SupplyId"
                                ValueChanged="v => OnSupplySelected(idx, v)"
                                LabelName="@nameof(InventoryDto.ItemName)"
                                ValueName="@nameof(InventoryDto.Id)"
                                Placeholder="Insumo"
                                Style="width: 100%;"
                                EnableSearch />
                    </AntDesign.Col>
                    <AntDesign.Col Span="4">
                        <AntDesign.InputNumber TValue="decimal" Value="supply.PlannedDose"
                                    ValueChanged="(decimal v) => OnDoseChanged(idx, v)"
                                    Min="0m" Step="0.01m"
                                    Style="width: 100%;" />
                    </AntDesign.Col>
                    <AntDesign.Col Span="4">
                        <Input @bind-Value="supply.DoseUnit"
                               Placeholder="Unidad dosis" />
                    </AntDesign.Col>
                    <AntDesign.Col Span="5">
                        <div class="calc-total">
                            <span style="color: rgba(255,255,255,0.4); font-size: 11px;">Total a retirar:</span>
                            <strong style="color: #2ECC71; font-size: 14px;">
                                @((supply.PlannedDose * _laborForm.Hectares).ToString("N2"))
                            </strong>
                            <span style="color: rgba(255,255,255,0.4); font-size: 11px;">@supply.SupplyUnit</span>
                        </div>
                    </AntDesign.Col>
                    <AntDesign.Col Span="2">
                        <Button Danger Size="@ButtonSize.Small" OnClick="() => RemoveSupply(idx)"
                                Style="border-radius: 6px;">
                            <Icon Type="delete" Theme="IconThemeType.Outline" />
                        </Button>
                    </AntDesign.Col>
                </AntDesign.Row>
            </div>
        }

        <Button Type="@ButtonType.Dashed" OnClick="AddSupply" Block
                Style="border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.5); margin-top: 8px;">
            <Icon Type="plus" Theme="IconThemeType.Outline" /> Agregar Insumo
        </Button>

        @if (_tankMixAlerts != null && _tankMixAlerts.Count > 0)
        {
            <div style="margin-top: 12px;">
                @foreach (var alert in _tankMixAlerts)
                {
                    <Alert Type="@(alert.Severity == "Danger" ? AlertType.Error : AlertType.Warning)"
                           ShowIcon="true" Style="margin-bottom: 8px; border-radius: 8px;">
                        <MessageTemplate>
                            <strong>@(alert.Severity == "Danger" ? "PELIGRO" : "ADVERTENCIA"):</strong>
                            @alert.ProductAName + @alert.ProductBName — @alert.WarningMessage
                        </MessageTemplate>
                    </Alert>
                }
                @if (_tankMixAlerts.Any(a => a.Severity == "Danger"))
                {
                    <div style="color: rgba(231,76,60,0.9); font-size: 12px; margin-top: 4px;">
                        Se detectó incompatibilidad crítica. Corrija la mezcla para continuar.
                    </div>
                }
            </div>
        }
    </Form>
</Modal>

<Modal Title="Ejecutar Labor — Confirmar Dosis Real"
       Visible="_realizeModalVisible"
       OnCancel="CloseRealizeModal"
       OnOk="ConfirmRealize"
       OkText="@("Confirmar Realizado")"
       ConfirmLoading="_savingRealize"
       Width="680">
    @if (_realizingLabor != null)
    {
        <div style="background: rgba(52,152,219,0.1); border: 1px solid rgba(52,152,219,0.3); border-radius: 8px; padding: 12px; margin-bottom: 16px;">
            <span style="color: #3498DB; font-weight: 600;">Lógica de Snapshot:</span>
            <span style="color: rgba(255,255,255,0.7); font-size: 13px;">
                La dosis planificada se copia como dosis real. Modificá si hubo variación en campo.
            </span>
        </div>
        <table class="supply-table" style="width: 100%;">
            <thead>
                <tr>
                    <th>Insumo</th>
                    <th>Dosis Planificada</th>
                    <th>Dosis Real</th>
                    <th>Total Real</th>
                    <th>Delta</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < _realizeSupplies.Count; i++)
                {
                    var idx = i;
                    var rs = _realizeSupplies[idx];
                    <tr>
                        <td style="font-weight: 600; color: #fff;">@rs.SupplyName</td>
                        <td>@rs.PlannedDose.ToString("N2") @rs.DoseUnit</td>
                        <td>
                            <AntDesign.InputNumber TValue="decimal" @bind-Value="rs.RealDoseInput" Min="0m" Step="0.01m"
                                        Style="width: 120px;" />
                        </td>
                        <td>
                            <strong style="color: #2ECC71;">
                                @((rs.RealDoseInput * _realizingLabor.Hectares).ToString("N2"))
                            </strong>
                        </td>
                        <td>
                            @{
                                var rdelta = rs.PlannedDose > 0 ? ((rs.RealDoseInput - rs.PlannedDose) / rs.PlannedDose) * 100 : 0;
                                var rdColor = rdelta > 0 ? "#E74C3C" : rdelta < 0 ? "#2ECC71" : "rgba(255,255,255,0.4)";
                            }
                            <span style="color: @rdColor; font-weight: 600;">
                                @(rdelta != 0 ? (rdelta > 0 ? "+" : "") + rdelta.ToString("N1") + "%" : "—")
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</Modal>

