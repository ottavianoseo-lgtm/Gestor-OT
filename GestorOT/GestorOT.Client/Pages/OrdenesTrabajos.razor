@code {
    private List<WorkOrderDto> _workOrders = new();
    private List<LotDto> _availableLots = new();
    private List<InventoryDto> _availableSupplies = new();
    private bool _loading;
    private string? _errorMessage;

    private WorkOrderDetailDto? _selectedOrder;

    private bool _modalVisible;
    private bool _saving;
    private bool _isEditing;
    private Guid _editingId;
    private WoFormModel _formModel = new();
    private IForm? _form;

    private bool _laborModalVisible;
    private bool _savingLabor;
    private List<TankMixAlertDto>? _tankMixAlerts;
    private bool _isEditingLabor;
    private Guid _editingLaborId;
    private LaborFormModel _laborForm = new();

    private bool _realizeModalVisible;
    private bool _savingRealize;
    private LaborDto? _realizingLabor;
    private List<RealizeSupplyModel> _realizeSupplies = new();

    private bool _approving;
    private bool _generatingLink;
    private string? _shareLink;
    private DateTime? _shareLinkExpiry;

    private readonly string[] _laborTypes = { "Siembra", "Pulverización", "Cosecha", "Fertilización", "Laboreo", "Riego", "Otro" };
    private readonly string[] _rateUnits = { "ha", "tn", "km", "hora", "jornal", "viaje" };

    public class WoFormModel
    {
        public string Description { get; set; } = string.Empty;
        public Guid LotId { get; set; }
        public string AssignedTo { get; set; } = string.Empty;
        public DateTime DueDate { get; set; } = DateTime.Today.AddDays(7);
        public string Status { get; set; } = "Draft";
    }

    public class LaborFormModel
    {
        public string LaborType { get; set; } = string.Empty;
        public Guid LotId { get; set; }
        public decimal Hectares { get; set; }
        public decimal Rate { get; set; }
        public string RateUnit { get; set; } = "ha";
        public List<SupplyFormModel> Supplies { get; set; } = new();
    }

    public class SupplyFormModel
    {
        public Guid Id { get; set; }
        public Guid SupplyId { get; set; }
        public decimal PlannedDose { get; set; }
        public string DoseUnit { get; set; } = string.Empty;
        public string SupplyUnit { get; set; } = string.Empty;
    }

    public class RealizeSupplyModel
    {
        public Guid Id { get; set; }
        public Guid SupplyId { get; set; }
        public string SupplyName { get; set; } = string.Empty;
        public decimal PlannedDose { get; set; }
        public string DoseUnit { get; set; } = string.Empty;
        public decimal RealDoseInput { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        CampaignState.OnChange += OnCampaignChanged;
        TenantState.OnChange += OnCampaignChanged;
        await LoadData();
    }

    private void OnCampaignChanged()
    {
        InvokeAsync(async () => { await LoadData(); StateHasChanged(); });
    }

    public void Dispose()
    {
        CampaignState.OnChange -= OnCampaignChanged;
        TenantState.OnChange -= OnCampaignChanged;
    }

    private async Task LoadData()
    {
        try
        {
            _loading = true;
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));
            var ordersTask = Http.GetFromJsonAsync("api/workorders",
                AppJsonSerializerContext.Default.ListWorkOrderDto, cts.Token);
            var lotsTask = Http.GetFromJsonAsync("api/lots",
                AppJsonSerializerContext.Default.ListLotDto, cts.Token);
            var suppliesTask = Http.GetFromJsonAsync("api/inventory",
                AppJsonSerializerContext.Default.ListInventoryDto, cts.Token);

            _workOrders = await ordersTask ?? new();
            _availableLots = await lotsTask ?? new();
            _availableSupplies = await suppliesTask ?? new();
            _errorMessage = null;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task OpenDetail(Guid workOrderId)
    {
        try
        {
            _loading = true;
            StateHasChanged();
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));
            _selectedOrder = await Http.GetFromJsonAsync($"api/workorders/{workOrderId}",
                AppJsonSerializerContext.Default.WorkOrderDetailDto, cts.Token);
            _errorMessage = null;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error al cargar detalle: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void BackToList()
    {
        _selectedOrder = null;
        StateHasChanged();
    }

    private async Task RefreshDetail()
    {
        if (_selectedOrder != null)
            await OpenDetail(_selectedOrder.Id);
    }

    private void OpenCreateModal()
    {
        _isEditing = false;
        _formModel = new WoFormModel();
        if (_availableLots.Count > 0)
            _formModel.LotId = _availableLots[0].Id;
        _modalVisible = true;
    }

    private void OpenEditModal(WorkOrderDto wo)
    {
        _isEditing = true;
        _editingId = wo.Id;
        _formModel = new WoFormModel
        {
            Description = wo.Description,
            LotId = wo.LotId,
            AssignedTo = wo.AssignedTo,
            DueDate = wo.DueDate,
            Status = wo.Status
        };
        _modalVisible = true;
    }

    private void CloseModal()
    {
        _modalVisible = false;
    }

    private async Task SaveWorkOrder()
    {
        if (string.IsNullOrWhiteSpace(_formModel.Description))
        {
            Message.Warning("La descripción es obligatoria.");
            return;
        }
        if (_formModel.LotId == Guid.Empty)
        {
            Message.Warning("Debe seleccionar un lote.");
            return;
        }

        _saving = true;
        try
        {
            var dto = new WorkOrderDto(
                _isEditing ? _editingId : Guid.Empty,
                _formModel.LotId,
                _formModel.Description,
                _formModel.Status,
                _formModel.AssignedTo,
                _formModel.DueDate,
                null
            );

            HttpResponseMessage response;
            if (_isEditing)
            {
                response = await Http.PutAsJsonAsync($"api/workorders/{_editingId}",
                    dto, AppJsonSerializerContext.Default.WorkOrderDto);
            }
            else
            {
                response = await Http.PostAsJsonAsync("api/workorders",
                    dto, AppJsonSerializerContext.Default.WorkOrderDto);
            }

            if (response.IsSuccessStatusCode)
            {
                Message.Success(_isEditing ? "Orden actualizada." : "Orden creada correctamente.");
                _modalVisible = false;
                await LoadData();
            }
            else
            {
                Message.Error($"Error al guardar: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteWorkOrder(Guid id)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/workorders/{id}");
            if (response.IsSuccessStatusCode)
            {
                Message.Success("Orden eliminada correctamente.");
                await LoadData();
            }
            else
            {
                Message.Error($"Error al eliminar: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
    }

    private void OpenLaborModal()
    {
        _isEditingLabor = false;
        _laborForm = new LaborFormModel();
        _tankMixAlerts = null;
        if (_selectedOrder != null)
            _laborForm.LotId = _selectedOrder.LotId;
        _laborModalVisible = true;
    }

    private void OpenEditLaborModal(LaborDto labor)
    {
        _isEditingLabor = true;
        _editingLaborId = labor.Id;
        _laborForm = new LaborFormModel
        {
            LaborType = labor.LaborType,
            LotId = labor.LotId,
            Hectares = labor.Hectares,
            Rate = labor.Rate,
            RateUnit = labor.RateUnit,
            Supplies = labor.Supplies?.Select(s => new SupplyFormModel
            {
                Id = s.Id,
                SupplyId = s.SupplyId,
                PlannedDose = s.PlannedDose,
                DoseUnit = s.DoseUnit,
                SupplyUnit = s.SupplyUnit ?? ""
            }).ToList() ?? new()
        };
        _laborModalVisible = true;
    }

    private void CloseLaborModal()
    {
        _laborModalVisible = false;
        _tankMixAlerts = null;
    }

    private void AddSupply()
    {
        _laborForm.Supplies.Add(new SupplyFormModel());
    }

    private void RemoveSupply(int index)
    {
        if (index >= 0 && index < _laborForm.Supplies.Count)
            _laborForm.Supplies.RemoveAt(index);
    }

    private void OnSupplySelected(int index, Guid supplyId)
    {
        var supply = _laborForm.Supplies[index];
        supply.SupplyId = supplyId;
        var inv = _availableSupplies.FirstOrDefault(s => s.Id == supplyId);
        if (inv != null)
        {
            supply.DoseUnit = $"{inv.UnitB}/ha";
            supply.SupplyUnit = inv.UnitB;
        }
    }

    private void OnDoseChanged(int index, decimal value)
    {
        _laborForm.Supplies[index].PlannedDose = value;
    }

    private async Task SaveLabor()
    {
        if (string.IsNullOrWhiteSpace(_laborForm.LaborType))
        {
            Message.Warning("Debe seleccionar un tipo de labor.");
            return;
        }
        if (_laborForm.LotId == Guid.Empty)
        {
            Message.Warning("Debe seleccionar un lote.");
            return;
        }
        if (_laborForm.Hectares <= 0)
        {
            Message.Warning("Las hectáreas deben ser mayores a 0.");
            return;
        }

        var supplyIds = _laborForm.Supplies
            .Where(s => s.SupplyId != Guid.Empty)
            .Select(s => s.SupplyId)
            .ToList();

        if (supplyIds.Count >= 2)
        {
            try
            {
                var validationRequest = new TankMixValidationRequest(supplyIds);
                var alertsResponse = await Http.PostAsJsonAsync("api/tankmixrules/validate",
                    validationRequest, AppJsonSerializerContext.Default.TankMixValidationRequest);

                if (alertsResponse.IsSuccessStatusCode)
                {
                    var alerts = await alertsResponse.Content.ReadFromJsonAsync(
                        AppJsonSerializerContext.Default.ListTankMixAlertDto);

                    if (alerts != null && alerts.Count > 0)
                    {
                        foreach (var alert in alerts)
                        {
                            if (alert.Severity == "Danger")
                            {
                                Message.Error($"PELIGRO: {alert.ProductAName} + {alert.ProductBName}: {alert.WarningMessage}");
                            }
                            else
                            {
                                Message.Warning($"Advertencia: {alert.ProductAName} + {alert.ProductBName}: {alert.WarningMessage}");
                            }
                        }

                        if (alerts.Any(a => a.Severity == "Danger"))
                        {
                            _tankMixAlerts = alerts;
                            StateHasChanged();
                            return;
                        }
                    }
                }
            }
            catch { }
        }

        _savingLabor = true;
        try
        {
            var dto = new LaborDto(
                _isEditingLabor ? _editingLaborId : Guid.Empty,
                _selectedOrder?.Id,
                _laborForm.LotId,
                _laborForm.LaborType,
                "Planned",
                null,
                _laborForm.Hectares,
                DateTime.MinValue,
                _laborForm.Rate,
                _laborForm.RateUnit,
                null,
                _laborForm.Supplies.Select(s => new LaborSupplyDto(
                    s.Id,
                    Guid.Empty,
                    s.SupplyId,
                    s.PlannedDose,
                    null,
                    s.PlannedDose * _laborForm.Hectares,
                    null,
                    s.DoseUnit,
                    null,
                    s.SupplyUnit
                )).ToList()
            );

            HttpResponseMessage response;
            if (_isEditingLabor)
            {
                response = await Http.PutAsJsonAsync($"api/labors/{_editingLaborId}",
                    dto, AppJsonSerializerContext.Default.LaborDto);
            }
            else
            {
                response = await Http.PostAsJsonAsync("api/labors",
                    dto, AppJsonSerializerContext.Default.LaborDto);
            }

            if (response.IsSuccessStatusCode)
            {
                Message.Success(_isEditingLabor ? "Labor actualizada." : "Labor creada correctamente.");
                _laborModalVisible = false;
                await RefreshDetail();
            }
            else
            {
                Message.Error($"Error al guardar labor: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
        finally
        {
            _savingLabor = false;
        }
    }

    private async Task DeleteLabor(Guid laborId)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/labors/{laborId}");
            if (response.IsSuccessStatusCode)
            {
                Message.Success("Labor eliminada.");
                await RefreshDetail();
            }
            else
            {
                Message.Error($"Error al eliminar: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
    }

    private void OpenRealizeModal(LaborDto labor)
    {
        _realizingLabor = labor;
        _realizeSupplies = labor.Supplies?.Select(s => new RealizeSupplyModel
        {
            Id = s.Id,
            SupplyId = s.SupplyId,
            SupplyName = s.SupplyName ?? "Insumo",
            PlannedDose = s.PlannedDose,
            DoseUnit = s.DoseUnit,
            RealDoseInput = s.PlannedDose
        }).ToList() ?? new();
        _realizeModalVisible = true;
    }

    private void CloseRealizeModal()
    {
        _realizeModalVisible = false;
        _realizingLabor = null;
    }

    private async Task ConfirmRealize()
    {
        if (_realizingLabor == null) return;

        _savingRealize = true;
        try
        {
            var realSupplies = _realizeSupplies.Select(rs => new LaborSupplyDto(
                rs.Id,
                _realizingLabor.Id,
                rs.SupplyId,
                rs.PlannedDose,
                rs.RealDoseInput,
                rs.PlannedDose * _realizingLabor.Hectares,
                rs.RealDoseInput * _realizingLabor.Hectares,
                rs.DoseUnit,
                rs.SupplyName,
                null
            )).ToList();

            var response = await Http.PostAsJsonAsync(
                $"api/labors/{_realizingLabor.Id}/realize",
                realSupplies,
                AppJsonSerializerContext.Default.ListLaborSupplyDto);

            if (response.IsSuccessStatusCode)
            {
                Message.Success("Labor confirmada como realizada.");
                _realizeModalVisible = false;
                _realizingLabor = null;
                await RefreshDetail();
            }
            else
            {
                var err = await response.Content.ReadAsStringAsync();
                Message.Error($"Error: {err}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
        finally
        {
            _savingRealize = false;
        }
    }

    private async Task ApproveWorkOrder()
    {
        if (_selectedOrder == null) return;

        _approving = true;
        try
        {
            var response = await Http.PostAsync($"api/workorders/{_selectedOrder.Id}/approve", null);

            if (response.IsSuccessStatusCode)
            {
                Message.Success("OT Aprobada. Liquidación generada exitosamente.");
                await RefreshDetail();
            }
            else
            {
                var err = await response.Content.ReadAsStringAsync();
                Message.Error($"Error al aprobar: {err}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
        finally
        {
            _approving = false;
        }
    }

    private async Task GenerateShareLink()
    {
        if (_selectedOrder == null) return;

        _generatingLink = true;
        try
        {
            var response = await Http.PostAsync($"api/share/generate/{_selectedOrder.Id}", null);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync(
                    AppJsonSerializerContext.Default.ShareLinkDto);
                if (result != null)
                {
                    _shareLink = result.Url;
                    _shareLinkExpiry = result.ExpiresAt;
                    Message.Success("Magic Link generado exitosamente.");
                }
            }
            else
            {
                Message.Error("Error al generar el enlace.");
            }
        }
        catch
        {
            Message.Error("Error de conexión.");
        }
        finally
        {
            _generatingLink = false;
            StateHasChanged();
        }
    }

    private async Task CopyShareLink()
    {
        if (!string.IsNullOrEmpty(_shareLink))
        {
            try
            {
                await JS.InvokeVoidAsync("navigator.clipboard.writeText", _shareLink);
                Message.Success("Enlace copiado al portapapeles.");
            }
            catch
            {
                Message.Info("Copia el enlace manualmente.");
            }
        }
    }
}
