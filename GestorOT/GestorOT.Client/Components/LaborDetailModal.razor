@using GestorOT.Shared.Dtos
@using AntDesign

@if (Labor != null)
{
    <div class="labor-modal-backdrop" @onclick="Close">
        <div class="labor-modal-content" @onclick:stopPropagation="true">
            <div class="labor-modal-header">
                <div class="labor-modal-header-left">
                    <span class="labor-modal-type-badge" style="background: @GetTypeColor(Labor.TipoLabor);">
                        @Labor.TipoLabor
                    </span>
                    <Tag Color="@GetStatusColor(Labor.Estado)"
                         Style="border-radius: 12px; font-size: 11px; margin: 0;">
                        @Labor.Estado
                    </Tag>
                </div>
                <div class="labor-modal-close" @onclick="Close">
                    <Icon Type="close" Theme="IconThemeType.Outline" />
                </div>
            </div>

            <div class="labor-modal-body">
                <div class="labor-modal-grid">
                    <div class="labor-modal-field">
                        <div class="labor-modal-label">
                            <Icon Type="environment" Theme="IconThemeType.Outline" Style="margin-right: 4px;" />
                            Lote
                        </div>
                        <div class="labor-modal-value">@Labor.LoteNombre</div>
                    </div>
                    <div class="labor-modal-field">
                        <div class="labor-modal-label">
                            <Icon Type="calendar" Theme="IconThemeType.Outline" Style="margin-right: 4px;" />
                            Fecha
                        </div>
                        <div class="labor-modal-value">
                            @(Labor.FechaPlanificada?.ToString("dd/MM/yyyy") ?? "Sin fecha")
                        </div>
                    </div>
                    <div class="labor-modal-field">
                        <div class="labor-modal-label">
                            <Icon Type="user" Theme="IconThemeType.Outline" Style="margin-right: 4px;" />
                            Responsable
                        </div>
                        <div class="labor-modal-value">@(Labor.NombreResponsable ?? "Sin Asignar")</div>
                    </div>
                    <div class="labor-modal-field">
                        <div class="labor-modal-label">
                            <Icon Type="column-height" Theme="IconThemeType.Outline" Style="margin-right: 4px;" />
                            Superficie
                        </div>
                        <div class="labor-modal-value">@Labor.Hectareas.ToString("N2") ha</div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Labor.Maquinaria) && Labor.Maquinaria != "N/A")
                {
                    <div class="labor-modal-row">
                        <Icon Type="car" Theme="IconThemeType.Outline" Style="color: #E67E22; margin-right: 6px;" />
                        <span class="labor-modal-label" style="margin-right: 6px;">Maquinaria:</span>
                        <span class="labor-modal-value">@Labor.Maquinaria</span>
                    </div>
                }

                @if (Labor.Insumos != null && Labor.Insumos.Count > 0)
                {
                    <div class="labor-modal-section">
                        <div class="labor-modal-label" style="margin-bottom: 8px;">
                            <Icon Type="medicine-box" Theme="IconThemeType.Outline" Style="margin-right: 4px;" />
                            Insumos
                        </div>
                        <div class="labor-modal-tags">
                            @foreach (var insumo in Labor.Insumos)
                            {
                                <Tag Style="border-radius: 10px; font-size: 11px; background: rgba(52,152,219,0.1); border-color: rgba(52,152,219,0.3); color: #3498DB;">
                                    @insumo
                                </Tag>
                            }
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(Labor.NotasLabor))
                {
                    <div class="labor-modal-notes">
                        <div class="labor-modal-label" style="margin-bottom: 4px;">
                            <Icon Type="file-text" Theme="IconThemeType.Outline" Style="margin-right: 4px;" />
                            Notas
                        </div>
                        <div class="labor-modal-notes-text">@Labor.NotasLabor</div>
                    </div>
                }
            </div>

            <div class="labor-modal-footer">
                <Button Size="@ButtonSize.Small"
                        Style="border-radius: 8px; background: #E74C3C15; border-color: #E74C3C40; color: #E74C3C;"
                        OnClick="() => GoToLot(Labor.LoteId)">
                    <Icon Type="environment" Theme="IconThemeType.Outline" /> Ir al Lote
                </Button>
                <Button Size="@ButtonSize.Small"
                        Style="border-radius: 8px; border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.7);"
                        OnClick="Close">
                    Cerrar
                </Button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public LaborDetalleDto? Labor { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<Guid> OnGoToLot { get; set; }

    private async Task Close()
    {
        await OnClose.InvokeAsync();
    }

    private async Task GoToLot(Guid lotId)
    {
        await OnGoToLot.InvokeAsync(lotId);
    }

    private static string GetTypeColor(string laborType) => laborType switch
    {
        "Fertilizacion" => "#27AE60",
        "Pulverizacion" => "#2980B9",
        "Siembra" => "#8E44AD",
        "Cosecha" => "#D35400",
        "Monitoreo" => "#16A085",
        "Laboreo" => "#7F8C8D",
        _ => "#95A5A6"
    };

    private static string GetStatusColor(string status) => status switch
    {
        "Planned" or "Pendiente" => "gold",
        "InProgress" or "En Progreso" => "blue",
        "Completed" or "Cerrada" => "green",
        "Cancelled" or "Cancelada" => "red",
        _ => "default"
    };
}

<style>
    .labor-modal-backdrop {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0, 0, 0, 0.5);
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        animation: fadeIn 0.2s ease;
    }

    .labor-modal-content {
        background: rgba(30, 30, 46, 0.92);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        width: 480px;
        max-width: 90vw;
        max-height: 85vh;
        overflow-y: auto;
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.5);
        animation: slideUp 0.25s ease;
    }

    .labor-modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 22px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .labor-modal-header-left {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .labor-modal-type-badge {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        color: #fff;
    }

    .labor-modal-close {
        cursor: pointer;
        color: rgba(255, 255, 255, 0.4);
        font-size: 18px;
        padding: 4px;
        border-radius: 6px;
        transition: all 0.2s;
    }

    .labor-modal-close:hover {
        color: rgba(255, 255, 255, 0.8);
        background: rgba(255, 255, 255, 0.06);
    }

    .labor-modal-body {
        padding: 20px 22px;
    }

    .labor-modal-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 16px;
    }

    .labor-modal-field {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .labor-modal-label {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.4);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: flex;
        align-items: center;
    }

    .labor-modal-value {
        font-size: 14px;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.85);
    }

    .labor-modal-row {
        display: flex;
        align-items: center;
        margin-bottom: 12px;
        font-size: 13px;
    }

    .labor-modal-section {
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        padding-top: 14px;
        margin-top: 14px;
    }

    .labor-modal-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .labor-modal-notes {
        background: rgba(255, 255, 255, 0.02);
        border-left: 3px solid #95A5A6;
        border-radius: 0 8px 8px 0;
        padding: 10px 14px;
        margin-top: 14px;
    }

    .labor-modal-notes-text {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.7);
        line-height: 1.5;
    }

    .labor-modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        padding: 14px 22px;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
    }

    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    @@keyframes slideUp {
        from { transform: translateY(20px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }
</style>
