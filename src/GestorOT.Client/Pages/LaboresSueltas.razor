@code {
    [SupplyParameterFromQuery] public Guid? targetOT { get; set; }
    
    private List<LaborDto> _labors = new();
    private List<CampaignLotDto> _lots = new();
    private List<WorkOrderDto> _workOrders = new();
    private List<LaborTypeDto> _laborTypes = new();
    private bool _loading = true;
    private string? _errorMessage;
    private bool _saving;
    private HashSet<Guid> _selectedIds = new();
    private Guid? _filterTypeId;
    private Guid? _filterContactId;
    private List<ContactDto> _contacts = new();
    private string? _filterAssigned;
    private string? _filterStatus;
    private string _sortBy = "default";
    private string? _quickStatusFilter;

    private bool _quickLaborSelectorVisible;
    private bool _strategyWizardVisible;
    private bool _drawerVisible;
    private Guid _editingLaborId = Guid.Empty;
    private bool _isExecuting;
    private bool _assignModalOpen;
    private Guid _assignTargetOT;
    private bool _executeModalOpen;
    private bool _executing;
    private LaborDto? _laborToExecute;
    private LaborEditorForm? _laborFormRef;

    private bool _allSelected => _labors.Count > 0 && _selectedIds.Count == _labors.Count;

    private List<LaborDto> FilteredLabors 
    {
        get
        {
            var result = _labors;
            
            // Filter by Type if selected
            if (_filterTypeId != null)
                result = result.Where(l => l.LaborTypeId == _filterTypeId).ToList();

            // Filter by Field if coming from a specific OT
            if (targetOT.HasValue && targetOT != Guid.Empty)
            {
                var targetWo = _workOrders.FirstOrDefault(w => w.Id == targetOT);
                if (targetWo != null && targetWo.FieldId.HasValue)
                {
                    result = result.Where(l => string.Equals(l.FieldName, targetWo.FieldName, StringComparison.OrdinalIgnoreCase)).ToList();
                }
            }

            // Quick filter from KPI cards
            if (_quickStatusFilter == "unassigned")
                result = result.Where(l => l.WorkOrderId == null).ToList();
            else if (_quickStatusFilter != null)
                result = result.Where(l => l.Status == _quickStatusFilter).ToList();

            return result;
        }
    }

    private void OpenExecuteModal(LaborDto labor)
    {
        EditLabor(labor.Id, true);
    }

    /* ExecuteStandalone removed in favor of full LaborEditorForm */

    protected override async Task OnInitializedAsync()
    {
        // Force unassigned filter if coming from a specific OT
        if (targetOT.HasValue && targetOT != Guid.Empty)
        {
            _filterAssigned = "unassigned";
        }
        
        CampaignState.OnChange += OnCampaignChanged;
        TenantState.OnChange += OnCampaignChanged;
        await LoadData();
    }

    private void OnCampaignChanged()
    {
        InvokeAsync(async () => { await LoadData(); StateHasChanged(); });
    }

    public void Dispose()
    {
        CampaignState.OnChange -= OnCampaignChanged;
        TenantState.OnChange -= OnCampaignChanged;
    }

    private async Task LoadData()
    {
        try
        {
            _loading = true;
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));

            var url = new StringBuilder("api/labors?");
            if (!string.IsNullOrEmpty(_filterAssigned)) 
            {
                var isAssigned = _filterAssigned == "assigned";
                url.Append($"assigned={isAssigned.ToString().ToLower()}&");
            }
            if (!string.IsNullOrEmpty(_filterStatus)) url.Append($"status={_filterStatus}&");
            if (_filterTypeId.HasValue && _filterTypeId != Guid.Empty) url.Append($"laborTypeId={_filterTypeId}&");
            if (_filterContactId.HasValue && _filterContactId != Guid.Empty) url.Append($"contactId={_filterContactId}&");
            if (CampaignState.CurrentCampaign != null) url.Append($"campaignId={CampaignState.CurrentCampaign.Id}&");
            url.Append($"sortBy={_sortBy}");

            var laborsTask = Http.GetFromJsonAsync(url.ToString(),
                AppJsonSerializerContext.Default.ListLaborDto, cts.Token);
            var woTask = Http.GetFromJsonAsync("api/workorders",
                AppJsonSerializerContext.Default.ListWorkOrderDto, cts.Token);
            var typesTask = Http.GetFromJsonAsync("api/catalogs/labor-types",
                AppJsonSerializerContext.Default.ListLaborTypeDto, cts.Token);
            var contactsTask = Http.GetFromJsonAsync("api/catalogs/contacts",
                AppJsonSerializerContext.Default.ListContactDto, cts.Token);
            
            Task<List<CampaignLotDto>?>? lotsTask = null;
            if (CampaignState.CurrentCampaign != null)
            {
                lotsTask = Http.GetFromJsonAsync(
                    $"api/campaigns/{CampaignState.CurrentCampaign.Id}/lots",
                    AppJsonSerializerContext.Default.ListCampaignLotDto, cts.Token);
            }

            var tasks = new List<Task?> { laborsTask, woTask, typesTask, contactsTask, lotsTask };
            await Task.WhenAll(tasks.Where(t => t != null).Select(t => t!));

            _labors = await laborsTask ?? new();
            if (lotsTask != null)
                _lots = await lotsTask ?? new();
            _workOrders = await woTask ?? new();
            _laborTypes = await typesTask ?? new();
            _contacts = await contactsTask ?? new();
            _errorMessage = null;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _loading = false;
            _selectedIds.Clear();
            
            if (targetOT.HasValue && targetOT != Guid.Empty && _workOrders.Any(w => w.Id == targetOT))
            {
                _assignTargetOT = targetOT.Value;
                // We don't open the modal automatically yet because they need to select labors first.
                // But we could show a message.
            }
            
            StateHasChanged();
        }
    }

    private async Task OnSortChanged(string value)
    {
        _sortBy = value;
        await LoadData();
    }



    private async Task UpdatePriority(LaborDto labor, LaborPriority newPriority)
    {
        var oldPriority = labor.Priority;
        labor.Priority = newPriority; // Optimistic update
        try
        {
            var response = await Http.PatchAsJsonAsync($"api/labors/{labor.Id}/priority", new PriorityRequest { Priority = (int)newPriority });
            if (!response.IsSuccessStatusCode)
            {
                labor.Priority = oldPriority;
                Message.Error("No se pudo actualizar la prioridad.");
            }
        }
        catch
        {
            labor.Priority = oldPriority;
            Message.Error("Error de conexión al actualizar prioridad.");
        }
    }

    private void ToggleSelect(Guid id, bool selected)
    {
        if (selected) _selectedIds.Add(id);
        else _selectedIds.Remove(id);
    }

    private void ToggleSelectAll(bool selected)
    {
        if (selected)
            _selectedIds = new HashSet<Guid>(_labors.Where(l => l.WorkOrderId == null).Select(l => l.Id));
        else
            _selectedIds.Clear();
    }

    private void OnSelectedRowsChanged(IEnumerable<LaborDto> selectedRows)
    {
        _selectedIds = selectedRows.Select(r => r.Id).ToHashSet();
        StateHasChanged();
    }

    private void ClearSelection()
    {
        _selectedIds.Clear();
        StateHasChanged();
    }

    private async Task OpenQuickCreator()
    {
        _quickLaborSelectorVisible = false;
        _editingLaborId = Guid.Empty;
        _drawerVisible = true;
        if (_laborFormRef != null)
        {
            await _laborFormRef.Reset();
        }
    }

    private void OpenStrategyWizard()
    {
        _quickLaborSelectorVisible = false;
        _strategyWizardVisible = true;
    }

    private async Task EditLabor(Guid id, bool isExecuting = false)
    {
        _editingLaborId = id;
        _isExecuting = isExecuting;
        _drawerVisible = true;
        if (_laborFormRef != null)
        {
            await _laborFormRef.Reset();
        }
    }

    private async Task HandleCancelLaborModal()
    {
        if (_laborFormRef != null)
        {
            await _laborFormRef.HandleCancel();
        }
        else
        {
            _drawerVisible = false;
        }
    }

    private async Task OnLaborSaved()
    {
        _drawerVisible = false;
        await LoadData();
    }

    private decimal GetLotHectares(Guid lotId)
    {
        var lot = _lots.FirstOrDefault(l => l.LotId == lotId);
        return lot != null ? (lot.ProductiveArea > 0 ? lot.ProductiveArea : lot.CadastralArea) : 0;
    }

    private void OpenAssignModal()
    {
        _assignTargetOT = Guid.Empty;
        _assignModalOpen = true;
    }

    private async Task AssignToExistingOT()
    {
        if (_assignTargetOT == Guid.Empty) return;
        try
        {
            _saving = true;
            var body = JsonSerializer.Serialize(new { LaborIds = _selectedIds.ToList(), WorkOrderId = _assignTargetOT });
            var content = new StringContent(body, Encoding.UTF8, "application/json");
            var request = new HttpRequestMessage(HttpMethod.Patch, "api/labors/assign-bulk") { Content = content };
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                Message.Success($"{_selectedIds.Count} labores asignadas correctamente.");
                _assignModalOpen = false;
                await LoadData();
            }
            else
            {
                Message.Error("Error al asignar labores.");
            }
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private async Task CreateOTFromSelected()
    {
        try
        {
            _saving = true;
            var selectedLabors = _labors.Where(l => _selectedIds.Contains(l.Id)).ToList();
            
            if (CampaignState.CurrentCampaign == null)
            {
                Message.Error("No hay una campaña activa seleccionada.");
                return;
            }

            // Logic for common responsible
            var responsibles = selectedLabors.Select(l => l.AssignedTo).Where(r => !string.IsNullOrEmpty(r)).Distinct().ToList();
            var commonResponsible = responsibles.Count == 1 ? responsibles.First() : string.Empty;

            // Logic for common field
            var firstLabor = selectedLabors.First();
            var lotInfo = _lots.FirstOrDefault(l => l.Id == firstLabor.CampaignLotId);
            var commonFieldId = lotInfo?.FieldId;

            var newOT = new WorkOrderDto
            {
                CampaignId = CampaignState.CurrentCampaign.Id,
                FieldId = commonFieldId,
                Description = $"OT generada - {selectedLabors.Count} labores ({DateTime.Today:dd/MM/yyyy})",
                Status = "Pending",
                AssignedTo = commonResponsible ?? string.Empty,
                DueDate = DateTime.Today.AddDays(7),
                PlannedDate = DateTime.Today,
                ExpirationDate = DateTime.Today.AddDays(14)
            };

            var otResponse = await Http.PostAsJsonAsync("api/workorders", newOT, AppJsonSerializerContext.Default.WorkOrderDto);
            if (!otResponse.IsSuccessStatusCode)
            {
                Message.Error("Error al crear la OT.");
                return;
            }

            var createdOT = await otResponse.Content.ReadFromJsonAsync(AppJsonSerializerContext.Default.WorkOrderDto);
            if (createdOT == null) return;

            var body = JsonSerializer.Serialize(new { LaborIds = _selectedIds.ToList(), WorkOrderId = createdOT.Id });
            var content = new StringContent(body, Encoding.UTF8, "application/json");
            var req = new HttpRequestMessage(HttpMethod.Patch, "api/labors/assign-bulk") { Content = content };
            var assignResponse = await Http.SendAsync(req);
            if (assignResponse.IsSuccessStatusCode)
            {
                Message.Success($"OT creada y {_selectedIds.Count} labores asignadas.");
                await LoadData();
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private async Task DeleteLabor(Guid id)
    {
        var response = await Http.DeleteAsync($"api/labors/{id}");
        if (response.IsSuccessStatusCode)
        {
            Message.Success("Labor eliminada.");
            await LoadData();
        }
        else
        {
            Message.Error("Error al eliminar.");
        }
    }

