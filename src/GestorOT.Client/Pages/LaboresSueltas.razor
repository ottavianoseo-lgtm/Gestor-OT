@page "/labores-sueltas"
@using GestorOT.Domain.Enums
@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using GestorOT.Client.Components
@using System.Net.Http.Json
@using System.Text
@using System.Text.Json
@using AntDesign
@inject HttpClient Http
@inject IJSRuntime JS
@inject IMessageService Message
@inject NavigationManager Nav
@inject GestorOT.Client.Services.CampaignState CampaignState
@inject GestorOT.Client.Services.TenantState TenantState
@implements IDisposable

<PageTitle>Labores - GestorOT</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title">Gestión de Labores</h2>
        <span class="page-subtitle">Todas las labores de la campaña</span>
    </div>
    <div style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap; row-gap: 8px;">
        <Select TItemValue="string?" TItem="string" @bind-Value="_filterAssigned"
                Placeholder="Asignación" AllowClear Style="width: 130px;" OnSelectedItemChanged="LoadData">
            <SelectOption TItemValue="string?" TItem="string" Value="@("assigned")" Label="Asignadas" />
            <SelectOption TItemValue="string?" TItem="string" Value="@("unassigned")" Label="Sin OT" />
        </Select>
        <Select TItemValue="string?" TItem="string" @bind-Value="_filterStatus"
                Placeholder="Estado" AllowClear Style="width: 120px;" OnSelectedItemChanged="LoadData">
            <SelectOption TItemValue="string?" TItem="string" Value="@("Planned")" Label="Planeadas" />
            <SelectOption TItemValue="string?" TItem="string" Value="@("Realized")" Label="Realizadas" />
            <SelectOption TItemValue="string?" TItem="string" Value="@("AwaitingValidation")" Label="En Validación" />
        </Select>
        <Select TItemValue="Guid?" TItem="LaborTypeDto" @bind-Value="_filterTypeId"
                Placeholder="Tipo labor" AllowClear Style="width: 140px;" OnSelectedItemChanged="LoadData"
                DataSource="@_laborTypes"
                LabelName="@nameof(LaborTypeDto.Name)" ValueName="@nameof(LaborTypeDto.Id)" />
        <Select TItemValue="Guid?" TItem="ContactDto" @bind-Value="_filterContactId"
                Placeholder="Responsable" AllowClear Style="width: 150px;" OnSelectedItemChanged="LoadData"
                DataSource="@_contacts"
                LabelName="@nameof(ContactDto.FullName)" ValueName="@nameof(ContactDto.Id)" />
        <Select TItemValue="string" TItem="string" Value="@_sortBy" ValueChanged="OnSortChanged" Style="width: 160px;">
            <SelectOption TItemValue="string" TItem="string" Value="@("default")" Label="Fecha Creación" />
            <SelectOption TItemValue="string" TItem="string" Value="@("priority")" Label="Prioridad" />
            <SelectOption TItemValue="string" TItem="string" Value="@("date")" Label="Fecha Estimada" />
        </Select>
        <Button Icon="sync" OnClick="LoadData" />
        @if (CampaignState.CurrentCampaign != null)
        {
            <Tag Style="@($"background: #2ECC7120; color: #2ECC71; border: 1px solid #2ECC7140; border-radius: 8px; font-size: 11px; font-weight: 600; padding: 2px 10px; cursor: default;")">
                <Icon Type="calendar" Theme="IconThemeType.Outline" Style="font-size: 11px;" /> @CampaignState.CurrentCampaign.Name
            </Tag>
        }
        <Button Type="@ButtonType.Primary" OnClick="() => _quickLaborSelectorVisible = true"
                Style="background: #2ECC71; border-color: #2ECC71; border-radius: 8px; font-weight: 600;">
            <Icon Type="plus" Theme="IconThemeType.Outline" /> Labor Rápida
        </Button>
    </div>
</div>

@if (_selectedIds.Count > 0)
{
    <div class="selection-action-bar">
        <span class="selection-count">
            <Icon Type="check-circle" Theme="IconThemeType.Fill" Style="color: #2ECC71;" />
            @_selectedIds.Count labor@(_selectedIds.Count == 1 ? "" : "es") seleccionada@(_selectedIds.Count == 1 ? "" : "s")
        </span>
        <div class="selection-actions">
            <Button Size="@ButtonSize.Small" OnClick="ClearSelection">Limpiar</Button>
            <Button Type="@ButtonType.Primary" OnClick="OpenAssignModal"
                    Style="background: #3498DB; border-color: #3498DB;">
                <Icon Type="link" Theme="IconThemeType.Outline" /> Asignar a OT
            </Button>
            <Button Type="@ButtonType.Primary" OnClick="CreateOTFromSelected"
                    Style="background: #E74C3C; border-color: #E74C3C;">
                <Icon Type="file-add" Theme="IconThemeType.Outline" /> Crear OT con la selección
            </Button>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <Alert Type="@AlertType.Error" Message="@_errorMessage" ShowIcon="true" Closable="true" Style="margin-bottom: 16px;" />
}

@if (targetOT.HasValue && targetOT != Guid.Empty && _workOrders.Any(w => w.Id == targetOT))
{
    var targetWo = _workOrders.First(w => w.Id == targetOT);
    <Alert Type="@AlertType.Info" ShowIcon="true" Style="margin-bottom: 16px; border-radius: 8px; background: rgba(52, 152, 219, 0.15); border: 1px solid rgba(52, 152, 219, 0.3); color: #fff;">
        <MessageTemplate>
            <div style="display: flex; justify-content: space-between; align-items: center; width: 100%; color: #fff;">
                <span style="color: #fff;">
                    <strong style="color: #3b82f6;">Modo Asignación:</strong> Seleccionando labores para <strong style="color: #fff;">@(targetWo.Description ?? targetWo.OTNumber)</strong>
                </span>
                <Button Size="@ButtonSize.Small" OnClick='() => { targetOT = null; _filterAssigned = null; LoadData(); }' Style="background: rgba(255,255,255,0.1); color: #fff; border: 1px solid rgba(255,255,255,0.2);">Quitar Filtro</Button>
            </div>
        </MessageTemplate>
    </Alert>
}

<div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 16px;">
    <div class="kpi-card" style="cursor:pointer; border-color: @(_quickStatusFilter == null ? "rgba(255,255,255,0.3)" : "rgba(255,255,255,0.06)")" @onclick="() => { _quickStatusFilter = null; }">
        <div class="kpi-value">@_labors.Count</div>
        <div class="kpi-label">Total Labores</div>
    </div>
    <div class="kpi-card" style="cursor:pointer; border-color: @(_quickStatusFilter == "unassigned" ? "rgba(255,255,255,0.3)" : "rgba(255,255,255,0.06)")" @onclick='() => { _quickStatusFilter = "unassigned"; }'>
        <div class="kpi-value">@_labors.Count(l => l.WorkOrderId == null)</div>
        <div class="kpi-label">Sin Asignar</div>
    </div>
    <div class="kpi-card" style="cursor:pointer; border-color: @(_quickStatusFilter == "Planned" ? "#3498DB" : "rgba(255,255,255,0.06)")" @onclick='() => { _quickStatusFilter = "Planned"; }'>
        <div class="kpi-value" style="color: #3498DB;">@_labors.Count(l => l.Status == "Planned")</div>
        <div class="kpi-label">Planeadas</div>
    </div>
    <div class="kpi-card" style="cursor:pointer; border-color: @(_quickStatusFilter == "Realized" ? "#2ECC71" : "rgba(255,255,255,0.06)")" @onclick='() => { _quickStatusFilter = "Realized"; }'>
        <div class="kpi-value" style="color: #2ECC71;">@_labors.Count(l => l.Status == "Realized")</div>
        <div class="kpi-label">Realizadas</div>
    </div>
</div>

@if (_loading)
{
    <div style="text-align: center; padding: 60px;">
        <Spin Size="AntDesign.SpinSize.Large" Tip="Cargando labores" />
    </div>
}
else
{
    <div class="glass-card table-container">
        <LaborList Labors="@FilteredLabors"
                   ShowOtColumn="true"
                   IsLocked="false"
                   OnEdit="id => EditLabor(id)"
                   OnExecute='(args) => EditLabor(args.Id, true)'
                   OnDelete="DeleteLabor"
                   DisableSelection="l => l.WorkOrderId != null"
                   OnSelectedRowsChanged="OnSelectedRowsChanged" />
    </div>
}

<!-- Quick Labor Selector Modal -->
<Modal Title="Nueva Labor" Visible="_quickLaborSelectorVisible" Footer="null" OnCancel="() => _quickLaborSelectorVisible = false" Width="400">
    <div style="display: flex; gap: 16px; justify-content: center; padding: 24px;">
        <Button Type="@ButtonType.Default" OnClick="OpenQuickCreator" 
                Style="height: 100px; width: 150px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; border-radius: 12px; background: rgba(255,255,255,0.03);">
            <Icon Type="file-add" Style="font-size: 24px; color: #2ECC71;" />
            <span style="font-weight: 600;">Labor Suelta</span>
        </Button>
        <Button Type="@ButtonType.Default" OnClick="OpenStrategyWizard"
                Style="height: 100px; width: 150px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; border-radius: 12px; background: rgba(255,255,255,0.03);">
            <Icon Type="apartment" Style="font-size: 24px; color: #3498DB;" />
            <span style="font-weight: 600;">Desde Estrategia</span>
        </Button>
    </div>
</Modal>

<Modal Title="Crear Labores desde Estrategia" Visible="_strategyWizardVisible" Footer="null" OnCancel="() => _strategyWizardVisible = false" Width="900">
    <StrategyLaborWizard OnClose="() => { _strategyWizardVisible = false; LoadData(); }" />
</Modal>

<Modal Title="@(_editingLaborId == Guid.Empty ? "Nueva Labor Suelta" : (_isExecuting ? "Ejecutar Labor" : "Editar Labor"))"
       Visible="@_drawerVisible"
       OnCancel="HandleCancelLaborModal"
       Footer="null"
       Width="800">
    <LaborEditorForm @ref="_laborFormRef" LaborId="@_editingLaborId" InitialStatus="@(_isExecuting ? "Realized" : null)" OnSaved="OnSaved" />
</Modal>

<Modal Title="@("Asignar Labores a Orden de Trabajo")" Visible="@_assignModalOpen"
       OnCancel="() => _assignModalOpen = false" Footer="null" Width="480"
       BodyStyle="background: #1E1E2E; padding: 24px;">
    <div style="margin-bottom: 16px; color: rgba(255,255,255,0.6); font-size: 13px;">
        @_selectedIds.Count labores seleccionadas para asignar
    </div>
    <Select TItemValue="Guid" TItem="Guid" @bind-Value="_assignTargetOT" Placeholder="Seleccionar OT existente"
            Style="width: 100%; margin-bottom: 16px;">
        @foreach (var wo in _workOrders)
        {
            <SelectOption TItemValue="Guid" TItem="Guid" Value="@wo.Id"
                          Label="@($"{wo.Description} ({wo.FieldName})")" />
        }
    </Select>
    <Button Type="@ButtonType.Primary" OnClick="AssignToExistingOT" Loading="_saving" Block
            Style="background: #3498DB; border-color: #3498DB; border-radius: 8px; font-weight: 600; height: 40px;"
            Disabled="@(_assignTargetOT == Guid.Empty)">
        <Icon Type="link" Theme="IconThemeType.Outline" /> Asignar a OT
    </Button>
</Modal>

<!-- Removed redundant execute modal -->

