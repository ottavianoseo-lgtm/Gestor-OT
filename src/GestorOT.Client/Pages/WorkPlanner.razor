@code {
    private List<LaborCalendarDto> _labors = new();
    private List<CampaignLotDto> _lots = new();
    private List<LaborTypeDto> _laborTypes = new();
    private bool _loading = true;
    private DateTime _currentDate = DateTime.Today;
    private string _viewMode = "month";
    private string? _errorMessage;
    private Guid? _filterTypeId;
    private bool _drawerVisible;
    private Guid _editingLaborId = Guid.Empty;

    private static readonly string[] _dayNames = { "Lun", "Mar", "Mie", "Jue", "Vie", "Sab", "Dom" };

    private List<LaborCalendarDto> FilteredLabors => _filterTypeId == null
        ? _labors
        : _labors.Where(l => _laborTypes.Any(lt => lt.Id == _filterTypeId && lt.Name == l.LaborType)).ToList();

    private List<DateTime[]> MonthWeeks
    {
        get
        {
            var firstDay = new DateTime(_currentDate.Year, _currentDate.Month, 1);
            var startOffset = ((int)firstDay.DayOfWeek + 6) % 7;
            var start = firstDay.AddDays(-startOffset);
            var weeks = new List<DateTime[]>();
            for (int w = 0; w < 6; w++)
            {
                var week = new DateTime[7];
                for (int d = 0; d < 7; d++)
                    week[d] = start.AddDays(w * 7 + d);
                if (w == 5 && week[0].Month != _currentDate.Month && week[0].Month != firstDay.AddMonths(1).Month)
                    break;
                weeks.Add(week);
            }
            return weeks;
        }
    }

    private DateTime[] WeekDays
    {
        get
        {
            var startOffset = ((int)_currentDate.DayOfWeek + 6) % 7;
            var monday = _currentDate.AddDays(-startOffset);
            return Enumerable.Range(0, 7).Select(i => monday.AddDays(i)).ToArray();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        CampaignState.OnChange += OnCampaignChanged;
        TenantState.OnChange += OnCampaignChanged;
        await LoadData();
    }

    private void OnCampaignChanged()
    {
        InvokeAsync(async () => { await LoadData(); StateHasChanged(); });
    }

    public void Dispose()
    {
        CampaignState.OnChange -= OnCampaignChanged;
        TenantState.OnChange -= OnCampaignChanged;
    }

    private async Task LoadData()
    {
        try
        {
            _loading = true;
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));

            var rangeStart = _viewMode == "month"
                ? new DateTime(_currentDate.Year, _currentDate.Month, 1).AddDays(-7)
                : _currentDate.AddDays(-((int)_currentDate.DayOfWeek + 6) % 7);
            var rangeEnd = _viewMode == "month"
                ? new DateTime(_currentDate.Year, _currentDate.Month, 1).AddMonths(1).AddDays(7)
                : rangeStart.AddDays(7);

            var laborsTask = Http.GetFromJsonAsync(
                $"api/labors/calendar?start={rangeStart:yyyy-MM-dd}&end={rangeEnd:yyyy-MM-dd}",
                AppJsonSerializerContext.Default.ListLaborCalendarDto, cts.Token);
            var typesTask = Http.GetFromJsonAsync("api/catalogs/labor-types",
                AppJsonSerializerContext.Default.ListLaborTypeDto, cts.Token);

            Task<List<CampaignLotDto>>? lotsTask = null;
            if (CampaignState.CurrentCampaign != null)
            {
                lotsTask = Http.GetFromJsonAsync(
                    $"api/campaigns/{CampaignState.CurrentCampaign.Id}/lots",
                    AppJsonSerializerContext.Default.ListCampaignLotDto, cts.Token);
            }

            var tasks = new List<Task?> { laborsTask, typesTask, lotsTask };
            await Task.WhenAll(tasks.Where(t => t != null).Select(t => t!));

            _labors = await laborsTask ?? new();
            _laborTypes = await typesTask ?? new();
            if (lotsTask != null)
                _lots = await lotsTask ?? new();
            _errorMessage = null;
        }
        catch (OperationCanceledException)
        {
            _errorMessage = "La solicitud tardo demasiado tiempo.";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private List<LaborCalendarDto> GetLaborsForDate(DateTime date)
    {
        return FilteredLabors
            .Where(l => l.Date.Date == date.Date)
            .ToList();
    }

    private DateTime _drawerDate = DateTime.Today;

    private void OpenCreateDrawer(DateTime date)
    {
        _editingLaborId = Guid.Empty;
        _drawerDate = date;
        _drawerVisible = true;
    }

    private void EditLabor(Guid id)
    {
        _editingLaborId = id;
        _drawerVisible = true;
    }

    private async Task OnLaborSaved()
    {
        _drawerVisible = false;
        await LoadData();
    }

    private void GoToLaboresSueltas() { Nav.NavigateTo("/labores-sueltas"); }
    private void GoToday() { _currentDate = DateTime.Today; _ = LoadData(); }
    private async void GoPrev()
    {
        _currentDate = _viewMode == "month"
            ? _currentDate.AddMonths(-1)
            : _currentDate.AddDays(-7);
        await LoadData();
    }
    private async void GoNext()
    {
        _currentDate = _viewMode == "month"
            ? _currentDate.AddMonths(1)
            : _currentDate.AddDays(7);
        await LoadData();
    }

    private string GetHeaderLabel()
    {
        if (_viewMode == "month")
            return _currentDate.ToString("MMMM yyyy", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
        var days = WeekDays;
        return $"{days[0]:dd MMM} — {days[6]:dd MMM yyyy}";
    }

    private void OnDayClick(DateTime day)
    {
        _currentDate = day;
        if (_viewMode == "month")
        {
            _viewMode = "week";
            _ = LoadData();
        }
    }

    private static string GetTypeColor(string laborType) => laborType switch
    {
        "Fertilizacion" => "#27AE60",
        "Pulverizacion" => "#2980B9",
        "Siembra" => "#8E44AD",
        "Cosecha" => "#D35400",
        "Monitoreo" => "#16A085",
        "Laboreo" => "#7F8C8D",
        _ => "#95A5A6"
    };

    private static string GetTypeIcon(string laborType) => laborType switch
    {
        "Fertilizacion" => "F",
        "Pulverizacion" => "P",
        "Siembra" => "S",
        "Cosecha" => "C",
        "Monitoreo" => "M",
        "Laboreo" => "L",
        _ => "?"
    };

    private static string TruncateText(string text, int maxLen) =>
        text.Length > maxLen ? text[..maxLen] + "..." : text;

    public class NewLaborModel
    {
        public Guid LotId { get; set; }
        public string LaborType { get; set; } = string.Empty;
        public DateTime? PlannedDate { get; set; } = DateTime.Today;
        public decimal Hectares { get; set; }
        public string? Notes { get; set; }
    }
}
