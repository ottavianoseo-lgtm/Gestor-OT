@page "/planner"
@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using GestorOT.Client.Components
@using System.Net.Http.Json
@using AntDesign
@inject HttpClient Http
@inject IMessageService Message
@inject NavigationManager Nav
@inject GestorOT.Client.Services.CampaignState CampaignState
@inject GestorOT.Client.Services.TenantState TenantState
@implements IDisposable

<PageTitle>Work Planner - GestorOT</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title">Work Planner</h2>
        <span class="page-subtitle">Planificacion visual de labores agricolas</span>
    </div>
    <div style="display: flex; gap: 8px; align-items: center;">
        <RadioGroup @bind-Value="_viewMode" ButtonStyle="RadioButtonStyle.Solid" Size="@InputSize.Small">
            <Radio RadioButton Value="@("month")">Mes</Radio>
            <Radio RadioButton Value="@("week")">Semana</Radio>
        </RadioGroup>
        <Button OnClick="GoToday" Size="@ButtonSize.Small"
                Style="border-radius: 6px; border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.7);">
            Hoy
        </Button>
        <Button OnClick="GoPrev" Size="@ButtonSize.Small"
                Style="border-radius: 6px; border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.7);">
            <Icon Type="left" Theme="IconThemeType.Outline" />
        </Button>
        <span style="color: #fff; font-weight: 600; min-width: 160px; text-align: center; font-size: 15px;">
            @GetHeaderLabel()
        </span>
        <Button OnClick="GoNext" Size="@ButtonSize.Small"
                Style="border-radius: 6px; border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.7);">
            <Icon Type="right" Theme="IconThemeType.Outline" />
        </Button>
        <Select TItemValue="Guid?" TItem="LaborTypeDto" @bind-Value="_filterTypeId" Placeholder="Filtrar tipo" AllowClear
                Style="width: 150px;" Size="@InputSize.Small">
            <SelectOption TItemValue="Guid?" TItem="LaborTypeDto" Value="@(null)" Label="Todos las actividades" />
            @foreach(var type in _laborTypes)
            {
                <SelectOption TItemValue="Guid?" TItem="LaborTypeDto" Value="@type.Id" Label="@type.Name" />
            }
        </Select>
        <Button Type="@ButtonType.Primary" OnClick="() => OpenCreateDrawer(DateTime.Today)"
                Style="background: #2ECC71; border-color: #2ECC71; border-radius: 8px; font-weight: 600;" Size="@ButtonSize.Small">
            <Icon Type="plus" Theme="IconThemeType.Outline" /> Nueva Labor
        </Button>
        <Button OnClick="GoToLaboresSueltas" Size="@ButtonSize.Small"
                Style="border-radius: 6px; border-color: rgba(255,165,0,0.4); color: #FFA500;">
            <Icon Type="disconnect" Theme="IconThemeType.Outline" /> Sueltas
        </Button>
    </div>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <Alert Type="@AlertType.Error" Message="@_errorMessage" ShowIcon="true" Closable="true" Style="margin-bottom: 16px;" />
}

<div class="planner-legend" style="margin-bottom: 12px; display: flex; gap: 16px; align-items: center;">
    <span class="legend-item"><span class="legend-dot" style="background: #4CAF50;"></span> Con OT</span>
    <span class="legend-item"><span class="legend-dot" style="background: #FFA500;"></span> Sin OT (Suelta)</span>
    <span class="legend-sep">|</span>
    <span class="legend-item"><span class="legend-dot" style="background: #27AE60;"></span> Fertilizacion</span>
    <span class="legend-item"><span class="legend-dot" style="background: #2980B9;"></span> Pulverizacion</span>
    <span class="legend-item"><span class="legend-dot" style="background: #8E44AD;"></span> Siembra</span>
    <span class="legend-item"><span class="legend-dot" style="background: #D35400;"></span> Cosecha</span>
    <span class="legend-item"><span class="legend-dot" style="background: #16A085;"></span> Monitoreo</span>
    <span style="margin-left: auto; color: rgba(255,255,255,0.4); font-size: 12px;">
        @FilteredLabors.Count labores visibles
    </span>
</div>

@if (_loading)
{
    <div style="text-align: center; padding: 60px;">
        <Spin Size="@SpinSize.Large" Tip="Cargando labores..." />
    </div>
}
else if (_viewMode == "month")
{
    <div class="glass-card" style="padding: 0; overflow: hidden;">
        <div class="cal-grid cal-header">
            @foreach (var day in _dayNames)
            {
                <div class="cal-header-cell">@day</div>
            }
        </div>
        @foreach (var week in MonthWeeks)
        {
            <div class="cal-grid cal-week">
                @foreach (var day in week)
                {
                    var isToday = day.Date == DateTime.Today;
                    var isCurrentMonth = day.Month == _currentDate.Month;
                    var dayLabors = GetLaborsForDate(day);
                        <div class="cal-day @(isToday ? "cal-today" : "") @(!isCurrentMonth ? "cal-other-month" : "")"
                             @onclick="() => OnDayClick(day)">
                            <div class="cal-day-top">
                                <div class="cal-day-number">@day.Day</div>
                                <button class="btn-add-mini" @onclick:stopPropagation="true" @onclick="() => OpenCreateDrawer(day)" title="Crear labor">+</button>
                            </div>
                            @foreach (var labor in dayLabors.Take(3))
                            {
                                <div class="cal-event" style="background: @(labor.ColorHex)20; border-left: 3px solid @(labor.ColorHex); cursor: pointer;"
                                     @onclick:stopPropagation="true" @onclick="() => EditLabor(labor.Id)">
                                    <span class="cal-event-icon" style="color: @GetTypeColor(labor.LaborType);">@GetTypeIcon(labor.LaborType)</span>
                                    <span class="cal-event-text">@TruncateText(labor.Title, 16)</span>
                                </div>
                            }
                            @if (dayLabors.Count > 3)
                            {
                                <div class="cal-more">+@(dayLabors.Count - 3) mas</div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="glass-card" style="padding: 0; overflow: hidden;">
            <div class="week-grid week-header">
                <div class="week-time-col"></div>
                @foreach (var day in WeekDays)
                {
                    var isToday = day.Date == DateTime.Today;
                    <div class="week-day-header @(isToday ? "week-today-header" : "")">
                        <span style="font-size: 10px; text-transform: uppercase;">@day.ToString("ddd")</span>
                        <span style="font-size: 18px; font-weight: 700;">@day.Day</span>
                    </div>
                }
            </div>
            <div class="week-body">
                @foreach (var day in WeekDays)
                {
                    var isToday = day.Date == DateTime.Today;
                    var dayLabors = GetLaborsForDate(day);
                    <div class="week-day-col @(isToday ? "week-today-col" : "")">
                        @if (dayLabors.Count == 0)
                        {
                            <div class="week-empty" @onclick="() => OpenCreateDrawer(day)">
                                <Icon Type="plus" Theme="IconThemeType.Outline" Style="font-size: 16px;" />
                            </div>
                        }
                        @foreach (var labor in dayLabors)
                        {
                            <div class="week-card" style="border-left: 4px solid @(labor.ColorHex);"
                                 @onclick="() => EditLabor(labor.Id)">
                                <div class="week-card-top">
                                    <div class="week-card-type" style="background: @GetTypeColor(labor.LaborType);">
                                        @labor.LaborType
                                    </div>
                                    @if (labor.HasWorkOrder)
                                    {
                                        <span class="week-card-ot-badge" title="Tiene OT asignada">OT</span>
                                    }
                                    else
                                    {
                                        <span class="week-card-loose-badge" title="Sin OT asignada">Suelta</span>
                                    }
                                </div>
                                <div class="week-card-title">@labor.Title</div>
                                @if (!string.IsNullOrEmpty(labor.LotName))
                                {
                                    <div class="week-card-meta">
                                        <Icon Type="environment" Theme="IconThemeType.Outline" Style="font-size: 10px;" />
                                        @labor.LotName
                                    </div>
                                }
                                <div class="week-card-meta">
                                    <Icon Type="column-width" Theme="IconThemeType.Outline" Style="font-size: 10px;" />
                                    @labor.Hectares.ToString("N0") ha
                                </div>
                                @if (!string.IsNullOrEmpty(labor.WorkOrderDescription))
                                {
                                    <div class="week-card-meta" style="color: rgba(255,255,255,0.3); font-size: 10px;">
                                        <Icon Type="file-text" Theme="IconThemeType.Outline" Style="font-size: 9px;" />
                                        @TruncateText(labor.WorkOrderDescription, 20)
                                    </div>
                                }
                            </div>
                        }
                        <div class="week-add-btn" @onclick="() => OpenCreateDrawer(day)">
                            <Icon Type="plus" Theme="IconThemeType.Outline" Style="font-size: 12px;" /> Agregar
                        </div>
                    </div>
                }
            </div>
        </div>
    }

<Modal Title="@(_editingLaborId == Guid.Empty ? "Planificar Nueva Labor" : "Detalle de Labor")"
       Visible="@_drawerVisible"
       OnCancel="() => _drawerVisible = false"
       Footer="null"
       Width="800">
    <LaborEditorForm LaborId="@_editingLaborId" DefaultDate="@_drawerDate" OnSaved="OnLaborSaved" />
</Modal>

<style>
