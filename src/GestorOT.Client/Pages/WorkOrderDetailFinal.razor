@page "/workorders/{WorkOrderIdParam}"
@namespace GestorOT.Client.Pages
@inherits WorkOrderDetailFinalBase
@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using GestorOT.Client.Components
@using AntDesign

<PageTitle>Detalle de OT - GestorOT</PageTitle>

@if (_loading && _order == null)
{
    <div style="text-align: center; padding: 100px;">
        <Spin Size="AntDesign.SpinSize.Large" Tip="Cargando Orden de Trabajo..." />
    </div>
}
else if (_order != null)
{
    <div class="page-header" style="margin-bottom: 8px;">
        <div style="display: flex; align-items: center; gap: 12px;">
            <Button OnClick="BackToList" Icon="arrow-left" Shape="@ButtonShape.Circle" />
            <div>
                <h2 class="page-title" style="margin-bottom: 0;">@(string.IsNullOrWhiteSpace(_order.Name) ? _order.OTNumber : _order.Name)</h2>
                <span class="page-subtitle">Campaña: @(_campaignState.CurrentCampaign?.Name ?? "—") · @_order.Description</span>
            </div>
        </div>
        <div style="display: flex; gap: 12px;">
             <Button OnClick="ExportHtmlInteractivo" Icon="share-alt" Ghost>Compartir Reporte</Button>
             <Button Type="@ButtonType.Primary" OnClick="SaveAllChanges" Loading="_savingGlobal" Icon="save" Style="background: #2ECC71; border-color: #2ECC71;" Disabled="@(_order.IsLocked && _order.Status == _originalStatus)">Guardar Cambios</Button>
        </div>
    </div>

    <div style="padding: 24px; max-width: 1400px; margin: 0 auto;">
    @if (_order != null && _order.IsLocked)
    {
        <Alert Type="@AlertType.Warning" Message="Esta OT se encuentra en un estado que no permite modificaciones." Description="Para realizar cambios, primero debe moverla a un estado editable." ShowIcon="true" Style="margin-bottom: 16px; border-radius: 12px;" />
    }

    <div class="glass-card" style="padding: 24px; margin-bottom: 24px;">
        <div style="margin-bottom: 20px;">
            <label class="ot-label">NOMBRE</label>
            <Input @bind-Value="_order.Name" Placeholder="Nombre de la OT (opcional)..." Disabled="@(_order.IsLocked)" Style="color: var(--text-primary); background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.1); font-size: 15px; font-weight: 600;" />
        </div>
        <div style="display: grid; grid-template-columns: 1.5fr 1fr 1fr; gap: 24px; margin-bottom: 20px;">
            <div>
                <label class="ot-label">RESPONSABLE</label>
                <Select TItem="ContactDto" TItemValue="Guid?" DataSource="_availableContacts" @bind-Value="_order.ContactId" LabelName="@nameof(ContactDto.FullName)" ValueName="@nameof(ContactDto.Id)" EnableSearch Placeholder="Seleccionar responsable" Style="width: 100%;" Disabled="@(_order.IsLocked)" />
            </div>
            <div>
                <label class="ot-label">FECHA LÍMITE</label>
                <DatePicker @bind-Value="_order.DueDate" Style="width: 100%;" Format="dd/MM/yyyy" Disabled="@(_order.IsLocked)" />
            </div>
            <div>
                <label class="ot-label">ESTADO</label>
                <Select TItem="WorkOrderStatusDto" TItemValue="string" DataSource="_availableStatuses" @bind-Value="_order.Status" LabelName="@nameof(WorkOrderStatusDto.Name)" ValueName="@nameof(WorkOrderStatusDto.Name)" Style="width: 100%;">
                    @foreach (var s in _availableStatuses)
                    {
                        <SelectOption Value="@s.Name" Label="@s.Name"><span style="@StatusBadgeStyle(s.ColorHex)"><span style="@($"width:8px;height:8px;border-radius:50%;background:{s.ColorHex};flex-shrink:0;display:inline-block;")"></span>@s.Name</span></SelectOption>
                    }
                </Select>
            </div>
        </div>
        <div style="margin-bottom: 20px;">
            <label class="ot-label">DESCRIPCIÓN</label>
            <TextArea @bind-Value="_order.Description" Placeholder="Notas o detalles adicionales..." AutoSize="true" Disabled="@(_order.IsLocked)" />
        </div>
        <div style="display: flex; gap: 40px; padding-top: 12px; border-top: 1px solid rgba(255,255,255,0.06);">
            <div style="display: flex; flex-direction: column; gap: 8px;"><span style="font-size: 13px; color: rgba(255,255,255,0.7);">¿Acepta múltiples personas?</span><RadioGroup @bind-Value="_order.AcceptsMultiplePeople" Disabled="@(_order.IsLocked)"><Radio Value="@true">Sí</Radio><Radio Value="@false">No</Radio></RadioGroup></div>
            <div style="display: flex; flex-direction: column; gap: 8px;"><span style="font-size: 13px; color: rgba(255,255,255,0.7);">¿Acepta múltiples fechas?</span><RadioGroup @bind-Value="_order.AcceptsMultipleDates" Disabled="@(_order.IsLocked)"><Radio Value="@true">Sí</Radio><Radio Value="@false">No</Radio></RadioGroup></div>
        </div>
    </div>

    <div style="margin-bottom: 24px;">
        <Tabs DefaultActiveKey="1" Type="@TabType.Card">
            <TabPane Tab="Resumen y KPIs" Key="1">
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; padding: 16px 0;">
                    <div class="kpi-card-new"><div class="kpi-label">HA. PLANEADAS</div><div class="kpi-value">@_order.Labors.Sum(l => l.Hectares).ToString("N2")</div></div>
                    <div class="kpi-card-new"><div class="kpi-label">HA. EJECUTADAS</div><div class="kpi-value" style="color: #52C41A;">@_order.Labors.Where(l => l.Status == "Realized").Sum(l => l.Hectares).ToString("N2")</div></div>
                    <div class="kpi-card-new">
                        <div class="kpi-label">% CUMPLIMIENTO</div>
                        @{ var planHa = _order.Labors.Sum(l => l.Hectares); var realHa = _order.Labors.Where(l => l.Status == "Realized").Sum(l => l.Hectares); var perc = planHa > 0 ? (realHa / planHa) * 100 : 0; }
                        <div class="kpi-value">@perc.ToString("N0")%</div>
                        <Progress Percent='(double)perc' Size="AntDesign.ProgressSize.Small" Status="@( (AntDesign.ProgressStatus)(perc >= 100 ? AntDesign.ProgressStatus.Success : AntDesign.ProgressStatus.Active) )" />
                    </div>
                </div>
            </TabPane>

            <TabPane Tab="Labores" Key="2">
                <div class="section-header" style="margin-top: 16px;">
                    <div style="display: flex; align-items: center; gap: 10px;">
                        <h3 class="section-title">Detalle de Labores</h3>
                        <div style="display: flex; gap: 6px;">
                            <button class="status-pill @(_filterLaborStatus == null ? "active" : "")" @onclick="() => _filterLaborStatus = null">Todas</button>
                            <button class="status-pill planned @(_filterLaborStatus == "Planned" ? "active" : "")" @onclick='() => _filterLaborStatus = "Planned"'>Planeadas</button>
                            <button class="status-pill realized @(_filterLaborStatus == "Realized" ? "active" : "")" @onclick='() => _filterLaborStatus = "Realized"'>Realizadas</button>
                            <button class="status-pill validation @(_filterLaborStatus == "AwaitingValidation" ? "active" : "")" @onclick='() => _filterLaborStatus = "AwaitingValidation"'>En Validación</button>
                        </div>
                    </div>
                    <div style="display: flex; gap: 8px;">
                        @if (_selectedLabors.Any()) { <Button Type="@ButtonType.Default" Size="@ButtonSize.Small" Icon="share-alt" OnClick="SubmitSelectedLabors" Style="background: rgba(59, 130, 246, 0.1); color: #3b82f6; border: 1px solid #3b82f6;">Validar Seleccionadas (@_selectedLabors.Count)</Button> }
                        <Button Type="@ButtonType.Primary" Size="@ButtonSize.Small" Icon="plus" OnClick="() => OnAddLaborClicked()" Disabled="@(_order.IsLocked)">Agregar Labor</Button>
                    </div>
                </div>
                <div class="glass-card table-container">
                    <style>
                        .ant-table-cell-fix-right { background-color: #1a1a2e !important; border-left: 1px solid rgba(255,255,255,0.05) !important; }
                        .ant-table-row:hover .ant-table-cell-fix-right { background-color: #252545 !important; }
                        .ant-table-row-expand-icon { 
                            color: #3498DB !important; 
                            border-color: rgba(52, 152, 219, 0.5) !important; 
                            background: rgba(52, 152, 219, 0.1) !important;
                            transition: all 0.3s;
                        }
                        .ant-table-row-expand-icon:hover {
                            color: #fff !important;
                            border-color: #3498DB !important;
                            background: #3498DB !important;
                        }
                    </style>
                    <Table @ref="_laborTable" TItem="LaborDto" DataSource='_order.Labors.Where(l => _filterLaborStatus == null || l.Status == _filterLaborStatus).ToList()' Size="TableSize.Small" HidePagination ScrollX="1300" ExpandIconColumnIndex="1" RowKey="GetRowKey">
                        <ChildContent>
                            <Column TData="bool" Title="" Width="50"><Checkbox Checked="_selectedLabors.Contains(context.Id)" CheckedChanged='(val) => ToggleLaborSelection(context.Id, val)' /></Column>
                            <Column TData="string" Title="Lote" Sortable>
                                <span style="font-weight: 600; color: #fff;">@context.LotName</span>
                            </Column>
                            <Column TData="string" Title="Tipo">@context.LaborTypeName</Column>
                            <Column TData="string" Title="Estado"><Tag Style="@StatusTagStyle(GetStatusColor(context.Status))">@GetStatusLabel(context.Status)</Tag></Column>
                            <Column TData="decimal" Title="Ha Plan.">@context.Hectares.ToString("N2")</Column>
                            <Column TData="decimal" Title="Ha Real.">@if (context.Status == "Realized") { <span>@context.EffectiveArea.ToString("N2")</span> } else { <span style="color: rgba(255,255,255,0.2);">—</span> }</Column>
                            <Column TData="decimal" Title="Diff">@if (context.Status == "Realized") { var diff = context.EffectiveArea - context.Hectares; <span style="color: @(diff > 0 ? "#ff4d4f" : (diff < 0 ? "#52c41a" : "inherit"))">@(diff > 0 ? "+" : "")@diff.ToString("N2")</span> }</Column>
                            <Column TData="DateTime" Title="Fecha">@context.CreatedAt.ToString("dd/MM/yyyy")</Column>
                            <Column TData="string" Title="Acciones" Width="90" Fixed="@AntDesign.ColumnFixPlacement.Right" TitleStyle="white-space: nowrap;">
                                <div style="display: flex; align-items: center; justify-content: center;">
                                    <Dropdown Trigger="@(new AntDesign.Trigger[] { AntDesign.Trigger.Click })" Disabled="@(_order.IsLocked)">
                                        <Overlay>
                                            <Menu Style="background: #1E1E2E; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;">
                                                <MenuItem OnClick="() => OpenLaborModal(context.Id)" Style="color: #fff;"><Icon Type="edit" /> Editar</MenuItem>
                                                <MenuItem OnClick="() => SubmitSingleLabor(context.Id)" Style="color: #fff;"><Icon Type="share-alt" /> Validar</MenuItem>
                                                <MenuItem OnClick="() => DeleteLabor(context.Id)" Style="color: #ff4d4f;"><Icon Type="delete" /> Quitar</MenuItem>
                                            </Menu>
                                        </Overlay>
                                        <ChildContent>
                                            <Button Type="@ButtonType.Text" Style="height: 32px; width: 32px; border: none; background: transparent; display: flex; align-items: center; justify-content: center; padding: 0; transition: background 0.2s;">
                                                <svg width="22" height="22" viewBox="0 0 1024 1024" xmlns="http://www.w3.org/2000/svg">
                                                    <path fill="white" d="M456 231a56 56 0 1 0 112 0 56 56 0 1 0-112 0zm0 280a56 56 0 1 0 112 0 56 56 0 1 0-112 0zm0 280a56 56 0 1 0 112 0 56 56 0 1 0-112 0z"/>
                                                </svg>
                                            </Button>
                                        </ChildContent>
                                    </Dropdown>
                                </div>
                            </Column>
                        </ChildContent>
                        <ExpandTemplate Context="laborRow">
                            <div style="padding: 12px; background: rgba(255,255,255,0.02); border-radius: 8px; border: 1px solid rgba(255,255,255,0.05);">
                                <h4 style="color: #fff; font-size: 13px; margin-bottom: 12px;"><Icon Type="experiment" /> Desvío de Insumos (Detalle Técnico)</h4>
                                <Table TItem="LaborSupplyDto" DataSource="laborRow.Data.Supplies" Context="supply" Size="TableSize.Small" HidePagination>
                                    <Column TData="string" Title="Insumo">@supply.SupplyName</Column>
                                    <Column TData="string" Title="Unidad">@supply.UnitOfMeasure</Column>
                                    <Column TData="decimal" Title="Dosis Plan.">@supply.PlannedDose.ToString("N2")</Column>
                                    <Column TData="decimal?" Title="Dosis Real">
                                        @if (supply.RealDose.HasValue) { <span style="color: #fff;">@supply.RealDose.Value.ToString("N2")</span> }
                                        else if (supply.CalculatedDose.HasValue) { <Tooltip Title="@("Prorrateado de la OT")"><span style="color: #FAAD14; font-style: italic;">@supply.CalculatedDose.Value.ToString("N2")</span></Tooltip> }
                                        else { <span style="color: rgba(255,255,255,0.2);">—</span> }
                                    </Column>
                                    <Column TData="decimal" Title="Total Plan.">@supply.PlannedTotal.ToString("N2")</Column>
                                    <Column TData="decimal?" Title="Total Real">
                                        @if (supply.RealTotal.HasValue) { <span style="color: #fff;">@supply.RealTotal.Value.ToString("N2")</span> }
                                        else if (supply.CalculatedTotal.HasValue) { <Tooltip Title="@("Prorrateado de la OT")"><span style="color: #FAAD14; font-style: italic;">@supply.CalculatedTotal.Value.ToString("N2")</span></Tooltip> }
                                        else { <span style="color: rgba(255,255,255,0.2);">—</span> }
                                    </Column>
                                    <Column TData="string" Title="Variación">@if (supply.RealTotal.HasValue) { var varPercent = supply.PlannedTotal > 0 ? ((supply.RealTotal.Value / supply.PlannedTotal) - 1) * 100 : 0; var color = Math.Abs(varPercent) > 5 ? "#ff4d4f" : "#52c41a"; <span style="color: @color; font-weight: 600;">@(varPercent > 0 ? "+" : "")@varPercent.ToString("N1")%</span> } else { <span style="color: rgba(255,255,255,0.2);">—</span> }</Column>
                                </Table>
                            </div>
                        </ExpandTemplate>
                    </Table>
                </div>
            </TabPane>

            <TabPane Tab="Insumos Consolidados" Key="3">
                <div class="section-header" style="margin-top: 16px;"><h3 class="section-title">Plan vs. Real</h3><Button Size="@ButtonSize.Small" Ghost Icon="sync" OnClick="ConsolidateSupplies">Recalcular de Labores</Button></div>
                <div class="glass-card table-container">
                    <Table TItem="WorkOrderSupplyApprovalDto" DataSource="_order.SupplyApprovals" Size="TableSize.Small" HidePagination>
                        <Column TData="string" Title="Insumo">@context.SupplyName</Column>
                        <Column TData="decimal" Title="Planeado">@context.TotalCalculated.ToString("N2")</Column>
                        <Column TData="decimal?" Title="Real">
                            @if (_order.IsLocked)
                            {
                                @(context.RealTotalUsed?.ToString("N2") ?? "0.00")
                            }
                            else
                            {
                                <AntDesign.InputNumber TValue="decimal?" @bind-Value="context.RealTotalUsed" Size="InputSize.Small" Style="width: 100px;" />
                            }
                        </Column>
                        <Column TData="decimal" Title="Delta">@{ var delta = (context.RealTotalUsed ?? 0) - context.TotalCalculated; var color = delta > 0 ? "#ff4d4f" : (delta < 0 ? "#52c41a" : "rgba(255,255,255,0.4)"); } <span style="color: @color; font-weight: 600;">@(delta > 0 ? "+" : "")@delta.ToString("N2")</span></Column>
                        <Column TData="string" Title="% Uso">@{ var usage = context.TotalCalculated > 0 ? ((context.RealTotalUsed ?? 0) / context.TotalCalculated) * 100 : 0; } <Progress Percent='(double)usage' Size="ProgressSize.Small" Steps="5" StrokeColor='usage > 100 ? "#ff4d4f" : "#52c41a"' /></Column>
                    </Table>
                </div>
            </TabPane>
        </Tabs>
    </div>

    <div style="grid; gap: 32px;">
        <section style="margin-bottom: 100px;">
             <div class="section-header"><h3 class="section-title">Archivos Adjuntos</h3></div>
            <div class="glass-card" style="padding: 20px;">
                @if (_order.Labors.Any(l => !string.IsNullOrEmpty(l.PrescriptionMapUrl))) {
                    <div style="display: flex; flex-direction: column; gap: 8px;">
                        @foreach (var l in _order.Labors.Where(l => !string.IsNullOrEmpty(l.PrescriptionMapUrl))) {
                            <div style="display: flex; align-items: center; justify-content: space-between; padding: 8px 12px; background: rgba(255,255,255,0.03); border-radius: 6px;">
                                <span><Icon Type="file" /> Prescripción: @l.LaborTypeName (@l.LotName)</span>
                                <Button Size="@ButtonSize.Small" Icon="download" OnClick='() => _js.InvokeVoidAsync("open", l.PrescriptionMapUrl, "_blank")' />
                            </div>
                        }
                    </div>
                } else { <div style="text-align: center; color: rgba(255,255,255,0.3); padding: 20px;">No hay archivos adjuntos en esta orden.</div> }
            </div>
        </section>
    </div>
    </div>
}

<Modal Title="@(_editingLaborId == Guid.Empty ? "Nueva Labor" : "Detalle de Labor")" Visible="_showLaborModal" OnCancel="HandleCancelLaborModal" Footer="null" Width="800">
    <LaborEditorForm @ref="_laborFormRef" WorkOrderId="WorkOrderId" LaborId="_editingLaborId" InitialStatus="@_pendingInitialStatus" OnSaved="OnLaborSaved" />
</Modal>

<Modal Title="Labores sin OT" 
       Visible="_showUnassignedWarning" 
       OnOk="ReviewUnassignedLabors"
       OnCancel="CreateNewLabor"
       OkText='@("Revisar Existentes")'
       CancelText='@("Crear Nueva")'
       Centered="true">
    <p style="color: #fff;">Tenés @_unassignedLaborsCount labores creadas sin OT. ¿Deseas crear una nueva o revisar las existentes para asignarlas a esta OT?</p>
</Modal>

<ValidationSuccessModal Visible="_showValidationModal" ValidationUrl="@_validationUrl" OnClose="() => _showValidationModal = false" />

<style>
    .ot-label { display: block; font-size: 11px; color: rgba(255,255,255,0.4); font-weight: 700; margin-bottom: 6px; letter-spacing: 0.5px; }
    .section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
    .section-title { color: #fff; margin: 0; font-size: 16px; font-weight: 600; }
    .table-container { border-radius: 12px; overflow: hidden; }
    .kpi-card-new { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 16px; }
    .kpi-card-new .kpi-label { font-size: 10px; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; }
    .kpi-card-new .kpi-value { font-size: 20px; font-weight: 700; color: #fff; }
    .status-pill { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.5); border: 1px solid rgba(255,255,255,0.12); border-radius: 20px; font-size: 11px; font-weight: 600; padding: 3px 12px; cursor: pointer; transition: all 0.2s; }
    .status-pill:hover { background: rgba(255,255,255,0.12); color: #fff; }
    .status-pill.active { background: rgba(255,255,255,0.15); color: #fff; border-color: rgba(255,255,255,0.4); }
    .status-pill.planned.active { background: rgba(52,152,219,0.2); color: #5DADE2; border-color: rgba(52,152,219,0.6); }
    .status-pill.realized.active { background: rgba(46,204,113,0.2); color: #58D68D; border-color: rgba(46,204,113,0.6); }
    .status-pill.validation.active { background: rgba(241,196,15,0.2); color: #F4D03F; border-color: rgba(241,196,15,0.6); }
    ::ng-deep .ant-table { background: transparent !important; }
    ::ng-deep .ant-table-thead > tr > th { background: rgba(255,255,255,0.05) !important; color: rgba(255,255,255,0.5) !important; border-bottom: 1px solid rgba(255,255,255,0.1) !important; font-size: 11px; text-transform: uppercase; }
    ::ng-deep .ant-table-tbody > tr > td { border-bottom: 1px solid rgba(255,255,255,0.05) !important; color: #eee !important; }
    ::ng-deep .ant-table-tbody > tr:hover > td { background: rgba(255,255,255,0.03) !important; }
    ::ng-deep .ant-table-tbody .ant-btn-text:hover { background: rgba(255, 255, 255, 0.1) !important; }
    ::ng-deep .ant-table-tbody .ant-btn-text .anticon svg path { fill: #fff !important; }
</style>

