@page "/reportes"
@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using System.Net.Http.Json
@using AntDesign
@inject HttpClient Http
@inject IMessageService Message
@inject GestorOT.Client.Services.CampaignState CampaignState
@implements IDisposable

<PageTitle>Reportes - GestorOT</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title">Reportes de Desvíos e Insumos</h2>
        <span class="page-subtitle">Plan vs Real por campaña</span>
    </div>
</div>

@if (!CampaignState.IsSelected)
{
    <Alert Message="Seleccione una campaña para ver reportes." Type="@AlertType.Warning" ShowIcon="true" Style="border-radius: 12px;" />
}
else if (_loading)
{
    <div style="text-align: center; padding: 80px;"><Spin Size="AntDesign.SpinSize.Large" Tip="Cargando reporte..." /></div>
}
else if (_report != null)
{
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 24px;">
        <div class="kpi-card" style="border-left: 4px solid #3498DB;">
            <div class="kpi-label">Órdenes de Trabajo</div>
            <div class="kpi-value">@_report.TotalWorkOrders</div>
        </div>
        <div class="kpi-card" style="border-left: 4px solid #2ECC71;">
            <div class="kpi-label">Labores Totales</div>
            <div class="kpi-value">@_report.TotalLabors</div>
        </div>
        <div class="kpi-card" style="border-left: 4px solid #F1C40F;">
            <div class="kpi-label">Labores Realizadas</div>
            <div class="kpi-value">@_report.RealizedLabors</div>
        </div>
        <div class="kpi-card" style="border-left: 4px solid #9B59B6;">
            <div class="kpi-label">Ha Plan. / Real.</div>
            <div class="kpi-value">@_report.PlannedHectares.ToString("N0") / @_report.RealizedHectares.ToString("N0")</div>
        </div>
    </div>

    <AntDesign.Tabs DefaultActiveKey="1" Type="@TabType.Card">
        <TabPane Tab="Desvíos por OT" Key="1">
            <div class="glass-card" style="margin-top: 16px;">
                <Table TItem="WorkOrderDeviation" DataSource="@_report.WorkOrderDeviations" Size="TableSize.Small" HidePagination>
                    <PropertyColumn Property="d => d.Description" Title="OT" Sortable />
                    <PropertyColumn Property="d => d.TotalLabors" Title="Labores" Sortable />
                    <PropertyColumn Property="d => d.RealizedLabors" Title="Realizadas" Sortable />
                    <PropertyColumn Property="d => d.PlanHa" Title="Ha Plan." Sortable Format="N2" />
                    <PropertyColumn Property="d => d.RealHa" Title="Ha Real." Sortable Format="N2" />
                    <Column TData="decimal" Title="Desvío %" Sortable>
                        @{
                            var color = context.HaDeviationPercent > 0 ? "#ff4d4f" : (context.HaDeviationPercent < 0 ? "#52c41a" : "inherit");
                        }
                        <span style="color: @color; font-weight: 600;">@(context.HaDeviationPercent > 0 ? "+" : "")@context.HaDeviationPercent.ToString("N1")%</span>
                    </Column>
                    <ActionColumn Title="" Width="80">
                        <Button Size="@ButtonSize.Small" Type="@ButtonType.Link" OnClick="() => OpenWorkOrder(context.WorkOrderId)">
                            <Icon Type="eye" /> Ver
                        </Button>
                    </ActionColumn>
                </Table>
            </div>
        </TabPane>

        <TabPane Tab="Resumen de Insumos" Key="2">
            <div class="glass-card" style="margin-top: 16px;">
                @if (_report.SupplySummary.Count == 0)
                {
                    <div style="text-align: center; padding: 40px; color: rgba(255,255,255,0.3);">No hay datos de insumos disponibles.</div>
                }
                else
                {
                    <Table TItem="SupplySummary" DataSource="@_report.SupplySummary" Size="TableSize.Small" HidePagination>
                        <PropertyColumn Property="s => s.SupplyName" Title="Insumo" Sortable />
                        <PropertyColumn Property="s => s.PlannedTotal" Title="Planificado" Sortable Format="N2" />
                        <PropertyColumn Property="s => s.RealTotal" Title="Real" Sortable Format="N2" />
                        <Column TData="decimal" Title="Desvío" Sortable>
                            @{
                                var devColor = context.DeviationPercent > 5 ? "#ff4d4f" : (context.DeviationPercent < -5 ? "#52c41a" : "inherit");
                            }
                            <span style="color: @devColor; font-weight: 600;">@(context.DeviationPercent > 0 ? "+" : "")@context.DeviationPercent.ToString("N1")%</span>
                        </Column>
                        <PropertyColumn Property="s => s.Unit" Title="U.M." />
                        <Column TData="decimal" Title="Barra">
                            <Progress Percent='(double)Math.Min(Math.Abs(context.DeviationPercent), 100)' Size="ProgressSize.Small" ShowInfo="false" StrokeColor='context.DeviationPercent > 5 ? "#ff4d4f" : "#52c41a"' />
                        </Column>
                    </Table>
                }
            </div>
        </TabPane>
    </AntDesign.Tabs>
}

<style>
    .kpi-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 20px; }
    .kpi-label { font-size: 11px; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
    .kpi-value { font-size: 24px; font-weight: 700; color: #fff; }
</style>

@code {
    [Inject] public NavigationManager Nav { get; set; } = default!;

    private void OpenWorkOrder(Guid id) => Nav.NavigateTo($"/workorders/{id}");

    private CampaignDeviationReport? _report;
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        CampaignState.OnChange += OnCampaignChanged;
        await LoadReport();
    }

    private async void OnCampaignChanged()
    {
        await LoadReport();
        StateHasChanged();
    }

    public void Dispose()
    {
        CampaignState.OnChange -= OnCampaignChanged;
    }

    private async Task LoadReport()
    {
        if (!CampaignState.IsSelected) return;
        _loading = true;
        try
        {
            _report = await Http.GetFromJsonAsync<CampaignDeviationReport>(
                $"api/workorders/campaign-deviations/{CampaignState.CurrentCampaign!.Id}");
        }
        catch (Exception ex)
        {
            Message.Error($"Error al cargar reporte: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }
}
