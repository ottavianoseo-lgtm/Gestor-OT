@page "/execution/{WorkOrderId:guid}"
@page "/public/labor-execution/{Token}"
@layout GestorOT.Client.Layout.PublicLayout
@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using System.Net.Http.Json
@using System.Text.Json
@using AntDesign
@inject HttpClient Http
@inject IMessageService Message
@inject NavigationManager Nav

<PageTitle>Ejecución de Labores - GestorOT</PageTitle>

<div class="execution-container">
    @if (_loading)
    {
        <div style="text-align: center; padding: 60px 0;">
            <Spin Size="@SpinSize.Large" Tip="Cargando orden de trabajo..." />
        </div>
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <Alert Type="@AlertType.Error" Message="@_errorMessage" ShowIcon="true" Style="margin-bottom: 16px;" />
        <Button OnClick="LoadData" Style="border-radius: 8px;">Reintentar</Button>
    }
    else if (_order != null)
    {
        <div class="glass-card wo-header">
            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
                @if (!IsPublic)
                {
                    <Button Type="@ButtonType.Text" OnClick="GoBack"
                            Style="color: rgba(255,255,255,0.7); padding: 4px 8px; min-width: auto;">
                        <Icon Type="arrow-left" Theme="IconThemeType.Outline" />
                    </Button>
                }
                <h2 class="page-title" style="margin: 0; font-size: 18px;">Ejecución de Labores</h2>
            </div>
            <div style="margin-bottom: 4px;">
                <Tag Style="background: #E74C3C20; color: #E74C3C; border: 1px solid #E74C3C40; border-radius: 12px; font-size: 11px; padding: 2px 10px;">
                    @(_order.OTNumber ?? "S/N")
                </Tag>
                <Tag Style="background: #3498DB20; color: #3498DB; border: 1px solid #3498DB40; border-radius: 12px; font-size: 11px; padding: 2px 10px;">
                    @_order.Status
                </Tag>
            </div>
            <h3 style="color: #fff; margin: 8px 0 4px; font-size: 16px; font-weight: 600;">@_order.Description</h3>
            <div style="display: flex; gap: 16px; flex-wrap: wrap; color: rgba(255,255,255,0.6); font-size: 13px;">
                <span><Icon Type="environment" Theme="IconThemeType.Outline" Style="margin-right: 4px;" />@(_order.FieldName ?? "—")</span>
            </div>
        </div>

        @if (_labors != null && _labors.Any())
        {
            @foreach (var labor in _labors)
            {
                var currentLabor = labor;
                var isRealized = currentLabor.Status == "Realized" || currentLabor.Status == "Done";
                <div class="glass-card labor-card">
                    <div class="labor-header">
                        <div>
                            <span style="font-weight: 700; color: #fff; font-size: 15px;">@currentLabor.LaborTypeName</span>
                            <div style="margin-top: 4px; display: flex; gap: 8px; flex-wrap: wrap; align-items: center;">
                                <Tag Style="@GetStatusTagStyle(currentLabor.Status)">@currentLabor.Status</Tag>
                                <span style="color: rgba(255,255,255,0.4); font-size: 11px;">Planificado: @currentLabor.Hectares.ToString("N2") ha</span>
                                @if (!isRealized)
                                {
                                    <div style="display: flex; align-items: center; gap: 4px; margin-left: 8px;">
                                        <span style="color: #fff; font-size: 11px; font-weight: 600;">HA. REALES:</span>
                                        <AntDesign.InputNumber TValue="decimal" @bind-Value="_realHectares[currentLabor.Id]"
                                                   Min="0.01m" Step="0.1m" Size="InputSize.Small"
                                                   Style="width: 80px;" />
                                    </div>
                                }
                                else
                                {
                                    <span style="color: #2ECC71; font-size: 12px; font-weight: 600; margin-left: 8px;">Real: @currentLabor.Hectares.ToString("N2") ha</span>
                                }
                            </div>
                        </div>
                        @if (!isRealized)
                        {
                            <Button Type="@ButtonType.Primary" Size="@ButtonSize.Small"
                                    OnClick="() => RealizeLabor(currentLabor)"
                                    Loading="@(_realizingLaborId == currentLabor.Id)"
                                    Style="background: #2ECC71; border-color: #2ECC71; border-radius: 8px; font-weight: 600; min-height: 40px; min-width: 100px;">
                                <Icon Type="check-circle" Theme="IconThemeType.Outline" /> Realizar
                            </Button>
                        }
                        else
                        {
                            <Tag Style="background: #2ECC7120; color: #2ECC71; border: 1px solid #2ECC7140; border-radius: 12px; font-size: 12px; padding: 4px 12px;">
                                <Icon Type="check-circle" Theme="IconThemeType.Outline" /> Realizada
                            </Tag>
                        }
                    </div>

                    @if (currentLabor.Supplies != null && currentLabor.Supplies.Any())
                    {
                        <div class="supplies-section">
                            <h4 style="color: rgba(255,255,255,0.8); font-size: 13px; margin: 0 0 8px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">
                                <Icon Type="experiment" Theme="IconThemeType.Outline" Style="margin-right: 4px;" /> Insumos y Dosis
                            </h4>
                            @foreach (var supply in currentLabor.Supplies.OrderBy(s => s.TankMixOrder))
                            {
                                var currentSupply = supply;
                                var laborId = currentLabor.Id;
                                var supplyId = currentSupply.Id;
                                <div class="supply-row">
                                    <div class="supply-info">
                                        <div style="display: flex; align-items: center; gap: 8px;">
                                            @if (currentSupply.TankMixOrder > 0)
                                            {
                                                <span class="tank-mix-badge">@currentSupply.TankMixOrder</span>
                                            }
                                            <span style="color: #fff; font-weight: 500; font-size: 14px;">@(currentSupply.SupplyName ?? "Insumo")</span>
                                        </div>
                                        <div style="color: rgba(255,255,255,0.5); font-size: 12px; margin-top: 2px;">
                                            Planificado: @currentSupply.PlannedDose.ToString("N2") @currentSupply.UnitOfMeasure
                                        </div>
                                    </div>
                                    <div class="supply-input">
                                        <label style="color: rgba(255,255,255,0.6); font-size: 11px; display: block; margin-bottom: 2px;">Dosis Real</label>
                                        <AntDesign.InputNumber TValue="decimal"
                                                   Value="@GetRealDose(laborId, supplyId, currentSupply.PlannedDose)"
                                                   ValueChanged="@((decimal v) => SetRealDose(laborId, supplyId, v))"
                                                   Min="0" Step="0.01m"
                                                   Style="width: 120px;"
                                                   Disabled="@isRealized" />
                                        <span style="color: rgba(255,255,255,0.5); font-size: 11px; margin-left: 4px;">@currentSupply.UnitOfMeasure</span>
                                    </div>
                                </div>
                            }
                        </div>

                        @if (currentLabor.Supplies.Any(s => s.TankMixOrder > 0))
                        {
                            <div class="tank-mix-section">
                                <h4 style="color: rgba(255,255,255,0.8); font-size: 13px; margin: 0 0 8px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">
                                    <Icon Type="ordered-list" Theme="IconThemeType.Outline" Style="margin-right: 4px;" /> Orden de Carga
                                </h4>
                                <div class="tank-mix-sequence">
                                    @foreach (var supply in currentLabor.Supplies.Where(s => s.TankMixOrder > 0).OrderBy(s => s.TankMixOrder))
                                    {
                                        <div class="tank-mix-step">
                                            <div class="tank-mix-number">@supply.TankMixOrder</div>
                                            <span style="color: rgba(255,255,255,0.8); font-size: 13px;">@(supply.SupplyName ?? "Insumo")</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }

                    <div class="weather-section">
                        <h4 style="color: rgba(255,255,255,0.8); font-size: 13px; margin: 0 0 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">
                            <Icon Type="cloud" Theme="IconThemeType.Outline" Style="margin-right: 4px;" /> Registro Climático
                        </h4>
                        @{
                            var wl = GetWeatherLog(currentLabor.Id);
                        }
                        <div class="weather-grid">
                            <div class="weather-field">
                                <label>Temperatura (°C)</label>
                                <AntDesign.InputNumber TValue="double?" Value="@wl.Temperature"
                                           ValueChanged="@((double? v) => { wl.Temperature = v; })"
                                           Placeholder="°C" Style="width: 100%;"
                                           Disabled="@isRealized" />
                            </div>
                            <div class="weather-field">
                                <label>Humedad (%)</label>
                                <AntDesign.InputNumber TValue="double?" Value="@wl.Humidity"
                                           ValueChanged="@((double? v) => { wl.Humidity = v; })"
                                           Min="0" Max="100" Placeholder="%"
                                           Style="width: 100%;"
                                           Disabled="@isRealized" />
                            </div>
                             <div class="weather-field">
                                 <label>Viento (km/h)</label>
                                 <AntDesign.InputNumber TValue="double?" Value="@wl.WindSpeed"
                                            ValueChanged="@((double? v) => { wl.WindSpeed = v; })"
                                            Min="0" Placeholder="km/h"
                                            Style="width: 100%;"
                                            Disabled="@isRealized" />
                             </div>
                             <div class="weather-field">
                                 <label>Dir. Viento</label>
                                 <Select TItemValue="string" TItem="string" @bind-Value="wl.WindDirection"
                                         Placeholder="Dir." Style="width: 100%;" Disabled="@isRealized">
                                     <SelectOption TItemValue="string" TItem="string" Value="@("N")" Label="N" />
                                     <SelectOption TItemValue="string" TItem="string" Value="@("NE")" Label="NE" />
                                     <SelectOption TItemValue="string" TItem="string" Value="@("E")" Label="E" />
                                     <SelectOption TItemValue="string" TItem="string" Value="@("SE")" Label="SE" />
                                     <SelectOption TItemValue="string" TItem="string" Value="@("S")" Label="S" />
                                     <SelectOption TItemValue="string" TItem="string" Value="@("SO")" Label="SO" />
                                     <SelectOption TItemValue="string" TItem="string" Value="@("O")" Label="O" />
                                     <SelectOption TItemValue="string" TItem="string" Value="@("NO")" Label="NO" />
                                 </Select>
                             </div>
                         </div>
                        <div style="margin-top: 8px;">
                            <label style="color: rgba(255,255,255,0.6); font-size: 12px; display: block; margin-bottom: 4px;">Notas</label>
                            <TextArea @bind-Value="wl.Notes"
                                      Rows="2" Placeholder="Observaciones climáticas..."
                                      Style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff; border-radius: 8px;"
                                      Disabled="@isRealized" />
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="glass-card" style="text-align: center; padding: 40px; color: rgba(255,255,255,0.5);">
                <Icon Type="inbox" Theme="IconThemeType.Outline" Style="font-size: 40px; margin-bottom: 12px;" />
                <p>No hay labores asignadas a esta orden.</p>
            </div>
        }
    }
</div>

<style>
    .execution-container {
        max-width: 600px;
        margin: 0 auto;
        padding: 16px;
    }

    .wo-header {
        margin-bottom: 16px;
    }

    .labor-card {
        margin-bottom: 16px;
    }

    .labor-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 16px;
    }

    .supplies-section {
        border-top: 1px solid rgba(255,255,255,0.08);
        padding-top: 12px;
        margin-top: 12px;
    }

    .supply-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        gap: 12px;
        flex-wrap: wrap;
    }

    .supply-info {
        flex: 1;
        min-width: 150px;
    }

    .supply-input {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .tank-mix-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: #3498DB;
        color: #fff;
        font-size: 12px;
        font-weight: 700;
        flex-shrink: 0;
    }

    .tank-mix-section {
        border-top: 1px solid rgba(255,255,255,0.08);
        padding-top: 12px;
        margin-top: 12px;
    }

    .tank-mix-sequence {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .tank-mix-step {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 8px 12px;
        background: rgba(52, 152, 219, 0.08);
        border-radius: 8px;
        border-left: 3px solid #3498DB;
    }

    .tank-mix-number {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: #3498DB;
        color: #fff;
        font-size: 13px;
        font-weight: 700;
        flex-shrink: 0;
    }

    .weather-section {
        border-top: 1px solid rgba(255,255,255,0.08);
        padding-top: 12px;
        margin-top: 12px;
    }

    .weather-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
        gap: 12px;
    }

    .weather-field label {
        color: rgba(255,255,255,0.6);
        font-size: 12px;
        display: block;
        margin-bottom: 4px;
    }

    @@media (max-width: 480px) {
        .weather-grid {
            grid-template-columns: 1fr;
        }

        .supply-row {
            flex-direction: column;
            align-items: flex-start;
        }

        .supply-input {
            width: 100%;
        }

        .labor-header {
            flex-direction: column;
        }
    }
</style>

@code {
    [Parameter] public Guid WorkOrderId { get; set; }
    [Parameter] public string? Token { get; set; }

    private WorkOrderDetailDto? _order;
    private List<LaborDto> _labors = new();
    private bool _loading = true;
    private string? _errorMessage;
    private Guid? _realizingLaborId;
    private Dictionary<string, decimal> _realDoses = new();
    private Dictionary<Guid, decimal> _realHectares = new();
    private Dictionary<Guid, WeatherLogModel> _weatherLogs = new();

    private bool IsPublic => !string.IsNullOrEmpty(Token);

    public class WeatherLogModel
    {
        public double? Temperature { get; set; }
        public double? Humidity { get; set; }
        public double? WindSpeed { get; set; }
        public string? WindDirection { get; set; }
        public string? Notes { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private void GoBack()
    {
        Nav.NavigateTo("/workorders");
    }

    private async Task LoadData()
    {
        try
        {
            _loading = true;
            _errorMessage = null;
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));

            if (IsPublic)
            {
                var response = await Http.GetAsync($"api/share/validate/{Token}", cts.Token);
                if (response.IsSuccessStatusCode)
                {
                    var publicOrder = await response.Content.ReadFromJsonAsync<PublicWorkOrderDto>(
                        AppJsonSerializerContext.Default.PublicWorkOrderDto, cts.Token);
                    
                    if (publicOrder != null)
                    {
                        // Map PublicWorkOrderDto to WorkOrderDetailDto for internal logic reuse
                        _order = new WorkOrderDetailDto
                        {
                            Id = publicOrder.Id,
                            Description = publicOrder.Description,
                            Status = publicOrder.Status,
                            AssignedTo = publicOrder.AssignedTo,
                            DueDate = publicOrder.DueDate,
                            FieldName = publicOrder.FieldName
                        };
                        
                        _labors = publicOrder.Labors?.Select(l => new LaborDto
                        {
                            Id = l.Id,
                            LaborTypeName = l.LaborType,
                            Status = l.Status,
                            Hectares = l.Hectares,
                            LotId = l.LotId,
                            LotName = l.LotName,
                            Supplies = l.Supplies?.Select(s => new LaborSupplyDto
                            {
                                Id = s.Id,
                                SupplyId = s.SupplyId,
                                SupplyName = s.SupplyName,
                                PlannedDose = s.PlannedDose,
                                RealDose = s.RealDose,
                                PlannedTotal = s.PlannedTotal,
                                RealTotal = s.RealTotal,
                                UnitOfMeasure = s.DoseUnit,
                                SupplyUnit = s.SupplyUnit
                            }).ToList() ?? new()
                        }).ToList() ?? new();
                    }
                }
                else
                {
                    var errorText = await response.Content.ReadAsStringAsync();
                    _errorMessage = errorText.Contains("expirado") ? "Este enlace ha expirado."
                        : errorText.Contains("revocado") ? "Este enlace ha sido revocado."
                        : "El enlace no es válido o ha expirado.";
                    return;
                }
            }
            else
            {
                _order = await Http.GetFromJsonAsync($"api/workorders/{WorkOrderId}",
                    AppJsonSerializerContext.Default.WorkOrderDetailDto, cts.Token);
                _labors = _order?.Labors ?? new();
            }

            if (_labors != null)
            {
                foreach (var labor in _labors)
                {
                    if (!_realHectares.ContainsKey(labor.Id))
                    {
                        _realHectares[labor.Id] = labor.Hectares;
                    }

                    if (labor.Supplies != null)
                    {
                        foreach (var supply in labor.Supplies)
                        {
                            var key = $"{labor.Id}_{supply.Id}";
                            if (!_realDoses.ContainsKey(key))
                            {
                                _realDoses[key] = supply.RealDose ?? supply.PlannedDose;
                            }
                        }
                    }

                    if (!_weatherLogs.ContainsKey(labor.Id) && !string.IsNullOrEmpty(labor.WeatherLogJson))
                    {
                        try
                        {
                            var wl = JsonSerializer.Deserialize<WeatherLogModel>(labor.WeatherLogJson);
                            if (wl != null) _weatherLogs[labor.Id] = wl;
                        }
                        catch { }
                    }
                }
            }
        }
        catch (OperationCanceledException)
        {
            _errorMessage = "La solicitud tardó demasiado tiempo. Intente recargar la página.";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error de conexión: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private decimal GetRealDose(Guid laborId, Guid supplyId, decimal planned)
    {
        var key = $"{laborId}_{supplyId}";
        return _realDoses.TryGetValue(key, out var val) ? val : planned;
    }

    private void SetRealDose(Guid laborId, Guid supplyId, decimal value)
    {
        var key = $"{laborId}_{supplyId}";
        _realDoses[key] = value;
    }

    private WeatherLogModel GetWeatherLog(Guid laborId)
    {
        if (!_weatherLogs.ContainsKey(laborId))
        {
            _weatherLogs[laborId] = new WeatherLogModel();
        }
        return _weatherLogs[laborId];
    }

    private string GetStatusTagStyle(string status) => status switch
    {
        "Planned" => "background: #1890FF20; color: #1890FF; border: 1px solid #1890FF40; border-radius: 12px; font-size: 11px; padding: 2px 10px;",
        "AwaitingValidation" => "background: #FAAD1420; color: #FAAD14; border: 1px solid #FAAD1440; border-radius: 12px; font-size: 11px; padding: 2px 10px;",
        "Validated" => "background: #FA8C1620; color: #FA8C16; border: 1px solid #FA8C1640; border-radius: 12px; font-size: 11px; padding: 2px 10px;",
        "Realized" or "Done" => "background: #52C41A20; color: #52C41A; border: 1px solid #52C41A40; border-radius: 12px; font-size: 11px; padding: 2px 10px;",
        _ => "background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.7); border: 1px solid rgba(255,255,255,0.2); border-radius: 12px; font-size: 11px; padding: 2px 10px;"
    };

    private async Task RealizeLabor(LaborDto labor)
    {
        _realizingLaborId = labor.Id;
        try
        {
            var realHa = _realHectares.TryGetValue(labor.Id, out var h) ? h : labor.Hectares;
            
            var realSupplies = labor.Supplies?.Select(s =>
            {
                var realDose = GetRealDose(labor.Id, s.Id, s.PlannedDose);
                return new LaborSupplyDto
                {
                    Id = s.Id,
                    LaborId = labor.Id,
                    SupplyId = s.SupplyId,
                    PlannedDose = s.PlannedDose,
                    RealDose = realDose,
                    PlannedTotal = s.PlannedDose * labor.Hectares,
                    RealTotal = realDose * realHa,
                    PlannedHectares = labor.Hectares,
                    RealHectares = realHa,
                    UnitOfMeasure = s.UnitOfMeasure,
                    SupplyName = s.SupplyName,
                    SupplyUnit = s.SupplyUnit,
                    TankMixOrder = s.TankMixOrder,
                    IsSubstitute = s.IsSubstitute
                };
            }).ToList() ?? new();

            // 1. Update Weather/Hectares first via standard PUT if not public (or we might need a public endpoint for this)
            // For simplicity and following requirements, we'll send everything to the realize endpoint if possible
            // but the current realize endpoint only takes supplies.
            
            var weatherLog = _weatherLogs.TryGetValue(labor.Id, out var wl) ? wl : null;
            var weatherJson = weatherLog != null ? JsonSerializer.Serialize(weatherLog) : labor.WeatherLogJson;

            HttpResponseMessage response;
            if (IsPublic)
            {
                // Public endpoint (doesn't handle weather yet, but we'll use what's available)
                var publicSupplies = realSupplies.Select(s => new PublicLaborSupplyDto(
                    s.Id, s.SupplyId, s.SupplyName ?? "", s.PlannedDose, s.RealDose ?? s.PlannedDose,
                    s.PlannedTotal, s.RealTotal ?? s.PlannedTotal, s.SupplyUnit ?? "u", s.SupplyUnit
                )).ToList();

                response = await Http.PostAsJsonAsync(
                    $"api/share/realize/{Token}/labor/{labor.Id}",
                    publicSupplies,
                    AppJsonSerializerContext.Default.ListPublicLaborSupplyDto);
            }
            else
            {
                // Update hectares and weather first
                var updatedLabor = labor with { 
                    WeatherLogJson = weatherJson,
                    Hectares = realHa
                };
                
                await Http.PutAsJsonAsync($"api/labors/{labor.Id}",
                    updatedLabor, AppJsonSerializerContext.Default.LaborDto);

                response = await Http.PostAsJsonAsync(
                    $"api/labors/{labor.Id}/realize",
                    realSupplies,
                    AppJsonSerializerContext.Default.ListLaborSupplyDto);
            }

            if (response.IsSuccessStatusCode)
            {
                Message.Success("Labor confirmada como realizada.");
                await LoadData();
            }
            else
            {
                var err = await response.Content.ReadAsStringAsync();
                Message.Error($"Error: {err}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
        finally
        {
            _realizingLaborId = null;
        }
    }
}
