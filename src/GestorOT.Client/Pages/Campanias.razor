@page "/campaigns"
@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using System.Net.Http.Json
@using AntDesign
@inject HttpClient Http
@inject IMessageService Message
@inject NavigationManager Nav

<PageTitle>Campañas - GestorOT</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title">Gestión de Campañas</h2>
        <span class="page-subtitle">@_campaigns.Count campañas registradas</span>
    </div>
    <Button Type="@ButtonType.Primary" OnClick="OpenCreateModal"
            Style="background: #E74C3C; border-color: #E74C3C; border-radius: 8px; font-weight: 600;">
        <Icon Type="plus" Theme="IconThemeType.Outline" /> Nueva Campaña
    </Button>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <Alert Type="@AlertType.Error" Message="@_errorMessage" ShowIcon="true" Closable="true" Style="margin-bottom: 16px;" />
}

<div class="glass-card">
    <Table TItem="CampaignDto"
           DataSource="@_campaigns"
           Loading="@_loading"
           Size="TableSize.Small"
           ScrollX="1100">
        <PropertyColumn Property="c => c.Name" Title="Nombre" Sortable>
            <span style="font-weight: 600;">@context.Name</span>
        </PropertyColumn>
        <PropertyColumn Property="c => c.StartDate" Title="Inicio" Sortable>
            @context.StartDate.ToString("dd/MM/yyyy")
        </PropertyColumn>
        <PropertyColumn Property="c => c.EndDate" Title="Fin">
            @context.EndDate.ToString("dd/MM/yyyy")
        </PropertyColumn>
        <Column TData="string" Title="Estado">
            @{
                var (color, label) = context.Status switch
                {
                    CampaignStatus.Active => ("#2ECC71", "Activa"),
                    CampaignStatus.Locked => ("#95A5A6", "Bloqueada"),
                    _ => ("#F1C40F", "Desconocido")
                };
            }
            <Tag Style="@($"background: {color}20; color: {color}; border: 1px solid {color}40; border-radius: 12px; font-size: 11px; padding: 2px 10px;")">
                @label
            </Tag>
        </Column>
        <PropertyColumn Property="c => c.BudgetTotalUSD" Title="Presupuesto USD">
            <span style="font-weight: 600;">$ @context.BudgetTotalUSD.ToString("N2")</span>
        </PropertyColumn>
        <Column TData="bool" Title="Activa">
            @if (context.IsActive)
            {
                <Tag Style="background: #2ECC7120; color: #2ECC71; border: 1px solid #2ECC7140; border-radius: 12px; font-size: 11px; padding: 2px 10px;">Sí</Tag>
            }
            else
            {
                <Tag Style="background: #E74C3C20; color: #E74C3C; border: 1px solid #E74C3C40; border-radius: 12px; font-size: 11px; padding: 2px 10px;">No</Tag>
            }
        </Column>
        <Column TData="int" Title="Campos">
            <Tag Style="background: #9B59B620; color: #9B59B6; border: 1px solid #9B59B640; border-radius: 12px; font-size: 11px; padding: 2px 10px;">
                @(context.Fields?.Count ?? 0) campos
            </Tag>
        </Column>
        <ActionColumn Title="Acciones" Width="240">
            <Space>
                @if (context.Status == CampaignStatus.Active)
                {
                    <SpaceItem>
                        <Popconfirm Title="¿Bloquear esta campaña? No se podrán hacer más cambios."
                                    OnConfirm="() => ChangeStatus(context, CampaignStatus.Locked)"
                                    OkText="Bloquear" CancelText="Cancelar">
                            <Tooltip Title="@("Bloquear campaña")">
                                <Button Size="@ButtonSize.Small"
                                        Style="border-radius: 6px; background: #95A5A615; border-color: #95A5A640; color: #95A5A6;">
                                    <Icon Type="lock" Theme="IconThemeType.Outline" />
                                </Button>
                            </Tooltip>
                        </Popconfirm>
                    </SpaceItem>
                }
                else if (context.Status == CampaignStatus.Locked)
                {
                    <SpaceItem>
                        <Popconfirm Title="¿Desbloquear esta campaña?"
                                    OnConfirm="() => UnlockCampaign(context.Id)"
                                    OkText="Desbloquear" CancelText="Cancelar">
                            <Tooltip Title="@("Desbloquear campaña")">
                                <Button Size="@ButtonSize.Small"
                                        Style="border-radius: 6px; border-color: #2ECC7140; color: #2ECC71;">
                                    <Icon Type="unlock" Theme="IconThemeType.Outline" />
                                </Button>
                            </Tooltip>
                        </Popconfirm>
                    </SpaceItem>
                }
                <SpaceItem>
                    <Tooltip Title="@("Gestionar lotes")">
                        <Button Size="@ButtonSize.Small" OnClick='() => Nav.NavigateTo($"/campaigns/{context.Id}/lots")'
                                Style="border-radius: 6px; border-color: #2ECC7140; color: #2ECC71;">
                            <Icon Type="block" Theme="IconThemeType.Outline" />
                        </Button>
                    </Tooltip>
                </SpaceItem>
                <SpaceItem>
                    <Tooltip Title="@("Gestionar campos")">
                        <Button Size="@ButtonSize.Small" OnClick="() => OpenFieldsModal(context)"
                                Style="border-radius: 6px; border-color: #9B59B640; color: #9B59B6;">
                            <Icon Type="cluster" Theme="IconThemeType.Outline" />
                        </Button>
                    </Tooltip>
                </SpaceItem>
                @if (context.Status != CampaignStatus.Locked)
                {
                    <SpaceItem>
                        <Button Size="@ButtonSize.Small" OnClick="() => OpenEditModal(context)"
                                Style="border-radius: 6px; border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.7);">
                            <Icon Type="edit" Theme="IconThemeType.Outline" />
                        </Button>
                    </SpaceItem>
                    <SpaceItem>
                        <Popconfirm Title="¿Eliminar esta campaña?"
                                    OnConfirm="() => DeleteCampaign(context.Id)"
                                    OkText="Eliminar" CancelText="Cancelar">
                            <Button Danger Size="@ButtonSize.Small" Style="border-radius: 6px;">
                                <Icon Type="delete" Theme="IconThemeType.Outline" />
                            </Button>
                        </Popconfirm>
                    </SpaceItem>
                }
            </Space>
        </ActionColumn>
    </Table>
</div>

<!-- Create/Edit Campaign Modal -->
<Modal Title="@(_isEditing ? "Editar Campaña" : "Nueva Campaña")"
       Visible="_modalVisible"
       OnCancel="CloseModal"
       OnOk="SaveCampaign"
       OkText="@(_isEditing ? "Guardar" : "Crear")"
       ConfirmLoading="_saving"
       Width="560">
    <Form @ref="_form" Model="_formModel" Layout="@FormLayout.Vertical">
        @if (!_isEditing)
        {
            <FormItem Label="Seleccionar Temporada">
                <Select TItem="SeasonInfo" TItemValue="string" DataSource="_availableSeasons"
                        LabelName="@nameof(SeasonInfo.Name)" ValueName="@nameof(SeasonInfo.Name)"
                        OnSelectedItemChanged="OnSeasonSelected"
                        Placeholder="Seleccionar temporada predefinida..."
                        Disabled="@(_availableSeasons == null || !_availableSeasons.Any(s => !s.AlreadyExists))">
                </Select>
            </FormItem>
        }
        
        <FormItem Label="Nombre de la Campaña">
            <Input @bind-Value="_formModel.Name" Placeholder="Ej: Campaña 2025/2026" />
        </FormItem>
        
        <AntDesign.Row Gutter="16">
            <AntDesign.Col Span="12">
                <FormItem Label="Estado">
                    <Select TItemValue="CampaignStatus" TItem="string" @bind-Value="_formModel.Status" Style="width: 100%;"
                            Disabled="@(_isEditing && _editingStatus == CampaignStatus.Locked)">
                        <SelectOption TItemValue="CampaignStatus" TItem="string" Value="CampaignStatus.Active" Label="Activa" />
                        <SelectOption TItemValue="CampaignStatus" TItem="string" Value="CampaignStatus.Locked" Label="Bloqueada" />
                    </Select>
                </FormItem>
            </AntDesign.Col>
            <AntDesign.Col Span="12">
                <FormItem Label="Presupuesto Total (USD)">
                    <AntDesign.InputNumber TValue="decimal" @bind-Value="_formModel.BudgetTotalUSD" Min="0m" Step="100m"
                                           Style="width: 100%;" Placeholder="0.00" />
                </FormItem>
            </AntDesign.Col>
        </AntDesign.Row>
        <FormItem Label="Campaña Activa">
            <Switch @bind-Checked="_formModel.IsActive" />
            <span style="margin-left: 8px; color: rgba(255,255,255,0.5); font-size: 12px;">
                @(_formModel.IsActive ? "Visible en el selector de campañas" : "Oculta del selector")
            </span>
        </FormItem>
    </Form>
</Modal>

<!-- Campaign Fields Management Modal -->
<Modal Title="@($"Campos de: {_fieldsModalCampaign?.Name}")"
       Visible="_fieldsModalVisible"
       OnCancel="CloseFieldsModal"
       Footer="null"
       Width="720">
    <div style="margin-bottom: 16px;">
        <h4 style="color: rgba(255,255,255,0.7); margin: 0 0 12px;">Campos asociados</h4>

        @if (_fieldsModalCampaign?.Fields != null && _fieldsModalCampaign.Fields.Count > 0)
        {
                    <Table TItem="CampaignFieldDto"
                           DataSource="@_fieldsModalCampaign.Fields"
                           Size="TableSize.Small"
                           HidePagination>
                        <PropertyColumn Property="cf => cf.FieldName" Title="Campo">
                            <span style="font-weight: 600;">@(context.FieldName ?? "—")</span>
                        </PropertyColumn>
                        <PropertyColumn Property="cf => cf.AllocatedHectares" Title="Ha. Totales">
                            @context.AllocatedHectares.ToString("N2") ha
                        </PropertyColumn>
                        <PropertyColumn Property="cf => cf.TargetYieldTonHa" Title="Rendimiento Obj.">
                            @context.TargetYieldTonHa.ToString("N2") tn/ha
                        </PropertyColumn>
                <ActionColumn Title="" Width="120">
                    @if (_fieldsModalCampaign.Status != CampaignStatus.Locked)
                    {
                        <Space>
                            <SpaceItem>
                                @{
                                    var fieldInfo = _allFields.FirstOrDefault(f => f.Id == context.FieldId);
                                    var lotCount = fieldInfo?.Lots?.Count ?? 0;
                                    var confirmTitle = $"¿Asignar la campaña '{_fieldsModalCampaign.Name}' a todos los lotes del campo '{context.FieldName ?? "?"}'? Esta acción afectará {lotCount} lote(s).";
                                }
                                <Popconfirm Title="@confirmTitle"
                                            OnConfirm="() => BatchAssignLots(context.CampaignId, context.FieldId)"
                                            OkText="Asignar" CancelText="Cancelar"
                                            Disabled="@(lotCount == 0)">
                                    <Tooltip Title="@("Asignar todos los lotes del campo")">
                                        <Button Size="@ButtonSize.Small"
                                                Style="border-radius: 6px; border-color: #2ECC7140; color: #2ECC71;"
                                                Loading="@(_batchAssigningFieldId == context.FieldId)"
                                                Disabled="@(lotCount == 0)">
                                            <Icon Type="thunderbolt" Theme="IconThemeType.Outline" />
                                        </Button>
                                    </Tooltip>
                                </Popconfirm>
                            </SpaceItem>
                            <SpaceItem>
                                <Popconfirm Title="¿Quitar este campo de la campaña?"
                                            OnConfirm="() => RemoveField(context.CampaignId, context.FieldId)"
                                            OkText="Quitar" CancelText="Cancelar">
                                    <Button Danger Size="@ButtonSize.Small" Style="border-radius: 6px;">
                                        <Icon Type="close" Theme="IconThemeType.Outline" />
                                    </Button>
                                </Popconfirm>
                            </SpaceItem>
                        </Space>
                    }
                </ActionColumn>
            </Table>
        }
        else
        {
            <div style="text-align: center; padding: 24px; color: rgba(255,255,255,0.35);">
                <Icon Type="inbox" Theme="IconThemeType.Outline" Style="font-size: 32px; display: block; margin-bottom: 8px;" />
                No hay campos asociados a esta campaña
            </div>
        }
    </div>

    @if (_fieldsModalCampaign?.Status != CampaignStatus.Locked)
    {
        <div style="border-top: 1px solid rgba(255,255,255,0.08); padding-top: 16px;">
            <h4 style="color: rgba(255,255,255,0.7); margin: 0 0 12px;">Agregar Campo</h4>
            <AntDesign.Row Gutter="12">
                <AntDesign.Col Span="12">
                    <Select @bind-Value="_addFieldId" Placeholder="Seleccionar campo" Style="width: 100%;"
                            TItemValue="Guid" TItem="string"
                            AllowClear>
                        @foreach (var f in _availableFields)
                        {
                            <SelectOption TItemValue="Guid" TItem="string" Value="f.Id" Label="@f.Name" />
                        }
                    </Select>
                </AntDesign.Col>
                <AntDesign.Col Span="8">
                    <AntDesign.InputNumber TValue="decimal" @bind-Value="_addTargetYield" Min="0m" Step="0.1m" Placeholder="tn/ha objetivo" Style="width: 100%;" />
                </AntDesign.Col>
                <AntDesign.Col Span="4">
                    <Button Type="@ButtonType.Primary" OnClick="AddFieldToCampaign" Loading="_addingField"
                            Style="background: #E74C3C; border-color: #E74C3C; border-radius: 8px; width: 100%;">
                        <Icon Type="plus" Theme="IconThemeType.Outline" />
                    </Button>
                </AntDesign.Col>
            </AntDesign.Row>
        </div>
    }
    else
    {
        <Alert Type="@AlertType.Warning" Message="Esta campaña está bloqueada. No se pueden modificar los campos." ShowIcon="true" Style="margin-top: 12px;" />
    }
</Modal>

@code {
    private List<CampaignDto> _campaigns = new();
    private List<FieldDto> _allFields = new();
    private bool _loading = true;
    private string? _errorMessage;

    private bool _modalVisible;
    private bool _isEditing;
    private bool _saving;
    private Guid _editingId;
    private CampaignStatus _editingStatus;
    private CampaignFormModel _formModel = new();
    private Form<CampaignFormModel>? _form;

    private bool _fieldsModalVisible;
    private CampaignDto? _fieldsModalCampaign;
    private List<FieldDto> _availableFields = new();
    private List<SeasonInfo> _availableSeasons = new();
    private Guid _addFieldId;
    private decimal _addAllocatedHa;
    private decimal _addTargetYield;
    private bool _addingField;
    private Guid _batchAssigningFieldId;

    public class CampaignFormModel
    {
        public string Name { get; set; } = string.Empty;
        public DateTime? StartDate { get; set; }
        public DateTime? EndDate { get; set; }
        public CampaignStatus Status { get; set; } = CampaignStatus.Active;
        public decimal BudgetTotalUSD { get; set; }
        public bool IsActive { get; set; } = true;
    }

    public record SeasonInfo(string Name, DateOnly StartDate, DateOnly EndDate, bool AlreadyExists);

    private void OnSeasonSelected(SeasonInfo season)
    {
        if (season != null)
        {
            _formModel.Name = $"Campaña {season.Name}";
            _formModel.StartDate = season.StartDate.ToDateTime(TimeOnly.MinValue);
            _formModel.EndDate = season.EndDate.ToDateTime(TimeOnly.MinValue);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            _loading = true;
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));
            var campaignsTask = Http.GetFromJsonAsync("api/campaigns",
                AppJsonSerializerContext.Default.ListCampaignDto, cts.Token);
            var fieldsTask = Http.GetFromJsonAsync("api/fields",
                AppJsonSerializerContext.Default.ListFieldDto, cts.Token);

            await Task.WhenAll(campaignsTask, fieldsTask);

            _campaigns = campaignsTask.Result ?? new();
            _allFields = fieldsTask.Result ?? new();
            _errorMessage = null;
        }
        catch (OperationCanceledException)
        {
            _errorMessage = "La solicitud tardó demasiado tiempo. Intente recargar la página.";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error de conexión: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task OpenCreateModal()
    {
        _isEditing = false;
        _formModel = new CampaignFormModel();
        
        try 
        {
            var seasons = await Http.GetFromJsonAsync<List<SeasonInfo>>("api/campaigns/available-seasons");
            _availableSeasons = seasons?.Where(s => !s.AlreadyExists).ToList() ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading seasons: {ex.Message}");
            _availableSeasons = new();
        }

        _modalVisible = true;
    }

    private void OpenEditModal(CampaignDto campaign)
    {
        _isEditing = true;
        _editingId = campaign.Id;
        _editingStatus = campaign.Status;
        _formModel = new CampaignFormModel
        {
            Name = campaign.Name,
            StartDate = campaign.StartDate.ToDateTime(TimeOnly.MinValue),
            EndDate = campaign.EndDate.ToDateTime(TimeOnly.MinValue),
            Status = campaign.Status,
            BudgetTotalUSD = campaign.BudgetTotalUSD,
            IsActive = campaign.IsActive
        };
        _modalVisible = true;
    }

    private void CloseModal()
    {
        _modalVisible = false;
    }

    private async Task SaveCampaign()
    {
        if (string.IsNullOrWhiteSpace(_formModel.Name))
        {
            Message.Warning("El nombre de la campaña es obligatorio.");
            return;
        }
        if (_formModel.StartDate == null)
        {
            Message.Warning("La fecha de inicio es obligatoria.");
            return;
        }
        if (_formModel.EndDate == null)
        {
            Message.Warning("La fecha de fin es obligatoria.");
            return;
        }

        _saving = true;
        try
        {
            var startDate = DateOnly.FromDateTime(_formModel.StartDate.Value);
            var endDate = DateOnly.FromDateTime(_formModel.EndDate.Value);

            var dto = new CampaignDto(
                _isEditing ? _editingId : Guid.Empty,
                _formModel.Name,
                startDate,
                endDate,
                _formModel.IsActive,
                _formModel.Status,
                _formModel.BudgetTotalUSD,
                null,
                DateTime.UtcNow,
                null
            );

            HttpResponseMessage response;
            if (_isEditing)
            {
                response = await Http.PutAsJsonAsync($"api/campaigns/{_editingId}",
                    dto, AppJsonSerializerContext.Default.CampaignDto);
            }
            else
            {
                response = await Http.PostAsJsonAsync("api/campaigns",
                    dto, AppJsonSerializerContext.Default.CampaignDto);
            }

            if (response.IsSuccessStatusCode)
            {
                Message.Success(_isEditing ? "Campaña actualizada correctamente." : "Campaña creada correctamente.");
                _modalVisible = false;
                await LoadData();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Message.Error($"Error al guardar: {body}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ChangeStatus(CampaignDto campaign, CampaignStatus newStatus)
    {
        try
        {
            var response = await Http.PutAsJsonAsync($"api/campaigns/{campaign.Id}/status",
                newStatus, AppJsonSerializerContext.Default.CampaignStatus);

            if (response.IsSuccessStatusCode)
            {
                var statusLabel = newStatus switch
                {
                    CampaignStatus.Active => "activada",
                    CampaignStatus.Locked => "bloqueada",
                    _ => "actualizada"
                };
                Message.Success($"Campaña {statusLabel} correctamente.");
                await LoadData();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Message.Error($"Error: {body}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
    }

    private async Task DeleteCampaign(Guid id)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/campaigns/{id}");
            if (response.IsSuccessStatusCode)
            {
                Message.Success("Campaña eliminada correctamente.");
                await LoadData();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Message.Error($"Error al eliminar: {body}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
    }

    private async Task OpenFieldsModal(CampaignDto campaign)
    {
        _fieldsModalCampaign = campaign;
        _addFieldId = Guid.Empty;
        _addAllocatedHa = 0;
        _addTargetYield = 0;
        RefreshAvailableFields();
        _fieldsModalVisible = true;
    }

    private void CloseFieldsModal()
    {
        _fieldsModalVisible = false;
        _fieldsModalCampaign = null;
    }

    private void RefreshAvailableFields()
    {
        var usedIds = _fieldsModalCampaign?.Fields?.Select(f => f.FieldId).ToHashSet() ?? new();
        _availableFields = _allFields.Where(f => !usedIds.Contains(f.Id)).ToList();
    }

    private async Task AddFieldToCampaign()
    {
        if (_fieldsModalCampaign == null || _addFieldId == Guid.Empty)
        {
            Message.Warning("Seleccioná un campo para agregar.");
            return;
        }

        _addingField = true;
        try
        {
            var dto = new CampaignFieldDto(
                _fieldsModalCampaign.Id,
                _addFieldId,
                null,
                _addTargetYield,
                _addAllocatedHa
            );

            var response = await Http.PostAsJsonAsync(
                $"api/campaigns/{_fieldsModalCampaign.Id}/fields",
                dto, AppJsonSerializerContext.Default.CampaignFieldDto);

            if (response.IsSuccessStatusCode)
            {
                Message.Success("Campo agregado a la campaña.");
                await LoadData();
                _fieldsModalCampaign = _campaigns.FirstOrDefault(c => c.Id == _fieldsModalCampaign.Id);
                RefreshAvailableFields();
                _addFieldId = Guid.Empty;
                _addAllocatedHa = 0;
                _addTargetYield = 0;
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Message.Error($"Error: {body}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
        finally
        {
            _addingField = false;
        }
    }

    private async Task BatchAssignLots(Guid campaignId, Guid fieldId)
    {
        _batchAssigningFieldId = fieldId;
        try
        {
            var req = new BatchAssignLotsRequest(fieldId);
            var response = await Http.PostAsJsonAsync(
                $"api/campaigns/{campaignId}/lots/batch",
                req, AppJsonSerializerContext.Default.BatchAssignLotsRequest);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<BatchAssignLotsResult>(
                    AppJsonSerializerContext.Default.BatchAssignLotsResult);
                Message.Success($"Se asignaron {result?.Assigned ?? 0} lote(s) correctamente. ({result?.Skipped ?? 0} ya estaban asignados)");
                await LoadData();
                _fieldsModalCampaign = _campaigns.FirstOrDefault(c => c.Id == campaignId);
                RefreshAvailableFields();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Message.Error($"Error: {body}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
        finally
        {
            _batchAssigningFieldId = Guid.Empty;
        }
    }

    private async Task RemoveField(Guid campaignId, Guid fieldId)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/campaigns/{campaignId}/fields/{fieldId}");
            if (response.IsSuccessStatusCode)
            {
                Message.Success("Campo removido de la campaña.");
                await LoadData();
                _fieldsModalCampaign = _campaigns.FirstOrDefault(c => c.Id == campaignId);
                RefreshAvailableFields();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Message.Error($"Error: {body}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
    }

    private async Task UnlockCampaign(Guid id)
    {
        try
        {
            var response = await Http.PostAsync($"api/campaigns/{id}/unlock", null);
            if (response.IsSuccessStatusCode)
            {
                Message.Success("Campaña desbloqueada.");
                await LoadData();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Message.Error($"Error: {body}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
    }
}
