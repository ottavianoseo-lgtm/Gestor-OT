@page "/fields"
@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using System.Net.Http.Json
@using AntDesign
@inject HttpClient Http
@inject IMessageService Message
@inject GestorOT.Client.Services.CampaignState CampaignState
@inject GestorOT.Client.Services.TenantState TenantState
@implements IDisposable

<PageTitle>Campos - GestorOT</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title">Gestión de Campos</h2>
        <span class="page-subtitle">@_fields.Count campos registrados</span>
    </div>
    <div style="display: flex; align-items: center; gap: 16px;">
        @if (CampaignState.IsSelected)
        {
            <div style="display: flex; align-items: center; gap: 8px; background: rgba(46, 204, 113, 0.1); padding: 6px 12px; border-radius: 8px; border: 1px solid rgba(46, 204, 113, 0.2);">
                <Icon Type="calendar" Theme="IconThemeType.Outline" Style="color: #2ECC71;" />
                <span style="color: #fff; font-size: 13px; font-weight: 600;">Campaña: @CampaignState.CurrentCampaign!.Name</span>
                <Checkbox @bind-Checked="_filterByCampaign" Style="margin-left: 8px; color: rgba(255,255,255,0.7); font-size: 12px;">Ver solo mis campos</Checkbox>
            </div>
        }
        <Button Type="@ButtonType.Primary" OnClick="OpenCreateModal"
                Style="background: #E74C3C; border-color: #E74C3C; border-radius: 8px; font-weight: 600;">
            <Icon Type="plus" Theme="IconThemeType.Outline" /> Nuevo Campo
        </Button>
    </div>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <Alert Type="@AlertType.Error" Message="@_errorMessage" ShowIcon="true" Closable="true" Style="margin-bottom: 16px;" />
}

<div class="glass-card">
    <Table TItem="FieldDto"
           DataSource="@FilteredFields"
           Loading="@_loading"
           Size="TableSize.Small"
           ScrollX="900">
        <PropertyColumn Property="c => c.Name" Title="Nombre del Campo" Sortable>
            <span style="font-weight: 600;">@context.Name</span>
        </PropertyColumn>
        <PropertyColumn Property="c => c.HectareasTotales" Title="Área Fiscal (ha)">
            @context.HectareasTotales.ToString("N2") ha
        </PropertyColumn>
        <Column TData="int" Title="Lotes">
            <Tag Style="background: #3498DB20; color: #3498DB; border: 1px solid #3498DB40; border-radius: 12px; font-size: 11px; padding: 2px 10px;">
                @context.Lots.Count lotes
            </Tag>
        </Column>
        <PropertyColumn Property="c => c.CreatedAt" Title="Creado" Sortable>
            @context.CreatedAt.ToString("dd/MM/yyyy")
        </PropertyColumn>
        <ActionColumn Title="Acciones" Width="160">
            <Space>
                <SpaceItem>
                    <Button Size="@ButtonSize.Small" OnClick="() => OpenEditModal(context)"
                            Style="border-radius: 6px; border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.7);">
                        <Icon Type="edit" Theme="IconThemeType.Outline" />
                    </Button>
                </SpaceItem>
                <SpaceItem>
                    <Popconfirm Title="¿Eliminar este campo? Se eliminarán todos sus lotes y OTs asociadas."
                                OnConfirm="() => DeleteField(context.Id)"
                                OkText="Eliminar" CancelText="Cancelar">
                        <Button Danger Size="@ButtonSize.Small" Style="border-radius: 6px;">
                            <Icon Type="delete" Theme="IconThemeType.Outline" />
                        </Button>
                    </Popconfirm>
                </SpaceItem>
            </Space>
        </ActionColumn>
    </Table>
</div>

<Modal Title="@(_isEditing ? "Editar Campo" : "Nuevo Campo")"
       Visible="_modalVisible"
       OnCancel="CloseModal"
       OnOk="SaveField"
       OkText="@(_isEditing ? "Guardar" : "Crear")"
       ConfirmLoading="_saving"
       Width="480">
    <Form @ref="_form" Model="_formModel" Layout="@FormLayout.Vertical">
        <FormItem Label="Nombre del Campo">
            <Input @bind-Value="_formModel.Name" Placeholder="Ej: Estancia Santa Rosa" />
        </FormItem>
        <FormItem Label="Área Fiscal (hectáreas)">
            <AntDesign.InputNumber @bind-Value="_formModel.HectareasTotales" Min="0" Step="0.01"
                       Style="width: 100%;" Placeholder="Ej: 150.00" />
        </FormItem>
    </Form>
</Modal>

@code {
    private List<FieldDto> _fields = new();
    private List<CampaignFieldDto> _campaignFields = new();
    private bool _loading = true;
    private bool _filterByCampaign = true;
    private string? _errorMessage;
    private bool _modalVisible;
    private bool _isEditing;
    private bool _saving;
    private Guid _editingId;
    private FieldFormModel _formModel = new();
    private Form<FieldFormModel>? _form;

    private IEnumerable<FieldDto> FilteredFields =>
        _filterByCampaign && CampaignState.IsSelected
            ? _fields.Where(f => _campaignFields.Any(cf => cf.FieldId == f.Id))
            : _fields;

    public class FieldFormModel
    {
        public string Name { get; set; } = string.Empty;
        public double HectareasTotales { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        CampaignState.OnChange += OnCampaignChanged;
        TenantState.OnChange += OnCampaignChanged;
        await LoadData();
    }

    private void OnCampaignChanged()
    {
        InvokeAsync(async () => { await LoadData(); StateHasChanged(); });
    }

    public void Dispose()
    {
        CampaignState.OnChange -= OnCampaignChanged;
        TenantState.OnChange -= OnCampaignChanged;
    }

    private async Task LoadData()
    {
        try
        {
            _loading = true;
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));
            _fields = await Http.GetFromJsonAsync("api/fields",
                AppJsonSerializerContext.Default.ListFieldDto, cts.Token) ?? new();

            if (CampaignState.IsSelected)
            {
                var campaign = await Http.GetFromJsonAsync<CampaignDto>($"api/campaigns/{CampaignState.CurrentCampaign!.Id}",
                    AppJsonSerializerContext.Default.CampaignDto, cts.Token);
                _campaignFields = campaign?.Fields ?? new();
            }
            else
            {
                _campaignFields.Clear();
            }

            _errorMessage = null;
        }
        catch (OperationCanceledException)
        {
            _errorMessage = "La solicitud tardó demasiado tiempo. Intente recargar la página.";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error de conexión: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void OpenCreateModal()
    {
        _isEditing = false;
        _formModel = new FieldFormModel();
        _modalVisible = true;
    }

    private void OpenEditModal(FieldDto field)
    {
        _isEditing = true;
        _editingId = field.Id;
        _formModel = new FieldFormModel { Name = field.Name, HectareasTotales = field.HectareasTotales };
        _modalVisible = true;
    }

    private void CloseModal()
    {
        _modalVisible = false;
    }

    private async Task SaveField()
    {
        if (string.IsNullOrWhiteSpace(_formModel.Name))
        {
            Message.Warning("El nombre del campo es obligatorio.");
            return;
        }

        _saving = true;
        try
        {
            var dto = new FieldDto(
                _isEditing ? _editingId : Guid.Empty,
                _formModel.Name,
                _formModel.HectareasTotales,
                DateTime.UtcNow,
                new List<LotSummaryDto>()
            );

            HttpResponseMessage response;
            if (_isEditing)
            {
                response = await Http.PutAsJsonAsync($"api/fields/{_editingId}",
                    dto, AppJsonSerializerContext.Default.FieldDto);
            }
            else
            {
                response = await Http.PostAsJsonAsync("api/fields",
                    dto, AppJsonSerializerContext.Default.FieldDto);
            }

            if (response.IsSuccessStatusCode)
            {
                if (!_isEditing && CampaignState.IsSelected)
                {
                    var createdField = await response.Content.ReadFromJsonAsync<FieldDto>(AppJsonSerializerContext.Default.FieldDto);
                    if (createdField != null)
                    {
                        await Http.PostAsJsonAsync($"api/campaigns/{CampaignState.CurrentCampaign!.Id}/fields",
                            new CampaignFieldDto(CampaignState.CurrentCampaign.Id, createdField.Id, createdField.Name, 0, 0),
                            AppJsonSerializerContext.Default.CampaignFieldDto);
                    }
                }

                Message.Success(_isEditing ? "Campo actualizado correctamente." : "Campo creado correctamente.");
                _modalVisible = false;
                await LoadData();
            }
            else
            {
                Message.Error($"Error al guardar: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteField(Guid id)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/fields/{id}");
            if (response.IsSuccessStatusCode)
            {
                Message.Success("Campo eliminado correctamente.");
                await LoadData();
            }
            else
            {
                Message.Error($"Error al eliminar: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
    }
}
