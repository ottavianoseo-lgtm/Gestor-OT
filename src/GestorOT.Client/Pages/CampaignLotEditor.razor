@page "/campaigns/{CampaignId:guid}/lots"
@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using System.Net.Http.Json
@using AntDesign
@using AntDesign.TableModels
@inject HttpClient Http
@inject IMessageService Message
@inject NavigationManager Nav
@inject GestorOT.Client.Services.CampaignState CampaignState

<PageTitle>Lotes de Campaña - GestorOT</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title">Gestión de Lotes de Campaña</h2>
        <span class="page-subtitle">@(_campaign?.Name ?? "Cargando...")</span>
    </div>
    <div style="display: flex; gap: 12px;">
        <Button OnClick='() => Nav.NavigateTo("/campaigns")' 
                Style="background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.1); color: #fff;">
            <Icon Type="arrow-left" /> Volver
        </Button>
        @if (_campaign?.Status != CampaignStatus.Locked)
        {
            <Button Type="@ButtonType.Primary" OnClick="() => _importModalVisible = true" Ghost>
                <Icon Type="import" /> Importar de otra Campaña
            </Button>
            <Button Type="@ButtonType.Primary" OnClick="() => _addModalVisible = true"
                    Style="background: #E74C3C; border-color: #E74C3C; border-radius: 8px;">
                <Icon Type="plus" /> Agregar Lote
            </Button>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <Alert Type="@AlertType.Error" Message="@_errorMessage" ShowIcon="true" Closable="true" Style="margin-bottom: 16px;" />
}

<div class="glass-card">
    @if (_loading)
    {
        <div style="text-align: center; padding: 40px;">
            <Spin Size="SpinSize.Large" Tip="Cargando lotes..." />
        </div>
    }
    else
    {
        <div class="summary-bar">
            <div class="summary-item">
                <span class="summary-label">Total ha</span>
                <span class="summary-value">@(_lots?.Sum(l => l.CadastralArea).ToString("N2") ?? "0") ha</span>
            </div>
            <div class="summary-item">
                <span class="summary-label">Total Productiva</span>
                <span class="summary-value" style="color: #2ECC71;">@(_lots?.Sum(l => l.ProductiveArea).ToString("N2") ?? "0") ha</span>
            </div>
            <div class="summary-item">
                <span class="summary-label">Diferencia</span>
                @{
                    var dTotal = (_lots?.Sum(l => l.CadastralArea) ?? 0) - (_lots?.Sum(l => l.ProductiveArea) ?? 0);
                }
                <span class="summary-value" style="color: @(dTotal > 0 ? "#F1C40F" : "#2ECC71");">
                    @(dTotal > 0 ? "-" : "")@dTotal.ToString("N2") ha
                </span>
            </div>
            <div class="summary-item">
                <span class="summary-label">Lotes</span>
                <span class="summary-value">@(_lots?.Count ?? 0)</span>
            </div>
        </div>

        <Table TItem="CampaignLotDto"
               DataSource="@_lots"
               Size="TableSize.Small"
               OnExpand="OnExpandLot"
               RowKey="x => x.Id">
            <ColumnDefinitions>
                <PropertyColumn Property="l => l.LotName" Title="Lote" Sortable />
                <PropertyColumn Property="l => l.FieldName" Title="Campo" Sortable />
                <PropertyColumn Property="l => l.CadastralArea" Title="Ha" Sortable />
                <Column TData="decimal" Title="Sup. Productiva">
                    @{ var lotData = context; }
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-weight: 600; color: #2ECC71;">@lotData.ProductiveArea.ToString("N2")</span>
                        @if (_campaign?.Status != CampaignStatus.Locked)
                        {
                            <Button Size="@ButtonSize.Small" OnClick="() => StartEdit(lotData)" Icon="edit" Type="@ButtonType.Link" />
                        }
                    </div>
                </Column>
                <ActionColumn Title="Acciones">
                    <Popconfirm Title="¿Remover?" OnConfirm="() => RemoveLot(context)">
                        <Button Danger Size="@ButtonSize.Small" Icon="delete" />
                    </Popconfirm>
                </ActionColumn>
            </ColumnDefinitions>
            <ExpandTemplate Context="row">
                <div style="padding: 16px; background: rgba(0,0,0,0.1); border-radius: 8px;">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 12px;">
                        <h4 style="color: #fff; margin: 0;">Rotaciones del Lote</h4>
                        <Button Size="@ButtonSize.Small" Type="@ButtonType.Primary" OnClick="() => OpenAddRotationModal(row.Data)">+ Agregar</Button>
                    </div>
                    <Table TItem="RotationDto" DataSource="@GetRotations(row.Data.Id)" Size="TableSize.Small" HidePagination>
                        <PropertyColumn Property="r => r.StartDate" Title="Inicio" />
                        <PropertyColumn Property="r => r.EndDate" Title="Fin" />
                        <PropertyColumn Property="r => r.ActivityName" Title="Cultivo" />
                        <ActionColumn>
                             @{ var rotData = context; }
                             <Button Size="@ButtonSize.Small" Icon="edit" OnClick="() => OpenEditRotationModal(row.Data, rotData)" />
                             <Button Danger Size="@ButtonSize.Small" Icon="delete" OnClick="() => DeleteRotation(rotData)" />
                        </ActionColumn>
                    </Table>
                </div>
            </ExpandTemplate>
        </Table>
    }
</div>

<Modal Title="Agregar Lote" Visible="_addModalVisible" OnCancel="() => _addModalVisible = false" OnOk="AddLotToCampaign">
    <div style="display: grid; gap: 12px;">
        <div>
            <label style="display: block; font-size: 12px; color: rgba(255,255,255,0.5); margin-bottom: 6px;">Filtrar por Campo (opcional)</label>
            <Select TItemValue="Guid" TItem="FieldDto"
                    DataSource="@_addFields"
                    Value="@_addFilterFieldId"
                    ValueChanged="@((Guid v) => OnAddFilterFieldChanged(v))"
                    LabelName="@nameof(FieldDto.Name)"
                    ValueName="@nameof(FieldDto.Id)"
                    Placeholder="— Todos los campos —"
                    AllowClear
                    Style="width: 100%;" />
        </div>
        <div>
            <label style="display: block; font-size: 12px; color: rgba(255,255,255,0.5); margin-bottom: 6px;">Lote</label>
            <Select @bind-Value="_addLotId" TItemValue="Guid" TItem="LotDto"
                    DataSource="@FilteredAvailableLots"
                    LabelName="@nameof(LotDto.Name)"
                    ValueName="@nameof(LotDto.Id)"
                    EnableSearch
                    Style="width: 100%;" />
        </div>
        <AntDesign.InputNumber TValue="decimal" @bind-Value="_addProductiveArea" Placeholder="Hectáreas productivas" Style="width:100%" />
    </div>
</Modal>

<Modal Title="Actualizar Superficie" Visible="_editModalVisible" OnCancel="() => _editModalVisible = false" OnOk="SaveProductiveArea">
    <AntDesign.InputNumber TValue="decimal" @bind-Value="_editProductiveArea" Style="width:100%" />
</Modal>

<Modal Title="Importar Lotes" Visible="_importModalVisible" OnCancel="() => _importModalVisible = false" OnOk="ExecuteImport">
    <div style="display: grid; gap: 12px;">
        <Select @bind-Value="_importFromCampaignId" TItemValue="Guid" TItem="CampaignDto" DataSource="@_otherCampaigns" LabelName="@nameof(CampaignDto.Name)" ValueName="@nameof(CampaignDto.Id)" />
        <RadioGroup @bind-Value="_useProductiveAreaFromPrevious">
            <Radio Value="false">Catastral</Radio>
            <Radio Value="true">Mantener</Radio>
        </RadioGroup>
    </div>
</Modal>

<Modal Title="@(_isEditingRotation ? "Editar Rotación" : "Nueva Rotación")"
       Visible="_rotationModalVisible"
       OnCancel="() => _rotationModalVisible = false"
       Footer="RotationModalFooter">
    <div style="display: grid; gap: 12px;">
        <DatePicker TValue="DateOnly" @bind-Value="_rotationModel.StartDate" />
        <DatePicker TValue="DateOnly" @bind-Value="_rotationModel.EndDate" />
        <Select @bind-Value="_rotationModel.ActivityId" TItemValue="Guid" TItem="ErpActivityDto" DataSource="_activities" LabelName="@nameof(ErpActivityDto.Name)" ValueName="@nameof(ErpActivityDto.Id)" EnableSearch />
        <TextArea @bind-Value="_rotationModel.Notes" Rows="2" />

        @if (RotationDatesInvalid)
        {
            <Alert Type="@AlertType.Error" Message="La fecha de inicio debe ser anterior a la fecha de fin" ShowIcon="true" />
        }
        else if (!string.IsNullOrEmpty(_rotationError))
        {
            <Alert Type="@AlertType.Error" Message="@_rotationError" ShowIcon="true" />
        }
    </div>
</Modal>

<style>
    .summary-bar {
        display: flex;
        gap: 32px;
        background: rgba(255,255,255,0.03);
        padding: 16px 24px;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.08);
        margin-bottom: 24px;
    }
    .summary-item { display: flex; flex-direction: column; }
    .summary-label { font-size: 11px; color: rgba(255,255,255,0.4); text-transform: uppercase; margin-bottom: 4px; }
    .summary-value { font-size: 18px; font-weight: 700; color: #fff; }
</style>

@code {
    [Parameter] public Guid CampaignId { get; set; }
    [Parameter][SupplyParameterFromQuery] public string? lotId { get; set; }

    private CampaignDto? _campaign;
    private List<CampaignLotDto> _lots = new();
    private List<LotDto> _availableLots = new();
    private List<CampaignDto> _otherCampaigns = new();
    private List<ErpActivityDto> _activities = new();
    private Dictionary<Guid, List<RotationDto>> _rotationsByLot = new Dictionary<Guid, List<RotationDto>>();
    private bool _loading = true;
    private string? _errorMessage;

    private bool _editModalVisible;
    private CampaignLotDto? _editingLot;
    private decimal _editProductiveArea;

    private bool _addModalVisible;
    private Guid _addLotId;
    private decimal _addProductiveArea;
    private Guid _addFilterFieldId;
    private List<FieldDto> _addFields = new();

    private bool _importModalVisible;
    private Guid _importFromCampaignId;
    private bool _useProductiveAreaFromPrevious;

    private bool _rotationModalVisible;
    private bool _isEditingRotation;
    private bool _savingRotation;
    private string? _rotationError;
    private RotationModel _rotationModel = new RotationModel();

    private class RotationModel { public Guid Id, CampaignLotId, ActivityId; public DateOnly StartDate, EndDate; public string? Notes; }

    private bool RotationDatesInvalid => _rotationModel.StartDate >= _rotationModel.EndDate;

    private IEnumerable<LotDto> FilteredAvailableLots =>
        _addFilterFieldId == Guid.Empty
            ? _availableLots
            : _availableLots.Where(l => l.FieldId == _addFilterFieldId);

    private void OnAddFilterFieldChanged(Guid fieldId)
    {
        _addFilterFieldId = fieldId;
        // Reset lot selection if it's no longer in the filtered list
        if (_addLotId != Guid.Empty && !FilteredAvailableLots.Any(l => l.Id == _addLotId))
        {
            _addLotId = Guid.Empty;
        }
    }
    private RenderFragment RotationModalFooter => @<div style="display: flex; justify-content: flex-end; gap: 8px;">
            <Button OnClick="() => _rotationModalVisible = false">Cancelar</Button>
            <Button Type="@ButtonType.Primary" OnClick="SaveRotation" Disabled="@RotationDatesInvalid" Loading="@_savingRotation">Guardar</Button>
        </div>;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        try {
            _loading = true;
            _campaign = await Http.GetFromJsonAsync<CampaignDto>($"api/campaigns/{CampaignId}");
            _lots = await Http.GetFromJsonAsync<List<CampaignLotDto>>($"api/campaigns/{CampaignId}/lots") ?? new();
            var all = await Http.GetFromJsonAsync<List<LotDto>>("api/lots") ?? new();
            _availableLots = all.Where(a => !_lots.Any(l => l.LotId == a.Id)).ToList();
            // Build field list for filter from available lots (distinct fields)
            _addFields = _availableLots
                .GroupBy(l => l.FieldId)
                .Select(g => new FieldDto(g.Key, g.First().FieldName ?? g.Key.ToString("N"), DateTime.MinValue, new()))
                .OrderBy(f => f.Name)
                .ToList();
            _otherCampaigns = (await Http.GetFromJsonAsync<List<CampaignDto>>("api/campaigns") ?? new()).Where(c => c.Id != CampaignId).ToList();
            _activities = await Http.GetFromJsonAsync<List<ErpActivityDto>>("api/catalogs/activities") ?? new();
        } catch (Exception ex) { _errorMessage = ex.Message; } finally { _loading = false; }
    }

    private async Task OnExpandLot(RowData<CampaignLotDto> args) { if (args.Expanded) await LoadRotations(args.Data.Id); }
    private async Task LoadRotations(Guid id) => _rotationsByLot[id] = await Http.GetFromJsonAsync<List<RotationDto>>($"api/campaigns/{CampaignId}/lots/{id}/rotations") ?? new();
    private List<RotationDto> GetRotations(Guid id) => _rotationsByLot.TryGetValue(id, out var r) ? r : new();

    private void StartEdit(CampaignLotDto lot) { _editingLot = lot; _editProductiveArea = lot.ProductiveArea; _editModalVisible = true; }
    private async Task SaveProductiveArea() {
        if (_editingLot == null) return;
        var resp = await Http.PutAsJsonAsync($"api/campaigns/{CampaignId}/lots/{_editingLot.LotId}", _editingLot with { ProductiveArea = _editProductiveArea });
        if (resp.IsSuccessStatusCode) { _editModalVisible = false; await LoadData(); }
    }

    private async Task AddLotToCampaign() {
        if (_addLotId == Guid.Empty) { Message.Warning("Seleccioná un lote."); return; }
        var fieldId = _availableLots.FirstOrDefault(l => l.Id == _addLotId)?.FieldId;
        var dto = new CampaignLotDto(Guid.Empty, CampaignId, _addLotId, fieldId, null, null, 0, _addProductiveArea, null);
        var resp = await Http.PostAsJsonAsync($"api/campaigns/{CampaignId}/lots", dto);
        if (resp.IsSuccessStatusCode)
        {
            _addModalVisible = false;
            _addLotId = Guid.Empty;
            _addFilterFieldId = Guid.Empty;
            _addProductiveArea = 0;
            await LoadData();
        }
        else
        {
            var err = await resp.Content.ReadAsStringAsync();
            Message.Error($"Error: {err}");
        }
    }

    private async Task RemoveLot(CampaignLotDto lot) { if ((await Http.DeleteAsync($"api/campaigns/{CampaignId}/lots/{lot.LotId}")).IsSuccessStatusCode) await LoadData(); }

    private void OpenAddRotationModal(CampaignLotDto lot) { _isEditingRotation = false; _rotationError = null; _rotationModel = new RotationModel { CampaignLotId = lot.Id, StartDate = _campaign?.StartDate ?? DateOnly.FromDateTime(DateTime.Today), EndDate = _campaign?.EndDate ?? DateOnly.FromDateTime(DateTime.Today.AddMonths(4)) }; _rotationModalVisible = true; }
    private void OpenEditRotationModal(CampaignLotDto lot, RotationDto r) { _isEditingRotation = true; _rotationError = null; _rotationModel = new RotationModel { Id = r.Id, CampaignLotId = r.CampaignLotId, ActivityId = r.ActivityId, StartDate = r.StartDate, EndDate = r.EndDate, Notes = r.Notes }; _rotationModalVisible = true; }
    private async Task SaveRotation() {
        _rotationError = null;
        if (RotationDatesInvalid)
        {
            _rotationError = "La fecha de inicio debe ser anterior a la fecha de fin";
            return;
        }

        _savingRotation = true;
        var dto = new RotationDto(_rotationModel.Id, _rotationModel.CampaignLotId, _rotationModel.ActivityId, null, _rotationModel.StartDate, _rotationModel.EndDate, _rotationModel.Notes);
        var resp = _isEditingRotation
            ? await Http.PutAsJsonAsync($"api/campaigns/{CampaignId}/lots/{_rotationModel.CampaignLotId}/rotations/{_rotationModel.Id}", dto)
            : await Http.PostAsJsonAsync($"api/campaigns/{CampaignId}/lots/{_rotationModel.CampaignLotId}/rotations", dto);

        if (resp.IsSuccessStatusCode)
        {
            _rotationModalVisible = false;
            await LoadRotations(_rotationModel.CampaignLotId);
        }
        else
        {
            _rotationError = await resp.Content.ReadAsStringAsync();
        }

        _savingRotation = false;
    }
    private async Task DeleteRotation(RotationDto r) { if ((await Http.DeleteAsync($"api/campaigns/{CampaignId}/lots/{r.CampaignLotId}/rotations/{r.Id}")).IsSuccessStatusCode) await LoadRotations(r.CampaignLotId); }

    private async Task ExecuteImport() {
        var req = new ImportLotsRequest(_importFromCampaignId, _useProductiveAreaFromPrevious);
        var resp = await Http.PostAsJsonAsync($"api/campaigns/{CampaignId}/lots/import", req);
        if (resp.IsSuccessStatusCode) { _importModalVisible = false; await LoadData(); }
    }
}
