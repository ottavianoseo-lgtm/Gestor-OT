@page "/campaigns/{CampaignId:guid}/lots"
@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using System.Net.Http.Json
@using AntDesign
@inject HttpClient Http
@inject IMessageService Message
@inject NavigationManager Nav

<PageTitle>Lotes de Campaña - GestorOT</PageTitle>

<div class="page-header">
    <div>
        <div style="display: flex; align-items: center; gap: 12px;">
            <Button Type="@ButtonType.Text" OnClick="GoBack"
                    Style="color: rgba(255,255,255,0.5); padding: 4px 8px; border-radius: 8px;">
                <Icon Type="arrow-left" Theme="IconThemeType.Outline" />
            </Button>
            <div>
                <h2 class="page-title">Lotes de Campaña</h2>
                <span class="page-subtitle">
                    @if (_campaign != null)
                    {
                        @_campaign.Name
                        <span> — @_lots.Count lotes asignados</span>
                    }
                </span>
            </div>
        </div>
    </div>
    <Space>
        @if (_campaign != null && _campaign.Status != CampaignStatus.Locked)
        {
            <SpaceItem>
                <Button OnClick="OpenImportModal"
                        Style="border-radius: 8px; border-color: #9B59B640; color: #9B59B6; font-weight: 600;">
                    <Icon Type="import" Theme="IconThemeType.Outline" /> Importar de otra Campaña
                </Button>
            </SpaceItem>
            <SpaceItem>
                <Button Type="@ButtonType.Primary" OnClick="OpenAddModal"
                        Style="background: #E74C3C; border-color: #E74C3C; border-radius: 8px; font-weight: 600;">
                    <Icon Type="plus" Theme="IconThemeType.Outline" /> Agregar Lote
                </Button>
            </SpaceItem>
        }
    </Space>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <Alert Type="@AlertType.Error" Message="@_errorMessage" ShowIcon="true" Closable="true" Style="margin-bottom: 16px;" />
}

@if (_campaign?.Status == CampaignStatus.Locked)
{
    <Alert Type="@AlertType.Warning" Message="Esta campaña está bloqueada. Los lotes no se pueden modificar." ShowIcon="true" Style="margin-bottom: 16px;" />
}

<div class="glass-card">
    @if (_loading)
    {
        <div style="text-align: center; padding: 40px;">
            <Spin Size="SpinSize.Large" Tip="Cargando lotes..." />
        </div>
    }
    else if (_lots.Count == 0)
    {
        <div style="text-align: center; padding: 48px; color: rgba(255,255,255,0.35);">
            <Icon Type="inbox" Theme="IconThemeType.Outline" Style="font-size: 48px; display: block; margin-bottom: 12px;" />
            <div style="font-size: 16px; margin-bottom: 8px;">No hay lotes asignados a esta campaña</div>
            <div style="font-size: 13px;">Usá "Agregar Lote" o "Importar de otra Campaña" para comenzar</div>
        </div>
    }
    else
    {
        <div class="summary-bar">
            <div class="summary-item">
                <span class="summary-label">Total Catastral</span>
                <span class="summary-value">@_lots.Sum(l => l.CadastralArea).ToString("N2") ha</span>
            </div>
            <div class="summary-item">
                <span class="summary-label">Total Productiva</span>
                <span class="summary-value" style="color: #2ECC71;">@_lots.Sum(l => l.ProductiveArea).ToString("N2") ha</span>
            </div>
            <div class="summary-item">
                <span class="summary-label">Diferencia</span>
                @{
                    var diff = _lots.Sum(l => l.CadastralArea) - _lots.Sum(l => l.ProductiveArea);
                }
                <span class="summary-value" style="color: @(diff > 0 ? "#F1C40F" : "#2ECC71");">
                    @(diff > 0 ? "-" : "")@diff.ToString("N2") ha
                </span>
            </div>
            <div class="summary-item">
                <span class="summary-label">Lotes</span>
                <span class="summary-value">@_lots.Count</span>
            </div>
        </div>

        <Table TItem="CampaignLotDto"
               DataSource="@_lots"
               Size="TableSize.Small"
               ScrollX="900">
            <PropertyColumn Property="l => l.LotName" Title="Lote" Sortable>
                <span style="font-weight: 600;">@context.LotName</span>
            </PropertyColumn>
            <PropertyColumn Property="l => l.FieldName" Title="Campo" Sortable>
                <span style="color: rgba(255,255,255,0.6);">@(context.FieldName ?? "—")</span>
            </PropertyColumn>
            <PropertyColumn Property="l => l.CadastralArea" Title="Sup. Catastral (ha)" Sortable>
                <span style="color: rgba(255,255,255,0.5);">@context.CadastralArea.ToString("N2")</span>
            </PropertyColumn>
            <Column TData="decimal" Title="Sup. Productiva (ha)">
                @if (_editingLotId == context.LotId && _campaign?.Status != CampaignStatus.Locked)
                {
                    <div style="display: flex; align-items: center; gap: 6px;">
                        <AntDesign.InputNumber TValue="decimal" @bind-Value="_editProductiveArea"
                                               Min="0m" Max="@context.CadastralArea"
                                               Step="0.5m"
                                               Style="width: 120px;" />
                        <Button Size="@ButtonSize.Small" OnClick="() => SaveProductiveArea(context)"
                                Loading="_savingArea"
                                Style="border-radius: 6px; background: #2ECC7115; border-color: #2ECC7140; color: #2ECC71;">
                            <Icon Type="check" Theme="IconThemeType.Outline" />
                        </Button>
                        <Button Size="@ButtonSize.Small" OnClick="CancelEdit"
                                Style="border-radius: 6px; border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.5);">
                            <Icon Type="close" Theme="IconThemeType.Outline" />
                        </Button>
                    </div>
                }
                else
                {
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-weight: 600; color: #2ECC71;">@context.ProductiveArea.ToString("N2")</span>
                        @if (context.CadastralArea > 0 && context.ProductiveArea < context.CadastralArea)
                        {
                            var delta = context.CadastralArea - context.ProductiveArea;
                            var pct = (delta / context.CadastralArea * 100);
                            <Tag Style="background: #F1C40F20; color: #F1C40F; border: 1px solid #F1C40F40; border-radius: 10px; font-size: 10px; padding: 0 6px;">
                                -@pct.ToString("N1")%
                            </Tag>
                        }
                        @if (_campaign?.Status != CampaignStatus.Locked)
                        {
                            <Button Size="@ButtonSize.Small" OnClick="() => StartEdit(context)"
                                    Style="border: none; background: transparent; color: rgba(255,255,255,0.3); padding: 2px 6px;">
                                <Icon Type="edit" Theme="IconThemeType.Outline" Style="font-size: 12px;" />
                            </Button>
                        }
                    </div>
                }
            </Column>
            <ActionColumn Title="" Width="60">
                @if (_campaign?.Status != CampaignStatus.Locked)
                {
                    <Popconfirm Title="¿Quitar este lote de la campaña?"
                                OnConfirm="() => RemoveLot(context)"
                                OkText="Quitar" CancelText="Cancelar">
                        <Button Danger Size="@ButtonSize.Small" Style="border-radius: 6px;">
                            <Icon Type="delete" Theme="IconThemeType.Outline" />
                        </Button>
                    </Popconfirm>
                }
            </ActionColumn>
        </Table>
    }
</div>

<Modal Title="Agregar Lote a la Campaña"
       Visible="_addModalVisible"
       OnCancel="CloseAddModal"
       OnOk="AddLotToCampaign"
       OkText="@("Agregar")"
       ConfirmLoading="_addingLot"
       Width="480">
    <div>
        <div style="margin-bottom: 16px;">
            <label style="display: block; color: rgba(255,255,255,0.7); font-size: 12px; font-weight: 600; margin-bottom: 6px;">Seleccionar Lote</label>
            <Select @bind-Value="_addLotId" Placeholder="Buscar lote..."
                    TItemValue="Guid" TItem="string"
                    AllowClear
                    ShowSearch
                    Style="width: 100%;">
                @foreach (var lot in _availableLots)
                {
                    <SelectOption TItemValue="Guid" TItem="string" Value="lot.Id"
                                  Label="@($"{lot.Name} ({lot.FieldName ?? "Sin campo"}) - {lot.Area:N2} ha")" />
                }
            </Select>
        </div>
        <div style="margin-bottom: 16px;">
            <label style="display: block; color: rgba(255,255,255,0.7); font-size: 12px; font-weight: 600; margin-bottom: 6px;">Superficie Productiva (ha)</label>
            <AntDesign.InputNumber TValue="decimal" @bind-Value="_addProductiveArea" Min="0m" Step="0.5m"
                                   Style="width: 100%;" Placeholder="Dejar en 0 para usar la catastral" />
            <div style="color: rgba(255,255,255,0.4); font-size: 11px; margin-top: 4px;">
                Si se deja en 0, se usará la superficie catastral del lote.
            </div>
        </div>
    </div>
</Modal>

<Modal Title="Importar Lotes de Campaña Anterior"
       Visible="_importModalVisible"
       OnCancel="CloseImportModal"
       OnOk="ExecuteImport"
       OkText="@("Importar")"
       ConfirmLoading="_importing"
       Width="480">
    <div>
        <div style="margin-bottom: 16px;">
            <label style="display: block; color: rgba(255,255,255,0.7); font-size: 12px; font-weight: 600; margin-bottom: 6px;">Campaña Origen</label>
            <Select @bind-Value="_importFromCampaignId" Placeholder="Seleccionar campaña anterior..."
                    TItemValue="Guid" TItem="string"
                    AllowClear
                    Style="width: 100%;">
                @foreach (var c in _otherCampaigns)
                {
                    <SelectOption TItemValue="Guid" TItem="string" Value="c.Id"
                                  Label="@($"{c.Name} ({c.Status})")" />
                }
            </Select>
        </div>
        <div style="margin-bottom: 16px;">
            <label style="display: block; color: rgba(255,255,255,0.7); font-size: 12px; font-weight: 600; margin-bottom: 6px;">Superficie Productiva</label>
            <RadioGroup @bind-Value="_useProductiveAreaFromPrevious">
                <Radio Value="false">Usar superficie catastral (resetear)</Radio>
                <Radio Value="true">Mantener superficie productiva anterior</Radio>
            </RadioGroup>
        </div>
        <Alert Type="@AlertType.Info"
               Message="Los lotes que ya estén asignados a esta campaña no se duplicarán."
               ShowIcon="true" Style="margin-top: 8px;" />
    </div>
</Modal>

<style>
    .summary-bar {
        display: flex;
        gap: 24px;
        padding: 14px 20px;
        margin-bottom: 16px;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 10px;
        flex-wrap: wrap;
    }

    .summary-item {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .summary-label {
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: rgba(255,255,255,0.4);
        font-weight: 600;
    }

    .summary-value {
        font-size: 18px;
        font-weight: 700;
        color: #fff;
    }
</style>

@code {
    [Parameter] public Guid CampaignId { get; set; }

    private CampaignDto? _campaign;
    private List<CampaignLotDto> _lots = new();
    private List<LotDto> _allLots = new();
    private List<LotDto> _availableLots = new();
    private List<CampaignDto> _otherCampaigns = new();
    private bool _loading = true;
    private string? _errorMessage;

    private Guid? _editingLotId;
    private decimal _editProductiveArea;
    private bool _savingArea;

    private bool _addModalVisible;
    private Guid _addLotId;
    private decimal _addProductiveArea;
    private bool _addingLot;

    private bool _importModalVisible;
    private Guid _importFromCampaignId;
    private bool _useProductiveAreaFromPrevious;
    private bool _importing;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            _loading = true;
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));

            var campaignTask = Http.GetFromJsonAsync($"api/campaigns/{CampaignId}",
                AppJsonSerializerContext.Default.CampaignDto, cts.Token);
            var lotsTask = Http.GetFromJsonAsync($"api/campaigns/{CampaignId}/lots",
                AppJsonSerializerContext.Default.ListCampaignLotDto, cts.Token);
            var allLotsTask = Http.GetFromJsonAsync("api/lots",
                AppJsonSerializerContext.Default.ListLotDto, cts.Token);
            var campaignsTask = Http.GetFromJsonAsync("api/campaigns",
                AppJsonSerializerContext.Default.ListCampaignDto, cts.Token);

            await Task.WhenAll(campaignTask, lotsTask, allLotsTask, campaignsTask);

            _campaign = campaignTask.Result;
            _lots = lotsTask.Result ?? new();
            _allLots = allLotsTask.Result ?? new();
            _otherCampaigns = (campaignsTask.Result ?? new())
                .Where(c => c.Id != CampaignId)
                .ToList();
            RefreshAvailableLots();
            _errorMessage = null;
        }
        catch (OperationCanceledException)
        {
            _errorMessage = "La solicitud tardó demasiado tiempo. Intente recargar la página.";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error de conexión: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void RefreshAvailableLots()
    {
        var usedLotIds = _lots.Select(l => l.LotId).ToHashSet();
        _availableLots = _allLots.Where(l => !usedLotIds.Contains(l.Id)).ToList();
    }

    private void StartEdit(CampaignLotDto lot)
    {
        _editingLotId = lot.LotId;
        _editProductiveArea = lot.ProductiveArea;
    }

    private void CancelEdit()
    {
        _editingLotId = null;
    }

    private async Task SaveProductiveArea(CampaignLotDto lot)
    {
        if (_editProductiveArea > lot.CadastralArea && lot.CadastralArea > 0)
        {
            Message.Warning($"La superficie productiva no puede superar la catastral ({lot.CadastralArea:N2} ha).");
            return;
        }

        _savingArea = true;
        try
        {
            var dto = new CampaignLotDto(
                lot.Id, lot.CampaignId, lot.LotId,
                lot.LotName, lot.FieldName,
                lot.CadastralArea, _editProductiveArea, lot.CropId);

            var response = await Http.PutAsJsonAsync(
                $"api/campaigns/{CampaignId}/lots/{lot.LotId}",
                dto, AppJsonSerializerContext.Default.CampaignLotDto);

            if (response.IsSuccessStatusCode)
            {
                Message.Success("Superficie productiva actualizada.");
                _editingLotId = null;
                await LoadData();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Message.Error($"Error: {body}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
        finally
        {
            _savingArea = false;
        }
    }

    private void OpenAddModal()
    {
        _addLotId = Guid.Empty;
        _addProductiveArea = 0;
        RefreshAvailableLots();
        _addModalVisible = true;
    }

    private void CloseAddModal()
    {
        _addModalVisible = false;
    }

    private async Task AddLotToCampaign()
    {
        if (_addLotId == Guid.Empty)
        {
            Message.Warning("Seleccioná un lote para agregar.");
            return;
        }

        _addingLot = true;
        try
        {
            var dto = new CampaignLotDto(
                Guid.Empty, CampaignId, _addLotId,
                null, null, 0, _addProductiveArea, null);

            var response = await Http.PostAsJsonAsync(
                $"api/campaigns/{CampaignId}/lots",
                dto, AppJsonSerializerContext.Default.CampaignLotDto);

            if (response.IsSuccessStatusCode)
            {
                Message.Success("Lote agregado a la campaña.");
                _addModalVisible = false;
                await LoadData();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Message.Error($"Error: {body}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
        finally
        {
            _addingLot = false;
        }
    }

    private async Task RemoveLot(CampaignLotDto lot)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/campaigns/{CampaignId}/lots/{lot.LotId}");
            if (response.IsSuccessStatusCode)
            {
                Message.Success("Lote removido de la campaña.");
                await LoadData();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Message.Error($"Error: {body}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
    }

    private void OpenImportModal()
    {
        _importFromCampaignId = Guid.Empty;
        _useProductiveAreaFromPrevious = false;
        _importModalVisible = true;
    }

    private void CloseImportModal()
    {
        _importModalVisible = false;
    }

    private async Task ExecuteImport()
    {
        if (_importFromCampaignId == Guid.Empty)
        {
            Message.Warning("Seleccioná una campaña origen.");
            return;
        }

        _importing = true;
        try
        {
            var request = new ImportLotsRequest(_importFromCampaignId, _useProductiveAreaFromPrevious);
            var response = await Http.PostAsJsonAsync(
                $"api/campaigns/{CampaignId}/lots/import",
                request, AppJsonSerializerContext.Default.ImportLotsRequest);

            if (response.IsSuccessStatusCode)
            {
                Message.Success("Lotes importados correctamente.");
                _importModalVisible = false;
                await LoadData();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Message.Error($"Error: {body}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
        finally
        {
            _importing = false;
        }
    }

    private void GoBack()
    {
        Nav.NavigateTo("/campaigns");
    }
}
