@page "/personas"
@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using GestorOT.Domain.Enums
@using System.Net.Http.Json
@using AntDesign
@inject HttpClient Http
@inject IMessageService Message
@inject GestorOT.Client.Services.TenantState TenantState
@implements IDisposable

<PageTitle>Personas - GestorOT</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title">Personas</h2>
        <span class="page-subtitle">Gestión de personas operativas. Active personas del ERP y administre su modalidad.</span>
    </div>
    <div style="display: flex; gap: 8px;">
        <RadioGroup @bind-Value="_filterMode" ButtonStyle="@RadioButtonStyle.Solid">
            <Radio Value="@("all")">Todas</Radio>
            <Radio Value="@("active")">Activas</Radio>
        </RadioGroup>
        <Input @bind-Value="@_searchText" Placeholder="Buscar por nombre o CUIT..." Style="width: 250px;" />
        <Button Icon="sync" OnClick="SyncFromErp" Loading="_syncing">Sincronizar con ERP</Button>
    </div>
</div>

@if (_loading)
{
    <div style="text-align: center; padding: 60px;">
        <Spin Size="AntDesign.SpinSize.Large" Tip="Cargando personas..." />
    </div>
}
else
{
    @if (_filterMode == "all")
    {
        <div class="directory-list">
            @foreach (var person in FilteredPeople)
            {
                <div class="person-card @(person.IsActiveContact ? "person-active" : "")">
                    <div class="person-icon">
                        <Icon Type="user" Theme="IconThemeType.Outline" Style="font-size: 24px;" />
                    </div>
                    <div class="person-info">
                        <div class="person-name">@person.FullName</div>
                        <div class="person-details">
                            @if (!string.IsNullOrEmpty(person.VatNumber)) { <span>CUIT: @person.VatNumber</span> }
                            @if (!string.IsNullOrEmpty(person.Position)) { <span>&bull; @person.Position</span> }
                        </div>
                    </div>
                    <div class="person-status">
                        @if (person.IsActiveContact)
                        {
                            var contact = _contacts.FirstOrDefault(c => c.ExternalErpId == person.ExternalId);
                            var modalityLabel = contact?.Role switch
                            {
                                ContactRole.InternalStaff => "Propio",
                                ContactRole.Contractor => "Contratista",
                                _ => "Activo"
                            };
                            <Tag Color="@(contact?.Role == ContactRole.Contractor ? "orange" : "green")">@modalityLabel</Tag>
                        }
                    </div>
                    <div class="person-actions">
                        @if (!person.IsActiveContact)
                        {
                            <Button Type="@ButtonType.Primary" OnClick="() => OpenActivationModal(person)"
                                    Style="background: #3498DB; border-color: #3498DB; border-radius: 6px;">
                                Activar Contacto
                            </Button>
                        }
                        else
                        {
                            var contact = _contacts.FirstOrDefault(c => c.ExternalErpId == person.ExternalId);
                            @if (contact != null)
                            {
                                <Select TItemValue="ContactRole" TItem="ContactRole"
                                        Value="contact.Role" ValueChanged="(v) => UpdateModality(contact, v)"
                                        Style="width: 140px;">
                                    <SelectOption TItemValue="ContactRole" TItem="ContactRole" Value="@ContactRole.InternalStaff" Label="Propio" />
                                    <SelectOption TItemValue="ContactRole" TItem="ContactRole" Value="@ContactRole.Contractor" Label="Contratista" />
                                </Select>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        @if (_contacts.Count == 0)
        {
            <div style="text-align: center; padding: 60px; color: rgba(255,255,255,0.4);">
                <Icon Type="team" Theme="IconThemeType.Outline" Style="font-size: 48px; margin-bottom: 16px; display: block;" />
                <p>No hay personas activas. Active personas desde la vista "Todas".</p>
            </div>
        }
        else
        {
            <Table DataSource="_contacts.Where(c => string.IsNullOrWhiteSpace(_searchText) ||
                c.FullName.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                (c.VatNumber != null && c.VatNumber.Contains(_searchText))).ToList()"
                   Size="@TableSize.Middle">
                <PropertyColumn Property="c => c.FullName" Title="Nombre Completo" Sortable />
                <PropertyColumn Property="c => c.Position" Title="Cargo" />
                <Column TData="ContactRole" Title="Modalidad">
                    @{
                        var roleLabel = context.Role switch
                        {
                            ContactRole.InternalStaff => "Propio",
                            ContactRole.Contractor => "Contratista",
                            _ => context.Role.GetDisplayName()
                        };
                        var roleColor = context.Role switch
                        {
                            ContactRole.InternalStaff => "#2ECC71",
                            ContactRole.Contractor => "#E67E22",
                            _ => "#95A5A6"
                        };
                    }
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <Tag Style="@($"background: {roleColor}20; color: {roleColor}; border: 1px solid {roleColor}40; border-radius: 8px; font-size: 11px;")">@roleLabel</Tag>
                        <Select TItemValue="ContactRole" TItem="ContactRole"
                                Value="context.Role" ValueChanged="(v) => UpdateModality(context, v)"
                                Style="width: 120px;" Trigger="click">
                            <SelectOption TItemValue="ContactRole" TItem="ContactRole" Value="@ContactRole.InternalStaff" Label="Propio" />
                            <SelectOption TItemValue="ContactRole" TItem="ContactRole" Value="@ContactRole.Contractor" Label="Contratista" />
                        </Select>
                    </div>
                </Column>
                <PropertyColumn Property="c => c.Email" Title="Email" />
                <PropertyColumn Property="c => c.VatNumber" Title="CUIT/VAT" />
            </Table>
        }
    }
}

<Modal Title="Activar Contacto" Visible="@_activationModalVisible" OnCancel="() => _activationModalVisible = false" Footer="null">
    @if (_selectedPerson != null)
    {
        <div style="margin-bottom: 20px;">
            <p style="color: rgba(255,255,255,0.7); margin-bottom: 16px;">
                Está a punto de activar a <strong>@_selectedPerson.FullName</strong> en Gestor-OT.
                Por favor, asigne la modalidad:
            </p>
            <div style="margin-bottom: 8px; color: #fff;">Modalidad:</div>
            <Select TItemValue="ContactRole" TItem="ContactRole" @bind-Value="_selectedRole" Style="width: 100%;">
                <SelectOption TItemValue="ContactRole" TItem="ContactRole" Value="@ContactRole.InternalStaff" Label="Propio" />
                <SelectOption TItemValue="ContactRole" TItem="ContactRole" Value="@ContactRole.Contractor" Label="Contratista" />
            </Select>
        </div>
        <div style="text-align: right;">
            <Button OnClick="() => _activationModalVisible = false" Style="margin-right: 8px;">Cancelar</Button>
            <Button Type="@ButtonType.Primary" Loading="_activating" OnClick="ActivateSelectedPerson">
                Confirmar Activación
            </Button>
        </div>
    }
</Modal>

<style>
    .directory-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    
    .person-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        padding: 16px;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: all 0.2s;
    }
    
    .person-card:hover {
        background: rgba(255,255,255,0.06);
    }
    
    .person-active {
        border-color: rgba(46, 204, 113, 0.3);
        background: rgba(46, 204, 113, 0.05);
    }

    .person-icon {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: rgba(255,255,255,0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(255,255,255,0.8);
    }
    
    .person-info {
        flex: 1;
    }
    
    .person-name {
        font-size: 16px;
        font-weight: 600;
        color: #fff;
    }
    
    .person-details {
        font-size: 13px;
        color: rgba(255,255,255,0.5);
        display: flex;
        gap: 8px;
        margin-top: 4px;
    }
    
    .person-status {
        width: 100px;
        text-align: center;
    }
</style>

@code {
    private List<ErpPersonDto> _people = new();
    private List<ContactDto> _contacts = new();
    private bool _loading = true;
    private string _searchText = string.Empty;
    private string _filterMode = "all";
    
    private bool _activationModalVisible = false;
    private ErpPersonDto? _selectedPerson;
    private ContactRole _selectedRole = ContactRole.InternalStaff;
    private bool _activating = false;
    private bool _syncing = false;

    private IEnumerable<ErpPersonDto> FilteredPeople => string.IsNullOrWhiteSpace(_searchText)
        ? _people
        : _people.Where(p => 
            p.FullName.Contains(_searchText, StringComparison.OrdinalIgnoreCase) || 
            (p.VatNumber != null && p.VatNumber.Contains(_searchText))
        );

    protected override async Task OnInitializedAsync()
    {
        TenantState.OnChange += OnTenantChanged;
        await LoadData();
    }

    public void Dispose()
    {
        TenantState.OnChange -= OnTenantChanged;
    }

    private void OnTenantChanged()
    {
        InvokeAsync(async () => { await LoadData(); StateHasChanged(); });
    }

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            var peopleTask = Http.GetFromJsonAsync("api/erppeople", AppJsonSerializerContext.Default.ListErpPersonDto);
            var contactsTask = Http.GetFromJsonAsync<List<ContactDto>>("api/catalogs/contacts");
            await Task.WhenAll(peopleTask, contactsTask);
            _people = await peopleTask ?? new();
            _contacts = await contactsTask ?? new();
        }
        catch (Exception ex)
        {
            Message.Error($"Error cargando personas: {ex.Message}");
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task UpdateModality(ContactDto contact, ContactRole newRole)
    {
        try
        {
            var response = await Http.PutAsJsonAsync($"api/catalogs/contacts/{contact.Id}/role", new { Role = newRole });
            if (response.IsSuccessStatusCode)
            {
                Message.Success($"Modalidad de {contact.FullName} actualizada.");
                await LoadData();
            }
            else
            {
                Message.Error("No se pudo actualizar la modalidad.");
            }
        }
        catch
        {
            Message.Error("Error al actualizar modalidad.");
        }
    }

    private void OpenActivationModal(ErpPersonDto person)
    {
        _selectedPerson = person;
        _selectedRole = ContactRole.InternalStaff;
        _activationModalVisible = true;
    }

    private async Task ActivateSelectedPerson()
    {
        if (_selectedPerson == null) return;
        
        _activating = true;
        try
        {
            var request = new ActivateContactRequest
            {
                ErpPersonId = _selectedPerson.Id,
                Role = _selectedRole
            };

            var response = await Http.PostAsJsonAsync("api/erppeople/activate", request, AppJsonSerializerContext.Default.ActivateContactRequest);
            
            if (response.IsSuccessStatusCode)
            {
                Message.Success("Contacto activado exitosamente.");
                await LoadData();
                _activationModalVisible = false;
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Message.Error($"Error al activar: {error}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error inesperado: {ex.Message}");
        }
        finally
        {
            _activating = false;
            StateHasChanged();
        }
    }

    private async Task SyncFromErp()
    {
        _syncing = true;
        try
        {
            var response = await Http.PostAsync($"api/tenants/{TenantState.CurrentTenant?.Id}/sync-contacts", null);
            if (response.IsSuccessStatusCode)
            {
                Message.Success("Sincronización completada.");
                await LoadData();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Message.Error($"Error sincronizando: {error}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
        finally
        {
            _syncing = false;
        }
    }
}
