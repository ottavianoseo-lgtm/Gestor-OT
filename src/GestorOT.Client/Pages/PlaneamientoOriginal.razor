@page "/planeamiento-original"
@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using GestorOT.Client.Components
@using System.Net.Http.Json
@using AntDesign
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@inject IMessageService Message
@inject NavigationManager Nav
@inject GestorOT.Client.Services.CampaignState CampaignState

<PageTitle>Planeamiento Original - GestorOT</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title">Planeamiento Original</h2>
        <span class="page-subtitle">Línea de base inmutable de la campaña</span>
    </div>
    <div style="display: flex; gap: 12px; align-items: center;">
        <Tag Color="@("gold")" Style="padding: 4px 12px; border-radius: 8px; font-weight: 600;">
            <Icon Type="lock" /> P.O.
        </Tag>
        <Button Type="@ButtonType.Primary" OnClick="() => _strategyWizardVisible = true"
                Style="background: #3498DB; border-color: #3498DB; border-radius: 8px; font-weight: 600;"
                Disabled="@(!_hasCampaign || _isLocked)">
            <Icon Type="apartment" /> Cargar Estrategia
        </Button>
        <Button Type="@ButtonType.Primary" OnClick="() => _drawerVisible = true"
                Style="background: #2ECC71; border-color: #2ECC71; border-radius: 8px; font-weight: 600;"
                Disabled="@(!_hasCampaign || _isLocked)">
            <Icon Type="plus" /> Nueva Labor Base
        </Button>
    </div>
</div>

@if (!_hasCampaign)
{
    <div class="glass-card" style="margin-bottom: 24px; padding: 16px; border-left: 4px solid #E74C3C;">
        <div style="display: flex; align-items: center; gap: 12px;">
            <Icon Type="exclamation-circle" Theme="IconThemeType.Fill" Style="color: #E74C3C; font-size: 20px;" />
            <div>
                <span style="color: #fff; font-weight: 600; display: block;">Seleccione una campaña</span>
                <span style="color: rgba(255,255,255,0.6); font-size: 13px;">Para utilizar Planeamiento Original, debe seleccionar una campaña activa en el selector de campañas.</span>
            </div>
        </div>
    </div>
}
else if (_isLocked)
{
    <div class="glass-card" style="margin-bottom: 24px; padding: 16px; border-left: 4px solid #FAAD14;">
        <div style="display: flex; align-items: center; gap: 12px;">
            <Icon Type="lock" Theme="IconThemeType.Fill" Style="color: #FAAD14; font-size: 20px;" />
            <div>
                <span style="color: #fff; font-weight: 600; display: block;">Campaña Bloqueada - Solo Lectura</span>
                <span style="color: rgba(255,255,255,0.6); font-size: 13px;">La campaña seleccionada está bloqueada. No se pueden crear ni modificar labores en el planeamiento original.</span>
            </div>
        </div>
    </div>
}
else
{
    <div class="glass-card" style="margin-bottom: 24px; padding: 16px; border-left: 4px solid #F1C40F;">
        <div style="display: flex; align-items: center; gap: 12px;">
            <Icon Type="info-circle" Theme="IconThemeType.Fill" Style="color: #F1C40F; font-size: 20px;" />
            <div>
                <span style="color: #fff; font-weight: 600; display: block;">Planeamiento Original</span>
                <span style="color: rgba(255,255,255,0.6); font-size: 13px;">Las labores creadas aquí conforman la línea de base inmutable de la campaña @CampaignState.CurrentCampaign?.Name.</span>
            </div>
        </div>
    </div>
}

<div class="glass-card">
    <Table TItem="LaborDto" 
           DataSource="@_labors" 
           Loading="@_loading" 
           Size="TableSize.Small" 
           ScrollX="1200">
        <ChildContent>
            <PropertyColumn Property="l => l.LaborTypeName" Title="Labor" Sortable>
                <div style="display: flex; align-items: center; gap: 8px;">
                    <div style="background: #F1C40F; width: 8px; height: 8px; border-radius: 50%;"></div>
                    @context.LaborTypeName
                </div>
            </PropertyColumn>
            <PropertyColumn Property="l => l.LotName" Title="Lote" Sortable />
            <PropertyColumn Property="l => l.FieldName" Title="Campo" Sortable />
            <PropertyColumn Property="l => l.ErpActivityName" Title="Actividad" Sortable />
            <Column TData="DateTime?" Title="Fecha Estimada" Sortable>
                @context.EstimatedDate?.ToString("dd/MM/yyyy")
            </Column>
            <PropertyColumn Property="l => l.Hectares" Title="Ha Plan." Sortable Format="N2" />
            <Column TData="string" Title="Insumos">
                @if (context.Supplies != null && context.Supplies.Count > 0)
                {
                    var first = context.Supplies.First();
                    <span style="color: rgba(255,255,255,0.6); font-size: 11px;">@first.SupplyName @first.PlannedTotal.ToString("N2") @first.UnitOfMeasure</span>
                    if (context.Supplies.Count > 1)
                    {
                        <Tag Style="background: rgba(52,152,219,0.15); color: #3498DB; border: 1px solid rgba(52,152,219,0.3); border-radius: 4px; font-size: 9px; margin-left: 4px;">+@(context.Supplies.Count - 1)</Tag>
                    }
                }
                else
                {
                    <span style="color: rgba(255,255,255,0.2); font-size: 11px;">—</span>
                }
            </Column>
            <Column TData="string" Title="Estado">
                <Tag Style="background: #1890FF33; color: #fff; border: 1px solid #1890FF80; border-radius: 12px; font-size: 11px; font-weight: 600; padding: 2px 10px;">Planeada (Base)</Tag>
            </Column>
            <Column TData="string" Title="OT Relacionada">
                @if (context.WorkOrderId != null)
                {
                    <Tag Color="@("blue")" Style="cursor: pointer;" OnClick='() => Nav.NavigateTo($"/workorders/{context.WorkOrderId}")'>
                        <Icon Type="link" /> @context.OTNumber
                    </Tag>
                }
                else
                {
                    <span style="color: rgba(255,255,255,0.3);">Sin asignar</span>
                }
            </Column>
            <ActionColumn Title="Acciones" Width="100">
                <Space>
                    <SpaceItem>
                        <Popconfirm Title="¿Desanclar esta labor de la línea de base?" OnConfirm="() => UnpinOriginalPlan(context.Id)">
                            <Button Type="@ButtonType.Text" Icon="unlock" Style="color: #E74C3C;" Disabled="@(_isLocked)" />
                        </Popconfirm>
                    </SpaceItem>
                </Space>
            </ActionColumn>
        </ChildContent>
    </Table>
</div>

<Modal Title="Crear Labores desde Estrategia (Base)" Visible="_strategyWizardVisible" Footer="null" OnCancel="() => _strategyWizardVisible = false" Width="900">
    <StrategyLaborWizard ForceOriginalPlan="true" OnClose="() => { _strategyWizardVisible = false; LoadData(); }" />
</Modal>

<Modal Title="Nueva Labor Base" Visible="@_drawerVisible" OnCancel="HandleCancelLaborForm" Footer="null" Width="800">
    <LaborEditorForm @ref="_laborFormRef" ForceOriginalPlan="true" OnSaved="OnSaved" />
</Modal>

@code {
    private List<LaborDto> _labors = new();
    private bool _loading = true;
    private bool _showModal;
    private bool _strategyWizardVisible;
    private bool _drawerVisible;
    private LaborDto? _selectedLabor;
    private bool _hasCampaign;
    private bool _isLocked;
    private LaborEditorForm? _laborFormRef;

    protected override async Task OnInitializedAsync()
    {
        CampaignState.OnChange += async () => await LoadData();
        await LoadData();
    }

    private void UpdateCampaignState()
    {
        _hasCampaign = CampaignState.CurrentCampaign != null;
        _isLocked = CampaignState.IsLocked;
    }

    private async Task LoadData()
    {
        _loading = true;
        UpdateCampaignState();
        try
        {
            if (_hasCampaign)
            {
                var campaignId = CampaignState.CurrentCampaign!.Id;
                _labors = await Http.GetFromJsonAsync<List<LaborDto>>(
                    $"api/labors?isOriginalPlan=true&campaignId={campaignId}") ?? new();
            }
            else
            {
                _labors = new();
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error al cargar planeamiento: {ex.Message}");
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task UnpinOriginalPlan(Guid laborId)
    {
        if (_isLocked)
        {
            Message.Warning("No se puede desanclar en campaña bloqueada.");
            return;
        }
        try
        {
            var response = await Http.PostAsync($"api/labors/{laborId}/unpin-original-plan", null);
            if (response.IsSuccessStatusCode)
            {
                Message.Success("Labor desanclada correctamente.");
                await LoadData();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Message.Error($"Error: {body}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error al desanclar: {ex.Message}");
        }
    }

    private async Task HandleCancelLaborForm()
    {
        if (_laborFormRef != null && _laborFormRef.HasDraftUploads())
        {
            var confirmed = await JSRuntime.InvokeAsync<bool>("confirm",
                "Tenés archivos subidos no guardados. ¿Eliminarlos? (Cancelar = conservar en biblioteca)");
            if (!confirmed)
            {
                _laborFormRef.DiscardDraftUploads();
            }
            else
            {
                var draftIds = _laborFormRef.GetDraftUploadIds();
                if (draftIds.Count > 0)
                {
                    await Http.PostAsJsonAsync("api/files/delete-unlinked",
                        new { FileAssetIds = draftIds });
                }
                _laborFormRef.DiscardDraftUploads();
            }
        }
        _drawerVisible = false;
    }

    private async Task OnSaved()
    {
        _drawerVisible = false;
        await LoadData();
    }
}
