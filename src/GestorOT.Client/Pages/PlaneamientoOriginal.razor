@page "/planeamiento-original"
@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using GestorOT.Client.Components
@using System.Net.Http.Json
@using AntDesign
@inject HttpClient Http
@inject IMessageService Message
@inject NavigationManager Nav
@inject GestorOT.Client.Services.CampaignState CampaignState

<PageTitle>Planeamiento Original - GestorOT</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title">Planeamiento Original</h2>
        <span class="page-subtitle">Línea de base inmutable de la campaña</span>
    </div>
    <div style="display: flex; gap: 12px; align-items: center;">
        <Tag Color="@("gold")" Style="padding: 4px 12px; border-radius: 8px; font-weight: 600;">
            <Icon Type="lock" /> LÍNEA DE BASE
        </Tag>
        <Button Type="@ButtonType.Primary" OnClick="() => _strategyWizardVisible = true"
                Style="background: #3498DB; border-color: #3498DB; border-radius: 8px; font-weight: 600;">
            <Icon Type="apartment" /> Cargar Estrategia
        </Button>
        <Button Type="@ButtonType.Primary" OnClick="() => _drawerVisible = true"
                Style="background: #2ECC71; border-color: #2ECC71; border-radius: 8px; font-weight: 600;">
            <Icon Type="plus" /> Nueva Labor Base
        </Button>
    </div>
</div>

<div class="glass-card" style="margin-bottom: 24px; padding: 16px; border-left: 4px solid #F1C40F;">
    <div style="display: flex; align-items: center; gap: 12px;">
        <Icon Type="info-circle" Theme="IconThemeType.Fill" Style="color: #F1C40F; font-size: 20px;" />
        <div>
            <span style="color: #fff; font-weight: 600; display: block;">Modo Lectura</span>
            <span style="color: rgba(255,255,255,0.6); font-size: 13px;">Las labores del Planeamiento Original no pueden ser modificadas. Representan el plan inicial de la campaña.</span>
        </div>
    </div>
</div>

<div class="glass-card">
    <Table TItem="LaborDto" 
           DataSource="@_labors" 
           Loading="@_loading" 
           Size="TableSize.Small" 
           ScrollX="1200">
        <ChildContent>
            <PropertyColumn Property="l => l.LaborTypeName" Title="Labor" Sortable>
                <div style="display: flex; align-items: center; gap: 8px;">
                    <div style="background: #F1C40F; width: 8px; height: 8px; border-radius: 50%;"></div>
                    @context.LaborTypeName
                </div>
            </PropertyColumn>
            <PropertyColumn Property="l => l.LotName" Title="Lote" Sortable />
            <PropertyColumn Property="l => l.FieldName" Title="Campo" Sortable />
            <PropertyColumn Property="l => l.Hectares" Title="Ha Plan." Sortable Format="N2" />
            <Column TData="decimal" Title="Ha Real." Sortable>
                @if (context.Status == "Realized")
                {
                    <span style="color: #fff; font-weight: 600;">@context.EffectiveArea.ToString("N2")</span>
                }
                else
                {
                    <span style="color: rgba(255,255,255,0.2);">—</span>
                }
            </Column>
            <Column TData="decimal" Title="Diff">
                @if (context.Status == "Realized")
                {
                    var diff = context.EffectiveArea - context.Hectares;
                    var color = diff > 0 ? "#ff4d4f" : (diff < 0 ? "#52c41a" : "inherit");
                    <span style="color: @color; font-weight: 600;">@(diff > 0 ? "+" : "")@diff.ToString("N2")</span>
                }
                else
                {
                    <span style="color: rgba(255,255,255,0.2);">—</span>
                }
            </Column>
            <Column TData="string" Title="Estado" Sortable>
                @{
                    var statusColor = context.Status switch { "Realized" => "#52C41A", "Validated" => "#FA8C16", "AwaitingValidation" => "#FAAD14", _ => "#1890FF" };
                    var statusLabel = context.Status switch { "Realized" => "Realizada", "Validated" => "Validada", "AwaitingValidation" => "En Validación", _ => "Planeada" };
                }
                <Tag Style="@($"background: {statusColor}33; color: #fff; border: 1px solid {statusColor}80; border-radius: 12px; font-size: 11px; font-weight: 600; padding: 2px 10px;")">@statusLabel</Tag>
            </Column>
            <Column TData="string" Title="OT Relacionada">
                @if (context.WorkOrderId != null)
                {
                    <Tag Color="@("blue")" Style="cursor: pointer;" OnClick='() => Nav.NavigateTo($"/workorders/{context.WorkOrderId}")'>
                        <Icon Type="link" /> @context.OTNumber
                    </Tag>
                }
                else
                {
                    <span style="color: rgba(255,255,255,0.3);">Sin asignar</span>
                }
            </Column>
            <ActionColumn Title="Acciones" Width="100">
                <Space>
                    <SpaceItem>
                        <Tooltip Title="Ver Desvíos">
                            <Button Type="@ButtonType.Text" Icon="bar-chart" OnClick="() => ViewDetails(context.Id)" Style="color: #3498DB;" />
                        </Tooltip>
                    </SpaceItem>
                    <SpaceItem>
                        <Popconfirm Title="¿Desanclar esta labor de la línea de base?" OnConfirm="() => UnpinOriginalPlan(context.Id)">
                            <Button Type="@ButtonType.Text" Icon="unlock" Style="color: #E74C3C;" />
                        </Popconfirm>
                    </SpaceItem>
                </Space>
            </ActionColumn>
        </ChildContent>
    </Table>
</div>

@if (_selectedLabor != null)
{
    <Modal Title="Análisis de Desvíos (Plan vs Real)" Visible="_showModal" OnCancel="() => _showModal = false" Footer="null" Width="850">
        <div style="padding: 16px;">
            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 16px; margin-bottom: 24px;">
                <div>
                    <label class="detail-label">LOTE</label>
                    <div class="detail-value">@_selectedLabor.LotName</div>
                </div>
                <div>
                    <label class="detail-label">ESTADO</label>
                    <div class="detail-value">@(_selectedLabor.Status == "Realized" ? "EJECUTADA" : "PENDIENTE")</div>
                </div>
                <div>
                    <label class="detail-label">HA PLANEADAS</label>
                    <div class="detail-value">@_selectedLabor.Hectares.ToString("N2")</div>
                </div>
                <div>
                    <label class="detail-label">HA REALES</label>
                    <div class="detail-value" style="@(_selectedLabor.Status == "Realized" ? "color: #52C41A;" : "")">
                        @(_selectedLabor.Status == "Realized" ? _selectedLabor.EffectiveArea.ToString("N2") : "—")
                    </div>
                </div>
            </div>

            <h4 style="color: #fff; margin-bottom: 16px; font-size: 14px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 8px;">Comparativa de Insumos</h4>
            <Table TItem="LaborSupplyDto" DataSource="@_selectedLabor.Supplies" Size="TableSize.Small" HidePagination>
                <PropertyColumn Property="s => s.SupplyName" Title="Insumo" />
                <PropertyColumn Property="s => s.PlannedTotal" Title="Total Plan." Format="N2" />
                <Column TData="decimal?" Title="Total Real">
                    @if (context.RealTotal.HasValue)
                    {
                        <span style="color: #fff; font-weight: 600;">@context.RealTotal.Value.ToString("N2")</span>
                    }
                    else
                    {
                        <span style="color: rgba(255,255,255,0.2);">—</span>
                    }
                </Column>
                <Column TData="string" Title="Variación">
                    @if (context.RealTotal.HasValue && context.PlannedTotal > 0)
                    {
                        var varPercent = ((context.RealTotal.Value / context.PlannedTotal) - 1) * 100;
                        var color = Math.Abs(varPercent) > 5 ? "#ff4d4f" : "#52c41a";
                        <span style="color: @color; font-weight: 600;">@(varPercent > 0 ? "+" : "")@varPercent.ToString("N1")%</span>
                    }
                    else
                    {
                        <span style="color: rgba(255,255,255,0.2);">—</span>
                    }
                </Column>
                <PropertyColumn Property="s => s.UnitOfMeasure" Title="U.M." />
            </Table>
            
            @if (_selectedLabor.Status != "Realized")
            {
                <div style="margin-top: 16px; background: rgba(52,152,219,0.1); border: 1px dashed rgba(52,152,219,0.3); padding: 12px; border-radius: 8px; color: #3498DB; font-size: 13px;">
                    <Icon Type="info-circle" /> La labor aún no ha sido marcada como realizada. Los datos reales se poblarán una vez que se complete la ejecución en la OT correspondiente.
                </div>
            }
        </div>
    </Modal>
}

<Modal Title="Crear Labores desde Estrategia (Base)" Visible="_strategyWizardVisible" Footer="null" OnCancel="() => _strategyWizardVisible = false" Width="900">
    <StrategyLaborWizard OnClose="() => { _strategyWizardVisible = false; LoadData(); }" />
</Modal>

<Modal Title="Nueva Labor Base" Visible="@_drawerVisible" OnCancel="() => _drawerVisible = false" Footer="null" Width="800">
    <LaborEditorForm ForceOriginalPlan="true" OnSaved="OnSaved" />
</Modal>

<style>
    .detail-label { display: block; font-size: 11px; color: rgba(255,255,255,0.4); font-weight: 700; margin-bottom: 4px; letter-spacing: 0.5px; }
    .detail-value { color: #fff; font-size: 15px; font-weight: 600; }
</style>

@code {
    private List<LaborDto> _labors = new();
    private bool _loading = true;
    private bool _showModal;
    private bool _strategyWizardVisible;
    private bool _drawerVisible;
    private LaborDto? _selectedLabor;

    protected override async Task OnInitializedAsync()
    {
        CampaignState.OnChange += async () => await LoadData();
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            // We fetch labors with isOriginalPlan=true
            _labors = await Http.GetFromJsonAsync<List<LaborDto>>("api/labors?isOriginalPlan=true") ?? new();
        }
        catch (Exception ex)
        {
            Message.Error($"Error al cargar planeamiento: {ex.Message}");
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void ViewDetails(Guid laborId)
    {
        _selectedLabor = _labors.FirstOrDefault(l => l.Id == laborId);
        _showModal = true;
    }

    private async Task UnpinOriginalPlan(Guid laborId)
    {
        try
        {
            var response = await Http.PostAsync($"api/labors/{laborId}/unpin-original-plan", null);
            if (response.IsSuccessStatusCode)
            {
                Message.Success("Labor desanclada correctamente.");
                await LoadData();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Message.Error($"Error: {body}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error al desanclar: {ex.Message}");
        }
    }

    private async Task OnSaved()
    {
        _drawerVisible = false;
        await LoadData();
    }
}
