@page "/workorders"
@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using GestorOT.Client.Components
@using System.Net.Http.Json
@using AntDesign
@inject HttpClient Http
@inject IMessageService Message
@inject IJSRuntime JS
@inject GestorOT.Client.Services.CampaignState CampaignState
@inject GestorOT.Client.Services.TenantState TenantState
@implements IDisposable
@inject NavigationManager Navigation

<PageTitle>Órdenes de Trabajo - GestorOT</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title">Órdenes de Trabajo</h2>
        <span class="page-subtitle">@_workOrders.Count órdenes registradas</span>
    </div>
    <Button Type="@ButtonType.Primary" OnClick="OpenCreateModal"
            Style="background: #E74C3C; border-color: #E74C3C; border-radius: 8px; font-weight: 600;">
        <Icon Type="plus" Theme="IconThemeType.Outline" /> Nueva Orden
    </Button>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <Alert Type="@AlertType.Error" Message="@_errorMessage" ShowIcon="true" Style="margin-bottom: 16px;" />
}

<AntDesign.Row Gutter="@((16, 16))" Style="margin-bottom: 16px;">
    <AntDesign.Col Xs="24" Sm="6">
        <div class="kpi-card-sm" style="border-left: 3px solid #E74C3C;">
            <span class="kpi-sm-value">@_workOrders.Count(w => w.Status == "Pending" || w.Status == "Draft")</span>
            <span class="kpi-sm-label">Pendientes</span>
        </div>
    </AntDesign.Col>
    <AntDesign.Col Xs="24" Sm="6">
        <div class="kpi-card-sm" style="border-left: 3px solid #F1C40F;">
            <span class="kpi-sm-value">@_workOrders.Count(w => w.Status == "InProgress")</span>
            <span class="kpi-sm-label">En Progreso</span>
        </div>
    </AntDesign.Col>
    <AntDesign.Col Xs="24" Sm="6">
        <div class="kpi-card-sm" style="border-left: 3px solid #3498DB;">
            <span class="kpi-sm-value">@_workOrders.Count(w => w.Status == "Completed" || w.Status == "Done")</span>
            <span class="kpi-sm-label">Completadas</span>
        </div>
    </AntDesign.Col>
    <AntDesign.Col Xs="24" Sm="6">
        <div class="kpi-card-sm" style="border-left: 3px solid #2ECC71;">
            <span class="kpi-sm-value">@_workOrders.Count(w => w.Status == "Approved")</span>
            <span class="kpi-sm-label">Aprobadas</span>
        </div>
    </AntDesign.Col>
</AntDesign.Row>

<div class="glass-card">
    <Table TItem="WorkOrderDto" DataSource="_workOrders" Loading="_loading" Size="@TableSize.Small" ScrollX="1200">
        <PropertyColumn Property="c => c.Description" Title="Descripción">
            <span style="font-weight: 600;">@context.Description</span>
        </PropertyColumn>
        <PropertyColumn Property="c => c.FieldName" Title="Campo" Sortable />
        <Column TData="string" Title="Estado">
            @{
                var (color, label) = context.Status switch
                {
                    "Approved" => ("#52C41A", "Aprobada"),
                    "Completed" or "Done" => ("#1890FF", "Completada"),
                    "InProgress" => ("#FAAD14", "En Progreso"),
                    "Cancelled" => ("#95A5A6", "Cancelada"),
                    "Draft" => ("#FA8C16", "Borrador"),
                    _ => ("#E74C3C", "Pendiente")
                };
            }
            <Tag Style="@($"background: {color}20; color: {color}; border: 1px solid {color}40; border-radius: 12px; font-size: 11px; font-weight: 600; padding: 2px 10px;")">
                @label
            </Tag>
        </Column>
        <PropertyColumn Property="c => c.AssignedTo" Title="Asignado a" Sortable />
        <PropertyColumn Property="c => c.DueDate" Title="Fecha Límite" Sortable>
            @context.DueDate.ToString("dd/MM/yyyy")
        </PropertyColumn>
        <ActionColumn Title="Acciones" Width="220">
            <Space>
                <SpaceItem>
                    <Button Size="@ButtonSize.Small" OnClick="() => OpenDetail(context.Id)"
                            Style="border-radius: 6px; background: #3498DB20; border-color: #3498DB40; color: #3498DB; font-size: 11px;">
                        <Icon Type="eye" Theme="IconThemeType.Outline" /> Ver
                    </Button>
                </SpaceItem>
                <SpaceItem>
                    <Button Size="@ButtonSize.Small" OnClick="() => OpenEditModal(context)"
                            Style="border-radius: 6px; border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.7);">
                        <Icon Type="edit" Theme="IconThemeType.Outline" />
                    </Button>
                </SpaceItem>
                <SpaceItem>
                    <Popconfirm Title="¿Eliminar esta orden de trabajo?"
                                OnConfirm="() => DeleteWorkOrder(context.Id)"
                                OkText="@("Eliminar")" CancelText="@("Cancelar")">
                        <Button Danger Size="@ButtonSize.Small" Style="border-radius: 6px;">
                            <Icon Type="delete" Theme="IconThemeType.Outline" />
                        </Button>
                    </Popconfirm>
                </SpaceItem>
            </Space>
        </ActionColumn>
    </Table>
</div>

<Modal Title="@(_isEditing ? "Editar Orden de Trabajo" : "Nueva Orden de Trabajo")"
       Visible="_modalVisible"
       OnCancel="CloseModal"
       OnOk="SaveWorkOrder"
       OkText="@(_isEditing ? "Guardar" : "Crear")"
       ConfirmLoading="_saving"
       Width="560">
    <Form @ref="_form" Model="_formModel" Layout="@FormLayout.Vertical">
        <FormItem Label="Descripción">
            <TextArea @bind-Value="_formModel.Description" Placeholder="Descripción de la orden" Rows="3" />
        </FormItem>
        <FormItem Label="Campo">
            <Select TItem="FieldDto" TItemValue="Guid" DataSource="_availableFields" @bind-Value="_formModel.FieldId"
                    LabelName="@nameof(FieldDto.Name)" ValueName="@nameof(FieldDto.Id)" Placeholder="Seleccionar campo"
                    Style="width: 100%;" EnableSearch />
        </FormItem>
        <AntDesign.Row Gutter="16">
            <AntDesign.Col Span="12">
                <FormItem Label="Responsable (Contacto)">
                    <Select TItem="ContactDto" TItemValue="Guid" DataSource="_availableContacts" @bind-Value="_formModel.ContactId"
                            LabelName="@nameof(ContactDto.FullName)" ValueName="@nameof(ContactDto.Id)" Placeholder="Seleccionar contacto"
                            Style="width: 100%;" EnableSearch />
                </FormItem>
            </AntDesign.Col>
            <AntDesign.Col Span="12">
                <FormItem Label="Fecha Límite">
                    <DatePicker @bind-Value="_formModel.DueDate" Style="width: 100%;" Format="dd/MM/yyyy" />
                </FormItem>
            </AntDesign.Col>
        </AntDesign.Row>
        <AntDesign.Row Gutter="16">
            <AntDesign.Col Span="12">
                <FormItem Label="Estado">
                    <Select TItem="string" TItemValue="string" @bind-Value="_formModel.Status" Style="width: 100%;">
                        <SelectOption Value="@("Draft")" Label="Borrador" />
                        <SelectOption Value="@("Pending")" Label="Pendiente" />
                        <SelectOption Value="@("InProgress")" Label="En Progreso" />
                    </Select>
                </FormItem>
            </AntDesign.Col>
            <AntDesign.Col Span="12">
                <div style="display: flex; gap: 8px; height: 100%; align-items: center; padding-top: 24px;">
                    <Checkbox @bind-Checked="_formModel.AcceptsMultiplePeople">Mult. Pers.</Checkbox>
                    <Checkbox @bind-Checked="_formModel.AcceptsMultipleDates">Mult. Fechas</Checkbox>
                </div>
            </AntDesign.Col>
        </AntDesign.Row>
    </Form>
</Modal>

<style>
    .kpi-card-sm {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 10px;
        padding: 14px 18px;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .kpi-sm-value {
        font-size: 22px;
        font-weight: 700;
        color: #fff;
    }
    .kpi-sm-label {
        font-size: 12px;
        color: rgba(255,255,255,0.5);
    }
</style>

@code {
    private List<WorkOrderDto> _workOrders = new();
    private List<FieldDto> _availableFields = new();
    private List<CampaignSummaryDto> _availableCampaigns = new();
    private List<ContactDto> _availableContacts = new();
    private bool _loading;
    private string? _errorMessage;

    private bool _modalVisible;
    private bool _saving;
    private bool _isEditing;
    private Guid _editingId;
    private WoFormModel _formModel = new();
    private Form<WoFormModel>? _form;

    public class WoFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "La descripción es obligatoria")]
        public string Description { get; set; } = string.Empty;
        
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Debe seleccionar un campo")]
        public Guid FieldId { get; set; }
        
        public Guid CampaignId { get; set; }
        public Guid ContactId { get; set; }
        public DateTime DueDate { get; set; } = DateTime.Today.AddDays(7);
        public string Status { get; set; } = "Draft";
        public bool AcceptsMultiplePeople { get; set; }
        public bool AcceptsMultipleDates { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        CampaignState.OnChange += OnCampaignChanged;
        TenantState.OnChange += OnCampaignChanged;
        await LoadData();
    }

    private void OnCampaignChanged()
    {
        InvokeAsync(async () => { await LoadData(); StateHasChanged(); });
    }

    public void Dispose()
    {
        CampaignState.OnChange -= OnCampaignChanged;
        TenantState.OnChange -= OnCampaignChanged;
    }

    private async Task LoadData()
    {
        try
        {
            _loading = true;
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));
            var ordersTask = Http.GetFromJsonAsync("api/workorders",
                AppJsonSerializerContext.Default.ListWorkOrderDto, cts.Token);
            var fieldsTask = Http.GetFromJsonAsync("api/fields",
                AppJsonSerializerContext.Default.ListFieldDto, cts.Token);
            var campaignsTask = Http.GetFromJsonAsync("api/campaigns",
                AppJsonSerializerContext.Default.ListCampaignSummaryDto, cts.Token);
            var contactsTask = Http.GetFromJsonAsync("api/catalogs/contacts",
                AppJsonSerializerContext.Default.ListContactDto, cts.Token);

            await Task.WhenAll(ordersTask, fieldsTask, campaignsTask, contactsTask);

            _workOrders = await ordersTask ?? new();
            _availableFields = await fieldsTask ?? new();
            _availableCampaigns = await campaignsTask ?? new();
            _availableContacts = await contactsTask ?? new();
            _errorMessage = null;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void OpenDetail(Guid workOrderId)
    {
        Navigation.NavigateTo($"/workorders/{workOrderId}");
    }

    private void OpenCreateModal()
    {
        if (CampaignState.CurrentCampaign == null)
        {
            Message.Warning("Debe seleccionar una campaña activa para crear una OT.");
            return;
        }

        _isEditing = false;
        _formModel = new WoFormModel();
        
        _formModel.CampaignId = CampaignState.CurrentCampaign?.Id ?? Guid.Empty;

        _modalVisible = true;
    }

    private void OpenEditModal(WorkOrderDto wo)
    {
        _isEditing = true;
        _editingId = wo.Id;
        _formModel = new WoFormModel
        {
            Description = wo.Description,
            CampaignId = wo.CampaignId ?? Guid.Empty,
            FieldId = wo.FieldId,
            ContactId = wo.ContactId ?? Guid.Empty,
            DueDate = wo.DueDate,
            Status = wo.Status,
            AcceptsMultiplePeople = wo.AcceptsMultiplePeople,
            AcceptsMultipleDates = wo.AcceptsMultipleDates
        };
        _modalVisible = true;
    }

    private void CloseModal()
    {
        _modalVisible = false;
    }

    private async Task SaveWorkOrder()
    {
        if (string.IsNullOrWhiteSpace(_formModel.Description))
        {
            Message.Warning("La descripción es obligatoria.");
            return;
        }
        if (_formModel.FieldId == Guid.Empty)
        {
            Message.Warning("Debe seleccionar un campo.");
            return;
        }

        _saving = true;
        try
        {
            var dto = new WorkOrderDto
            {
                Id = _isEditing ? _editingId : Guid.Empty,
                CampaignId = _formModel.CampaignId != Guid.Empty ? _formModel.CampaignId : null,
                FieldId = _formModel.FieldId,
                Description = _formModel.Description,
                Status = _formModel.Status,
                ContactId = _formModel.ContactId,
                OTNumber = _isEditing ? null : $"OT_{Guid.NewGuid().ToString().Substring(0, 5).ToUpper()}",
                DueDate = _formModel.DueDate,
                AcceptsMultiplePeople = _formModel.AcceptsMultiplePeople,
                AcceptsMultipleDates = _formModel.AcceptsMultipleDates
            };

            HttpResponseMessage response;
            if (_isEditing)
            {
                response = await Http.PutAsJsonAsync($"api/workorders/{_editingId}",
                    dto, AppJsonSerializerContext.Default.WorkOrderDto);
            }
            else
            {
                response = await Http.PostAsJsonAsync("api/workorders",
                    dto, AppJsonSerializerContext.Default.WorkOrderDto);
            }

            if (response.IsSuccessStatusCode)
            {
                Message.Success(_isEditing ? "Orden actualizada." : "Orden creada correctamente.");
                _modalVisible = false;
                await LoadData();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Message.Error($"No se pudo guardar: {body}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteWorkOrder(Guid id)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/workorders/{id}");
            if (response.IsSuccessStatusCode)
            {
                Message.Success("Orden eliminada correctamente.");
                await LoadData();
            }
            else
            {
                Message.Error($"Error al eliminar: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
    }
}
