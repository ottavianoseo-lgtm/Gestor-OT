@page "/workorders"
@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using GestorOT.Client.Components
@using System.Net.Http.Json
@using AntDesign
@inject HttpClient Http
@inject IMessageService Message
@inject IJSRuntime JS
@inject GestorOT.Client.Services.CampaignState CampaignState
@inject GestorOT.Client.Services.TenantState TenantState
@implements IDisposable
@inject NavigationManager Navigation

<PageTitle>Órdenes de Trabajo - GestorOT</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title">Órdenes de Trabajo</h2>
        <span class="page-subtitle">@_workOrders.Count órdenes registradas</span>
    </div>
    <Button Type="@ButtonType.Primary" OnClick="OpenCreateModal"
            Style="background: #E74C3C; border-color: #E74C3C; border-radius: 8px; font-weight: 600;">
        <Icon Type="plus" Theme="IconThemeType.Outline" /> Nueva Orden
    </Button>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <Alert Type="@AlertType.Error" Message="@_errorMessage" ShowIcon="true" Style="margin-bottom: 16px;" />
}

<AntDesign.Row Gutter="@((16, 16))" Style="margin-bottom: 16px;">
    <AntDesign.Col Xs="24" Sm="6">
        <div class="kpi-card-sm" style="border-left: 3px solid #3498DB;">
            <span class="kpi-sm-value">@_workOrders.Count</span>
            <span class="kpi-sm-label">Total</span>
        </div>
    </AntDesign.Col>
    <AntDesign.Col Xs="24" Sm="6">
        <div class="kpi-card-sm" style="border-left: 3px solid #F1C40F;">
            <span class="kpi-sm-value">@EditablesCount</span>
            <span class="kpi-sm-label">Editables</span>
        </div>
    </AntDesign.Col>
    <AntDesign.Col Xs="24" Sm="6">
        <div class="kpi-card-sm" style="border-left: 3px solid #2ECC71;">
            <span class="kpi-sm-value">@NoEditablesCount</span>
            <span class="kpi-sm-label">No editables</span>
        </div>
    </AntDesign.Col>
    <AntDesign.Col Xs="24" Sm="6">
        <div class="kpi-card-sm" style="border-left: 3px solid #E74C3C;">
            <span class="kpi-sm-value">@SinEstadoCount</span>
            <span class="kpi-sm-label">Sin estado</span>
        </div>
    </AntDesign.Col>
</AntDesign.Row>

<div class="glass-card">
    <Table TItem="WorkOrderDto" DataSource="_workOrders" Loading="_loading" Size="@TableSize.Small" ScrollX="1200"
           OnRow="GetRowAttributes">
        <PropertyColumn Property="c => c.Name" Title="Nombre" Sortable>
            <Popover Visible="@(_hoveredWoId == context.Id && !_suppressPreview)" Title="@($"Labores \u2014 {context.Name ?? context.OTNumber}")" OverlayStyle="max-width: 480px; padding: 0;">
                <ContentTemplate>
                    @if (_previewLoading.Contains(context.Id))
                    {
                        <div style="padding: 12px; text-align: center;"><Spin Size="AntDesign.SpinSize.Small" /></div>
                    }
                    else if (_laborPreviews.TryGetValue(context.Id, out var labors) && labors.Count > 0)
                    {
                        <div style="padding: 4px 0; min-width: 380px;">
                            <div style="display: grid; grid-template-columns: 1fr 1fr auto auto; gap: 4px 12px; font-size: 11px; color: rgba(255,255,255,0.4); padding: 4px 12px; border-bottom: 1px solid rgba(255,255,255,0.08); text-transform: uppercase; letter-spacing: 0.5px;">
                                <span>Tipo</span><span>Lote</span><span>Ha</span><span>Estado</span>
                            </div>
                            @foreach (var l in labors.Take(8))
                            {
                                var stColor = l.Status == "Realized" ? "#2ECC71" : l.Status == "AwaitingValidation" ? "#F1C40F" : "#3498DB";
                                var stLabel = l.Status == "Realized" ? "Real." : l.Status == "AwaitingValidation" ? "Val." : "Plan.";
                                <div style="display: grid; grid-template-columns: 1fr 1fr auto auto; gap: 4px 12px; padding: 5px 12px; border-bottom: 1px solid rgba(255,255,255,0.04); align-items: center;">
                                    <span style="color: #eee; font-size: 12px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@l.LaborTypeName</span>
                                    <span style="color: rgba(255,255,255,0.6); font-size: 12px;">@l.LotName</span>
                                    <span style="color: #fff; font-size: 12px; font-weight: 600;">@l.Hectares.ToString("N0")</span>
                                    <span style="background: @(stColor)22; color: @stColor; border: 1px solid @(stColor)44; border-radius: 10px; font-size: 10px; font-weight: 700; padding: 1px 7px;">@stLabel</span>
                                </div>
                            }
                            @if (labors.Count > 8)
                            {
                                <div style="padding: 6px 12px; font-size: 11px; color: rgba(255,255,255,0.4); text-align: center;">+ @(labors.Count - 8) más</div>
                            }
                        </div>
                    }
                    else
                    {
                        <div style="padding: 12px; color: rgba(255,255,255,0.4); font-size: 12px;">Sin labores registradas</div>
                    }
                </ContentTemplate>
                <ChildContent>
                    <span style="font-weight: 700; color: #fff;">@(context.Name ?? context.OTNumber)</span>
                </ChildContent>
            </Popover>
        </PropertyColumn>
        <PropertyColumn Property="c => c.Description" Title="Descripción">
            <span style="font-weight: 600;">@context.Description</span>
        </PropertyColumn>
        <Column TData="string" Title="Estado">
            @{
                var (color, label) = GetStatusDisplay(context.WorkOrderStatusId);
            }
            <Tag Style="@($"background: {color}20; color: {color}; border: 1px solid {color}40; border-radius: 12px; font-size: 11px; font-weight: 600; padding: 2px 10px;")">
                @label
            </Tag>
        </Column>
        <PropertyColumn Property="c => c.AssignedTo" Title="Asignado a" Sortable />
        <PropertyColumn Property="c => c.DueDate" Title="Fecha" Sortable>
            @context.DueDate.ToString("dd/MM/yyyy")
        </PropertyColumn>
        <ActionColumn Title="Acciones" Width="220">
            <div @onmouseenter="() => { _suppressPreview = true; StateHasChanged(); }" 
                 @onmouseleave="() => { _suppressPreview = false; StateHasChanged(); }"
                 style="width: 100%; height: 100%; display: flex; align-items: center;">
                <Space>
                    <SpaceItem>
                        <Button Size="@ButtonSize.Small" OnClick="() => OpenDetail(context.Id)"
                                Style="border-radius: 6px; background: #3498DB20; border-color: #3498DB40; color: #3498DB; font-size: 11px;">
                            <Icon Type="eye" Theme="IconThemeType.Outline" /> Ver
                        </Button>
                    </SpaceItem>
                    <SpaceItem>
                        <Button Size="@ButtonSize.Small" OnClick="() => OpenEditModal(context)"
                                Style="border-radius: 6px; border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.7);">
                            <Icon Type="edit" Theme="IconThemeType.Outline" />
                        </Button>
                    </SpaceItem>
                    <SpaceItem>
                        <Button Size="@ButtonSize.Small" OnClick='() => Navigation.NavigateTo($"/workorder-final/{context.Id}")'
                                Style="border-radius: 6px; background: #2ECC7120; border-color: #2ECC7140; color: #2ECC71;">
                            <Icon Type="check-circle" Theme="IconThemeType.Outline" /> Finalizar
                        </Button>
                    </SpaceItem>
                    <SpaceItem>
                        <Popconfirm Title="¿Eliminar esta orden de trabajo?"
                                    OnConfirm="() => DeleteWorkOrder(context.Id)"
                                    OkText="@("Eliminar")" CancelText="@("Cancelar")">
                            <Button Danger Size="@ButtonSize.Small" Style="border-radius: 6px;">
                                <Icon Type="delete" Theme="IconThemeType.Outline" />
                            </Button>
                        </Popconfirm>
                    </SpaceItem>
                </Space>
            </div>
        </ActionColumn>
    </Table>
</div>

<Modal Title="@(_isEditing ? "Editar Orden de Trabajo" : "Nueva Orden de Trabajo")"
       Visible="_modalVisible"
       OnCancel="CloseModal"
       OnOk="SaveWorkOrder"
       OkText="@(_isEditing ? "Guardar" : "Crear")"
       ConfirmLoading="_saving"
       Width="560">
    <Form @ref="_form" Model="_formModel" Layout="@FormLayout.Vertical">
        <FormItem Label="Nombre (opcional)">
            <Input @bind-Value="_formModel.Name" Placeholder="Ej: Siembra Lote Norte — si se deja vacío se genera automáticamente" />
        </FormItem>
        <FormItem Label="Descripción (opcional)">
            <TextArea @bind-Value="_formModel.Description" Placeholder="Notas o detalles adicionales..." AutoSize="true" />
        </FormItem>
        <AntDesign.Row Gutter="16">
            <AntDesign.Col Span="12">
                @if (!_formModel.AcceptsMultiplePeople)
                {
                    <FormItem Label="Responsable (Contacto)">
                        <Select TItem="ContactDto" TItemValue="Guid" DataSource="_availableContacts" @bind-Value="_formModel.ContactId"
                                LabelName="@nameof(ContactDto.FullName)" ValueName="@nameof(ContactDto.Id)" Placeholder="Seleccionar contacto"
                                Style="width: 100%;" EnableSearch />
                    </FormItem>
                }
            </AntDesign.Col>
            <AntDesign.Col Span="12">
                @if (!_formModel.AcceptsMultipleDates)
                {
                    <FormItem Label="Fecha">
                        <DatePicker @bind-Value="_formModel.DueDate" Style="width: 100%;" Format="dd/MM/yyyy" />
                    </FormItem>
                }
            </AntDesign.Col>
        </AntDesign.Row>
        <AntDesign.Row Gutter="16">
            <AntDesign.Col Span="12">
                <FormItem Label="Estado">
                    @if (_loadingStatuses)
                    {
                        <Spin Size="AntDesign.SpinSize.Small" />
                    }
                    else if (_workOrderStatuses.Count > 0)
                    {
                        <Select TItem="WorkOrderStatusDto" TItemValue="Guid"
                                DataSource="_workOrderStatuses"
                                @bind-Value="WorkOrderStatusIdBind"
                                LabelName="@nameof(WorkOrderStatusDto.Name)"
                                ValueName="@nameof(WorkOrderStatusDto.Id)"
                                Style="width: 100%;" />
                    }
                    else
                    {
                        <Alert Type="@AlertType.Error" Message="No hay estados de OT configurados. Cree al menos un estado inicial en Administración > Estados de OT." ShowIcon="true" />
                    }
                </FormItem>
            </AntDesign.Col>
            <AntDesign.Col Span="12">
                <div style="display: flex; gap: 8px; height: 100%; align-items: center; padding-top: 24px;">
                    <Checkbox @bind-Checked="_formModel.AcceptsMultiplePeople" OnChange="() => StateHasChanged()">Mult. Pers.</Checkbox>
                    <Checkbox @bind-Checked="_formModel.AcceptsMultipleDates" OnChange="() => StateHasChanged()">Mult. Fechas</Checkbox>
                </div>
            </AntDesign.Col>
        </AntDesign.Row>
    </Form>
</Modal>

<style>
    .kpi-card-sm {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 10px;
        padding: 14px 18px;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .kpi-sm-value {
        font-size: 22px;
        font-weight: 700;
        color: #fff;
    }
    .kpi-sm-label {
        font-size: 12px;
        color: rgba(255,255,255,0.5);
    }
</style>

@code {
    private List<WorkOrderDto> _workOrders = new();
    private List<ContactDto> _availableContacts = new();
    private List<WorkOrderStatusDto> _workOrderStatuses = new();
    private bool _loading;
    private bool _loadingStatuses;
    private string? _errorMessage;

    // Labor preview popover state
    private Dictionary<Guid, List<LaborDto>> _laborPreviews = new();
    private HashSet<Guid> _previewLoading = new();
    private Guid? _hoveredWoId;
    private bool _suppressPreview;

    private Dictionary<string, object> GetRowAttributes(RowData<WorkOrderDto> row) => new()
    {
        { "onmouseenter", EventCallback.Factory.Create<MouseEventArgs>(this, async () => await OnRowHover(row.Data.Id)) },
        { "onmouseleave", EventCallback.Factory.Create<MouseEventArgs>(this, _ => OnRowLeave()) }
    };

    private async Task OnRowHover(Guid woId)
    {
        _suppressPreview = false;
        _hoveredWoId = woId;
        await LoadLaborPreview(woId);
        StateHasChanged();
    }

    private void OnRowLeave()
    {
        _hoveredWoId = null;
        StateHasChanged();
    }

    private async Task LoadLaborPreview(Guid workOrderId)
    {
        if (_laborPreviews.ContainsKey(workOrderId)) return; // already cached
        _previewLoading.Add(workOrderId);
        StateHasChanged();
        try
        {
            var detail = await Http.GetFromJsonAsync<WorkOrderDetailDto>(
                $"api/workorders/{workOrderId}",
                AppJsonSerializerContext.Default.WorkOrderDetailDto);
            _laborPreviews[workOrderId] = detail?.Labors ?? new();
        }
        catch
        {
            _laborPreviews[workOrderId] = new();
        }
        finally
        {
            _previewLoading.Remove(workOrderId);
            StateHasChanged();
        }
    }

    private bool _modalVisible;
    private bool _saving;
    private bool _isEditing;
    private Guid _editingId;
    private WoFormModel _formModel = new();
    private Form<WoFormModel>? _form;

    private Guid WorkOrderStatusIdBind
    {
        get => _formModel.WorkOrderStatusId ?? Guid.Empty;
        set => _formModel.WorkOrderStatusId = value == Guid.Empty ? null : value;
    }

    public class WoFormModel
    {
        public string? Name { get; set; }

        public string? Description { get; set; }
        
        public Guid CampaignId { get; set; }
        public Guid ContactId { get; set; }
        public DateTime DueDate { get; set; } = DateTime.Today.AddDays(7);
        public Guid? WorkOrderStatusId { get; set; }
        public bool AcceptsMultiplePeople { get; set; }
        public bool AcceptsMultipleDates { get; set; }
    }

    private int EditablesCount => _workOrders.Count(w => 
        w.WorkOrderStatusId.HasValue && w.WorkOrderStatusId != Guid.Empty &&
        _workOrderStatuses.Any(s => s.Id == w.WorkOrderStatusId.Value && s.IsEditable));

    private int NoEditablesCount => _workOrders.Count(w => 
        w.WorkOrderStatusId.HasValue && w.WorkOrderStatusId != Guid.Empty &&
        _workOrderStatuses.Any(s => s.Id == w.WorkOrderStatusId.Value && !s.IsEditable));

    private int SinEstadoCount => _workOrders.Count(w => 
        w.WorkOrderStatusId == null || w.WorkOrderStatusId == Guid.Empty);

    private (string ColorHex, string Name) GetStatusDisplay(Guid? workOrderStatusId)
    {
        if (workOrderStatusId == null || workOrderStatusId == Guid.Empty)
            return ("#E74C3C", "Sin estado");
        
        var status = _workOrderStatuses.FirstOrDefault(s => s.Id == workOrderStatusId.Value);
        if (status == null)
            return ("#E74C3C", "Pendiente");
        
        return (status.ColorHex, status.Name);
    }

    protected override async Task OnInitializedAsync()
    {
        CampaignState.OnChange += OnCampaignChanged;
        TenantState.OnChange += OnCampaignChanged;
        await Task.WhenAll(LoadData(), LoadStatuses());
    }

    private async Task LoadStatuses()
    {
        _loadingStatuses = true;
        try
        {
            _workOrderStatuses = await Http.GetFromJsonAsync<List<WorkOrderStatusDto>>(
                "api/workorderstatuses",
                AppJsonSerializerContext.Default.ListWorkOrderStatusDto) ?? new();
        }
        catch (HttpRequestException ex)
        {
            _workOrderStatuses = new();
            Message.Error($"No se pudieron cargar los estados de OT: {ex.Message}");
        }
        catch (Exception ex)
        {
            _workOrderStatuses = new();
            Message.Error($"Error inesperado al cargar estados de OT: {ex.Message}");
        }
        finally
        {
            _loadingStatuses = false;
        }
    }

    private void OnCampaignChanged()
    {
        InvokeAsync(async () => { await LoadData(); StateHasChanged(); });
    }

    public void Dispose()
    {
        CampaignState.OnChange -= OnCampaignChanged;
        TenantState.OnChange -= OnCampaignChanged;
    }

    private async Task LoadData()
    {
        try
        {
            _loading = true;
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));
            var ordersTask = Http.GetFromJsonAsync("api/workorders",
                AppJsonSerializerContext.Default.ListWorkOrderDto, cts.Token);
            var contactsTask = Http.GetFromJsonAsync("api/catalogs/contacts",
                AppJsonSerializerContext.Default.ListContactDto, cts.Token);

            await Task.WhenAll(ordersTask, contactsTask);

            _workOrders = await ordersTask ?? new();
            _availableContacts = await contactsTask ?? new();
            _errorMessage = null;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void OpenDetail(Guid workOrderId)
    {
        Navigation.NavigateTo($"/workorders/{workOrderId}");
    }

    private void OpenCreateModal()
    {
        _errorMessage = null;

        if (CampaignState.CurrentCampaign == null)
        {
            _errorMessage = "Seleccione una campaña activa para crear una OT.";
            return;
        }

        if (CampaignState.IsLocked)
        {
            _errorMessage = "La campaña está bloqueada. Solo consulta.";
            return;
        }

        _isEditing = false;
        _formModel = new WoFormModel();

        var defaultStatus = _workOrderStatuses.FirstOrDefault(s => s.IsDefault)
                           ?? _workOrderStatuses.OrderBy(s => s.SortOrder).FirstOrDefault();
        _formModel.WorkOrderStatusId = defaultStatus?.Id;

        _formModel.CampaignId = CampaignState.CurrentCampaign.Id;

        _modalVisible = true;
    }

    private void OpenEditModal(WorkOrderDto wo)
    {
        _errorMessage = null;

        if (wo.CampaignId.HasValue && CampaignState.IsLocked)
        {
            _errorMessage = "La campaña está bloqueada. Solo consulta.";
            return;
        }

        if (wo.IsLocked)
        {
            _errorMessage = "Esta orden no permite modificaciones.";
            return;
        }

        _isEditing = true;
        _editingId = wo.Id;
        _formModel = new WoFormModel
        {
            Name = wo.Name,
            Description = wo.Description,
            CampaignId = wo.CampaignId ?? Guid.Empty,
            ContactId = wo.ContactId ?? Guid.Empty,
            DueDate = wo.DueDate,
            WorkOrderStatusId = wo.WorkOrderStatusId,
            AcceptsMultiplePeople = wo.AcceptsMultiplePeople,
            AcceptsMultipleDates = wo.AcceptsMultipleDates
        };
        _modalVisible = true;
    }

    private void CloseModal()
    {
        _modalVisible = false;
    }

    private async Task SaveWorkOrder()
    {
        if (_saving) return;

        if (!_formModel.AcceptsMultiplePeople && _formModel.ContactId == Guid.Empty)
        {
            Message.Warning("Debe seleccionar un responsable (Contacto) o marcar 'Mult. Pers.'");
            return;
        }

        _saving = true;
        try
        {
            var selectedStatus = _formModel.WorkOrderStatusId.HasValue && _formModel.WorkOrderStatusId != Guid.Empty
                ? _workOrderStatuses.FirstOrDefault(s => s.Id == _formModel.WorkOrderStatusId.Value)
                : null;
            var dto = new WorkOrderDto
            {
                Id = _isEditing ? _editingId : Guid.Empty,
                Name = string.IsNullOrWhiteSpace(_formModel.Name) ? null : _formModel.Name.Trim(),
                CampaignId = _formModel.CampaignId != Guid.Empty ? _formModel.CampaignId : null,
                Description = _formModel.Description,
                Status = selectedStatus?.Name ?? string.Empty,
                WorkOrderStatusId = selectedStatus?.Id,
                ContactId = _formModel.ContactId,
                OTNumber = _isEditing ? null : $"OT_{Guid.NewGuid().ToString().Substring(0, 5).ToUpper()}",
                DueDate = _formModel.DueDate,
                AcceptsMultiplePeople = _formModel.AcceptsMultiplePeople,
                AcceptsMultipleDates = _formModel.AcceptsMultipleDates
            };

            HttpResponseMessage response;
            if (_isEditing)
            {
                response = await Http.PutAsJsonAsync($"api/workorders/{_editingId}",
                    dto, AppJsonSerializerContext.Default.WorkOrderDto);
            }
            else
            {
                response = await Http.PostAsJsonAsync("api/workorders",
                    dto, AppJsonSerializerContext.Default.WorkOrderDto);
            }

            if (response.IsSuccessStatusCode)
            {
                Message.Success(_isEditing ? "Orden actualizada." : "Orden creada correctamente.");
                _modalVisible = false;
                await LoadData();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Message.Error($"No se pudo guardar: {body}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteWorkOrder(Guid id)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/workorders/{id}");
            if (response.IsSuccessStatusCode)
            {
                Message.Success("Orden eliminada correctamente.");
                await LoadData();
            }
            else
            {
                Message.Error($"Error al eliminar: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
    }
}
