@page "/"
@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using System.Net.Http.Json
@using System.Text.Json
@using AntDesign
@inject HttpClient Http
@inject IJSRuntime JS
@inject IMessageService Message
@inject GestorOT.Client.Services.CampaignState CampaignState
@inject GestorOT.Client.Services.TenantState TenantState
@inject GestorOT.Client.Services.DashboardState DashboardState
@implements IAsyncDisposable
@implements IDisposable

<PageTitle>Command Center - GestorOT</PageTitle>

<div class="dashboard-immersive">
    <div id="dashboardMap" class="dashboard-map-bg"></div>

    <div class="dashboard-gradient-overlay"></div>

    <div class="dashboard-content">
        <div class="dashboard-header">
            <div class="dashboard-sync">
                <div class="sync-indicator @(_isConnected ? "sync-online" : "sync-offline")"></div>
                <span class="sync-text">@(_isConnected ? "En Vivo" : "Sin conexión")</span>
                <span class="sync-time">@_lastSync</span>
                <Tooltip Title="Forzar Sincronización">
                    <Button Type="@ButtonType.Text" Icon="sync" Size="@ButtonSize.Small" OnClick="ForceSync" Loading="_isFetching" Style="color: rgba(255,255,255,0.7);" />
                </Tooltip>
            </div>
        </div>

        <div class="widgets-container">
            <div class="widgets-column">
                <div class="widget-glass widget-hero">
                    <div class="hero-icon">
                        <Icon Type="appstore" Theme="IconThemeType.Fill" Style="font-size: 28px; color: #2ECC71;" />
                    </div>
                    <div class="hero-value">@_stats.LotsCount</div>
                    <div class="hero-label">Total Lotes</div>
                    <div class="hero-sub">@_stats.ActiveLotsCount Activos</div>
                </div>

                <div class="widget-glass widget-stats">
                    <div class="stats-title">Quick Stats</div>

                    <div class="stat-row">
                        <span class="stat-label">Hectáreas Productivas</span>
                        <span class="stat-value">@_stats.TotalProductiveArea.ToString("N0") ha</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Campos Activos</span>
                        <span class="stat-value">@_stats.FieldsCount</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">OT Abiertas</span>
                        <span class="stat-value stat-alert">@(_stats.PendingWorkOrders + _stats.InProgressWorkOrders)</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">OT En Progreso</span>
                        <span class="stat-value stat-warning">@_stats.InProgressWorkOrders</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">OT Completadas</span>
                        <span class="stat-value stat-success">@_stats.CompletedWorkOrders</span>
                    </div>
                </div>

                <div class="widget-glass widget-system">
                    <div class="stats-title">Estado del Sistema</div>
                    <div class="stat-row">
                        <span class="stat-label">Servidor API</span>
                        @{ var connClass = _isConnected ? "badge-success" : "badge-error"; }
                        <span class="stat-badge @connClass">@(_isConnected ? "Conectado" : "Error")</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">PostGIS</span>
                        <span class="stat-badge badge-success">Habilitado</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Última Sync</span>
                        <span class="stat-value">@_lastSync</span>
                    </div>
                </div>
            </div>

            <div class="widgets-column widgets-column-right">
                @if (_recentOrders.Any())
                {
                    <div class="widget-glass widget-orders">
                        <div class="orders-header">
                            <span class="stats-title">Órdenes Recientes</span>
                            <a href="/workorders" class="orders-link">Ver todas →</a>
                        </div>
                        @foreach (var order in _recentOrders.Take(5))
                        {
                            var (dotColor, statusLabel) = order.Status switch
                            {
                                "Completed" => ("#2ECC71", "Completada"),
                                "InProgress" => ("#F1C40F", "En Progreso"),
                                _ => ("#E74C3C", "Pendiente")
                            };
                            <div class="order-item">
                                <div class="order-dot" style="background: @dotColor;"></div>
                                <div class="order-info">
                                    <span class="order-desc">@order.Description</span>
                                    <span class="order-meta">@order.FieldName · @order.AssignedTo</span>
                                </div>
                                <span class="order-status" style="color: @dotColor;">@statusLabel</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .dashboard-immersive {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        width: 100vw;
        height: 100vh;
        z-index: 0;
        overflow: hidden;
    }

    .dashboard-map-bg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
        min-height: 100%;
        pointer-events: auto;
    }

    .dashboard-map-bg .leaflet-container {
        width: 100% !important;
        height: 100% !important;
    }

    .dashboard-map-bg .leaflet-tile-pane {
        filter: brightness(0.7) saturate(1.2);
    }

    .dashboard-map-bg .leaflet-control-zoom {
        border: 1px solid rgba(255,255,255,0.15) !important;
        border-radius: 10px !important;
        overflow: hidden;
        background: rgba(30, 30, 46, 0.5) !important;
        backdrop-filter: blur(10px);
    }

    .dashboard-map-bg .leaflet-control-zoom a {
        background: transparent !important;
        color: rgba(255,255,255,0.8) !important;
        border-bottom: 1px solid rgba(255,255,255,0.1) !important;
        width: 36px !important;
        height: 36px !important;
        line-height: 36px !important;
        font-size: 18px !important;
    }

    .dashboard-map-bg .leaflet-control-zoom a:hover {
        background: rgba(255,255,255,0.1) !important;
        color: #fff !important;
    }

    .dashboard-map-bg .leaflet-control-zoom a:last-child {
        border-bottom: none !important;
    }

    .dashboard-gradient-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 2;
        pointer-events: none;
        background:
            linear-gradient(90deg, rgba(15, 15, 26, 0.4) 0%, rgba(15, 15, 26, 0.25) 35%, rgba(15, 15, 26, 0.1) 65%, transparent 100%),
            linear-gradient(180deg, rgba(15, 15, 26, 0.3) 0%, transparent 30%, transparent 70%, rgba(15, 15, 26, 0.4) 100%);
    }

    .dashboard-content {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 3;
        display: flex;
        flex-direction: column;
        padding: 20px 28px 20px 290px;
        pointer-events: none;
    }

    .dashboard-content > * {
        pointer-events: none;
    }

    .dashboard-content .widget-glass,
    .dashboard-content .dashboard-sync,
    .dashboard-content .kpi-mini-card {
        pointer-events: auto;
    }

    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        padding-left: 4px;
    }

    .dashboard-title-group {
        display: flex;
        flex-direction: column;
    }

    .dashboard-title {
        margin: 0;
        font-size: 28px;
        font-weight: 800;
        color: #FFFFFF;
        letter-spacing: 3px;
        line-height: 1;
    }

    .dashboard-subtitle {
        font-size: 12px;
        color: rgba(255,255,255,0.45);
        letter-spacing: 1px;
        margin-top: 4px;
        font-weight: 500;
    }

    .dashboard-sync {
        display: flex;
        align-items: center;
        gap: 8px;
        background: rgba(30, 30, 46, 0.20);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 20px;
        padding: 8px 16px;
    }

    .sync-indicator {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        animation: pulse 2s infinite;
    }

    .sync-online {
        background: #2ECC71;
        box-shadow: 0 0 8px rgba(46, 204, 113, 0.6);
    }

    .sync-offline {
        background: #E74C3C;
        box-shadow: 0 0 8px rgba(231, 76, 60, 0.6);
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
    }

    .sync-text {
        font-size: 12px;
        font-weight: 600;
        color: rgba(255,255,255,0.8);
    }

    .sync-time {
        font-size: 11px;
        color: rgba(255,255,255,0.4);
    }

    .widgets-container {
        display: flex;
        gap: 20px;
        flex: 1;
        overflow: hidden;
    }

    .widgets-column {
        display: flex;
        flex-direction: column;
        gap: 16px;
        width: 320px;
        flex-shrink: 0;
    }

    .widgets-column-right {
        width: 380px;
    }

    .widget-glass {
        background: rgba(30, 30, 46, 0.20);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 16px;
        padding: 20px;
        transition: all 0.3s ease;
    }

    .widget-glass:hover {
        border-color: rgba(255,255,255,0.18);
        box-shadow: 0 8px 32px rgba(0,0,0,0.3);
    }

    .widget-hero {
        text-align: center;
        padding: 28px 20px;
    }

    .hero-icon {
        width: 56px;
        height: 56px;
        background: rgba(46, 204, 113, 0.12);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
    }

    .hero-value {
        font-size: 52px;
        font-weight: 800;
        color: #FFFFFF;
        line-height: 1;
        letter-spacing: -2px;
    }

    .hero-label {
        font-size: 14px;
        color: rgba(255,255,255,0.5);
        margin-top: 6px;
        font-weight: 600;
    }

    .hero-sub {
        font-size: 12px;
        color: #2ECC71;
        margin-top: 4px;
        font-weight: 500;
    }

    .stats-title {
        font-size: 14px;
        font-weight: 700;
        color: #FFFFFF;
        margin-bottom: 14px;
        letter-spacing: 0.3px;
    }

    .stat-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .stat-row:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .stat-label {
        font-size: 13px;
        color: rgba(255,255,255,0.5);
        font-weight: 500;
    }

    .stat-value {
        font-size: 14px;
        color: rgba(255,255,255,0.9);
        font-weight: 700;
    }

    .stat-alert {
        color: #E74C3C !important;
    }

    .stat-warning {
        color: #F1C40F !important;
    }

    .stat-success {
        color: #2ECC71 !important;
    }

    .stat-badge {
        font-size: 11px;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 12px;
    }

    .badge-success {
        background: rgba(46, 204, 113, 0.15);
        color: #2ECC71;
        border: 1px solid rgba(46, 204, 113, 0.3);
    }

    .badge-error {
        background: rgba(231, 76, 60, 0.15);
        color: #E74C3C;
        border: 1px solid rgba(231, 76, 60, 0.3);
    }

    .kpi-row-widget {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 20px;
    }

    .kpi-mini {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .kpi-mini-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .kpi-mini-data {
        display: flex;
        flex-direction: column;
    }

    .kpi-mini-value {
        font-size: 20px;
        font-weight: 800;
        color: #FFFFFF;
        line-height: 1;
    }

    .kpi-mini-label {
        font-size: 10px;
        color: rgba(255,255,255,0.4);
        font-weight: 600;
        margin-top: 2px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .kpi-mini-divider {
        width: 1px;
        height: 36px;
        background: rgba(255,255,255,0.1);
    }

    .orders-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
    }

    .orders-link {
        font-size: 12px;
        color: #E74C3C;
        text-decoration: none;
        font-weight: 600;
    }

    .orders-link:hover {
        color: #ff6b5e;
    }

    .order-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 0;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .order-item:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .order-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .order-info {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-width: 0;
    }

    .order-desc {
        font-size: 13px;
        color: rgba(255,255,255,0.85);
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .order-meta {
        font-size: 11px;
        color: rgba(255,255,255,0.35);
        margin-top: 2px;
    }

    .order-status {
        font-size: 11px;
        font-weight: 700;
        flex-shrink: 0;
    }
</style>

@code {
    private DashboardStatsDto _stats = new();
    private List<RecentWorkOrderDto> _recentOrders = new();
    private bool _isConnected = false;
    private string _lastSync = "Cargando...";
    private string? _errorMessage;
    private bool _mapInitialized = false;

    protected override async Task OnInitializedAsync()
    {
        CampaignState.OnChange += OnCampaignChanged;
        TenantState.OnChange += OnCampaignChanged;
        
        if (DashboardState.Initialized)
        {
            _stats = DashboardState.Stats!;
            _recentOrders = DashboardState.RecentOrders!;
            _isConnected = true;
            _lastSync = DashboardState.LastSync?.ToString("HH:mm:ss") ?? "Reciente";
        }
        else
        {
            await LoadData();
        }
    }

    private bool _isFetching = false;

    private async Task ForceSync()
    {
        DashboardState.Clear();
        await LoadData();
    }

    private async Task LoadData()
    {
        if (_isFetching) return;
        _isFetching = true;

        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(45));

            var statsTask = Http.GetFromJsonAsync("api/dashboard/stats",
                AppJsonSerializerContext.Default.DashboardStatsDto, cts.Token);
            var ordersTask = Http.GetFromJsonAsync("api/dashboard/recent-orders",
                AppJsonSerializerContext.Default.ListRecentWorkOrderDto, cts.Token);
            var geoJsonTask = Http.GetFromJsonAsync("api/lots/geojson",
                AppJsonSerializerContext.Default.GeoJsonFeatureCollection, cts.Token);

            await Task.WhenAll(statsTask, ordersTask, geoJsonTask);

            _stats = statsTask.Result ?? new();
            _recentOrders = ordersTask.Result ?? new();
            var geoJson = geoJsonTask.Result;

            DashboardState.SetData(_stats, _recentOrders, geoJson);

            _isConnected = true;
            _lastSync = DateTime.Now.ToString("HH:mm:ss");
        }
        catch (OperationCanceledException)
        {
            _errorMessage = "Timeout de conexión al obtener datos.";
            _isConnected = false;
            Message.Error("No se pudo conectar con el servidor. Verifique su conexión.");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
            _isConnected = false;
            _lastSync = "Error";
            Message.Error($"Error al cargar el dashboard: {ex.Message}");
        }
        finally
        {
            _isFetching = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_mapInitialized)
        {
            _mapInitialized = true;
            try
            {
                await Task.Delay(200);
                await JS.InvokeVoidAsync("mapInterop.initDashboardMap", "dashboardMap", -34.6, -58.4, 6);

                var geojson = DashboardState.CachedGeoJson;

                if (geojson?.Features != null)
                {
                    foreach (var feature in geojson.Features)
                    {
                        if (feature.Geometry?.Coordinates != null)
                        {
                            var leafletCoords = feature.Geometry.Coordinates[0]
                                .Select(c => new double[] { c[1], c[0] })
                                .ToArray();
                            var coordsJson = JsonSerializer.Serialize(leafletCoords);
                            var status = feature.Properties?.ContainsKey("status") == true
                                ? feature.Properties["status"]?.ToString() ?? "Active"
                                : "Active";
                            await JS.InvokeVoidAsync("mapInterop.addDashboardLotPolygon", coordsJson, status);
                        }
                    }
                    await JS.InvokeVoidAsync("mapInterop.fitDashboardLots");
                }
            }
            catch
            {
                // JS interop for map init can fail if the DOM element is not ready.
                // Non-critical: dashboard works without map background.
            }
        }
    }

    private void OnCampaignChanged()
    {
        // Always clear cache when campaign/tenant changes so LoadData fetches fresh data (#17)
        DashboardState.Clear();
        InvokeAsync(async () =>
        {
            await LoadData();
            // Reload dashboard map with lots for the new context
            await ReloadDashboardMap();
            StateHasChanged();
        });
    }

    private async Task ReloadDashboardMap()
    {
        try
        {
            await JS.InvokeVoidAsync("mapInterop.destroyDashboardMap");
            _mapInitialized = false;
            await Task.Delay(100);
            await JS.InvokeVoidAsync("mapInterop.initDashboardMap", "dashboardMap", -34.6, -58.4, 6);

            var geojson = DashboardState.CachedGeoJson;
            if (geojson?.Features != null)
            {
                foreach (var feature in geojson.Features)
                {
                    if (feature.Geometry?.Coordinates != null)
                    {
                        var leafletCoords = feature.Geometry.Coordinates[0]
                            .Select(c => new double[] { c[1], c[0] })
                            .ToArray();
                        var coordsJson = System.Text.Json.JsonSerializer.Serialize(leafletCoords);
                        var status = feature.Properties?.ContainsKey("status") == true
                            ? feature.Properties["status"]?.ToString() ?? "Active"
                            : "Active";
                        await JS.InvokeVoidAsync("mapInterop.addDashboardLotPolygon", coordsJson, status);
                    }
                }
                await JS.InvokeVoidAsync("mapInterop.fitDashboardLots");
            }

            _mapInitialized = true;
        }
        catch
        {
            // Map reload failures are non-critical; do not surface to user
        }
    }

    public void Dispose()
    {
        CampaignState.OnChange -= OnCampaignChanged;
        TenantState.OnChange -= OnCampaignChanged;
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("mapInterop.destroyDashboardMap");
        }
        catch
        {
            // Disposing after navigation: JS runtime may already be gone — safe to ignore.
        }
    }
}
