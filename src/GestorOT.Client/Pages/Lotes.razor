@page "/lots"
@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using System.Net.Http.Json
@using AntDesign
@using AntDesign.TableModels
@inject HttpClient Http
@inject IMessageService Message
@inject NavigationManager Nav
@inject GestorOT.Client.Services.CampaignState CampaignState
@inject GestorOT.Client.Services.TenantState TenantState
@implements IDisposable

<PageTitle>Lotes - GestorOT</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title">Gestión de Lotes</h2>
        <span class="page-subtitle">@_lots.Count lotes registrados</span>
    </div>
    <div style="display: flex; align-items: center; gap: 16px;">
        @if (CampaignState.IsSelected)
        {
            <div style="display: flex; align-items: center; gap: 8px; background: rgba(46, 204, 113, 0.1); padding: 6px 12px; border-radius: 8px; border: 1px solid rgba(46, 204, 113, 0.2);">
                <Icon Type="calendar" Theme="IconThemeType.Outline" Style="color: #2ECC71;" />
                <span style="color: #fff; font-size: 13px; font-weight: 600;">Campaña: @CampaignState.CurrentCampaign!.Name</span>
                <Checkbox @bind-Checked="_filterByCampaign" Style="margin-left: 8px; color: rgba(255,255,255,0.7); font-size: 12px;">Ver solo mis lotes</Checkbox>
            </div>
        }
        <Button Type="@ButtonType.Primary" OnClick="OpenCreateModal"
                Style="background: #E74C3C; border-color: #E74C3C; border-radius: 8px; font-weight: 600;">
            <Icon Type="plus" Theme="IconThemeType.Outline" /> Nuevo Lote
        </Button>
    </div>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <Alert Type="@AlertType.Error" Message="@_errorMessage" ShowIcon="true" Style="margin-bottom: 16px;" />
}

<div class="summary-bar" style="display: flex; gap: 24px; background: rgba(255,255,255,0.03); padding: 16px 24px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.08); margin-bottom: 16px;">
    <div class="summary-item">
        <div style="font-size: 11px; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">Total Catastral</div>
        <div style="font-size: 18px; font-weight: 700; color: #fff;">@FilteredLots.Sum(l => (decimal)l.CadastralArea).ToString("N2") ha</div>
    </div>
    @if (CampaignState.IsSelected)
    {
        <div class="summary-item">
            <div style="font-size: 11px; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">Total Productiva</div>
            <div style="font-size: 18px; font-weight: 700; color: #2ECC71;">@_campaignLots.Sum(l => l.ProductiveArea).ToString("N2") ha</div>
        </div>
        <div class="summary-item">
            <div style="font-size: 11px; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">Variación Total</div>
            @{
                var totalVari = _campaignLots.Sum(l => l.ProductiveArea) - FilteredLots.Where(l => _campaignLots.Any(cl => cl.LotId == l.Id)).Sum(l => (decimal)l.CadastralArea);
                var variColor = totalVari < 0 ? "#E74C3C" : (totalVari > 0 ? "#2ECC71" : "#fff");
            }
            <div style="font-size: 18px; font-weight: 700; color: @variColor;">@(totalVari > 0 ? "+" : "")@totalVari.ToString("N2") ha</div>
        </div>
    }
    <div class="summary-item">
        <div style="font-size: 11px; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">Cant. Lotes</div>
        <div style="font-size: 18px; font-weight: 700; color: #fff;">@FilteredLots.Count()</div>
    </div>
</div>

<div class="glass-card">
    <Table TItem="LotDto" DataSource="FilteredLots" Loading="_loading" Size="@TableSize.Small"
           ScrollX="1200" OnExpand="OnExpandLot">
        <ExpandTemplate Context="lot">
            <div style="padding: 16px; background: rgba(0,0,0,0.2); border-radius: 8px;">
                <h4 style="color: #fff; margin-bottom: 12px;">Historial de Superficies por Campaña</h4>
                @if (_historyByLot.TryGetValue(lot.Data.Id, out var history))
                {
                    <Table TItem="SurfaceHistoryDto" DataSource="history" Size="TableSize.Small" PageSize="10" HidePagination>
                        <PropertyColumn Property="h => h.CampaignName" Title="Campaña" />
                        <PropertyColumn Property="h => h.StartDate" Title="Inicio" />
                        <PropertyColumn Property="h => h.CadastralArea" Title="Sup. Catastral" />
                        <PropertyColumn Property="h => h.ProductiveArea" Title="Sup. Productiva" />
                        <PropertyColumn Property="h => h.Variation" Title="Variación">
                            @{
                                var h = context;
                                var color = h.Variation < 0 ? "#E74C3C" : (h.Variation > 0 ? "#2ECC71" : "#fff");
                            }
                            <span style="color: @color; font-weight: 600;">@(h.Variation > 0 ? "+" : "")@h.Variation.ToString("N2") ha</span>
                        </PropertyColumn>
                    </Table>
                }
                else
                {
                    <div style="text-align: center; padding: 10px; color: rgba(255,255,255,0.4);">
                        Cargando historial...
                    </div>
                }
            </div>
        </ExpandTemplate>
        <ChildContent>
            <PropertyColumn Property="c => c.Name" Title="Nombre" Sortable>
                <span style="font-weight: 600;">@context.Name</span>
            </PropertyColumn>
            <PropertyColumn Property="c => c.FieldName" Title="Campo" Sortable />
            <PropertyColumn Property="c => c.Status" Title="Estado">
                <Tag Color="@(context.Status == "Active" ? TagColor.Green : TagColor.Red)" Style="border-radius: 12px; font-size: 11px; padding: 2px 10px;">
                    @(context.Status == "Active" ? "Activo" : "Inactivo")
                </Tag>
            </PropertyColumn>
            <PropertyColumn Property="c => c.CadastralArea" Title="Área Catastral (ha)">
                <span style="font-weight: 600;">@context.CadastralArea.ToString("N2") ha</span>
            </PropertyColumn>
            @if (CampaignState.IsSelected)
            {
                <Column TData="decimal" Title="Área Productiva (ha)">
                    @{
                        var cl = _campaignLots.FirstOrDefault(x => x.LotId == context.Id);
                        if (cl != null)
                        {
                            <span>@cl.ProductiveArea.ToString("N2") ha</span>
                        }
                        else
                        {
                            <span style="color: rgba(255,255,255,0.3);">—</span>
                        }
                    }
                </Column>
                <Column TData="decimal" Title="Variación">
                    @{
                        var clv = _campaignLots.FirstOrDefault(x => x.LotId == context.Id);
                        if (clv != null)
                        {
                            var vari = clv.ProductiveArea - context.CadastralArea;
                            var colorv = vari < 0 ? "#E74C3C" : (vari > 0 ? "#2ECC71" : "rgba(255,255,255,0.3)");
                            <span style="color: @colorv; font-weight: 600;">@(vari > 0 ? "+" : "")@vari.ToString("N2") ha</span>
                        }
                    }
                </Column>
            }
            <ActionColumn Title="Geometría">
                @{
                    var hasGeometry = !string.IsNullOrEmpty(context.WktGeometry);
                }
                @if (hasGeometry)
                {
                    <Tag Color="@TagColor.Blue" Style="border-radius: 12px; font-size: 11px; padding: 2px 10px;">
                        Con geometría
                    </Tag>
                }
                else
                {
                    <a href="/mapa" class="ant-tag ant-tag-red" style="border-radius: 12px; font-size: 11px; padding: 2px 10px; cursor: pointer;">
                        Sin geometría (Configurar)
                    </a>
                }
            </ActionColumn>
            <ActionColumn Title="Acciones" Width="160">
                <Space>
                    <SpaceItem>
                        <Button Size="@ButtonSize.Small" OnClick="() => OpenEditModal(context)"
                                Style="border-radius: 6px; border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.7);">
                            <Icon Type="edit" Theme="IconThemeType.Outline" />
                        </Button>
                    </SpaceItem>
                    <SpaceItem>
                        <Popconfirm Title="¿Eliminar este lote? Se eliminarán las OTs asociadas."
                                    OnConfirm="() => DeleteLot(context.Id)"
                                    OkText="Eliminar" CancelText="Cancelar">
                            <Button Danger Size="@ButtonSize.Small" Style="border-radius: 6px;">
                                <Icon Type="delete" Theme="IconThemeType.Outline" />
                            </Button>
                        </Popconfirm>
                    </SpaceItem>
                </Space>
            </ActionColumn>
        </ChildContent>
    </Table>
</div>

<Modal Title="@(_isEditing ? "Editar Lote" : "Nuevo Lote")"
       Visible="_modalVisible"
       OnCancel="CloseModal"
       Footer="null"
       Width="520"
       BodyStyle="background: #1E1E2E; padding: 24px; color: #fff;">
    <div style="font-size: 16px; font-weight: 700; color: #fff; margin-bottom: 24px;">@(_isEditing ? "Editar Lote" : "Nuevo Lote")</div>

    <div style="display: grid; gap: 20px;">
        <div>
            <label style="display: block; color: rgba(255,255,255,0.6); font-size: 13px; margin-bottom: 8px;">Nombre de Lote</label>
            <Input @bind-Value="_formModel.Name" Placeholder="Nombre" 
                   Style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15); border-radius: 12px; height: 42px; color: #fff;" />
        </div>

        <div>
            <label style="display: block; color: rgba(255,255,255,0.6); font-size: 13px; margin-bottom: 8px;">Campo</label>
            <Select TItem="FieldDto" TItemValue="Guid" DataSource="_availableFields" @bind-Value="_formModel.FieldId"
                    LabelName="@nameof(FieldDto.Name)" ValueName="@nameof(FieldDto.Id)" Placeholder="Campo"
                    Style="width: 100%;" EnableSearch />
        </div>

        @if (_isEditing)
        {
            <div>
                <div style="font-weight: 700; color: #fff; margin-bottom: 12px; font-size: 14px;">Campañas Asignadas</div>
                <div style="display: grid; gap: 8px;">
                    <div style="display: grid; grid-template-columns: 1fr 60px 40px 85px; gap: 8px; font-size: 11px; color: rgba(255,255,255,0.4); text-transform: uppercase; padding: 0 4px;">
                        <span>Campaña</span>
                        <span>Ha</span>
                        <span></span>
                        <span></span>
                    </div>

                    @foreach (var c in _lotCampaigns)
                    {
                        <div style="display: grid; grid-template-columns: 1fr 80px 40px 85px; gap: 8px; align-items: center;">
                            <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 8px 12px; color: #fff; font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                @c.LotName
                            </div>
                            <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 4px; display: flex; align-items: center;">
                                <AntDesign.InputNumber TValue="decimal" Value="@c.ProductiveArea" 
                                           ValueChanged="@((decimal v) => UpdateCampaignLotArea(c, v))"
                                           Size="InputSize.Small" Bordered="false"
                                           Style="width: 100%; background: transparent; color: #2ECC71; font-weight: 700; text-align: center;" />
                            </div>
                            <Button Size="@ButtonSize.Small" OnClick="() => GoToGis(c.LotId)"
                                    Style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; color: #fff; height: 36px; font-size: 11px; font-weight: 600;">
                                GIS
                            </Button>
                            <Button Size="@ButtonSize.Small" OnClick="() => GoToRotations(c.CampaignId, c.LotId)"
                                    Style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; color: #fff; height: 36px; font-size: 11px; font-weight: 600;">
                                Rotac.
                            </Button>
                        </div>
                    }

                    <Button OnClick="() => _addCampaignModalVisible = true"
                            Style="background: transparent; border: 1px dashed rgba(255,255,255,0.2); border-radius: 10px; color: rgba(255,255,255,0.6); height: 40px; margin-top: 4px; font-size: 13px;">
                        +Campaña
                    </Button>
                </div>
            </div>
        }

        <div>
            <label style="display: block; color: rgba(255,255,255,0.6); font-size: 13px; margin-bottom: 8px;">Superficie Catastral (ha)</label>
            <AntDesign.InputNumber TValue="decimal" @bind-Value="_formModel.CadastralArea" Min="0m" Step="0.1m"
                       Style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15); border-radius: 12px; height: 42px; color: #fff; width: 100%;" />
        </div>

        <div style="margin-top: 10px;">
            <RadioGroup @bind-Value="_formModel.Status">
                <Radio Value="@("Active")" Style="color: #fff;">Activo</Radio>
                <Radio Value="@("Inactive")" Style="color: #fff;">Inactivo</Radio>
            </RadioGroup>
        </div>
    </div>

    <div style="display: flex; justify-content: flex-end; gap: 12px; padding-top: 30px;">
        <Button OnClick="SaveLot" Loading="_saving" 
                Style="background: #1890FF; color: #fff; border: none; border-radius: 20px; padding: 0 24px; font-weight: 700; height: 40px;">
            Guardar
        </Button>
        <Button OnClick="CloseModal"
                Style="background: rgba(255,255,255,0.05); color: #fff; border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 0 24px; font-weight: 600; height: 40px;">
            Cancelar
        </Button>
    </div>
</Modal>

<Modal Title="Asignar a Campaña" Visible="_addCampaignModalVisible" OnCancel="() => _addCampaignModalVisible = false" OnOk="AddLotToLotCampaign" Width="400">
    <div style="display: grid; gap: 16px; padding: 10px 0;">
        <div>
            <label style="display: block; color: rgba(255,255,255,0.5); font-size: 11px; text-transform: uppercase; margin-bottom: 8px;">Seleccionar Campaña</label>
            <Select TItem="CampaignSummaryDto" TItemValue="Guid" DataSource="_allCampaigns" @bind-Value="_selectedCampaignId"
                    LabelName="@nameof(CampaignSummaryDto.Name)" ValueName="@nameof(CampaignSummaryDto.Id)"
                    OnSelectedItemChanged="OnAddCampaignChanged"
                    Placeholder="Campaña" Style="width: 100%;" />
        </div>
        <div>
            <label style="display: block; margin-bottom: 8px; font-size: 12px; color: rgba(255,255,255,0.5);">Superficie Productiva (ha)</label>
            <AntDesign.InputNumber TValue="decimal" @bind-Value="_newCampaignProductiveArea" Style="width: 100%;" />
        </div>
    </div>
</Modal>

<Drawer Title="@($"Rotaciones del Lote: {_selectedLotForRotation?.Name}")"
        Visible="_rotationsDrawerVisible"
        OnClose="() => _rotationsDrawerVisible = false"
        Width='800'
        ZIndex="2000"
        BodyStyle="background: #0f0f1a; padding: 24px;">
    @if (_loadingRotations)
    {
        <div style="text-align: center; padding: 40px;">
            <Spin Tip="Cargando rotaciones..." />
        </div>
    }
    else
    {
        <div class="rotations-timeline-wrapper" style="margin-top: 10px;">
            <Timeline Mode="TimelineMode.Alternate">
                @foreach (var rot in _rotations.OrderByDescending(r => r.StartDate))
                {
                    <TimelineItem Color="@(rot.EndDate >= DateOnly.FromDateTime(DateTime.Today) ? "green" : "gray")">
                        <div style="background: rgba(255,255,255,0.03); padding: 16px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.08);">
                            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
                                <div>
                                    <h4 style="color: #fff; margin: 0; font-size: 16px;">@rot.ActivityName</h4>
                                    <span style="font-size: 12px; color: rgba(255,255,255,0.4);">@rot.CampaignName</span>
                                </div>
                                <Popconfirm Title="¿Eliminar esta rotación?" OnConfirm="() => DeleteRotation(rot.Id)">
                                    <Button Danger Icon="delete" Size="@ButtonSize.Small" Ghost Type="@ButtonType.Text" />
                                </Popconfirm>
                            </div>
                            
                            <div style="display: flex; gap: 16px; margin-top: 8px;">
                                <div>
                                    <div style="font-size: 10px; color: rgba(255,255,255,0.3); text-transform: uppercase;">Período</div>
                                    <div style="color: rgba(255,255,255,0.8); font-size: 13px;">
                                        @rot.StartDate.ToString("MMM yyyy") - @rot.EndDate.ToString("MMM yyyy")
                                    </div>
                                </div>
                                <div style="flex: 1;">
                                    @{
                                        var totalDays = (rot.EndDate.ToDateTime(TimeOnly.MinValue) - rot.StartDate.ToDateTime(TimeOnly.MinValue)).TotalDays;
                                        var elapsed = (DateTime.Today - rot.StartDate.ToDateTime(TimeOnly.MinValue)).TotalDays;
                                        var percent = totalDays > 0 ? Math.Clamp((elapsed / totalDays) * 100, 0, 100) : 0.0;
                                        var strokeColor = "#2ECC71";
                                    }
                                    <div style="font-size: 10px; color: rgba(255,255,255,0.3); text-transform: uppercase; margin-bottom: 4px;">Progreso Ciclo</div>
                                    <Progress Percent="@percent" Size="ProgressSize.Small" Status="@ProgressStatus.Active" StrokeColor="@strokeColor" />
                                </div>
                            </div>
                        </div>
                    </TimelineItem>
                }
                @if (!_rotations.Any())
                {
                    <TimelineItem Color="@("gray")">
                        <div style="color: rgba(255,255,255,0.3); padding: 20px; text-align: center;">
                            No hay rotaciones registradas para este lote en esta campaña.
                        </div>
                    </TimelineItem>
                }
            </Timeline>
            
            <div style="margin-top: 32px; border-top: 1px solid rgba(255,255,255,0.08); padding-top: 24px;">
                <h4 style="color: #fff; margin-bottom: 20px; display: flex; align-items: center; gap: 8px;">
                    <Icon Type="plus-circle" /> Agregar Cultivo a la Rotación
                </h4>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px;">
                    <div>
                        <label style="color: rgba(255,255,255,0.4); font-size: 11px; display: block; margin-bottom: 8px;">ACTIVIDAD / CULTIVO (ERP)</label>
                        <Select TItem="ErpActivityDto" TItemValue="Guid" DataSource="_allActivities"
                                LabelName="@nameof(ErpActivityDto.Name)" ValueName="@nameof(ErpActivityDto.Id)"
                                @bind-Value="_newRotationActivityId" EnableSearch Placeholder="Seleccionar..." 
                                Style="width: 100%;" />
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
                        <div>
                            <label style="color: rgba(255,255,255,0.4); font-size: 11px; display: block; margin-bottom: 8px;">INICIO</label>
                            <DatePicker TValue="DateTime?" @bind-Value="_newRotationStart" Format="MMM yyyy" Picker="@DatePickerType.Month" Style="width: 100%;" />
                        </div>
                        <div>
                            <label style="color: rgba(255,255,255,0.4); font-size: 11px; display: block; margin-bottom: 8px;">FIN</label>
                            <DatePicker TValue="DateTime?" @bind-Value="_newRotationEnd" Format="MMM yyyy" Picker="@DatePickerType.Month" Style="width: 100%;" />
                        </div>
                    </div>
                </div>
                <Button Type="@ButtonType.Primary" Block OnClick="AddRotation" Loading="_savingRotation" 
                        Style="background: #E74C3C; border-color: #E74C3C; height: 40px; font-weight: 600; border-radius: 8px;">
                    Registrar Rotación
                </Button>
            </div>
        </div>
    }
</Drawer>

@code {
    private List<LotDto> _lots = new();
    private List<FieldDto> _availableFields = new();
    private List<CampaignLotDto> _campaignLots = new();
    private Dictionary<Guid, List<SurfaceHistoryDto>> _historyByLot = new();
    private bool _loading = true;
    private bool _filterByCampaign = true;
    private string? _errorMessage;
    private bool _modalVisible;
    private bool _isEditing;
    private bool _saving;
    private Guid _editingId;
    private LotFormModel _formModel = new();
    // private Form<LotFormModel>? _form; // Unused
    private List<CampaignLotDto> _lotCampaigns = new();
    private List<CampaignSummaryDto> _allCampaigns = new();
    private List<ErpActivityDto> _allActivities = new();
    private bool _addCampaignModalVisible;
    private Guid _selectedCampaignId;
    private decimal _newCampaignProductiveArea;

    private bool _rotationsDrawerVisible;
    private bool _loadingRotations;
    private bool _savingRotation;
    private LotDto? _selectedLotForRotation;
    private List<RotationDto> _rotations = new();
    private Guid _newRotationActivityId;
    private DateTime? _newRotationStart;
    private DateTime? _newRotationEnd;
    private Guid _currentRotationCampaignId;

    private IEnumerable<LotDto> FilteredLots =>
        _filterByCampaign && CampaignState.IsSelected
            ? _lots.Where(l => _campaignLots.Any(cl => cl.LotId == l.Id))
            : _lots;

    public class LotFormModel
    {
        public string Name { get; set; } = string.Empty;
        public Guid FieldId { get; set; }
        public string Status { get; set; } = "Active";
        public decimal CadastralArea { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        CampaignState.OnChange += OnCampaignChanged;
        TenantState.OnChange += OnCampaignChanged;
        await LoadData();
    }

    private void OnCampaignChanged()
    {
        InvokeAsync(async () => { await LoadData(); StateHasChanged(); });
    }

    public void Dispose()
    {
        CampaignState.OnChange -= OnCampaignChanged;
        TenantState.OnChange -= OnCampaignChanged;
    }

    private async Task OnExpandLot(RowData<LotDto> args)
    {
        if (args.Expanded && !_historyByLot.ContainsKey(args.Data.Id))
        {
            await LoadHistory(args.Data.Id);
        }
    }

    private async Task LoadHistory(Guid lotId)
    {
        try
        {
            var history = await Http.GetFromJsonAsync<List<SurfaceHistoryDto>>($"api/lots/{lotId}/surface-history");
            if (history != null)
            {
                _historyByLot[lotId] = history;
            }
        }
        catch (Exception)
        {
            Message.Error("Error al cargar historial.");
        }
    }

    private async Task LoadData()
    {
        try
        {
            _loading = true;
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));
            var lotsTask = Http.GetFromJsonAsync("api/lots",
                AppJsonSerializerContext.Default.ListLotDto, cts.Token);
            var fieldsTask = Http.GetFromJsonAsync("api/fields",
                AppJsonSerializerContext.Default.ListFieldDto, cts.Token);
            var campTask = Http.GetFromJsonAsync("api/campaigns/active",
                AppJsonSerializerContext.Default.ListCampaignSummaryDto, cts.Token);

            _lots = await lotsTask ?? new();
            _availableFields = await fieldsTask ?? new();
            _allCampaigns = await campTask ?? new();
            
            _allActivities = await Http.GetFromJsonAsync<List<ErpActivityDto>>("api/catalogs/activities") ?? new();

            if (CampaignState.IsSelected)
            {
                var campaignLots = await Http.GetFromJsonAsync($"api/campaigns/{CampaignState.CurrentCampaign!.Id}/lots",
                    AppJsonSerializerContext.Default.ListCampaignLotDto, cts.Token);
                _campaignLots = campaignLots ?? new();
            }
            else
            {
                _campaignLots.Clear();
            }

            _errorMessage = null;
        }
        catch (Exception)
        {
            _errorMessage = $"Error al cargar datos.";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void OpenCreateModal()
    {
        _isEditing = false;
        _formModel = new LotFormModel();
        if (_availableFields.Count > 0)
            _formModel.FieldId = _availableFields[0].Id;
        _modalVisible = true;
    }

    private async Task OpenEditModal(LotDto lot)
    {
        _isEditing = true;
        _editingId = lot.Id;
        _formModel = new LotFormModel
        {
            Name = lot.Name,
            FieldId = lot.FieldId,
            Status = lot.Status,
            CadastralArea = lot.CadastralArea
        };
        
        await LoadLotCampaigns(lot.Id);
        
        // Prepoblado: Si el lote ya está en la campaña activa, asegurar que el modelo refleje datos actuales si fuera necesario
        // Aunque por ahora el modelo base solo tiene Nombre, Campo y Estado.
        
        _modalVisible = true;
    }

    private async Task LoadLotCampaigns(Guid lotId)
    {
        try
        {
            _lotCampaigns = await Http.GetFromJsonAsync<List<CampaignLotDto>>($"api/lots/{lotId}/campaigns") ?? new();
        }
        catch (Exception)
        {
            Message.Error("Error al cargar campañas del lote.");
        }
    }

    private void GoToGis(Guid lotId)
    {
        Nav.NavigateTo($"/mapa?lotId={lotId}");
    }

    private async Task GoToRotations(Guid campaignId, Guid lotId)
    {
        _selectedLotForRotation = _lots.FirstOrDefault(l => l.Id == lotId);
        _currentRotationCampaignId = campaignId;
        _rotationsDrawerVisible = true;
        await LoadRotations();
    }

    private async Task LoadRotations()
    {
        if (_selectedLotForRotation == null) return;
        _loadingRotations = true;
        try
        {
            // Find CampaignLotId for the selected lot and campaign
            var cl = _lotCampaigns.FirstOrDefault(x => x.LotId == _selectedLotForRotation.Id && x.CampaignId == _currentRotationCampaignId);
            if (cl != null)
            {
                _rotations = await Http.GetFromJsonAsync<List<RotationDto>>($"api/campaigns/{_currentRotationCampaignId}/lots/{cl.Id}/rotations") ?? new();
            }
        }
        catch (Exception) { Message.Error("Error al cargar rotaciones."); }
        finally { _loadingRotations = false; }
    }

    private async Task AddRotation()
    {
        if (_newRotationActivityId == Guid.Empty || _newRotationStart == null || _newRotationEnd == null || _selectedLotForRotation == null)
        {
            Message.Warning("Complete todos los campos de la rotación.");
            return;
        }

        _savingRotation = true;
        try
        {
            var cl = _lotCampaigns.FirstOrDefault(x => x.LotId == _selectedLotForRotation.Id && x.CampaignId == _currentRotationCampaignId);
            if (cl == null) return;

            var dto = new RotationDto(
                Guid.Empty, cl.Id, _newRotationActivityId, null,
                DateOnly.FromDateTime(_newRotationStart.Value),
                DateOnly.FromDateTime(_newRotationEnd.Value),
                null);

            var response = await Http.PostAsJsonAsync($"api/campaigns/{_currentRotationCampaignId}/lots/{cl.Id}/rotations", dto);
            if (response.IsSuccessStatusCode)
            {
                Message.Success("Rotación agregada.");
                _newRotationActivityId = Guid.Empty;
                await LoadRotations();
            }
            else
            {
                var err = await response.Content.ReadAsStringAsync();
                Message.Error(err);
            }
        }
        catch (Exception) { Message.Error($"Error al agregar rotación."); }
        finally { _savingRotation = false; }
    }

    private async Task DeleteRotation(Guid id)
    {
        try
        {
            var cl = _lotCampaigns.FirstOrDefault(x => x.LotId == _selectedLotForRotation?.Id && x.CampaignId == _currentRotationCampaignId);
            if (cl == null) return;

            var response = await Http.DeleteAsync($"api/campaigns/{_currentRotationCampaignId}/lots/{cl.Id}/rotations/{id}");
            if (response.IsSuccessStatusCode)
            {
                Message.Success("Rotación eliminada.");
                await LoadRotations();
            }
        }
        catch (Exception) { Message.Error("Error al eliminar."); }
    }

    private async Task UpdateCampaignLotArea(CampaignLotDto item, decimal newArea)
    {
        try
        {
            var updated = item with { ProductiveArea = newArea };
            var response = await Http.PutAsJsonAsync($"api/campaigns/{item.CampaignId}/lots/{item.LotId}", updated);
            if (response.IsSuccessStatusCode)
            {
                Message.Success("Superficie productiva actualizada.");
                await LoadLotCampaigns(_editingId);
                await LoadData();
            }
            else
            {
                var err = await response.Content.ReadAsStringAsync();
                Message.Error(err);
            }
        }
        catch (Exception ex) { Message.Error($"Error: {ex.Message}"); }
    }

    private void OnAddCampaignChanged(CampaignSummaryDto campaign)
    {
        if (campaign != null)
        {
            var lot = _lots.FirstOrDefault(x => x.Id == _editingId);
            if (lot != null)
            {
                _newCampaignProductiveArea = lot.CadastralArea;
            }
        }
    }

    private async Task AddLotToLotCampaign()
    {
        if (_selectedCampaignId == Guid.Empty) return;
        
        try
        {
            var dto = new CampaignLotDto(Guid.Empty, _selectedCampaignId, _editingId, null, null, 0, _newCampaignProductiveArea, null);
            var response = await Http.PostAsJsonAsync($"api/campaigns/{_selectedCampaignId}/lots", dto);
            if (response.IsSuccessStatusCode)
            {
                Message.Success("Asignado a campaña.");
                _addCampaignModalVisible = false;
                await LoadLotCampaigns(_editingId);
            }
            else
            {
                var err = await response.Content.ReadAsStringAsync();
                Message.Error($"Error: {err}");
            }
        }
        catch (Exception)
        {
            Message.Error($"Error al asignar campaña.");
        }
    }

    private void CloseModal()
    {
        _modalVisible = false;
    }

    private async Task SaveLot()
    {
        if (string.IsNullOrWhiteSpace(_formModel.Name))
        {
            Message.Warning("El nombre del lote es obligatorio.");
            return;
        }
        if (_formModel.FieldId == Guid.Empty)
        {
            Message.Warning("Debe seleccionar un campo.");
            return;
        }

        _saving = true;
        try
        {
            var existingWkt = _isEditing
                ? _lots.FirstOrDefault(l => l.Id == _editingId)?.WktGeometry
                : null;

            var dto = new LotDto(
                _isEditing ? _editingId : Guid.Empty,
                _formModel.FieldId,
                _formModel.Name,
                _formModel.Status,
                existingWkt
            );

            HttpResponseMessage response;
            if (_isEditing)
            {
                response = await Http.PutAsJsonAsync($"api/lots/{_editingId}",
                    dto, AppJsonSerializerContext.Default.LotDto);
            }
            else
            {
                response = await Http.PostAsJsonAsync("api/lots",
                    dto, AppJsonSerializerContext.Default.LotDto);
            }

            if (response.IsSuccessStatusCode)
            {
                if (!_isEditing && CampaignState.IsSelected)
                {
                    var createdLot = await response.Content.ReadFromJsonAsync<LotDto>(AppJsonSerializerContext.Default.LotDto);
                    if (createdLot != null)
                    {
                        var lotAddResp = await Http.PostAsJsonAsync($"api/campaigns/{CampaignState.CurrentCampaign!.Id}/lots",
                            new CampaignLotDto(Guid.Empty, CampaignState.CurrentCampaign.Id, createdLot.Id, null, null, 0, 0, null),
                            AppJsonSerializerContext.Default.CampaignLotDto);
                        
                        if (!lotAddResp.IsSuccessStatusCode)
                        {
                            var lotAddErr = await lotAddResp.Content.ReadAsStringAsync();
                            Message.Warning($"El lote se creó pero no pudo asignarse a la campaña: {lotAddErr}");
                        }
                    }
                }

                Message.Success(_isEditing ? "Lote actualizado." : "Lote creado correctamente.");
                _modalVisible = false;
                await LoadData();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Message.Error($"Error al guardar: {body}");
            }
        }
        catch (Exception)
        {
            Message.Error($"Error al asignar campaña.");
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteLot(Guid id)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/lots/{id}");
            if (response.IsSuccessStatusCode)
            {
                Message.Success("Lote eliminado correctamente.");
                await LoadData();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Message.Error($"Error al eliminar: {body}");
            }
        }
        catch (Exception)
        {
            Message.Error($"Error al asignar campaña.");
        }
    }
}
