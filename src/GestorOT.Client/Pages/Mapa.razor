@page "/mapa"
@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using System.Net.Http.Json
@using AntDesign
@inject HttpClient Http
@inject IJSRuntime JS
@inject IMessageService Message
@inject GestorOT.Client.Services.CampaignState CampaignState
@inject GestorOT.Client.Services.TenantState TenantState
@implements IDisposable

<PageTitle>Explorador GIS - GestorOT</PageTitle>

<div class="gis-container">
    <div id="map" class="gis-map"></div>

    @if (_loading)
    {
        <div class="gis-overlay">
            <Spin Size="@SpinSize.Large" Tip="Cargando lotes..." />
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="gis-toast">
            <Alert Type="@AlertType.Error" Message="@_errorMessage" ShowIcon="true" />
        </div>
    }

    <div class="gis-toolbar">
        <Tooltip Title="@("Importar archivo GeoJSON/KML")">
            <div class="toolbar-btn" @onclick="() => _showImportModal = true">
                <Icon Type="upload" Theme="IconThemeType.Outline" />
            </div>
        </Tooltip>
        <Tooltip Title="@("Lotes sin geometría")">
            <div class="toolbar-btn @(_orphanLots.Count > 0 ? "toolbar-btn--alert" : "")" @onclick="() => _showOrphanPanel = !_showOrphanPanel">
                <Icon Type="warning" Theme="IconThemeType.Outline" />
                @if (_orphanLots.Count > 0)
                {
                    <span class="toolbar-badge">@_orphanLots.Count</span>
                }
            </div>
        </Tooltip>
        <Tooltip Title="@("Recargar mapa")">
            <div class="toolbar-btn" @onclick="ReloadMap">
                <Icon Type="reload" Theme="IconThemeType.Outline" />
            </div>
        </Tooltip>
    </div>

    <div class="gis-legend">
        <div style="font-weight: 700; font-size: 12px; color: #fff; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 1px;">Leyenda</div>
        <div class="legend-item">
            <div class="legend-dot" style="background: #2ECC71;"></div>
            <span>Lote Activo</span>
        </div>
        <div class="legend-item">
            <div class="legend-dot" style="background: #E74C3C;"></div>
            <span>Lote Inactivo</span>
        </div>
        <div class="legend-item">
            <div class="legend-dot" style="background: #9B59B6;"></div>
            <span>Importado</span>
        </div>
        <div class="legend-divider"></div>
        <div style="font-size: 11px; color: rgba(255,255,255,0.4);">
            Lotes: @_lotsCount
        </div>
    </div>

    @if (_showOrphanPanel)
    {
        <div class="orphan-panel">
            <div class="orphan-header">
                <span style="font-weight: 700; color: #fff; font-size: 14px;">Lotes Huérfanos</span>
                <div style="cursor: pointer;" @onclick="() => _showOrphanPanel = false">
                    <Icon Type="close" Theme="IconThemeType.Outline" Style="color: rgba(255,255,255,0.5);" />
                </div>
            </div>
            <div style="padding: 12px; font-size: 12px; color: rgba(255,255,255,0.5);">
                Lotes del sistema sin geometría definida. Dibuje un polígono y vincúlelo.
            </div>
            @if (_orphanLots.Count == 0)
            {
                <div style="padding: 20px; text-align: center; color: rgba(255,255,255,0.3); font-size: 12px;">
                    Todos los lotes tienen geometría
                </div>
            }
            else
            {
                @foreach (var lot in _orphanLots)
                {
                    <div class="orphan-item @(lot.Id == _linkingLotId ? "orphan-item--active" : "")"
                         @onclick="() => SelectOrphanForLinking(lot)">
                        <div>
                            <div style="font-weight: 600; color: #fff; font-size: 13px;">@lot.Name</div>
                            <div style="font-size: 11px; color: rgba(255,255,255,0.4);">@(lot.FieldName ?? "Sin campo")</div>
                        </div>
                        @if (lot.Id == _linkingLotId)
                        {
                            <Tag Color="@("orange")" Style="border-radius: 10px; font-size: 10px;">Vincular</Tag>
                        }
                        else
                        {
                            <Icon Type="link" Theme="IconThemeType.Outline" Style="color: rgba(255,255,255,0.3);" />
                        }
                    </div>
                }
            }
        </div>
    }

    <div class="gis-rail @(_selectedLot != null || _drawnWkt != null ? "gis-rail--open" : "")">
        @if (_drawnWkt != null && _selectedLot == null)
        {
            <div class="rail-header">
                <span class="rail-title">Polígono Dibujado</span>
                <div style="cursor: pointer;" @onclick="ClearDrawn">
                    <Icon Type="close" Theme="IconThemeType.Outline" Style="color: rgba(255,255,255,0.5); font-size: 16px;" />
                </div>
            </div>
            <div class="rail-body">
                <div class="rail-section">
                    <span class="rail-label">Área Calculada</span>
                    <span class="rail-value">@_drawnArea.ToString("N2") ha</span>
                </div>
                <div style="margin-top: 16px;">
                    <div style="font-size: 12px; color: rgba(255,255,255,0.5); margin-bottom: 8px;">Vincular a lote:</div>
                    <Select TItem="LotDto"
                            TItemValue="Guid"
                            DataSource="_orphanLots"
                            @bind-Value="_linkingLotId"
                            LabelName="@nameof(LotDto.Name)"
                            ValueName="@nameof(LotDto.Id)"
                            Placeholder="Seleccionar lote huérfano"
                            Style="width: 100%;"
                            EnableSearch />
                </div>
            </div>
            <div class="rail-actions">
                <Button Type="@ButtonType.Primary" Block Size="@ButtonSize.Small"
                        Style="background: #E74C3C; border-color: #E74C3C; border-radius: 8px;"
                        OnClick="SaveDrawnGeometry"
                        Disabled="@(_linkingLotId == Guid.Empty)"
                        Loading="_savingGeometry">
                    <Icon Type="save" Theme="IconThemeType.Outline" /> Guardar Geometría
                </Button>
            </div>
        }
        else if (_selectedLot != null)
        {
            <div class="rail-header">
                <span class="rail-title">@_selectedLot.Name</span>
                <div style="cursor: pointer;" @onclick="CloseRail">
                    <Icon Type="close" Theme="IconThemeType.Outline" Style="color: rgba(255,255,255,0.5); font-size: 16px;" />
                </div>
            </div>

            <div class="rail-body">
                <div class="rail-section">
                    <span class="rail-label">Estado</span>
                    <Tag Style="@($"background: {(_selectedLot.Status == "Active" ? "#2ECC71" : "#E74C3C")}20; color: {(_selectedLot.Status == "Active" ? "#2ECC71" : "#E74C3C")}; border: 1px solid {(_selectedLot.Status == "Active" ? "#2ECC71" : "#E74C3C")}40; border-radius: 12px; font-size: 11px; padding: 2px 10px;")">
                        @(_selectedLot.Status == "Active" ? "Activo" : "Inactivo")
                    </Tag>
                </div>
                <div class="rail-section">
                    <span class="rail-label">Campo</span>
                    <span class="rail-value">@(_selectedLot.FieldName ?? "—")</span>
                </div>
                <div class="rail-section">
                    <span class="rail-label">Área Dibujada</span>
                    <span class="rail-value">@_selectedLot.Area.ToString("N2") ha</span>
                </div>
                @{
                    var field = _allFields.FirstOrDefault(f => f.Id == _selectedLot.FieldId);
                    if (field != null)
                    {
                        var delta = _selectedLot.Area - field.HectareasTotales;
                        var pct = field.HectareasTotales > 0 ? (delta / field.HectareasTotales * 100) : 0;
                        <div class="rail-section">
                            <span class="rail-label">Área Fiscal</span>
                            <span class="rail-value">@field.HectareasTotales.ToString("N2") ha</span>
                        </div>
                        <div class="surface-comparison">
                            <div style="font-size: 11px; color: rgba(255,255,255,0.5); margin-bottom: 6px;">Diferencia Superficie</div>
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <span style="font-size: 18px; font-weight: 700; color: @(Math.Abs(pct) < 5 ? "#2ECC71" : "#F1C40F");">
                                    @(delta > 0 ? "+" : "")@delta.ToString("N2") ha
                                </span>
                                <Tag Style="@($"background: {(Math.Abs(pct) < 5 ? "#2ECC71" : "#F1C40F")}20; color: {(Math.Abs(pct) < 5 ? "#2ECC71" : "#F1C40F")}; border: none; border-radius: 10px; font-size: 11px;")">
                                    @(pct > 0 ? "+" : "")@pct.ToString("N1")%
                                </Tag>
                            </div>
                        </div>
                    }
                }
                <div class="rail-section">
                    <span class="rail-label">Geometría</span>
                    <span class="rail-value">@(!string.IsNullOrEmpty(_selectedLot.WktGeometry) ? "Definida" : "Sin datos")</span>
                </div>
            </div>

            <div class="rail-actions">
                <Button Type="@ButtonType.Primary" Block Size="@ButtonSize.Small"
                        Style="background: #E74C3C; border-color: #E74C3C; border-radius: 8px;"
                        OnClick="() => CenterOnSelectedLot()">
                    <Icon Type="aim" Theme="IconThemeType.Outline" /> Centrar en mapa
                </Button>
            </div>
        }
    </div>
</div>

<Modal Title="Importar Archivo GIS"
       Visible="_showImportModal"
       OnCancel="() => _showImportModal = false"
       Footer="@null"
       Width="500">
    <div style="margin-bottom: 16px; color: rgba(255,255,255,0.7); font-size: 13px;">
        Seleccione un archivo <strong>.geojson</strong> o <strong>.kml</strong> para importar polígonos al mapa.
    </div>
    <InputFile OnChange="HandleFileImport" accept=".geojson,.json,.kml" style="margin-bottom: 16px;" />
    @if (_importLoading)
    {
        <div style="text-align: center; padding: 20px;">
            <Spin Tip="Procesando archivo..." />
        </div>
    }
    @if (_importResults.Count > 0)
    {
        <div style="margin-top: 12px;">
            <div style="font-size: 12px; color: rgba(255,255,255,0.5); margin-bottom: 8px;">
                @_importResults.Count polígono(s) encontrado(s):
            </div>
            @foreach (var result in _importResults)
            {
                <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; padding: 10px; margin-bottom: 6px; display: flex; justify-content: space-between; align-items: center;">
                    <span style="color: rgba(255,255,255,0.8); font-size: 13px;">@(string.IsNullOrEmpty(result.Name) ? "Sin nombre" : result.Name)</span>
                    <Button Size="@ButtonSize.Small" OnClick="() => LinkImportedToLot(result)"
                            Style="border-radius: 6px; background: #9B59B620; border-color: #9B59B640; color: #9B59B6; font-size: 11px;">
                        <Icon Type="link" Theme="IconThemeType.Outline" /> Vincular
                    </Button>
                </div>
            }
        </div>
    }
</Modal>

<Modal Title="Vincular Geometría Importada"
       Visible="_showLinkModal"
       OnCancel="() => _showLinkModal = false"
       OnOk="SaveImportedGeometry"
       OkText="@("Vincular y Guardar")"
       ConfirmLoading="_savingGeometry"
       Width="450">
    <div style="margin-bottom: 12px; color: rgba(255,255,255,0.7); font-size: 13px;">
        Seleccione el lote al que desea vincular esta geometría:
    </div>
    <Select TItem="LotDto"
            TItemValue="Guid"
            DataSource="_allLots"
            @bind-Value="_linkingLotId"
            LabelName="@nameof(LotDto.Name)"
            ValueName="@nameof(LotDto.Id)"
            Placeholder="Seleccionar lote"
            Style="width: 100%;"
            EnableSearch />
</Modal>

