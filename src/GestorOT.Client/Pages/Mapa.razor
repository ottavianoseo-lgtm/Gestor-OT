@code {
    private int _lotsCount = 0;
    private bool _loading = true;
    private bool _hasLoaded = false;
    private string? _errorMessage;
    private LotDto? _selectedLot;
    private List<LotDto> _allLots = new();
    private List<FieldDto> _allFields = new();
    private List<LotDto> _orphanLots = new();
    private bool _showOrphanPanel;
    private bool _showImportModal;
    private bool _showLinkModal;
    private bool _importLoading;
    private bool _savingGeometry;
    private string? _drawnWkt;
    private double _drawnArea;
    private Guid _linkingLotId;
    private string? _importLinkWkt;
    private List<ImportResult> _importResults = new();

    public class ImportResult
    {
        public string Wkt { get; set; } = "";
        public string Name { get; set; } = "";
    }

    protected override void OnInitialized()
    {
        CampaignState.OnChange += OnCampaignChanged;
        TenantState.OnChange += OnCampaignChanged;
    }

    private void OnCampaignChanged()
    {
        InvokeAsync(async () => { await ReloadMap(); StateHasChanged(); });
    }

    public void Dispose()
    {
        CampaignState.OnChange -= OnCampaignChanged;
        TenantState.OnChange -= OnCampaignChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_hasLoaded)
        {
            _hasLoaded = true;
            await InitializeMapAsync();
            StateHasChanged();
        }
    }

    private async Task InitializeMapAsync()
    {
        try
        {
            await JS.InvokeAsync<bool>("mapInterop.initMap", "map", -34.6, -58.5, 10);

            var dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("mapInterop.setDotNetRef", dotNetRef);

            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));

            var lotsTask = Http.GetFromJsonAsync("api/lots",
                AppJsonSerializerContext.Default.ListLotDto, cts.Token);
            var geoTask = Http.GetFromJsonAsync("api/lots/geojson",
                AppJsonSerializerContext.Default.GeoJsonFeatureCollection, cts.Token);
            var fieldsTask = Http.GetFromJsonAsync("api/fields",
                AppJsonSerializerContext.Default.ListFieldDto, cts.Token);

            _allLots = await lotsTask ?? new();
            _allFields = await fieldsTask ?? new();
            _orphanLots = _allLots.Where(l => string.IsNullOrEmpty(l.WktGeometry)).ToList();

            var featureCollection = await geoTask;

            if (featureCollection?.Features != null)
            {
                _lotsCount = featureCollection.Features.Count;

                foreach (var feature in featureCollection.Features)
                {
                    if (feature.Geometry?.Coordinates != null && feature.Properties != null)
                    {
                        var lotId = feature.Properties.TryGetValue("id", out var id) ? id?.ToString() ?? "" : "";
                        var lotName = feature.Properties.TryGetValue("name", out var name) ? name?.ToString() ?? "" : "";
                        var status = feature.Properties.TryGetValue("status", out var s) ? s?.ToString() ?? "Active" : "Active";
                        var fieldName = feature.Properties.TryGetValue("fieldName", out var fn) ? fn?.ToString() ?? "" : "";
                        double area = 0;
                        if (feature.Properties.TryGetValue("area", out var a))
                        {
                            if (a is System.Text.Json.JsonElement je)
                                area = je.GetDouble();
                            else
                                area = Convert.ToDouble(a);
                        }

                        var leafletCoords = ConvertToLeafletCoords(feature.Geometry.Coordinates);
                        var coordsJson = System.Text.Json.JsonSerializer.Serialize(leafletCoords);

                        await JS.InvokeAsync<bool>("mapInterop.addLotPolygon",
                            lotId, lotName, status, area, fieldName, coordsJson);
                    }
                }

                if (_lotsCount > 0)
                {
                    await JS.InvokeAsync<bool>("mapInterop.fitAllLots");
                }
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ReloadMap()
    {
        _loading = true;
        _hasLoaded = false;
        _selectedLot = null;
        _drawnWkt = null;
        StateHasChanged();
        await JS.InvokeVoidAsync("mapInterop.clearLots");
        await JS.InvokeVoidAsync("mapInterop.clearDrawn");
        await InitializeMapAsync();
        StateHasChanged();
    }

    private void CloseRail()
    {
        _selectedLot = null;
    }

    private void ClearDrawn()
    {
        _drawnWkt = null;
        _drawnArea = 0;
        _linkingLotId = Guid.Empty;
        JS.InvokeVoidAsync("mapInterop.clearDrawn");
    }

    private async Task CenterOnSelectedLot()
    {
        if (_selectedLot != null)
        {
            await JS.InvokeAsync<bool>("mapInterop.centerOnLot", _selectedLot.Id.ToString());
        }
    }

    [JSInvokable]
    public void OnLotSelected(string lotId)
    {
        var lot = _allLots.FirstOrDefault(l => l.Id.ToString() == lotId);
        if (lot != null)
        {
            _selectedLot = lot;
            _drawnWkt = null;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void OnPolygonDrawn(string wkt, double area)
    {
        _drawnWkt = wkt;
        _drawnArea = area;
        _selectedLot = null;
        _linkingLotId = Guid.Empty;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnPolygonEdited(string wkt, double area)
    {
        _drawnWkt = wkt;
        _drawnArea = area;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnPolygonDeleted()
    {
        _drawnWkt = null;
        _drawnArea = 0;
        _linkingLotId = Guid.Empty;
        StateHasChanged();
    }

    private void SelectOrphanForLinking(LotDto lot)
    {
        _linkingLotId = lot.Id;
        StateHasChanged();
    }

    private async Task SaveDrawnGeometry()
    {
        if (string.IsNullOrEmpty(_drawnWkt) || _linkingLotId == Guid.Empty) return;

        _savingGeometry = true;
        try
        {
            var lot = _allLots.FirstOrDefault(l => l.Id == _linkingLotId);
            if (lot == null) return;

            var dto = new LotDto(
                lot.Id, lot.FieldId, lot.Name, lot.Status, _drawnWkt, lot.FieldName
            );

            var response = await Http.PutAsJsonAsync($"api/lots/{lot.Id}",
                dto, AppJsonSerializerContext.Default.LotDto);

            if (response.IsSuccessStatusCode)
            {
                Message.Success($"Geometría guardada para '{lot.Name}'.");
                _drawnWkt = null;
                _drawnArea = 0;
                _linkingLotId = Guid.Empty;
                await ReloadMap();
            }
            else
            {
                Message.Error($"Error al guardar: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
        finally
        {
            _savingGeometry = false;
        }
    }

    private async Task HandleFileImport(InputFileChangeEventArgs e)
    {
        _importLoading = true;
        _importResults.Clear();
        StateHasChanged();

        try
        {
            var file = e.File;
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var reader = new System.IO.StreamReader(stream);
            var content = await reader.ReadToEndAsync();

            string resultsJson;
            if (file.Name.EndsWith(".kml", StringComparison.OrdinalIgnoreCase))
            {
                resultsJson = await JS.InvokeAsync<string>("mapInterop.parseKmlFile", content);
            }
            else
            {
                resultsJson = await JS.InvokeAsync<string>("mapInterop.parseGeoJsonFile", content);
            }

            var parsed = System.Text.Json.JsonSerializer.Deserialize<List<ImportResult>>(resultsJson,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            if (parsed != null && parsed.Count > 0)
            {
                _importResults = parsed;
                foreach (var result in parsed)
                {
                    await JS.InvokeAsync<bool>("mapInterop.addImportedPolygon", result.Wkt, result.Name);
                }
                Message.Success($"{parsed.Count} polígono(s) importado(s).");
            }
            else
            {
                Message.Warning("No se encontraron polígonos en el archivo.");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error al importar: {ex.Message}");
        }
        finally
        {
            _importLoading = false;
            StateHasChanged();
        }
    }

    private void LinkImportedToLot(ImportResult result)
    {
        _importLinkWkt = result.Wkt;
        _linkingLotId = Guid.Empty;
        _showLinkModal = true;
        _showImportModal = false;
    }

    private async Task SaveImportedGeometry()
    {
        if (string.IsNullOrEmpty(_importLinkWkt) || _linkingLotId == Guid.Empty) return;

        _savingGeometry = true;
        try
        {
            var lot = _allLots.FirstOrDefault(l => l.Id == _linkingLotId);
            if (lot == null) return;

            var dto = new LotDto(
                lot.Id, lot.FieldId, lot.Name, lot.Status, _importLinkWkt, lot.FieldName
            );

            var response = await Http.PutAsJsonAsync($"api/lots/{lot.Id}",
                dto, AppJsonSerializerContext.Default.LotDto);

            if (response.IsSuccessStatusCode)
            {
                Message.Success($"Geometría vinculada a '{lot.Name}'.");
                _showLinkModal = false;
                _importLinkWkt = null;
                _linkingLotId = Guid.Empty;
                await ReloadMap();
            }
            else
            {
                Message.Error($"Error: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
        finally
        {
            _savingGeometry = false;
        }
    }

    private static double[][][] ConvertToLeafletCoords(double[][][] geoJsonCoords)
    {
        return geoJsonCoords.Select(ring =>
            ring.Select(coord => new double[] { coord[1], coord[0] }).ToArray()
        ).ToArray();
    }
}
