@page "/admin/users"
@page "/admin"
@layout GestorOT.Client.Layout.AdminDashboardLayout
@using Microsoft.AspNetCore.Components.QuickGrid
@using GestorOT.Domain.Enums
@inject HttpClient Http
@inject PersistentComponentState PersistentState

<div class="page-header">
    <div>
        <h1 class="page-title">Gestión de Usuarios</h1>
        <span class="page-subtitle">@_users.Count usuarios registrados</span>
    </div>
    <button class="btn-admin btn-admin-primary" @onclick="OpenCreateModal">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/>
        </svg>
        Nuevo Usuario
    </button>
</div>

<div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 20px;">
    <div class="stat-card">
        <div class="stat-card-value">@_users.Count</div>
        <div class="stat-card-label">Total Usuarios</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-value">@_users.Count(u => u.IsActive)</div>
        <div class="stat-card-label">Activos</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-value">@_users.Count(u => u.Role == "Admin")</div>
        <div class="stat-card-label">Administradores</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-value">@_users.Count(u => !u.IsActive)</div>
        <div class="stat-card-label">Bloqueados</div>
    </div>
</div>

<div class="glass-card">
    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
        <div class="search-wrapper">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input class="search-input" type="text" placeholder="Buscar por nombre o email..."
                   @bind="_searchText" @bind:event="oninput" />
        </div>
        <select class="search-input" style="width: 180px; padding-left: 14px;"
                @bind="_roleFilter">
            <option value="">Todos los roles</option>
            @foreach (ContactRole role in Enum.GetValues(typeof(ContactRole)))
            {
                <option value="@role.ToString()">@role.GetDisplayName()</option>
            }
        </select>
    </div>

    @if (_loading)
    {
        <div style="text-align: center; padding: 40px; color: rgba(255,255,255,0.4);">
            <div style="margin-bottom: 8px;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation: spin 1s linear infinite;"><line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/><line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"/><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/></svg>
            </div>
            Cargando usuarios...
        </div>
    }
    else if (_error != null)
    {
        <div style="background: rgba(231,76,60,0.1); border: 1px solid rgba(231,76,60,0.2); border-radius: 8px; padding: 14px; color: rgba(231,76,60,0.9); font-size: 13px;">
            @_error
        </div>
    }
    else
    {
        <QuickGrid Items="@FilteredUsers" Pagination="@_pagination"
                   Class="admin-quickgrid"
                   RowClass="@(u => !u.IsActive ? "row-locked" : "")">
            <TemplateColumn Title="Usuario">
                <div style="display: flex; align-items: center; gap: 10px;">
                    <div style="width: 32px; height: 32px; border-radius: 8px; background: linear-gradient(135deg, @GetAvatarColor(context.Role)); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 12px; font-weight: 700;">
                        @(context.DisplayName?.Length > 0 ? context.DisplayName[0].ToString().ToUpper() : "?")
                    </div>
                    <div>
                        <div style="font-weight: 600; color: rgba(255,255,255,0.9);">@context.DisplayName</div>
                        <div style="font-size: 11px; color: rgba(255,255,255,0.4);">@context.Email</div>
                    </div>
                </div>
            </TemplateColumn>
            <TemplateColumn Title="Rol" Sortable="true" SortBy="@(GridSort<UserProfileDto>.ByAscending(u => u.Role))">
                <span class="badge badge-@(context.Role.ToLower())">@context.Role</span>
            </TemplateColumn>
            <TemplateColumn Title="Estado">
                @if (context.IsActive)
                {
                    <span class="badge badge-active">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" style="margin-right: 4px;"><circle cx="12" cy="12" r="8"/></svg>
                        Activo
                    </span>
                }
                else
                {
                    <span class="badge badge-locked">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" style="margin-right: 4px;"><circle cx="12" cy="12" r="8"/></svg>
                        Bloqueado
                    </span>
                }
            </TemplateColumn>
            <PropertyColumn Property="@(u => u.CreatedAt)" Title="Registrado" Format="dd/MM/yyyy" Sortable="true" />
            <TemplateColumn Title="Acciones">
                <div style="display: flex; gap: 4px;">
                    <button class="btn-icon" title="Editar" @onclick="() => OpenEditModal(context)">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    </button>
                    <button class="btn-icon btn-icon-danger" title="Eliminar" @onclick="() => ConfirmDelete(context)">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                    </button>
                </div>
            </TemplateColumn>
        </QuickGrid>

        <div class="admin-paginator">
            <Paginator State="@_pagination" />
        </div>
    }
</div>

@if (_modalVisible)
{
    <div style="position: fixed; inset: 0; z-index: 1000; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);" @onclick="CloseModal">
        <div style="background: #1e1e2e; border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 28px; width: 460px; max-width: 90vw;" @onclick:stopPropagation>
            <h3 style="color: rgba(255,255,255,0.9); font-size: 16px; font-weight: 600; margin: 0 0 20px;">
                @(_editingUser != null ? "Editar Usuario" : "Nuevo Usuario")
            </h3>

            <EditForm Model="_formModel" OnValidSubmit="SaveUser">
                <DataAnnotationsValidator />

                <div style="margin-bottom: 14px;">
                    <label style="display: block; color: rgba(255,255,255,0.5); font-size: 12px; margin-bottom: 4px;">Nombre</label>
                    <InputText @bind-Value="_formModel.DisplayName" class="search-input" style="width: 100%; box-sizing: border-box; padding-left: 14px;" />
                    <ValidationMessage For="() => _formModel.DisplayName" />
                </div>

                <div style="margin-bottom: 14px;">
                    <label style="display: block; color: rgba(255,255,255,0.5); font-size: 12px; margin-bottom: 4px;">Email</label>
                    <InputText @bind-Value="_formModel.Email" class="search-input" style="width: 100%; box-sizing: border-box; padding-left: 14px;" />
                    <ValidationMessage For="() => _formModel.Email" />
                </div>


...
                <div style="margin-bottom: 14px;">
                    <label style="display: block; color: rgba(255,255,255,0.5); font-size: 12px; margin-bottom: 4px;">Rol</label>
                    <InputSelect @bind-Value="_formModel.Role" class="search-input" style="width: 100%; box-sizing: border-box; padding-left: 14px;">
                        @foreach (ContactRole role in Enum.GetValues(typeof(ContactRole)))
                        {
                            <option value="@role.ToString()">@role.GetDisplayName()</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => _formModel.Role" />
                </div>

                <div style="margin-bottom: 20px;">
                    <label style="display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.7); font-size: 13px; cursor: pointer;">
                        <InputCheckbox @bind-Value="_formModel.IsActive" style="accent-color: #E74C3C;" />
                        Usuario activo
                    </label>
                </div>

                <ValidationSummary />

                <div style="display: flex; justify-content: flex-end; gap: 8px; margin-top: 16px;">
                    <button type="button" class="btn-admin btn-admin-ghost" @onclick="CloseModal">Cancelar</button>
                    <button type="submit" class="btn-admin btn-admin-primary">Guardar</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (_deleteTarget != null)
{
    <div style="position: fixed; inset: 0; z-index: 1000; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);" @onclick="() => _deleteTarget = null">
        <div style="background: #1e1e2e; border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 28px; width: 400px; text-align: center;" @onclick:stopPropagation>
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(231,76,60,0.12); display: inline-flex; align-items: center; justify-content: center; margin-bottom: 16px;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E74C3C" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <h3 style="color: rgba(255,255,255,0.9); font-size: 15px; margin: 0 0 8px;">¿Eliminar usuario?</h3>
            <p style="color: rgba(255,255,255,0.5); font-size: 13px; margin: 0 0 20px;">
                Se eliminará <strong style="color: rgba(255,255,255,0.7);">@_deleteTarget.DisplayName</strong>. Esta acción no se puede deshacer.
            </p>
            <div style="display: flex; justify-content: center; gap: 8px;">
                <button class="btn-admin btn-admin-ghost" @onclick="() => _deleteTarget = null">Cancelar</button>
                <button class="btn-admin" style="background: #E74C3C; color: #fff;" @onclick="DeleteUser">Eliminar</button>
            </div>
        </div>
    </div>
}

<style>
    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .validation-message {
        color: #E74C3C;
        font-size: 11px;
        margin-top: 4px;
    }

    .validation-errors {
        color: #E74C3C;
        font-size: 12px;
        list-style: none;
        padding: 0;
        margin: 8px 0 0;
    }
</style>

@code {
    private List<UserProfileDto> _users = new();
    private bool _loading = true;
    private string? _error;

    private string _searchText = "";
    private string _roleFilter = "";
    private PaginationState _pagination = new PaginationState { ItemsPerPage = 10 };

    private bool _modalVisible;
    private UserProfileDto? _editingUser;
    private GestorOT.Shared.Validation.UserFormDto _formModel = new();
    private UserProfileDto? _deleteTarget;

    private PersistingComponentStateSubscription _persistingSubscription;

    private IQueryable<UserProfileDto> FilteredUsers => _users
        .Where(u =>
            (string.IsNullOrEmpty(_searchText) ||
             u.DisplayName.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
             u.Email.Contains(_searchText, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(_roleFilter) || u.Role == _roleFilter))
        .AsQueryable();

    protected override async Task OnInitializedAsync()
    {
        _persistingSubscription = PersistentState.RegisterOnPersisting(PersistState);

        if (PersistentState.TryTakeFromJson<string>("admin_users_search", out var savedSearch))
        {
            _searchText = savedSearch ?? "";
        }
        if (PersistentState.TryTakeFromJson<string>("admin_users_role", out var savedRole))
        {
            _roleFilter = savedRole ?? "";
        }

        await LoadUsers();
    }

    private Task PersistState()
    {
        PersistentState.PersistAsJson("admin_users_search", _searchText);
        PersistentState.PersistAsJson("admin_users_role", _roleFilter);
        return Task.CompletedTask;
    }

    private async Task LoadUsers()
    {
        _loading = true;
        _error = null;
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));
            _users = await Http.GetFromJsonAsync("api/userprofiles",
                AppJsonSerializerContext.Default.ListUserProfileDto, cts.Token) ?? new();
        }
        catch (Exception ex)
        {
            _error = $"Error al cargar usuarios: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void OpenCreateModal()
    {
        _editingUser = null;
        _formModel = new GestorOT.Shared.Validation.UserFormDto
        {
            Role = "Agronomist",
            IsActive = true
        };
        _modalVisible = true;
    }

    private void OpenEditModal(UserProfileDto user)
    {
        _editingUser = user;
        _formModel = new GestorOT.Shared.Validation.UserFormDto
        {
            DisplayName = user.DisplayName,
            Email = user.Email,
            Role = user.Role,
            IsActive = user.IsActive
        };
        _modalVisible = true;
    }

    private void CloseModal()
    {
        _modalVisible = false;
        _editingUser = null;
    }

    private async Task SaveUser()
    {
        try
        {
            var dto = new UserProfileDto(
                _editingUser?.Id ?? Guid.Empty,
                _formModel.Email,
                _formModel.DisplayName,
                _formModel.Role,
                _formModel.IsActive,
                _editingUser?.CreatedAt ?? DateTime.UtcNow
            );

            if (_editingUser != null)
            {
                await Http.PutAsJsonAsync($"api/userprofiles/{_editingUser.Id}", dto,
                    AppJsonSerializerContext.Default.UserProfileDto);
            }
            else
            {
                await Http.PostAsJsonAsync("api/userprofiles", dto,
                    AppJsonSerializerContext.Default.UserProfileDto);
            }

            CloseModal();
            await LoadUsers();
        }
        catch (Exception ex)
        {
            _error = $"Error al guardar: {ex.Message}";
        }
    }

    private void ConfirmDelete(UserProfileDto user)
    {
        _deleteTarget = user;
    }

    private async Task DeleteUser()
    {
        if (_deleteTarget == null) return;
        try
        {
            await Http.DeleteAsync($"api/userprofiles/{_deleteTarget.Id}");
            _deleteTarget = null;
            await LoadUsers();
        }
        catch (Exception ex)
        {
            _error = $"Error al eliminar: {ex.Message}";
        }
    }

    private string GetAvatarColor(string role) => role switch
    {
        "Admin" => "#E74C3C, #c0392b",
        "TenantAdmin" => "#E67E22, #d35400",
        "Agronomist" => "#2ECC71, #27ae60",
        "Contractor" => "#3498DB, #2980b9",
        _ => "#95a5a6, #7f8c8d"
    };

    public void Dispose()
    {
        _persistingSubscription.Dispose();
    }
}
