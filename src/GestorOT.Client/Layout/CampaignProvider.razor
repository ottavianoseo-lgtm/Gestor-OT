@using GestorOT.Shared.Dtos
@inject GestorOT.Client.Services.CampaignState CampaignState

@ChildContent

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [PersistentState]
    public string? PersistedCampaignId { get; set; }

    [PersistentState]
    public string? PersistedCampaignName { get; set; }

    [PersistentState]
    public string? PersistedCampaignStatus { get; set; }

    protected override void OnInitialized()
    {
        if (!CampaignState.IsSelected && !string.IsNullOrEmpty(PersistedCampaignId) && Guid.TryParse(PersistedCampaignId, out var campaignId))
        {
            var status = Enum.TryParse<CampaignStatus>(PersistedCampaignStatus, out var s) ? s : CampaignStatus.Active;
            CampaignState.SetCampaign(new CampaignSummaryDto(campaignId, PersistedCampaignName ?? "", status, true));
        }

        CampaignState.OnChange += OnCampaignChanged;
    }

    private void OnCampaignChanged()
    {
        if (CampaignState.CurrentCampaign != null)
        {
            PersistedCampaignId = CampaignState.CurrentCampaign.Id.ToString();
            PersistedCampaignName = CampaignState.CurrentCampaign.Name;
            PersistedCampaignStatus = CampaignState.CurrentCampaign.Status.ToString();
        }
        else
        {
            PersistedCampaignId = null;
            PersistedCampaignName = null;
            PersistedCampaignStatus = null;
        }
        StateHasChanged();
    }
}
