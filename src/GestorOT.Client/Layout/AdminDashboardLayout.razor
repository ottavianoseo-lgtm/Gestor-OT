@inherits LayoutComponentBase
@using AntDesign
@inject NavigationManager Nav
@inject GestorOT.Client.Services.TenantState TenantState

<div class="admin-dashboard">
    <aside class="admin-sidebar @(_collapsed ? "collapsed" : "")">
        <div class="sidebar-header">
            @if (!_collapsed)
            {
                <div class="brand">
                    <div class="brand-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
                            <rect x="3" y="3" width="7" height="7" rx="1.5" fill="#E74C3C"/>
                            <rect x="14" y="3" width="7" height="7" rx="1.5" fill="#E74C3C" opacity="0.7"/>
                            <rect x="3" y="14" width="7" height="7" rx="1.5" fill="#E74C3C" opacity="0.5"/>
                            <rect x="14" y="14" width="7" height="7" rx="1.5" fill="#E74C3C" opacity="0.3"/>
                        </svg>
                    </div>
                    <div>
                        <div class="brand-title">GestorOT</div>
                        <div class="brand-subtitle">Panel Admin</div>
                    </div>
                </div>
            }
            else
            {
                <div class="brand-icon-only">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                        <rect x="3" y="3" width="7" height="7" rx="1.5" fill="#E74C3C"/>
                        <rect x="14" y="3" width="7" height="7" rx="1.5" fill="#E74C3C" opacity="0.7"/>
                        <rect x="3" y="14" width="7" height="7" rx="1.5" fill="#E74C3C" opacity="0.5"/>
                        <rect x="14" y="14" width="7" height="7" rx="1.5" fill="#E74C3C" opacity="0.3"/>
                    </svg>
                </div>
            }
            <button class="collapse-btn" @onclick="() => _collapsed = !_collapsed">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    @if (_collapsed)
                    {
                        <polyline points="9 18 15 12 9 6"></polyline>
                    }
                    else
                    {
                        <polyline points="15 18 9 12 15 6"></polyline>
                    }
                </svg>
            </button>
        </div>

        <nav class="sidebar-nav">
            @if (!_collapsed)
            {
                <div class="nav-section-label">Identidad</div>
            }
            <a href="/admin/users" class="nav-item @(IsActive("/admin/users") || IsActive("/admin") ? "active" : "")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                @if (!_collapsed) { <span>Usuarios</span> }
            </a>
            <a href="/admin/tenants" class="nav-item @(IsActive("/admin/tenants") ? "active" : "")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                @if (!_collapsed) { <span>Empresas</span> }
            </a>

            @if (!_collapsed)
            {
                <div class="nav-section-label">Catálogos</div>
            }
            <a href="/admin/tankmix" class="nav-item @(IsActive("/admin/tankmix") ? "active" : "")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 3h6v7l4 4v7H5v-7l4-4V3z"/><line x1="9" y1="3" x2="15" y2="3"/></svg>
                @if (!_collapsed) { <span>Reglas de Mezcla</span> }
            </a>

            @if (!_collapsed)
            {
                <div class="nav-section-label">Auditoría</div>
            }
            <a href="/admin/audit" class="nav-item @(IsActive("/admin/audit") ? "active" : "")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                @if (!_collapsed) { <span>Auditoría</span> }
            </a>
        </nav>

        <div class="sidebar-footer">
            <a href="/" class="nav-item back-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                @if (!_collapsed) { <span>Volver al Sistema</span> }
            </a>
        </div>
    </aside>

    <main class="admin-main">
        <header class="admin-topbar">
            <div class="topbar-left">
                <h2 class="topbar-title">Administración</h2>
            </div>
            <div class="topbar-right">
                <div class="topbar-tenant">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
                    <span>@(TenantState.CurrentTenant?.Name ?? "Sin empresa")</span>
                </div>
                <div class="topbar-user">
                    <div class="user-avatar">A</div>
                    <span class="user-name">Admin</span>
                </div>
            </div>
        </header>

        <div class="admin-content">
            @Body
        </div>
    </main>
</div>

<TenantSelector />

@code {
    private bool _collapsed = false;

    protected override void OnInitialized()
    {
        TenantState.OnChange += StateHasChanged;
        Nav.LocationChanged += (_, _) => InvokeAsync(StateHasChanged);
    }

    private bool IsActive(string path)
    {
        var uri = new Uri(Nav.Uri);
        return uri.AbsolutePath.Equals(path, StringComparison.OrdinalIgnoreCase);
    }
}
