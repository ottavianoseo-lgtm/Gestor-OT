@implements IDisposable
@inject HttpClient Http
@inject GestorOT.Client.Services.CampaignState CampaignState
@using GestorOT.Shared
@using GestorOT.Shared.Dtos
@using AntDesign

<div class="campaign-selector-wrapper">
    @if (_loading)
    {
        <Spin Size="AntDesign.SpinSize.Small" />
    }
    else if (_campaigns.Count == 0)
    {
        <div class="campaign-empty" @onclick="OpenModal">
            <Icon Type="calendar" Theme="IconThemeType.Outline" Style="color: rgba(255,255,255,0.4); font-size: 14px;" />
            <span style="color: rgba(255,255,255,0.5); font-size: 12px;">Sin campañas</span>
        </div>
    }
    else if (CampaignState.IsSelected)
    {
        <div class="campaign-badge" @onclick="OpenModal" style="cursor: @(_campaigns.Count > 1 ? "pointer" : "default")">
            <div class="campaign-icon">
                <Icon Type="calendar" Theme="IconThemeType.Outline" Style="color: #fff; font-size: 13px;" />
            </div>
            <div style="flex: 1; min-width: 0;">
                <div style="color: rgba(255,255,255,0.5); font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px;">Campaña</div>
                <div style="color: #fff; font-size: 12px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@CampaignState.CurrentCampaign!.Name</div>
            </div>
            @if (_campaigns.Count > 1)
            {
                <Icon Type="swap" Theme="IconThemeType.Outline" Style="color: rgba(255,255,255,0.3); font-size: 12px;" />
            }
        </div>
    }
    else
    {
        <div class="campaign-badge campaign-badge-empty" @onclick="OpenModal">
            <div class="campaign-icon" style="background: rgba(255,255,255,0.1);">
                <Icon Type="calendar" Theme="IconThemeType.Outline" Style="color: rgba(255,255,255,0.5); font-size: 13px;" />
            </div>
            <div style="flex: 1;">
                <div style="color: rgba(255,255,255,0.5); font-size: 12px;">Seleccionar Campaña</div>
            </div>
        </div>
    }
</div>

@if (_modalVisible)
{
    <div class="campaign-modal-overlay" @onclick="CloseModal">
        <div class="campaign-modal" @onclick:stopPropagation="true">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                <h3 style="color: #fff; margin: 0; font-size: 16px; font-weight: 700;">Campañas</h3>
                <div style="cursor: pointer; color: rgba(255,255,255,0.4);" @onclick="CloseModal">
                    <Icon Type="close" Theme="IconThemeType.Outline" />
                </div>
            </div>



            <div class="campaign-list">
                @foreach (var campaign in _campaigns.OrderByDescending(c => c.Name))
                {
                    var isSelected = campaign.Id == CampaignState.CurrentCampaign?.Id;
                    var isLocked = campaign.Status == CampaignStatus.Locked;
                    var statusLabel = campaign.Status switch
                    {
                        CampaignStatus.Active => "Activa",
                        CampaignStatus.Locked => "Bloqueada",
                        _ => "Inactiva"
                    };
                    var statusColor = campaign.Status switch
                    {
                        CampaignStatus.Active => "#2ECC71",
                        CampaignStatus.Locked => "#95A5A6",
                        _ => "#F1C40F"
                    };
                    <div class="campaign-item @(isSelected ? "campaign-item-selected" : "") @(isLocked ? "campaign-item-locked" : "")" @onclick="() => SelectCampaign(campaign)">
                        <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                            <div style="display: flex; align-items: center; gap: 8px; flex: 1; min-width: 0;">
                                <span style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@campaign.Name</span>
                                <Tag Style="@($"background: {statusColor}20; color: {statusColor}; border: 1px solid {statusColor}40; border-radius: 8px; font-size: 10px; padding: 1px 8px;")">
                                    @statusLabel
                                </Tag>
                                @if (isLocked)
                                {
                                    <Tag Style="background: #E67E2220; color: #E67E22; border: 1px solid #E67E2240; border-radius: 8px; font-size: 10px; padding: 1px 8px;">
                                        <Icon Type="lock" Theme="IconThemeType.Outline" Style="font-size: 10px; margin-right: 2px;" /> Solo lectura
                                    </Tag>
                                }
                            </div>
                            @if (isSelected)
                            {
                                <Icon Type="check" Theme="IconThemeType.Outline" Style="color: #2ECC71; font-size: 16px; margin-left: 8px; flex-shrink: 0;" />
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<style>
    .campaign-selector-wrapper {
        margin: 6px 14px;
    }

    .campaign-badge {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 12px;
        border-radius: 10px;
        background: rgba(46, 204, 113, 0.08);
        border: 1px solid rgba(46, 204, 113, 0.15);
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .campaign-badge:hover {
        background: rgba(46, 204, 113, 0.15);
        border-color: rgba(46, 204, 113, 0.3);
    }

    .campaign-badge-empty {
        background: rgba(255,255,255,0.04);
        border-color: rgba(255,255,255,0.08);
    }

    .campaign-badge-empty:hover {
        background: rgba(255,255,255,0.08);
        border-color: rgba(255,255,255,0.15);
    }

    .campaign-icon {
        width: 28px;
        height: 28px;
        border-radius: 7px;
        background: linear-gradient(135deg, #2ECC71, #27AE60);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .campaign-empty {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 10px;
        background: rgba(255,255,255,0.03);
        border: 1px dashed rgba(255,255,255,0.1);
        cursor: pointer;
    }

    .campaign-modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 10000;
        background: rgba(0,0,0,0.6);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .campaign-modal {
        background: #1E1E2E;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 16px;
        padding: 24px;
        width: 400px;
        max-width: 90vw;
        max-height: 70vh;
        overflow-y: auto;
    }

    .campaign-clear {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 14px;
        border-radius: 10px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        color: rgba(255,255,255,0.6);
        font-size: 12px;
        cursor: pointer;
        margin-bottom: 12px;
        transition: all 0.2s ease;
    }

    .campaign-clear:hover {
        background: rgba(255,255,255,0.08);
        color: #fff;
    }

    .campaign-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .campaign-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 14px;
        border-radius: 10px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.06);
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .campaign-item:hover {
        background: rgba(46, 204, 113, 0.08);
        border-color: rgba(46, 204, 113, 0.2);
    }

    .campaign-item-selected {
        background: rgba(46, 204, 113, 0.12);
        border-color: rgba(46, 204, 113, 0.3);
    }

    .campaign-item-locked {
        opacity: 0.85;
    }
</style>

@code {
    private List<CampaignSummaryDto> _campaigns = new();
    private bool _loading = true;
    private bool _modalVisible = false;

    protected override async Task OnInitializedAsync()
    {
        CampaignState.OnChange += StateHasChanged;
        CampaignState.OnCampaignsChanged += HandleCampaignsChanged;
        await LoadCampaigns(skipAutoSelect: false);
    }

    private async Task HandleCampaignsChanged()
    {
        try
        {
            _loading = true;
            await InvokeAsync(StateHasChanged);
            await LoadCampaigns(skipAutoSelect: true);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[CampaignSelector] Error handling campaign change: {ex.Message}");
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadCampaigns(bool skipAutoSelect = false)
    {
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(10));
            var allCampaigns = await Http.GetFromJsonAsync("api/campaigns/selector",
                AppJsonSerializerContext.Default.ListCampaignSummaryDto, cts.Token);

            _campaigns = allCampaigns?.ToList() ?? new();

            if (_campaigns.Count > 0)
            {
                var savedId = await CampaignState.GetSavedCampaignId();
                var currentId = CampaignState.CurrentCampaign?.Id;
                
                // If we have a saved ID and no selection (or stale selection), try to restore it
                if (savedId.HasValue && (!CampaignState.IsSelected || currentId != savedId))
                {
                    var savedCampaign = _campaigns.FirstOrDefault(c => c.Id == savedId.Value);
                    if (savedCampaign != null)
                    {
                        CampaignState.SetCampaign(savedCampaign);
                    }
                }

                // If still no selection, or the current selection is no longer in the list, pick the first one
                if (!CampaignState.IsSelected || !_campaigns.Any(c => c.Id == CampaignState.CurrentCampaign?.Id))
                {
                    CampaignState.SetCampaign(_campaigns[0]);
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[CampaignSelector] Error loading campaigns: {ex.Message}");
            _campaigns = new();
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenModal()
    {
        if (_campaigns.Count > 1)
        {
            _modalVisible = true;
        }
    }

    private void CloseModal()
    {
        if (CampaignState.IsSelected || _campaigns.Count == 0)
        {
            _modalVisible = false;
        }
    }

    private void SelectCampaign(CampaignSummaryDto campaign)
    {
        CampaignState.SetCampaign(campaign);
        _modalVisible = false;
    }



    public void Dispose()
    {
        CampaignState.OnChange -= StateHasChanged;
        CampaignState.OnCampaignsChanged -= HandleCampaignsChanged;
    }
}
