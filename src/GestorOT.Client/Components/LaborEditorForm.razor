@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using GestorOT.Domain.Enums
@using System.Net.Http.Json
@using System.Text.Json
@using AntDesign
@inject HttpClient Http
@inject IMessageService Message
@inject IJSRuntime JSRuntime
@inject GestorOT.Client.Services.CampaignState CampaignState
@inject ModalService ModalService
@implements IDisposable

<Card Title="@(LaborId == Guid.Empty ? "Nueva Labor" : "Editar Labor")"
      Style="border-radius: 12px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1);">
    <Form Model="@_model" OnFinish="HandleSubmit" Layout="@FormLayout.Vertical">
        @if (_model.IsOriginalPlan && !ForceOriginalPlan)
        {
            <Alert Type="@AlertType.Info" ShowIcon="true" Style="margin-bottom: 16px; background: rgba(241,196,15,0.1); border: 1px solid rgba(241,196,15,0.3); color: #F1C40F;"
                   MessageTemplate="@((RenderFragment)(builder => { builder.AddContent(0, "Planeamiento Original (P.O.): solo lectura. Solo un administrador puede modificar o desanclar esta labor."); }))" />
        }
        @if (CampaignState.CurrentCampaign != null && _lots.Count == 0 && !_loading)
        {
            <Alert Type="@AlertType.Warning" Message="La campaña actual no tiene lotes asignados. Asigne lotes a la campaña antes de crear labores." ShowIcon="true" Style="margin-bottom: 16px;" />
        }
        @if (!string.IsNullOrEmpty(_saveError))
        {
            <Alert Type="@AlertType.Error" Message="@_saveError" ShowIcon="true" Closable="true" OnClose="() => _saveError = null" Style="margin-bottom: 16px;" />
        }
        @if (_saveWarnings != null && _saveWarnings.Any())
        {
            <Alert Type="@AlertType.Warning" ShowIcon="true" Style="margin-bottom: 16px;">
                <MessageTemplate>
                    <ul style="margin: 0; padding-left: 18px;">
                        @foreach (var w in _saveWarnings)
                        {
                            <li>@w</li>
                        }
                    </ul>
                </MessageTemplate>
            </Alert>
        }
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <FormItem Label="Campo (Filtro)">
                <Select TItemValue="Guid" TItem="FieldDto" @bind-Value="_filterFieldId"
                        Placeholder="Filtrar por campo" EnableSearch AllowClear
                        DataSource="@FilteredFields"
                        LabelName="@nameof(FieldDto.Name)"
                        ValueName="@nameof(FieldDto.Id)"
                        OnSelectedItemChanged="OnFieldFilterChanged">
                </Select>
            </FormItem>

            <FormItem Label="Lote" Style="@(HasError("lot") ? "border: 1px solid #E74C3C; border-radius: 8px; padding: 8px;" : "")">
                <Select TItemValue="Guid" TItem="CampaignLotDto" @bind-Value="_model.LotId"
                        Placeholder="Seleccionar lote" EnableSearch 
                        DataSource="@FilteredLots"
                        LabelName="@nameof(CampaignLotDto.LotName)"
                        ValueName="@nameof(CampaignLotDto.LotId)"
                        OnSelectedItemChanged="OnLotChanged">
                </Select>
                @if (HasError("lot"))
                {
                    <div style="color: #E74C3C; font-size: 11px; margin-top: 4px;">@GetError("lot")</div>
                }
            </FormItem>

            <FormItem Label="Hectáreas" Style="@(HasError("hectares") ? "border: 1px solid #E74C3C; border-radius: 8px; padding: 8px;" : "")">
                <AntDesign.InputNumber TValue="decimal" Value="@_model.Hectares" OnChange="OnHectareasChanged" Min="0m" Step="0.1m" Style="width: 100%; color: var(--text-primary);" />
                @if (_noProductiveAreaWarning)
                {
                    <div style="color: #F1C40F; font-size: 11px; margin-top: 4px;">
                        <Icon Type="warning" /> Este lote no tiene superficie productiva definida en la campaña. Se usa el área catastral como valor inicial. Revisá la configuración en la sección Campañas.
                    </div>
                }
                else if (_haSuperaLote)
                {
                    <div style="color: #FAAD14; font-size: 11px; margin-top: 4px;">
                        <Icon Type="warning" /> La superficie supera el área productiva del lote (@_lotProductiveArea ha).
                    </div>
                }
                @if (HasError("hectares"))
                {
                    <div style="color: #E74C3C; font-size: 11px; margin-top: 4px;">@GetError("hectares")</div>
                }
            </FormItem>
        </div>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <FormItem Label="Actividad (ERP)" Style="@(HasError("activity") ? "border: 1px solid #E74C3C; border-radius: 8px; padding: 8px;" : "")">
                <div style="display: flex; align-items: center; gap: 8px;">
                    <Select TItemValue="Guid?" TItem="ErpActivityDto" @bind-Value="_model.ErpActivityId"
                            Placeholder="Seleccionar actividad" Disabled="@_actividadLocked"
                            Style="@($"flex: 1;{(_actividadLocked ? " opacity: 0.5; pointer-events: none;" : "")}")"
                            LabelName="@nameof(ErpActivityDto.Name)" ValueName="@nameof(ErpActivityDto.Id)"
                            DataSource="@_activities" EnableSearch>
                    </Select>
                    @if (_activeRotation != null)
                    {
                        <Tooltip Title="@("Actividad definida en el plan de Rotaciones. Para modificarla, dirigirse a la sección Rotaciones.")">
                            <Tag Color="TagColor.Processing">Planeada</Tag>
                        </Tooltip>
                    }
                    else if (_showNoRotacionWarning)
                    {
                        <Tooltip Title="Sin rotación proyectada para esta fecha">
                            <Tag Color="TagColor.Warning">Sin rotación</Tag>
                        </Tooltip>
                    }
                </div>
                @if (HasError("activity"))
                {
                    <div style="color: #E74C3C; font-size: 11px; margin-top: 4px;">@GetError("activity")</div>
                }
            </FormItem>

            <FormItem Label="Tipo de Labor (Tarea)" Style="@(HasError("laborType") ? "border: 1px solid #E74C3C; border-radius: 8px; padding: 8px;" : "")">
                <Select TItemValue="Guid" TItem="LaborTypeDto" @bind-Value="_model.LaborTypeId"
                        Placeholder="Seleccionar tipo de labor" EnableSearch
                        LabelName="@nameof(LaborTypeDto.Name)" ValueName="@nameof(LaborTypeDto.Id)"
                        DataSource="@_laborTypes">
                </Select>
                @if (HasError("laborType"))
                {
                    <div style="color: #E74C3C; font-size: 11px; margin-top: 4px;">@GetError("laborType")</div>
                }
            </FormItem>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <FormItem Label="Persona Responsable" Style="@(HasError("contact") ? "border: 1px solid #E74C3C; border-radius: 8px; padding: 8px;" : "")">
                <div style="display: flex; align-items: center; gap: 16px;">
                    <Select TItemValue="Guid?" TItem="ContactDto" @bind-Value="_model.ContactId"
                            Placeholder="Seleccionar responsable" EnableSearch Style="flex: 1;"
                            OnSelectedItemChanged="OnContactChanged">
                        @foreach (var contact in _contacts)
                        {
                            <SelectOption TItemValue="Guid?" TItem="ContactDto" Value="@((Guid?)contact.Id)" Label="@contact.FullName" />
                        }
                    </Select>
                    <RadioGroup @bind-Value="_model.IsExternalBilling">
                        <Radio Value="@false">Propio</Radio>
                        <Radio Value="@true">Contratista</Radio>
                    </RadioGroup>
                </div>
                @if (HasError("contact"))
                {
                    <div style="color: #E74C3C; font-size: 11px; margin-top: 4px;">@GetError("contact")</div>
                }
            </FormItem>

            <FormItem Label="@($"Fecha {(_model.Status == "Realized" ? "Ejecución" : "Estimada")}")" Style="@(HasError("date") ? "border: 1px solid #E74C3C; border-radius: 8px; padding: 8px;" : "")">
                <DatePicker TValue="DateTime?" Value="@(_model.Status == "Realized" ? _model.ExecutionDate : _model.EstimatedDate)" 
                            OnChange="@(async args => { if (_model.Status == "Realized") _model.ExecutionDate = args.Date; else await OnFechaEstimadaChanged(args); })" 
                            Style="width: 100%; color: var(--text-primary);" />
                @if (_fechaFueraRotacion && _model.Status != "Realized")
                {
                    <div style="color: #FAAD14; font-size: 11px; margin-top: 4px;">
                        <Icon Type="warning" /> Fecha fuera del rango de rotación.
                    </div>
                }
                @if (HasError("date"))
                {
                    <div style="color: #E74C3C; font-size: 11px; margin-top: 4px;">@GetError("date")</div>
                }
            </FormItem>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <FormItem Label="Orden de Trabajo">
                <Select TItemValue="Guid?" TItem="WorkOrderDto" @bind-Value="_model.WorkOrderId"
                        Placeholder="Sin asignar" EnableSearch AllowClear
                        DataSource="@_workOrders"
                        LabelName="@nameof(WorkOrderDto.DisplayName)"
                        ValueName="@nameof(WorkOrderDto.Id)">
                </Select>
            </FormItem>

            <FormItem Label="Estado de la Labor">
                @if (ForceOriginalPlan || _model.IsOriginalPlan)
                {
                    <Tag Color="@("#1890FF" + "33")" Style="color: #fff; border: 1px solid #1890FF80; border-radius: 12px; font-weight: 600; padding: 4px 16px;">
                        Planeada
                    </Tag>
                }
                else
                {
                    <RadioGroup @bind-Value="_model.Status" OnChange="@((string val) => OnStatusChanged(val))" TValue="string">
                        <Radio Value="@("Planned")"><span style="color: var(--text-primary);">Planeada</span></Radio>
                        <Radio Value="@("Realized")"><span style="color: var(--text-primary);">Realizada</span></Radio>
                    </RadioGroup>
                }
            </FormItem>
        </div>

        <FormItem Label="Notas / Prescripción">
            <TextArea @bind-Value="_model.Notes" Rows="2" Placeholder="Instrucciones para el contratista..." Style="color: var(--text-primary); background: rgba(255,255,255,0.05);" />
        </FormItem>

        <Divider Style="border-color: rgba(255,255,255,0.1); color: var(--text-primary);" Text="Insumos" Orientation="@AntDesign.DividerOrientation.Left" />

        <div class="supplies-grid">
            @foreach (var supply in _model.Supplies)
            {
                <div style="border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 15px; margin-bottom: 10px; background: rgba(255,255,255,0.02);">
                    <div style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr 50px; gap: 15px; align-items: end;">
                        <FormItem Label="Insumo" Style="margin-bottom: 0;">
                            <Select TItemValue="Guid" TItem="InventoryDto" @bind-Value="supply.SupplyId" 
                                    OnSelectedItemChanged="(InventoryDto s) => OnSupplySelected(supply, s)"
                                    OnSearch="async (e) => await SearchSupplies(e)" EnableSearch 
                                    Style="width: 100%; color: var(--text-primary);">
                                @foreach (var inv in _inventories)
                                {
                                    <SelectOption TItemValue="Guid" TItem="InventoryDto" Value="@inv.Id" Label="@inv.ItemName" />
                                }
                            </Select>
                        </FormItem>
                        <FormItem Label="@(_model.Status == "Realized" ? "Ha. Reales" : "Hectáreas")" Style="margin-bottom: 0;">
                            <AntDesign.InputNumber TValue="decimal" Value="@(_model.Status == "Realized" ? (supply.RealHectares ?? supply.PlannedHectares) : supply.PlannedHectares)" 
                                                   OnChange="@(v => { if (_model.Status == "Realized") supply.RealHectares = v; else supply.PlannedHectares = v; })"
                                                   Min="0m" Step="0.1m" Style="width: 100%; color: var(--text-primary);" />
                        </FormItem>
                        <FormItem Label="@(_model.Status == "Realized" ? "Dosis Real" : "Dosis Plan.")" Style="margin-bottom: 0;">
                            <AntDesign.InputNumber TValue="decimal" Value="@(_model.Status == "Realized" ? (supply.RealDose ?? supply.PlannedDose) : supply.PlannedDose)" 
                                                   OnChange="@(v => { if (_model.Status == "Realized") supply.RealDose = v; else supply.PlannedDose = v; })"
                                                   Min="0m" Step="0.01m" Style="width: 100%; color: var(--text-primary);" />
                        </FormItem>
                        <FormItem Label="Cantidad" Style="margin-bottom: 0;">
                            <div style="display: flex; align-items: center; gap: 4px;">
                                @{
                                    var dose = _model.Status == "Realized" ? (supply.RealDose ?? supply.PlannedDose) : supply.PlannedDose;
                                    var has = _model.Status == "Realized" ? (supply.RealHectares ?? supply.PlannedHectares) : supply.PlannedHectares;
                                    var total = dose * has;
                                }
                                <span style="color: #fff; font-weight: 600;">@total.ToString("N2")</span>
                                <span style="font-size: 11px; color: rgba(255,255,255,0.4);">@supply.UnitOfMeasure</span>
                            </div>
                        </FormItem>
                        <Button Danger OnClick="() => RemoveSupply(supply)" Style="margin-bottom: 4px;">
                            <Icon Type="delete" />
                        </Button>
                    </div>
                </div>
            }
            <Button Type="@ButtonType.Default" Block OnClick="AddSupply" Style="margin-top: 8px; color: #fff; background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.2); height: 40px; border-radius: 8px;">
                <Icon Type="plus" /> Agregar Insumo
            </Button>
        </div>

        <Collapse DefaultActiveKey="@(new[] { "" })" Style="margin-top: 16px; background: transparent; border: 1px solid rgba(255,255,255,0.08);">
            <Panel Header="Condiciones Climáticas (Opcional)" Key="1">
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 16px;">
                    <FormItem Label="Temperatura (°C)">
                        <AntDesign.InputNumber TValue="double?" @bind-Value="_weather.Temperature" Placeholder="°C" Style="width: 100%; color: var(--text-primary);" />
                    </FormItem>
                    <FormItem Label="Humedad (%)">
                        <AntDesign.InputNumber TValue="double?" @bind-Value="_weather.Humidity" Min="0" Max="100" Placeholder="%" Style="width: 100%; color: var(--text-primary);" />
                    </FormItem>
                    <FormItem Label="Viento (km/h)">
                        <AntDesign.InputNumber TValue="double?" @bind-Value="_weather.WindSpeed" Min="0" Placeholder="km/h" Style="width: 100%; color: var(--text-primary);" />
                    </FormItem>
                    <FormItem Label="Dir. Viento">
                        <Select TItemValue="string" TItem="string" @bind-Value="_weather.WindDirection" Placeholder="Dir.">
                            <SelectOption TItemValue="string" TItem="string" Value="@("N")" Label="N" />
                            <SelectOption TItemValue="string" TItem="string" Value="@("NE")" Label="NE" />
                            <SelectOption TItemValue="string" TItem="string" Value="@("E")" Label="E" />
                            <SelectOption TItemValue="string" TItem="string" Value="@("SE")" Label="SE" />
                            <SelectOption TItemValue="string" TItem="string" Value="@("S")" Label="S" />
                            <SelectOption TItemValue="string" TItem="string" Value="@("SO")" Label="SO" />
                            <SelectOption TItemValue="string" TItem="string" Value="@("O")" Label="O" />
                            <SelectOption TItemValue="string" TItem="string" Value="@("NO")" Label="NO" />
                        </Select>
                    </FormItem>
                </div>
            </Panel>
        </Collapse>

        @if (!string.IsNullOrEmpty(_validationSummary))
        {
            <div style="margin-top: 16px; padding: 10px 14px; background: rgba(231, 76, 60, 0.1); border: 1px solid rgba(231, 76, 60, 0.3); border-radius: 8px; color: #E74C3C; font-size: 13px;">
                <Icon Type="exclamation-circle" Theme="IconThemeType.Outline" Style="margin-right: 6px;" />
                @_validationSummary
            </div>
        }

        <div style="display: flex; gap: 12px; margin-top: 24px;">
            <Button Type="@ButtonType.Default" OnClick="HandleCancel" Style="flex: 1; height: 45px; border-radius: 8px;">
                Cancelar
            </Button>
            @if (LaborId != Guid.Empty && (_model.Mode == "Planned" || _model.Status == "Planned"))
            {
                <Button Type="@ButtonType.Default" OnClick="SubmitForValidation" Loading="_submitting"
                        Style="flex: 1; height: 45px; border-radius: 8px; font-weight: 600; border-color: #FAAD14; color: #FAAD14;">
                    <Icon Type="send" /> Enviar para Validación
                </Button>
            }
            <Button Type="@ButtonType.Primary" HtmlType="submit" Loading="_loading" Block="false"
                    Style="flex: 2; height: 45px; border-radius: 8px; font-weight: 600;">
                <Icon Type="save" /> Guardar Labor
            </Button>
        </div>
    </Form>

    <LaborAttachments @ref="_attachmentsRef" LaborId="@LaborId" />
</Card>

<Modal Title="Cerrar sin guardar" Visible="_confirmCancelVisible" OnCancel="() => _confirmCancelVisible = false" Footer="null">
    <div style="padding: 10px 0;">
        <p style="color: #fff;">Has subido archivos que no se han vinculado permanentemente a ninguna labor.</p>
        <p style="color: rgba(255,255,255,0.6); font-size: 13px;">¿Qué deseas hacer con estos archivos?</p>
        <div style="display: flex; flex-direction: column; gap: 10px; margin-top: 20px;">
            <Button Type="@ButtonType.Primary" Danger Block OnClick="ConfirmDeleteFiles">Eliminar archivos subidos</Button>
            <Button Type="@ButtonType.Default" Block OnClick="ConfirmKeepFiles" Style="color: #fff; background: rgba(255,255,255,0.05);">Conservar en biblioteca</Button>
            <Button Type="@ButtonType.Text" Block OnClick="() => _confirmCancelVisible = false" Style="color: rgba(255,255,255,0.4);">Continuar editando</Button>
        </div>
    </div>
</Modal>

<ValidationSuccessModal Visible="_magicLinkModalVisible" 
                        ValidationUrl="@_magicLinkUrl" 
                        OnClose="() => _magicLinkModalVisible = false" />

@code {
    [Parameter] public Guid? WorkOrderId { get; set; }
    [Parameter] public Guid LaborId { get; set; }
    [Parameter] public DateTime? DefaultDate { get; set; }
    [Parameter] public string? InitialStatus { get; set; }
    [Parameter] public bool ForceOriginalPlan { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private LaborDto _model = new();
    private List<CampaignLotDto> _lots = new();
    private List<FieldDto> _allFieldsRaw = new();
    
    private List<FieldDto> FilteredFields =>
        CampaignState.CurrentCampaign != null
            ? _lots
                .Where(l => l.FieldId.HasValue)
                .GroupBy(l => l.FieldId!.Value)
                .Select(g => new FieldDto { Id = g.Key, Name = g.First().FieldName ?? "Campo sin nombre" })
                .OrderBy(f => f.Name)
                .ToList()
            : _allFieldsRaw.OrderBy(f => f.Name).ToList();
    private Guid _filterFieldId;
    private List<LaborTypeDto> _laborTypes = new();
    private List<ErpActivityDto> _activities = new();
    private List<InventoryDto> _inventories = new();
    private List<ContactDto> _contacts = new();
    private List<WorkOrderDto> _workOrders = new();
    private bool _loading;
    private bool _submitting;

    private bool _actividadLocked;
    private bool _showNoRotacionWarning;
    private RotationDto? _activeRotation;
    private bool _haSuperaLote;
    private bool _fechaFueraRotacion;
    private decimal _lotProductiveArea;
    private string? _saveError;
    private List<string> _saveWarnings = new();

    private IEnumerable<CampaignLotDto> FilteredLots =>
        (_filterFieldId == Guid.Empty
            ? _lots
            : _lots.Where(l => l.FieldId == _filterFieldId))
        .OrderBy(l => l.LotName);

    private WeatherLogModel _weather = new();
    private bool _magicLinkModalVisible;
    private string _magicLinkUrl = "";
    private bool _confirmCancelVisible;

    private LaborAttachments? _attachmentsRef;
    public bool HasDraftUploads() => _attachmentsRef?.HasDraftUploads ?? false;
    public List<Guid> GetDraftUploadIds() => _attachmentsRef?.GetDraftUploadIds() ?? new();
    public void DiscardDraftUploads() => _attachmentsRef?.DiscardDraftUploads();

    public async Task HandleCancel()
    {
        if (LaborId == Guid.Empty && _attachmentsRef?.HasDraftUploads == true)
        {
            _confirmCancelVisible = true;
        }
        else
        {
            await OnSaved.InvokeAsync();
        }
    }

    private async Task ConfirmDeleteFiles()
    {
        var ids = _attachmentsRef?.GetDraftUploadIds();
        if (ids != null && ids.Any())
        {
            await _attachmentsRef!.DeleteUnlinkedFiles(ids);
        }
        _confirmCancelVisible = false;
        await OnSaved.InvokeAsync();
    }

    private async Task ConfirmKeepFiles()
    {
        _attachmentsRef?.DiscardDraftUploads();
        _confirmCancelVisible = false;
        await OnSaved.InvokeAsync();
    }

    public class WeatherLogModel
    {
        public double? Temperature { get; set; }
        public double? Humidity { get; set; }
        public double? WindSpeed { get; set; }
        public string? WindDirection { get; set; }
        public string? Notes { get; set; }
    }

    private Guid _lastLaborId = Guid.Empty;
    private Guid? _lastWorkOrderId;
    private string? _lastInitialStatus;
    private bool _initialized;

    protected override async Task OnInitializedAsync()
    {
        CampaignState.OnChange += OnCampaignChanged;
        await InitializeForm();
        _initialized = true;
    }

    public async Task Reset()
    {
        ResetFormState();
        await InitializeForm();
        StateHasChanged();
    }

    /// <summary>
    /// #23: Called when parameters change (e.g. modal re-opened with different LaborId).
    /// Reinitializes the form when the labor being edited changes.
    /// </summary>
    protected override async Task OnParametersSetAsync()
    {
        if (!_initialized) return;

        var laborChanged = LaborId != _lastLaborId;
        var woChanged = WorkOrderId != _lastWorkOrderId;
        var initialStatusChanged = InitialStatus != _lastInitialStatus;

        if (laborChanged || woChanged || initialStatusChanged)
        {
            ResetFormState();
            await InitializeForm();
        }
    }

    private void ResetFormState()
    {
        _model = new LaborDto();
        _weather = new WeatherLogModel();
        _actividadLocked = false;
        _showNoRotacionWarning = false;
        _activeRotation = null;
        _haSuperaLote = false;
        _fechaFueraRotacion = false;
        _noProductiveAreaWarning = false;
        _lotProductiveArea = 0;
        _loading = false;
        _submitting = false;
        _magicLinkModalVisible = false;
        _magicLinkUrl = "";
        _filterFieldId = Guid.Empty;
    }

    private async Task InitializeForm()
    {
        _lastLaborId = LaborId;
        _lastWorkOrderId = WorkOrderId;
        _lastInitialStatus = InitialStatus;

        await LoadCatalogs();

        if (LaborId != Guid.Empty)
        {
            await LoadLabor();
            if (_model.EstimatedDate.HasValue) await CheckRotation(_model.EstimatedDate.Value);
            CheckHectaresWarning(_model.Hectares);
        }
        else
        {
            _model = new LaborDto
            {
                WorkOrderId = WorkOrderId,
                Status = InitialStatus ?? "Planned",
                Mode = InitialStatus ?? "Planned",
                EstimatedDate = DefaultDate ?? DateTime.Today,
                IsOriginalPlan = ForceOriginalPlan
            };
            if (_model.EstimatedDate.HasValue) await CheckRotation(_model.EstimatedDate.Value);
        }
    }

    private void OnFieldFilterChanged(FieldDto field)
    {
        _model.LotId = Guid.Empty;
        _model.CampaignLotId = null;
        ClearError("lot");
        StateHasChanged();
    }

    private void OnCampaignChanged()
    {
        InvokeAsync(async () => { await LoadCatalogs(); StateHasChanged(); });
    }

    public void Dispose()
    {
        CampaignState.OnChange -= OnCampaignChanged;
    }

    private async Task LoadCatalogs()
    {
        var typesTask = Http.GetFromJsonAsync<List<LaborTypeDto>>("api/catalogs/labor-types");
        var activitiesTask = Http.GetFromJsonAsync<List<ErpActivityDto>>("api/catalogs/activities");
        var itemsTask = Http.GetFromJsonAsync<List<InventoryDto>>("api/inventory");
        var contactsTask = Http.GetFromJsonAsync<List<ContactDto>>("api/catalogs/contacts");
        var workOrdersTask = Http.GetFromJsonAsync<List<WorkOrderDto>>("api/workorders");
        var fieldsTask = Http.GetFromJsonAsync<List<FieldDto>>("api/fields");

        Task<List<CampaignLotDto>>? lotsTask = null;
        if (CampaignState.CurrentCampaign != null)
        {
            lotsTask = Http.GetFromJsonAsync<List<CampaignLotDto>>(
                $"api/campaigns/{CampaignState.CurrentCampaign.Id}/lots");
        }

        var tasks = new List<Task?> { typesTask, activitiesTask, itemsTask, contactsTask, workOrdersTask, fieldsTask };
        if (lotsTask != null)
        {
            tasks.Add(lotsTask);
        }

        try
        {
            await Task.WhenAll(tasks.Where(t => t != null).Select(t => t!));
            
            _laborTypes = (await typesTask) ?? new();
            _activities = (await activitiesTask) ?? new();
            _inventories = (await itemsTask) ?? new();
            _contacts = (await contactsTask) ?? new();
            _workOrders = ((await workOrdersTask) ?? new()).GroupBy(w => w.Id).Select(g => g.First()).ToList();

            if (lotsTask != null)
                _lots = ((await lotsTask) ?? new())
                    .GroupBy(l => l.Id)
                    .Select(g => g.First())
                    .OrderBy(l => l.LotName)
                    .ToList();

            _allFieldsRaw = (await fieldsTask) ?? new();
                
            Console.WriteLine($"[DEBUG] Catalogs loaded: Types={_laborTypes.Count}, Lots={_lots.Count}, Fields={FilteredFields.Count}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[DEBUG] Error loading catalogs: {ex.Message}");
            Message.Error($"Error cargando catálogos: {ex.Message}");
        }
    }

    private async Task LoadLabor()
    {
        _model = await Http.GetFromJsonAsync<LaborDto>($"api/labors/{LaborId}") ?? new();
        if (!string.IsNullOrEmpty(_model.WeatherLogJson))
        {
            try
            {
                _weather = JsonSerializer.Deserialize<WeatherLogModel>(_model.WeatherLogJson) ?? new();
            }
            catch { /* Malformed JSON in WeatherLogJson — silently ignore, use default */ }
        }

        // Improved fallback: If the lot is not in the currently loaded _lots list, try to load lots from
        // the labor's own campaign if it differs from the globally selected one.
        var lotInList = _lots.Any(l => l.LotId == _model.LotId);
        if (!lotInList && _model.LotId != Guid.Empty)
        {
            try
            {
                Guid? campaignId = _model.CampaignId;
                
                // Fallback to OT's campaign if Labor.CampaignId is missing (redundancy)
                if (!campaignId.HasValue && _model.WorkOrderId.HasValue)
                {
                    var ot = await Http.GetFromJsonAsync<WorkOrderDetailDto>($"api/workorders/{_model.WorkOrderId}");
                    campaignId = ot?.CampaignId;
                }

                if (campaignId.HasValue)
                {
                    var extraLots = await Http.GetFromJsonAsync<List<CampaignLotDto>>(
                        $"api/campaigns/{campaignId.Value}/lots");
                    if (extraLots != null)
                    {
                        foreach (var lot in extraLots)
                        {
                            if (!_lots.Any(l => l.Id == lot.Id))
                                _lots.Add(lot);
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[LaborEditorForm] Could not load lots from labor's campaign: {ex.Message}");
            }
        }

        // Set the field filter based on the labor's lot
        var currentLot = _lots.FirstOrDefault(l => l.LotId == _model.LotId);
        if (currentLot != null && currentLot.FieldId.HasValue)
        {
            _filterFieldId = currentLot.FieldId.Value;
        }

        // #25: Ensure all labor supplies are in the _inventories list so the Select component can display them
        if (_model.Supplies != null)
        {
            foreach (var s in _model.Supplies)
            {
                if (s.SupplyId != Guid.Empty && !_inventories.Any(i => i.Id == s.SupplyId))
                {
                    _inventories.Add(new InventoryDto(
                        s.SupplyId, 
                        "Cargado", 
                        s.SupplyName ?? "Insumo desconocido", 
                        0, 0, 
                        null, s.SupplyUnit, 1, 
                        "INSUMOS", null
                    ));
                }
            }
        }
    }

    private async Task SubmitForValidation()
    {
        _submitting = true;
        try
        {
            var response = await Http.PostAsync($"api/labors/{LaborId}/submit-for-validation", null);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LaborValidationResponse>(AppJsonSerializerContext.Default.LaborValidationResponse);
                _magicLinkUrl = result?.Url ?? "";
                _magicLinkModalVisible = true;
                _model.Status = "AwaitingValidation";
                StateHasChanged();
            }
            else
            {
                var err = await response.Content.ReadAsStringAsync();
                Message.Error($"Error: {err}");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
        finally
        {
            _submitting = false;
        }
    }

    // Validation methods handled by ValidationSuccessModal
    
    private void OnStatusChanged(string status)
    {
        if (ForceOriginalPlan || _model.IsOriginalPlan)
        {
            _model.Status = "Planned";
            _model.Mode = "Planned";
            return;
        }
        _model.Mode = status;
        if (status == "Realized" && !_model.ExecutionDate.HasValue)
        {
            _model.ExecutionDate = DateTime.Today;
        }
    }

    private bool _noProductiveAreaWarning;

    private Dictionary<string, string> _fieldErrors = new();
    private string _validationSummary = "";

    private bool HasError(string field) => _fieldErrors.ContainsKey(field);
    private string GetError(string field) => _fieldErrors.GetValueOrDefault(field, "");
    private void ClearError(string field) { _fieldErrors.Remove(field); _validationSummary = ""; }
    private void SetError(string field, string message) { _fieldErrors[field] = message; _validationSummary = ""; }

    private void OnContactChanged(ContactDto contact)
    {
        if (contact != null)
        {
            _model.IsExternalBilling = contact.Role == ContactRole.Contractor;
        }
    }

    private async Task OnLotChanged(CampaignLotDto lot)
    {
        ClearError("lot");
        if (lot != null)
        {
            _model.LotId = lot.LotId;
            _model.CampaignLotId = lot.Id;
            _lotProductiveArea = lot.ProductiveArea;

            // #22: Productive area is the single source of truth for labor calculations
            if (lot.ProductiveArea > 0)
            {
                _noProductiveAreaWarning = false;
                if (_model.Hectares == 0)
                    _model.Hectares = lot.ProductiveArea;
            }
            else
            {
                // No productive area defined — alert user and use cadastral as initial fallback
                _noProductiveAreaWarning = true;
                if (_model.Hectares == 0)
                    _model.Hectares = lot.CadastralArea;
            }

            CheckHectaresWarning(_model.Hectares);
            
            if (_model.EstimatedDate.HasValue) 
            {
                await CheckRotation(_model.EstimatedDate.Value);
            }
        }
    }

    private void OnHectareasChanged(decimal val)
    {
        _model.Hectares = val;
        ClearError("hectares");
        CheckHectaresWarning(val);
    }

    private void CheckHectaresWarning(decimal val)
    {
        var lot = _lots.FirstOrDefault(l => l.LotId == _model.LotId);
        if (lot != null)
        {
            _lotProductiveArea = lot.ProductiveArea;
            _haSuperaLote = val > lot.ProductiveArea;
        }
    }

    private async Task OnFechaEstimadaChanged(DateTimeChangedEventArgs<DateTime?> args)
    {
        _model.EstimatedDate = args.Date;
        if (args.Date.HasValue)
        {
            await CheckRotation(args.Date.Value);
            CheckDateOverlap(args.Date.Value);
        }
        else
        {
            _activeRotation = null;
            _actividadLocked = false;
            _showNoRotacionWarning = false;
            _fechaFueraRotacion = false;
        }
    }

    private void CheckDateOverlap(DateTime date)
    {
        if (_activeRotation != null)
        {
            var dateOnly = DateOnly.FromDateTime(date);
            _fechaFueraRotacion = dateOnly < _activeRotation.StartDate || dateOnly > _activeRotation.EndDate;
        }
        else
        {
            _fechaFueraRotacion = false;
        }
    }

    private async Task CheckRotation(DateTime date)
    {
        if (_model.LotId == Guid.Empty || CampaignState.CurrentCampaign == null) return;

        if (_model.CampaignLotId == null || _model.CampaignLotId == Guid.Empty)
        {
            var currentLot = _lots.FirstOrDefault(l => l.LotId == _model.LotId);
            if (currentLot != null)
            {
                _model.CampaignLotId = currentLot.Id;
            }
            else
            {
                return;
            }
        }

        try
        {
            var dateOnly = DateOnly.FromDateTime(date);
            var response = await Http.GetAsync($"api/campaigns/{CampaignState.CurrentCampaign.Id}/lots/{_model.CampaignLotId}/rotations/active?date={dateOnly:yyyy-MM-dd}");
            
            if (response.IsSuccessStatusCode)
            {
                _activeRotation = await response.Content.ReadFromJsonAsync<RotationDto>(AppJsonSerializerContext.Default.RotationDto);
                if (_activeRotation != null)
                {
                    _showNoRotacionWarning = false;
                    _model.ErpActivityId = _activeRotation.ActivityId;
                    _actividadLocked = true;
                    CheckDateOverlap(date);
                }
            }
            else
            {
                _activeRotation = null;
                _actividadLocked = false;
                _showNoRotacionWarning = true;
                _fechaFueraRotacion = false;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error checking rotation: {ex.Message}");
            _activeRotation = null;
            _actividadLocked = false;
            _showNoRotacionWarning = false;
            _fechaFueraRotacion = false;
        }
        StateHasChanged();
    }

    private void OnSupplySelected(LaborSupplyDto row, InventoryDto supply)
    {
        if (supply != null && _model.Supplies != null)
        {
            var index = _model.Supplies.IndexOf(row);
            if (index != -1)
            {
                _model.Supplies[index] = row with { 
                    SupplyId = supply.Id,
                    SupplyName = supply.ItemName, 
                    UnitOfMeasure = supply.UnitB ?? "un",
                    SupplyUnit = supply.UnitB ?? "un"
                };
            }
        }
    }

    private void AddSupply()
    {
        _model.Supplies ??= new();
        _model.Supplies.Add(new LaborSupplyDto 
        { 
            Id = Guid.NewGuid(), 
            LaborId = LaborId,
            PlannedHectares = _model.Hectares,
            RealHectares = _model.Status == "Realized" ? _model.Hectares : null
        });
        StateHasChanged();
    }

    private void RemoveSupply(LaborSupplyDto supply)
    {
        _model.Supplies?.Remove(supply);
        StateHasChanged();
    }

    private async Task SearchSupplies(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            await LoadCatalogs();
            // Re-ensure current supplies are still there after reloading catalog
            if (_model.Supplies != null)
            {
                foreach (var s in _model.Supplies)
                {
                    if (!_inventories.Any(i => i.Id == s.SupplyId))
                    {
                        _inventories.Add(new InventoryDto(s.SupplyId, "Cargado", s.SupplyName ?? "Insumo", 0, 0, null, s.SupplyUnit, 1));
                    }
                }
            }
            return;
        }

        var results = await Http.GetFromJsonAsync<List<InventoryDto>>($"api/inventory?search={Uri.EscapeDataString(value)}&pageSize=20") ?? new();
        
        // #25: Keep current supplies in the list so other rows don't go blank when searching in one row
        if (_model.Supplies != null)
        {
            foreach (var s in _model.Supplies)
            {
                if (s.SupplyId != Guid.Empty && !results.Any(i => i.Id == s.SupplyId))
                {
                    results.Add(new InventoryDto(s.SupplyId, "Cargado", s.SupplyName ?? "Insumo", 0, 0, null, s.SupplyUnit, 1));
                }
            }
        }
        
        _inventories = results;
        StateHasChanged();
    }

    private bool ValidateForm()
    {
        _fieldErrors.Clear();
        _validationSummary = "";

        // Load lot selector: must use CampaignLotDto linked to current campaign
        if (_lots.Count == 0 && CampaignState.CurrentCampaign == null)
        {
            _validationSummary = "Seleccione una campaña activa para crear labores.";
            return false;
        }

        if (_lots.Count == 0 && CampaignState.CurrentCampaign != null)
        {
            _validationSummary = "La campaña actual no tiene lotes asignados. Asigne lotes a la campaña antes de crear labores.";
            return false;
        }

        if (_model.IsOriginalPlan && _model.Status != "Planned")
        {
            _validationSummary = "Planeamiento Original (P.O.) solo permite labores planeadas.";
            return false;
        }

        if (CampaignState.IsLocked)
        {
            _validationSummary = "La campaña está bloqueada. Solo consulta.";
            return false;
        }

        if (_model.LotId == Guid.Empty)
            SetError("lot", "El lote es obligatorio.");

        if (_model.ErpActivityId == null || _model.ErpActivityId == Guid.Empty)
            SetError("activity", "La actividad es obligatoria.");

        if (_model.LaborTypeId == Guid.Empty)
            SetError("laborType", "El tipo de labor es obligatorio.");

        if (_model.Hectares <= 0)
            SetError("hectares", "Las hectáreas deben ser mayores a cero.");

        var laborDate = _model.ExecutionDate ?? _model.EstimatedDate;
        if (laborDate == null || laborDate == default)
            SetError("date", "La fecha es obligatoria.");

        if (_model.ContactId == null || _model.ContactId == Guid.Empty)
            SetError("contact", "El responsable es obligatorio.");

        // Validate supplies: if supply is added, dose must be valid
        if (_model.Supplies != null)
        {
            foreach (var s in _model.Supplies)
            {
                if (s.SupplyId != Guid.Empty && s.PlannedDose <= 0 && !s.RealDose.HasValue)
                {
                    _validationSummary = "Los insumos agregados deben tener dosis válida.";
                    return false;
                }
            }
        }

        return !_fieldErrors.Any();
    }

    private async Task HandleSubmit()
    {
        if (!ValidateForm())
        {
            Message.Warning("Corregí los campos marcados en rojo antes de guardar.");
            return;
        }

        if (_haSuperaLote)
        {
            var confirmed = await JSRuntime.InvokeAsync<bool>("confirm",
                $"Las hectáreas ({_model.Hectares:N2}) superan la superficie productiva del lote ({_lotProductiveArea} ha).\n\n¿Guardar de todas formas?");
            if (!confirmed) return;
        }

        if (_fechaFueraRotacion && _model.Status != "Realized")
        {
            Message.Warning("Atención: La fecha seleccionada está fuera del rango de la rotación activa.");
        }

        try
        {
            _loading = true;
            _saveError = null;
            _saveWarnings.Clear();
            _model.WeatherLogJson = JsonSerializer.Serialize(_weather);
            
            if (ForceOriginalPlan || _model.IsOriginalPlan)
            {
                _model.IsOriginalPlan = true;
                _model.Status = "Planned";
                _model.Mode = "Planned";
            }
            
            Console.WriteLine($"[LaborEditorForm] Submitting Labor: Id={LaborId}, WorkOrderId={_model.WorkOrderId}, LotId={_model.LotId}, Hectares={_model.Hectares}");

            HttpResponseMessage response;
            if (LaborId == Guid.Empty)
                response = await Http.PostAsJsonAsync("api/labors", _model);
            else
                response = await Http.PutAsJsonAsync($"api/labors/{LaborId}", _model);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LaborSaveResponse>(AppJsonSerializerContext.Default.LaborSaveResponse);
                
                if (result?.Labor != null)
                {
                    // Do not overwrite LaborId parameter locally as it causes issues with Blazor's parameter tracking
                    // Instead, use the ID from the result to link files if necessary
                    var newLaborId = result.Labor.Id;

                    if (_attachmentsRef != null)
                    {
                        var linkResult = await _attachmentsRef.LinkPendingFiles(newLaborId);
                        if (!linkResult.Success)
                        {
                            Message.Warning("La labor se guardó pero hubo un problema al vincular archivos. Reintentá desde la biblioteca.");
                        }
                    }
                }

                if (result?.Warnings != null && result.Warnings.Any())
                {
                    _saveWarnings = result.Warnings;
                }

                Message.Success("Labor guardada correctamente.");
                await OnSaved.InvokeAsync();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                _saveError = body;
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }
