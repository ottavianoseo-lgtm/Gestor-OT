@using GestorOT.Shared.Dtos
@using GestorOT.Shared
@using System.Net.Http.Json
@using AntDesign
@inject HttpClient Http
@inject IMessageService Message

<Card Title="@(LaborId == Guid.Empty ? "Nueva Labor" : "Editar Labor")"
      Style="border-radius: 12px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1);">
    <Form Model="@_model" OnFinish="HandleSubmit" Layout="@FormLayout.Vertical">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <FormItem Label="Lote / Superficie">
                <Select TItemValue="Guid" TItem="LotDto" @bind-Value="_model.LotId"
                        Placeholder="Seleccionar lote" EnableSearch 
                        OnSelectedItemChanged="OnLotChanged">
                    @foreach (var lot in _lots)
                    {
                        <SelectOption TItemValue="Guid" TItem="LotDto" Value="@lot.Id"
                                      Label="@($"{lot.Name} ({lot.FieldName})")" />
                    }
                </Select>
            </FormItem>

            <FormItem Label="Tipo de Actividad (ERP)">
                <Select TItemValue="Guid" TItem="LaborTypeDto" @bind-Value="_model.LaborTypeId"
                        Placeholder="Seleccionar actividad">
                    @foreach (var type in _laborTypes)
                    {
                        <SelectOption TItemValue="Guid" TItem="LaborTypeDto" Value="@type.Id"
                                      Label="@type.Name" />
                    }
                </Select>
            </FormItem>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px;">
            <FormItem Label="Hectáreas">
                <AntDesign.InputNumber TValue="decimal" @bind-Value="_model.Hectares" Min="0m" Step="0.1m" Style="width: 100%;" />
            </FormItem>
            <FormItem Label="Fecha Est.">
                <DatePicker TValue="DateTime?" @bind-Value="_model.EstimatedDate" Style="width: 100%;" />
            </FormItem>
            <FormItem Label="Fecha Ejec.">
                <DatePicker TValue="DateTime?" @bind-Value="_model.ExecutionDate" Style="width: 100%;" />
            </FormItem>
        </div>

        <FormItem Label="Notas / Prescripción">
            <TextArea @bind-Value="_model.Notes" Rows="2" Placeholder="Instrucciones para el contratista..." />
        </FormItem>

        <Divider Text="Insumos / Mezcla de Tanque" Orientation="@DividerOrientation.Left" />

        <div class="supplies-grid">
            <Table DataSource="_model.Supplies" TItem="LaborSupplyDto" Size="@TableSize.Small" Pagination="false" Context="supplyContext">
                <Column Title="Insumo" TItem="LaborSupplyDto" TData="Guid">
                    <Select TItemValue="Guid" TItem="InventoryDto" @bind-Value="supplyContext.SupplyId" 
                            OnSelectedItemChanged="(InventoryDto s) => OnSupplySelected(supplyContext, s)" EnableSearch>
                        @foreach (var inv in _inventories)
                        {
                            <SelectOption TItemValue="Guid" TItem="InventoryDto" Value="@inv.Id" Label="@inv.ItemName" />
                        }
                    </Select>
                </Column>
                <Column Title="Dosis Plan." TItem="LaborSupplyDto" TData="decimal">
                    <AntDesign.InputNumber TValue="decimal" @bind-Value="supplyContext.PlannedDose" Min="0m" Step="0.01m" />
                </Column>
                <Column Title="Dosis Real" TItem="LaborSupplyDto" TData="decimal?">
                    <AntDesign.InputNumber TValue="decimal?" @bind-Value="supplyContext.RealDose" Min="0m" Step="0.01m" />
                </Column>
                <Column Title="Acción" TItem="LaborSupplyDto" TData="Guid">
                    <Button Danger Icon="delete" OnClick="() => RemoveSupply(supplyContext)" />
                </Column>
            </Table>
            <Button Type="@ButtonType.Dashed" Block OnClick="AddSupply" Style="margin-top: 8px;">
                <Icon Type="plus" /> Agregar Insumo
            </Button>
        </div>

        <FormItem Style="margin-top: 24px;">
            <Button Type="@ButtonType.Primary" HtmlType="submit" Loading="_loading" Block
                    Style="height: 45px; border-radius: 8px; font-weight: 600;">
                <Icon Type="save" /> Guardar Labor
            </Button>
        </FormItem>
    </Form>
</Card>

@code {
    [Parameter] public Guid? WorkOrderId { get; set; }
    [Parameter] public Guid LaborId { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private LaborDto _model = new();
    private List<LotDto> _lots = new();
    private List<LaborTypeDto> _laborTypes = new();
    private List<InventoryDto> _inventories = new();
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        await LoadCatalogs();
        if (LaborId != Guid.Empty)
        {
            await LoadLabor();
        }
        else
        {
            _model = new LaborDto { WorkOrderId = WorkOrderId, Status = "Planned", EstimatedDate = DateTime.Today };
        }
    }

    private async Task LoadCatalogs()
    {
        var lotsTask = Http.GetFromJsonAsync<List<LotDto>>("api/lots");
        var typesTask = Http.GetFromJsonAsync<List<LaborTypeDto>>("api/catalogs/labor-types");
        var itemsTask = Http.GetFromJsonAsync<List<InventoryDto>>("api/inventory");

        await Task.WhenAll(lotsTask, typesTask, itemsTask);
        _lots = lotsTask.Result ?? new();
        _laborTypes = typesTask.Result ?? new();
        _inventories = itemsTask.Result ?? new();
    }

    private async Task LoadLabor()
    {
        _model = await Http.GetFromJsonAsync<LaborDto>($"api/labors/{LaborId}") ?? new();
    }

    private void OnLotChanged(LotDto lot)
    {
        if (lot != null)
        {
            _model = _model with { LotId = lot.Id };
            if (_model.Hectares == 0)
            {
                _model = _model with { Hectares = (decimal)lot.Area };
            }
        }
    }

    private void OnSupplySelected(LaborSupplyDto row, InventoryDto supply)
    {
        if (supply != null && _model.Supplies != null)
        {
            var index = _model.Supplies.IndexOf(row);
            if (index != -1)
            {
                _model.Supplies[index] = row with { 
                    SupplyId = supply.Id,
                    SupplyName = supply.ItemName, 
                    UnitOfMeasure = supply.UnitB ?? "un",
                    SupplyUnit = supply.UnitB ?? "un"
                };
            }
        }
    }

    private void AddSupply()
    {
        _model.Supplies ??= new();
        _model.Supplies.Add(new LaborSupplyDto { Id = Guid.Empty, LaborId = LaborId });
    }

    private void RemoveSupply(LaborSupplyDto supply)
    {
        _model.Supplies?.Remove(supply);
    }

    private async Task HandleSubmit()
    {
        try
        {
            _loading = true;
            HttpResponseMessage response;
            if (LaborId == Guid.Empty)
                response = await Http.PostAsJsonAsync("api/labors", _model, AppJsonSerializerContext.Default.LaborDto);
            else
                response = await Http.PutAsJsonAsync($"api/labors/{LaborId}", _model, AppJsonSerializerContext.Default.LaborDto);

            if (response.IsSuccessStatusCode)
            {
                Message.Success("Labor guardada correctamente.");
                await OnSaved.InvokeAsync();
            }
            else
            {
                Message.Error("Error al guardar la labor.");
            }
        }
        catch (Exception ex)
        {
            Message.Error($"Error: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }
}
